@model HcPortal.Models.SettingsViewModel
@{
    ViewData["Title"] = "Pengaturan Akun";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">

        <a asp-controller="Account" asp-action="Profile" class="text-decoration-none small text-muted d-inline-block mb-3">
            <i class="bi bi-arrow-left me-1"></i> Kembali ke Profil
        </a>

        <h4 class="fw-bold mb-4">Pengaturan Akun</h4>

        @* --- SECTION 1: Edit Profil --- *@

        @if (TempData["ProfileSuccess"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["ProfileSuccess"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ProfileError"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                <i class="bi bi-x-circle-fill me-2"></i>@TempData["ProfileError"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <p class="text-uppercase fw-bold small text-muted mb-3">Edit Profil</p>

        <form asp-action="EditProfile" method="post">
            @Html.AntiForgeryToken()

            @* Editable fields *@
            <div class="row mb-3">
                <div class="col-sm-4">
                    <label asp-for="EditProfile.FullName" class="col-form-label text-muted small fw-medium">Nama Lengkap</label>
                </div>
                <div class="col-sm-8">
                    <input asp-for="EditProfile.FullName" class="form-control" />
                    <span asp-validation-for="EditProfile.FullName" class="text-danger small"></span>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-4">
                    <label asp-for="EditProfile.Position" class="col-form-label text-muted small fw-medium">Jabatan</label>
                </div>
                <div class="col-sm-8">
                    <input asp-for="EditProfile.Position" class="form-control" />
                    <span asp-validation-for="EditProfile.Position" class="text-danger small"></span>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-4">
                    <label asp-for="EditProfile.PhoneNumber" class="col-form-label text-muted small fw-medium">Nomor Telepon</label>
                </div>
                <div class="col-sm-8">
                    <input asp-for="EditProfile.PhoneNumber" class="form-control" />
                    <span asp-validation-for="EditProfile.PhoneNumber" class="text-danger small"></span>
                </div>
            </div>

            @* Read-only fields *@
            <div class="row mb-3">
                <div class="col-sm-4">
                    <label class="col-form-label text-muted small fw-medium">NIP</label>
                </div>
                <div class="col-sm-8">
                    <input type="text" class="form-control" value="@(Model.NIP ?? "—")" disabled />
                    <div class="form-text text-muted small">Dikelola oleh admin</div>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-4">
                    <label class="col-form-label text-muted small fw-medium">Email</label>
                </div>
                <div class="col-sm-8">
                    <input type="text" class="form-control" value="@(Model.Email ?? "—")" disabled />
                    <div class="form-text text-muted small">Dikelola oleh admin</div>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-4">
                    <label class="col-form-label text-muted small fw-medium">Role</label>
                </div>
                <div class="col-sm-8">
                    <input type="text" class="form-control" value="@(Model.Role ?? "—")" disabled />
                    <div class="form-text text-muted small">Dikelola oleh admin</div>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-4">
                    <label class="col-form-label text-muted small fw-medium">Bagian</label>
                </div>
                <div class="col-sm-8">
                    <input type="text" class="form-control" value="@(Model.Section ?? "—")" disabled />
                    <div class="form-text text-muted small">Dikelola oleh admin</div>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-4">
                    <label class="col-form-label text-muted small fw-medium">Direktorat</label>
                </div>
                <div class="col-sm-8">
                    <input type="text" class="form-control" value="@(Model.Directorate ?? "—")" disabled />
                    <div class="form-text text-muted small">Dikelola oleh admin</div>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-4">
                    <label class="col-form-label text-muted small fw-medium">Unit</label>
                </div>
                <div class="col-sm-8">
                    <input type="text" class="form-control" value="@(Model.Unit ?? "—")" disabled />
                    <div class="form-text text-muted small">Dikelola oleh admin</div>
                </div>
            </div>

            <button type="submit" class="btn btn-primary mt-2">Simpan Profil</button>
        </form>

        <hr class="my-4">

        @* --- SECTION: Preview P-Sign --- *@

        <p class="text-uppercase fw-bold small text-muted mb-3">Preview P-Sign</p>

        @if (Model.PSign != null)
        {
            @await Html.PartialAsync("_PSign", Model.PSign)
        }


        @section Scripts {
            @await Html.PartialAsync("_ValidationScriptsPartial")
            <script>
                $(document).ready(function() {
                    setTimeout(function() {
                        $('.alert').fadeOut('slow');
                    }, 5000);
                });
            </script>
        }

    </div>
</div>
