@model HcPortal.Models.CreateTrainingRecordViewModel

@{
    ViewData["Title"] = "Tambah Training Record";
}

@if (ViewBag.IsRenewalMode != true)
{
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select@2/dist/css/tom-select.css">
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Admin")">Admin</a></li>
        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Admin")">Kelola Data</a></li>
        <li class="breadcrumb-item">
            <a href="@Url.Action("ManageAssessment", "AssessmentAdmin", new { tab = "training" })">Manage Assessment & Training</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Tambah Training</li>
    </ol>
</nav>

@if (ViewBag.IsRenewalMode == true)
{
    <div class="alert alert-warning d-flex align-items-center mb-3">
        <i class="bi bi-arrow-repeat me-2 fs-5"></i>
        <span>Mode Renewal — Training ini akan me-renew sertifikat
            <strong>@ViewBag.RenewalSourceTitle</strong>
            milik <strong>@ViewBag.RenewalSourceUserName</strong>
        </span>
    </div>
}

<!-- Page Header -->
<div class="mb-4">
    <h2 class="fw-bold mb-1">
        <i class="bi bi-plus-circle me-2 text-primary"></i>Tambah Training Record
    </h2>
    <p class="text-muted">Buat record training manual untuk pekerja</p>
</div>

<!-- Validation Summary -->
@if (!ViewData.ModelState.IsValid)
{
    <div asp-validation-summary="All" class="alert alert-danger"></div>
}

<form asp-action="AddTraining" asp-controller="TrainingAdmin" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-person me-2"></i>Data Pekerja</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-12">
                    @if (ViewBag.IsRenewalMode == true)
                    {
                        <label asp-for="UserId" class="form-label fw-bold">Pekerja <span class="text-danger">*</span> <i class="bi bi-question-circle text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Pilih satu atau beberapa pekerja yang mengikuti pelatihan ini (maks 20)"></i></label>
                        <select asp-for="UserId" asp-items="@(ViewBag.Workers as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)" class="form-select">
                            <option value="">-- Pilih Pekerja --</option>
                        </select>
                        <span asp-validation-for="UserId" class="text-danger small"></span>
                    }
                    else
                    {
                        <label class="form-label fw-bold">Pekerja <span class="text-danger">*</span> <i class="bi bi-question-circle text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Pilih satu atau beberapa pekerja yang mengikuti pelatihan ini (maks 20)"></i></label>
                        <select id="WorkerSelect" multiple>
                            @foreach (var w in (List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.Workers)
                            {
                                <option value="@w.Value">@w.Text</option>
                            }
                        </select>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-journal-text me-2"></i>Data Training</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <!-- Baris 1: Nama Pelatihan | Penyelenggara -->
                <div class="col-md-6">
                    <label asp-for="Judul" class="form-label fw-bold">Nama Pelatihan <span class="text-danger">*</span> <i class="bi bi-question-circle text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Nama lengkap pelatihan/kursus yang diikuti pekerja"></i></label>
                    <input asp-for="Judul" class="form-control" placeholder="Masukkan nama pelatihan" />
                    <span asp-validation-for="Judul" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Penyelenggara" class="form-label fw-bold">Penyelenggara <span class="text-danger">*</span> <i class="bi bi-question-circle text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Lembaga/institusi yang menyelenggarakan pelatihan"></i></label>
                    <input asp-for="Penyelenggara" class="form-control" placeholder="Masukkan penyelenggara" />
                    <span asp-validation-for="Penyelenggara" class="text-danger small"></span>
                </div>

                <!-- Baris 2: Kategori | Sub Kategori -->
                <div class="col-md-6">
                    <label asp-for="Kategori" class="form-label fw-bold">Kategori <span class="text-danger">*</span> <i class="bi bi-question-circle text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Kategori kompetensi sesuai klasifikasi HC (contoh: HSE, Technical, Leadership)"></i></label>
                    <select id="kategoriSelect" asp-for="Kategori" class="form-select" required>
                        <option value="">-- Pilih Kategori --</option>
                        @foreach (var cat in (IEnumerable<dynamic>)ViewBag.KategoriOptions)
                        {
                            <option value="@cat.Name">@cat.Name</option>
                        }
                    </select>
                    <span asp-validation-for="Kategori" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="SubKategori" class="form-label">Sub Kategori (opsional) <i class="bi bi-question-circle text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Sub-klasifikasi dari kategori utama. Otomatis tersedia setelah memilih kategori"></i></label>
                    <select id="subKategoriSelect" asp-for="SubKategori" class="form-select" disabled>
                        <option value="">-- Pilih Sub Kategori --</option>
                        @foreach (var sub in (IEnumerable<dynamic>)ViewBag.SubKategoriOptions)
                        {
                            <option value="@sub.Name" data-parent-id="@sub.ParentId">@sub.Name</option>
                        }
                    </select>
                    <div class="form-text">Pilih kategori terlebih dahulu</div>
                </div>

                <!-- Baris 3: Kota | Status -->
                <div class="col-md-6">
                    <label asp-for="Kota" class="form-label fw-bold">Kota <i class="bi bi-question-circle text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Kota tempat pelatihan dilaksanakan"></i></label>
                    <input asp-for="Kota" class="form-control" placeholder="Masukkan kota pelatihan" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Status" class="form-label fw-bold">Status <span class="text-danger">*</span> <i class="bi bi-question-circle text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Passed = lulus, Valid = sertifikat masih berlaku, Expired = sudah kedaluwarsa, Failed = tidak lulus"></i></label>
                    <select asp-for="Status" class="form-select">
                        <option value="Passed">Passed</option>
                        <option value="Valid">Valid</option>
                        <option value="Expired">Expired</option>
                        <option value="Failed">Failed</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger small"></span>
                </div>

                <!-- Baris 4: Tanggal -->
                <div class="col-md-6">
                    <label asp-for="Tanggal" class="form-label fw-bold">Tanggal <span class="text-danger">*</span> <i class="bi bi-question-circle text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Tanggal pelatihan (jika hanya 1 hari) atau tanggal sertifikat diterbitkan"></i></label>
                    <input asp-for="Tanggal" type="date" class="form-control" />
                    <span asp-validation-for="Tanggal" class="text-danger small"></span>
                    <div class="form-text">Jika pelatihan hanya 1 hari, cukup isi field ini saja</div>
                </div>

                <!-- Baris 5: Tanggal Mulai | Tanggal Selesai -->
                <div class="col-md-6">
                    <label asp-for="TanggalMulai" class="form-label fw-bold">Tanggal Mulai <i class="bi bi-question-circle text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Isi jika pelatihan berlangsung lebih dari 1 hari"></i></label>
                    <input asp-for="TanggalMulai" type="date" class="form-control" />
                    <div class="form-text">Opsional — isi jika pelatihan lebih dari 1 hari</div>
                </div>
                <div class="col-md-6">
                    <label asp-for="TanggalSelesai" class="form-label fw-bold">Tanggal Selesai <i class="bi bi-question-circle text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Isi jika pelatihan berlangsung lebih dari 1 hari"></i></label>
                    <input asp-for="TanggalSelesai" type="date" class="form-control" />
                    <div class="form-text">Opsional — isi jika pelatihan lebih dari 1 hari</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold">
                <i class="bi bi-award me-2"></i>Data Sertifikat
                @if (ViewBag.IsRenewalMode != true)
                {
                    <span id="workerCountBadge" class="badge bg-primary ms-2" style="display:none;"></span>
                }
            </h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                @if (ViewBag.IsRenewalMode == true)
                {
                    <!-- Nomor Sertifikat (renewal mode - shared) -->
                    <div class="col-md-6">
                        <label asp-for="NomorSertifikat" class="form-label fw-bold">Nomor Sertifikat</label>
                        <input asp-for="NomorSertifikat" class="form-control" placeholder="Masukkan nomor sertifikat" />
                    </div>
                }

                <!-- Tipe Sertifikat (shared) -->
                <div class="col-md-6">
                    <label asp-for="CertificateType" class="form-label fw-bold">Tipe Sertifikat <i class="bi bi-question-circle text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Permanent = tidak ada masa berlaku, Annual = berlaku 1 tahun, 3-Year = berlaku 3 tahun"></i></label>
                    <select asp-for="CertificateType" class="form-select">
                        <option value="">-- Pilih Tipe --</option>
                        <option value="Permanent">Permanent</option>
                        <option value="Annual">Annual</option>
                        <option value="3-Year">3-Year</option>
                    </select>
                </div>

                <!-- Berlaku Sampai (shared) -->
                <div class="col-md-6">
                    <label asp-for="ValidUntil" class="form-label fw-bold">Berlaku Sampai <i class="bi bi-question-circle text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Tanggal kedaluwarsa sertifikat. Wajib diisi jika tipe bukan Permanent"></i></label>
                    <input asp-for="ValidUntil" type="date" class="form-control" />
                </div>

                @if (ViewBag.IsRenewalMode == true)
                {
                    <!-- Certificate File (renewal mode - shared) -->
                    <div class="col-md-6">
                        <label asp-for="CertificateFile" class="form-label fw-bold">File Sertifikat <i class="bi bi-question-circle text-muted" data-bs-toggle="tooltip" data-bs-placement="top" title="Upload scan sertifikat dalam format PDF, JPG, atau PNG (maks 10MB)"></i></label>
                        <input asp-for="CertificateFile" type="file" class="form-control" accept=".pdf,.jpg,.jpeg,.png" />
                        <div class="form-text">PDF, JPG, atau PNG. Maksimal 10MB.</div>
                        <span asp-validation-for="CertificateFile" class="text-danger small"></span>
                    </div>
                }
            </div>

            @if (ViewBag.IsRenewalMode != true)
            {
                <div id="workerCertsContainer" class="mt-3">
                    <p class="text-muted fst-italic" id="emptyWorkerMsg">Pilih pekerja di atas untuk menambahkan data sertifikat.</p>
                </div>
            }
        </div>
    </div>

    @if (ViewBag.IsRenewalMode == true)
    {
        if (Model.RenewsTrainingId != null)
        {
            <input type="hidden" name="RenewsTrainingId" value="@Model.RenewsTrainingId" />
        }
        if (Model.RenewsSessionId != null)
        {
            <input type="hidden" name="RenewsSessionId" value="@Model.RenewsSessionId" />
        }
        if (ViewBag.RenewalFkMap != null)
        {
            <input type="hidden" id="renewal-fk-map" name="renewalFkMap" value='@ViewBag.RenewalFkMap' />
            <input type="hidden" id="renewal-fk-map-type" name="renewalFkMapType" value="@ViewBag.RenewalFkMapType" />
        }
    }

    <!-- Submit Buttons -->
    <div class="d-flex justify-content-end gap-2">
        <a href="@Url.Action("ManageAssessment", "AssessmentAdmin", new { tab = "training" })" class="btn btn-outline-secondary">
            <i class="bi bi-x-lg me-2"></i>Batal
        </a>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-2"></i>Simpan Training
        </button>
    </div>
</form>

@if (ViewBag.IsRenewalMode != true)
{
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2/dist/js/tom-select.complete.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        var workerSelect = new TomSelect('#WorkerSelect', {
            maxItems: 20,
            plugins: ['remove_button'],
            placeholder: 'Pilih pekerja (maks 20)...',
            onItemAdd: function(value) {
                var option = this.options[value];
                addWorkerRow(value, option.text);
                updateWorkerCount();
                updateSubmitButton();
            },
            onItemRemove: function(value) {
                removeWorkerRow(value);
                reindexWorkerRows();
                updateWorkerCount();
                updateSubmitButton();
            }
        });

        var submitBtn = document.querySelector('button[type="submit"]');
        if (submitBtn) submitBtn.disabled = true;

        function addWorkerRow(userId, userName) {
            var container = document.getElementById('workerCertsContainer');
            var emptyMsg = document.getElementById('emptyWorkerMsg');
            if (emptyMsg) emptyMsg.style.display = 'none';

            var index = container.querySelectorAll('.worker-cert-card').length;
            var row = document.createElement('div');
            row.className = 'card mb-2 worker-cert-card';
            row.dataset.userId = userId;
            row.innerHTML =
                '<div class="card-body py-2">' +
                    '<div class="fw-bold mb-2">' + escapeHtml(userName) + '</div>' +
                    '<input type="hidden" name="WorkerCerts[' + index + '].UserId" value="' + userId + '" />' +
                    '<div class="row g-2">' +
                        '<div class="col-md-6">' +
                            '<label class="form-label">File Sertifikat</label>' +
                            '<input type="file" name="WorkerCerts[' + index + '].CertificateFile" class="form-control" accept=".pdf,.jpg,.jpeg,.png" />' +
                            '<div class="form-text">PDF, JPG, PNG. Maks 10MB.</div>' +
                        '</div>' +
                        '<div class="col-md-6">' +
                            '<label class="form-label">Nomor Sertifikat</label>' +
                            '<input type="text" name="WorkerCerts[' + index + '].NomorSertifikat" class="form-control" placeholder="Nomor sertifikat" />' +
                        '</div>' +
                    '</div>' +
                '</div>';
            container.appendChild(row);
        }

        function removeWorkerRow(userId) {
            var container = document.getElementById('workerCertsContainer');
            var card = container.querySelector('.worker-cert-card[data-user-id="' + userId + '"]');
            if (card) card.remove();

            var remaining = container.querySelectorAll('.worker-cert-card');
            if (remaining.length === 0) {
                var emptyMsg = document.getElementById('emptyWorkerMsg');
                if (emptyMsg) emptyMsg.style.display = '';
            }
        }

        function reindexWorkerRows() {
            var container = document.getElementById('workerCertsContainer');
            var cards = container.querySelectorAll('.worker-cert-card');
            cards.forEach(function(card, i) {
                var hidden = card.querySelector('input[type="hidden"]');
                if (hidden) hidden.name = 'WorkerCerts[' + i + '].UserId';
                var fileInput = card.querySelector('input[type="file"]');
                if (fileInput) fileInput.name = 'WorkerCerts[' + i + '].CertificateFile';
                var textInput = card.querySelector('input[type="text"]');
                if (textInput) textInput.name = 'WorkerCerts[' + i + '].NomorSertifikat';
            });
        }

        function updateWorkerCount() {
            var badge = document.getElementById('workerCountBadge');
            var count = document.querySelectorAll('.worker-cert-card').length;
            if (count > 0) {
                badge.textContent = count + ' pekerja';
                badge.style.display = '';
            } else {
                badge.style.display = 'none';
            }
        }

        function updateSubmitButton() {
            var submitBtn = document.querySelector('button[type="submit"]');
            var count = document.querySelectorAll('.worker-cert-card').length;
            if (submitBtn) submitBtn.disabled = (count === 0);
        }

        function escapeHtml(text) {
            var div = document.createElement('div');
            div.appendChild(document.createTextNode(text));
            return div.innerHTML;
        }

        // Submit loading state
        var form = document.querySelector('form');
        if (form) {
            form.addEventListener('submit', function() {
                var btn = form.querySelector('button[type="submit"]');
                if (btn && !btn.disabled) {
                    btn.disabled = true;
                    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Menyimpan...';
                }
            });
        }
    });
    </script>
}

<script>
(function() {
    const kategoriMap = {};
    @foreach (var cat in (IEnumerable<dynamic>)ViewBag.KategoriOptions)
    {
        @:kategoriMap["@cat.Name"] = @cat.Id;
    }

    const kategoriSelect = document.getElementById('kategoriSelect');
    const subKategoriSelect = document.getElementById('subKategoriSelect');

    kategoriSelect.addEventListener('change', function() {
        const selectedName = this.value;
        const parentId = kategoriMap[selectedName];
        const options = subKategoriSelect.querySelectorAll('option[data-parent-id]');

        options.forEach(function(opt) {
            opt.hidden = parentId === undefined || parseInt(opt.dataset.parentId) !== parentId;
        });

        subKategoriSelect.value = '';
        subKategoriSelect.disabled = !selectedName;
    });
})();
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    tooltipTriggerList.forEach(function(el) { new bootstrap.Tooltip(el); });
});
</script>

@if (ViewBag.SelectedUserId != null)
{
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        var sel = document.getElementById('UserId');
        if (sel) sel.value = '@ViewBag.SelectedUserId';
    });
    </script>
}
@if (ViewBag.SelectedUserIds != null)
{
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        var sel = document.getElementById('UserId');
        if (sel) {
            var ids = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.SelectedUserIds));
            if (ids.length === 1) {
                sel.value = ids[0];
            }
            if (ids.length > 1) {
                var hiddenIds = document.createElement('input');
                hiddenIds.type = 'hidden';
                hiddenIds.name = 'UserIds';
                hiddenIds.value = JSON.stringify(ids);
                sel.closest('form').appendChild(hiddenIds);
                // Sembunyikan field UserId tunggal karena akan pakai UserIds
                var wrapper = sel.closest('.mb-3') || sel.closest('.col-md-12');
                if (wrapper) wrapper.style.display = 'none';
                // Tampilkan info jumlah peserta
                var info = document.createElement('div');
                info.className = 'alert alert-info mb-3';
                info.innerHTML = '<i class="bi bi-people me-1"></i>' + ids.length + ' peserta akan di-renew';
                var form = sel.closest('form');
                if (form) form.insertBefore(info, form.firstChild);
            }
        }
    });
    </script>
}
