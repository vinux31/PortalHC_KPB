@model HcPortal.Models.MonitoringGroupViewModel

@{
    ViewData["Title"] = "Assessment Detail — " + Model.Title;

    var catBadgeClass = Model.Category switch
    {
        "OJT"                     => "bg-primary",
        "IHT"                     => "bg-success",
        "Training Licencor"        => "bg-danger",
        "OTS"                     => "bg-warning text-dark",
        "Mandatory HSSE Training"  => "bg-info",
        "Proton"                  => "bg-purple",
        "Assessment Proton"        => "bg-purple",
        _                         => "bg-secondary"
    };

    var statusBadgeClass = Model.GroupStatus switch
    {
        "Open"     => "bg-success",
        "Upcoming" => "bg-warning text-dark",
        "Closed"   => "bg-secondary",
        _          => "bg-secondary"
    };

    bool isProtonInterview = Model.Category == "Assessment Proton" && (ViewBag.GroupTahunKe as string) == "Tahun 3";
    var interviewAspects = new List<string>
    {
        "Pengetahuan Teknis", "Kemampuan Operasional", "Keselamatan Kerja",
        "Komunikasi & Kerjasama", "Sikap Profesional"
    };

    int completedPct = Model.TotalCount > 0
        ? (int)Math.Round(Model.CompletedCount * 100.0 / Model.TotalCount)
        : 0;

    int passRatePct = Model.CompletedCount > 0
        ? (int)Math.Round(Model.PassedCount * 100.0 / Model.CompletedCount)
        : 0;
}

<div class="container-fluid px-4 py-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* 90-review: breadcrumb verified *@
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Admin")">Kelola Data</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("AssessmentMonitoring", "Admin")">Assessment Monitoring</a></li>
            <li class="breadcrumb-item active">@Model.Title</li>
        </ol>
    </nav>

    <!-- Back link -->
    <div class="mb-4">
        <a href="@ViewBag.BackUrl" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to Monitoring
        </a>
    </div>

    <!-- Header -->
    <div class="mb-4">
        <div class="d-flex align-items-center gap-2 mb-1">
            <span class="badge @catBadgeClass">@Model.Category</span>
            <span class="badge @statusBadgeClass">@Model.GroupStatus</span>
            <span id="hubStatusBadge" class="badge bg-secondary ms-1 small">Connecting...</span>
        </div>
        <h2 class="fw-bold mb-1">@Model.Title</h2>
        <p class="text-muted mb-0">
            <i class="bi bi-calendar3 me-1"></i>@Model.Schedule.ToString("dd MMM yyyy")
        </p>
    </div>

    @if (Model.IsTokenRequired)
    {
        <!-- Token Card -->
        <div class="card border-0 shadow-sm mb-4" style="border-left: 4px solid #0d6efd !important;">
            <div class="card-body py-3">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-key-fill text-primary fs-5"></i>
                        <span class="fw-semibold">Access Token:</span>
                        <code id="token-display" class="fs-6 text-primary">@Model.AccessToken</code>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button"
                                class="btn btn-outline-secondary btn-sm"
                                id="btn-copy-token"
                                onclick="copyToken()"
                                title="Copy token">
                            <i class="bi bi-clipboard me-1"></i><span id="copy-label">Copy</span>
                        </button>
                        <button type="button"
                                class="btn btn-outline-warning btn-sm"
                                id="btn-regen-token"
                                data-id="@Model.RepresentativeId"
                                onclick="regenToken(this)"
                                title="Regenerate token">
                            <i class="bi bi-arrow-repeat me-1"></i>Regenerate Token
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Summary cards -->
    <div class="row g-3 mb-4">
        <div class="col">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-primary" id="count-total">@Model.TotalCount</div>
                <div class="text-muted small">Total Assigned</div>
            </div>
        </div>
        <div class="col">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-success" id="count-completed">@Model.CompletedCount</div>
                <div class="text-muted small">Completed</div>
            </div>
        </div>
        <div class="col">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-warning" id="count-inprogress">@(Model.Sessions.Count(s => s.UserStatus == "InProgress"))</div>
                <div class="text-muted small">In Progress</div>
            </div>
        </div>
        <div class="col">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-secondary" id="count-notstarted">@Model.PendingCount</div>
                <div class="text-muted small">Not Started</div>
            </div>
        </div>
        <div class="col">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-secondary" id="count-cancelled">@Model.CancelledCount</div>
                <div class="text-muted small">Dibatalkan</div>
            </div>
        </div>
    </div>

    <!-- Per-user table -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-semibold">
                <i class="bi bi-people me-2 text-primary"></i>Per-User Status
            </h5>
            <div class="d-flex gap-2 align-items-center">
                <!-- Export Results: GET download, no antiforgery needed -->
                <form asp-action="ExportAssessmentResults" asp-controller="Admin" method="get" class="d-inline">
                    <input type="hidden" name="title" value="@Model.Title" />
                    <input type="hidden" name="category" value="@Model.Category" />
                    <input type="hidden" name="scheduleDate" value="@Model.Schedule.ToString("yyyy-MM-dd")" />
                    <button type="submit" class="btn btn-outline-success btn-sm">
                        <i class="bi bi-download me-1"></i>Export Results
                    </button>
                </form>
                <!-- Akhiri Semua Ujian: triggers Bootstrap modal confirmation -->
                <button type="button" class="btn btn-danger btn-sm" id="akhiriSemuaBtn"
                        data-bs-toggle="modal" data-bs-target="#akhiriSemuaModal">
                    <i class="bi bi-x-circle me-1"></i>Akhiri Semua Ujian
                </button>
                @if (Model.IsPackageMode && Model.PendingCount > 0)
                {
                    <button type="button" class="btn btn-outline-primary btn-sm"
                            onclick="reshuffleAll(event)">
                        <i class="bi bi-shuffle me-1"></i>Reshuffle All (@Model.PendingCount pending)
                    </button>
                }
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Progress</th>
                            <th>Status</th>
                            <th>Score</th>
                            <th>Result</th>
                            <th>Completed At</th>
                            <th>Time Remaining</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Sessions.Count == 0)
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">No sessions found for this group.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var session in Model.Sessions)
                            {
                                var statusClass = session.UserStatus switch
                                {
                                    "Completed"  => "bg-success",
                                    "InProgress" => "bg-warning text-dark",
                                    "Cancelled"  => "bg-secondary",
                                    _            => "bg-light text-dark border"
                                };

                                var statusLabel = session.UserStatus == "Cancelled" ? "Dibatalkan" : session.UserStatus;

                                string resultText;
                                string resultClass;
                                if (session.IsPassed == true)
                                {
                                    resultText  = "Pass";
                                    resultClass = "text-success fw-semibold";
                                }
                                else if (session.IsPassed == false)
                                {
                                    resultText  = "Fail";
                                    resultClass = "text-danger fw-semibold";
                                }
                                else
                                {
                                    resultText  = "\u2014";
                                    resultClass = "text-muted";
                                }

                                <tr data-session-id="@session.Id">
                                    <td class="fw-semibold">@session.UserFullName</td>
                                    <td class="text-center progress-cell">@(session.QuestionCount > 0 ? $"\u2014/{session.QuestionCount}" : "\u2014")</td>
                                    <td class="status-cell"><span class="badge @statusClass">@statusLabel</span></td>
                                    <td class="score-cell">
                                        @if (session.Score.HasValue)
                                        {
                                            <span>@session.Score%</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">\u2014</span>
                                        }
                                    </td>
                                    <td class="result-cell @resultClass">@resultText</td>
                                    <td class="completedat-cell text-muted small">
                                        @(session.CompletedAt.HasValue ? session.CompletedAt.Value.ToString("dd MMM yyyy HH:mm") : "\u2014")
                                    </td>
                                    <td class="timeremaining-cell text-muted">\u2014</td>
                                    <td>
                                        @* Reshuffle -- package mode, Not started or Abandoned (always enabled) *@
                                        @if (Model.IsPackageMode && (session.UserStatus == "Not started" || session.UserStatus == "Abandoned"))
                                        {
                                            <button type="button"
                                                    class="btn btn-outline-primary btn-sm me-1"
                                                    data-session-id="@session.Id"
                                                    onclick="reshuffleWorker(@session.Id)"
                                                    title="Reshuffle paket ujian">
                                                <i class="bi bi-shuffle me-1"></i>Reshuffle
                                            </button>
                                        }
                                        @* Akhiri Ujian -- InProgress only *@
                                        @if (session.UserStatus == "InProgress")
                                        {
                                            <form asp-action="AkhiriUjian" asp-controller="Admin" method="post" class="d-inline me-1"
                                                  onsubmit="return confirm('Akhiri ujian untuk @(session.UserFullName)? Jawaban tersimpan akan dinilai otomatis.')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@session.Id" />
                                                <button type="submit" class="btn btn-danger btn-sm">
                                                    <i class="bi bi-x-circle me-1"></i>Akhiri Ujian
                                                </button>
                                            </form>
                                        }
                                        @* Reset -- all statuses except Cancelled *@
                                        @if (session.UserStatus != "Cancelled")
                                        {
                                            <form asp-action="ResetAssessment" asp-controller="Admin" method="post" class="d-inline me-1"
                                                  onsubmit="return confirm('Reset sesi ini? Semua jawaban akan dihapus dan peserta dapat mengulang ujian.')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@session.Id" />
                                                <button type="submit" class="btn btn-warning btn-sm">
                                                    <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
                                                </button>
                                            </form>
                                        }
                                        @* View Results -- Completed only *@
                                        @if (session.UserStatus == "Completed")
                                        {
                                            <a href="@Url.Action("Results", "CMP", new { id = session.Id })" target="_blank"
                                               class="btn btn-success btn-sm">
                                                View Results
                                            </a>
                                        }
                                        @* Activity Log button -- always shown, enabled if session has started *@
                                        <button type="button"
                                                class="btn btn-outline-secondary btn-sm ms-1"
                                                onclick="showActivityLog(@session.Id, '@Html.Raw(session.UserFullName.Replace("'", "\\'"))')"
                                                title="Lihat activity log">
                                            <i class="bi bi-clock-history"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Global antiforgery token for JS-rendered action buttons -->
    <form id="antiforgeryForm" style="display:none">@Html.AntiForgeryToken()</form>

    <!-- Hidden fields for polling endpoint params -->
    <input type="hidden" id="hTitle" value="@Model.Title" />
    <input type="hidden" id="hCategory" value="@Model.Category" />
    <input type="hidden" id="hScheduleDate" value="@Model.Schedule.ToString("yyyy-MM-dd")" />

    <!-- Last updated + error indicator -->
    <div class="d-flex align-items-center gap-3 mt-2 px-1">
        <small class="text-muted">
            Last updated: <span id="last-updated-time">\u2014</span>
        </small>
        <span id="poll-error" class="badge bg-warning text-dark" style="display:none;">Update error -- retrying</span>
    </div>

    @if (Model.IsPackageMode)
    {
        <!-- Hidden form for antiforgery token (used by AJAX reshuffle calls) -->
        <form id="reshuffleForm" style="display:none">@Html.AntiForgeryToken()</form>

        <!-- Toast container (top-right, Bootstrap 5) -->
        <div class="position-fixed top-0 end-0 p-3" style="z-index: 1080;">
            <div id="reshuffleToast" class="toast align-items-center text-bg-success border-0" role="alert">
                <div class="d-flex">
                    <div class="toast-body" id="reshuffleToastBody">
                        Package reshuffled successfully.
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        </div>

        <!-- Result modal for Reshuffle All -->
        <div class="modal fade" id="reshuffleResultModal" tabindex="-1">
            <div class="modal-dialog modal-dialog-scrollable">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="bi bi-shuffle me-2"></i>Reshuffle All -- Results</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div id="reshuffleResultBody"></div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Akhiri Semua Ujian Confirmation Modal -->
    <div class="modal fade" id="akhiriSemuaModal" tabindex="-1" aria-labelledby="akhiriSemuaModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title fw-semibold" id="akhiriSemuaModalLabel">
                        <i class="bi bi-x-circle me-2"></i>Akhiri Semua Ujian
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div id="akhiriSemuaLoading" class="text-center py-3">
                        <span class="spinner-border spinner-border-sm me-2"></span>Memuat data...
                    </div>
                    <div id="akhiriSemuaContent" style="display:none;">
                        <p class="mb-2 fw-semibold">Akhiri semua ujian?</p>
                        <ul class="mb-2">
                            <li><strong id="akhiriInProgressCount">0</strong> peserta InProgress akan dinilai dari jawaban tersimpan.</li>
                            <li><strong id="akhiriNotStartedCount">0</strong> peserta belum mulai akan dibatalkan.</li>
                        </ul>
                        <p class="text-danger mb-0"><i class="bi bi-exclamation-triangle-fill me-1"></i>Tindakan ini tidak dapat dibatalkan.</p>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                    <form asp-action="AkhiriSemuaUjian" asp-controller="Admin" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="title" value="@Model.Title" />
                        <input type="hidden" name="category" value="@Model.Category" />
                        <input type="hidden" name="scheduleDate" value="@Model.Schedule.ToString("yyyy-MM-dd")" />
                        <button type="submit" class="btn btn-danger" id="akhiriSemuaSubmitBtn">
                            <i class="bi bi-x-circle me-1"></i>Ya, Akhiri Semua
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Activity Log Modal -->
    <div class="modal fade" id="activityLogModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-clock-history me-2 text-primary"></i>Activity Log:
                        <span id="logWorkerName" class="text-primary"></span>
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="logSummary" class="mb-3 p-2 bg-light rounded small text-muted"></div>
                    <div id="logTimeline"></div>
                    <div id="logLoading" class="text-center d-none">
                        <div class="spinner-border spinner-border-sm me-2"></div>Memuat...
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (isProtonInterview)
    {
        var sessionObjects = ViewBag.SessionObjects as List<HcPortal.Models.AssessmentSession> ?? new List<HcPortal.Models.AssessmentSession>();
        <div class="card mt-4 border-warning shadow-sm">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="bi bi-person-video3 me-2"></i>Input Hasil Interview Proton — Tahun 3</h5>
            </div>
            <div class="card-body">
                @foreach (var monSess in Model.Sessions)
                {
                    var fullSession = sessionObjects.FirstOrDefault(s => s.Id == monSess.Id);
                    bool hasResults = !string.IsNullOrEmpty(fullSession?.InterviewResultsJson);
                    HcPortal.Models.InterviewResultsDto? existingDto = null;
                    if (hasResults)
                    {
                        try { existingDto = System.Text.Json.JsonSerializer.Deserialize<HcPortal.Models.InterviewResultsDto>(fullSession!.InterviewResultsJson!); } catch { }
                    }

                    <div class="card mb-4 border-secondary">
                        <div class="card-header d-flex justify-content-between align-items-center py-2">
                            <strong><i class="bi bi-person-fill me-1 text-primary"></i>@monSess.UserFullName</strong>
                            @if (hasResults)
                            {
                                if (existingDto?.IsPassed == true)
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle-fill me-1"></i>Lulus</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger"><i class="bi bi-x-circle-fill me-1"></i>Tidak Lulus</span>
                                }
                            }
                            else
                            {
                                <span class="badge bg-secondary">Belum Diinput</span>
                            }
                        </div>
                        <div class="card-body">
                            <form asp-action="SubmitInterviewResults" asp-controller="Admin" method="post" enctype="multipart/form-data">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="sessionId" value="@monSess.Id" />
                                <input type="hidden" name="returnTitle" value="@Model.Title" />
                                <input type="hidden" name="returnCategory" value="@Model.Category" />
                                <input type="hidden" name="returnDate" value="@Model.Schedule.ToString("yyyy-MM-dd")" />

                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Daftar Juri</label>
                                    <input type="text" name="judges" class="form-control"
                                        placeholder="Nama juri dipisahkan koma"
                                        value="@(existingDto?.Judges ?? "")" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Penilaian per Aspek (1=Kurang, 5=Luar Biasa)</label>
                                    <div class="row g-2">
                                        @foreach (var aspect in interviewAspects)
                                        {
                                            var formKey = "aspect_" + aspect.Replace(" ", "_").Replace("&", "and").Replace(",", "");
                                            var existingScore = existingDto?.AspectScores != null && existingDto.AspectScores.ContainsKey(aspect)
                                                ? existingDto.AspectScores[aspect] : 3;
                                            <div class="col-md-6 col-lg-4">
                                                <label class="form-label small fw-semibold">@aspect</label>
                                                <select name="@formKey" class="form-select form-select-sm">
                                                    @for (int sv = 1; sv <= 5; sv++)
                                                    {
                                                        var lbl = sv switch { 1 => "Kurang", 2 => "Cukup", 3 => "Baik", 4 => "Sangat Baik", 5 => "Luar Biasa", _ => "" };
                                                        if (existingScore == sv)
                                                        {
                                                            <option value="@sv" selected>@sv — @lbl</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@sv">@sv — @lbl</option>
                                                        }
                                                    }
                                                </select>
                                            </div>
                                        }
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Catatan</label>
                                    <textarea name="notes" class="form-control" rows="3"
                                        placeholder="Catatan tambahan (opsional)">@(existingDto?.Notes ?? "")</textarea>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Upload Dokumen Pendukung (Opsional)</label>
                                    <input type="file" name="supportingDoc" class="form-control"
                                        accept=".pdf,.doc,.docx,.jpg,.jpeg,.png" />
                                    @if (!string.IsNullOrEmpty(existingDto?.SupportingDocPath))
                                    {
                                        <div class="form-text">
                                            <i class="bi bi-paperclip me-1"></i>Dokumen saat ini:
                                            <a href="@existingDto.SupportingDocPath" target="_blank">Lihat dokumen</a>
                                        </div>
                                    }
                                    <div class="form-text text-muted">PDF, Word, atau gambar. Maks 10MB.</div>
                                </div>

                                <div class="mb-3">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" name="isPassed" value="true"
                                            id="isPassed_@monSess.Id" @(existingDto?.IsPassed == true ? "checked" : "") />
                                        <label class="form-check-label fw-semibold" for="isPassed_@monSess.Id">
                                            <i class="bi bi-check-circle text-success me-1"></i>Dinyatakan Lulus
                                        </label>
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-save me-1"></i>@(hasResults ? "Update Hasil Interview" : "Simpan Hasil Interview")
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

</div>

@if (Model.IsPackageMode)
{
<script>
    var antiForgeryToken = document.querySelector('#reshuffleForm input[name="__RequestVerificationToken"]').value;

    function reshuffleWorker(sessionId) {
        var btn = document.querySelector('[data-session-id="' + sessionId + '"]');
        var originalHtml = btn.innerHTML;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
        btn.disabled = true;

        $.ajax({
            url: '/Admin/ReshufflePackage',
            type: 'POST',
            data: {
                sessionId: sessionId,
                __RequestVerificationToken: antiForgeryToken
            },
            success: function(resp) {
                if (resp.success) {
                    // Show toast
                    var toastBody = document.getElementById('reshuffleToastBody');
                    toastBody.textContent = 'Package berhasil di-reshuffle \u2192 ' + resp.packageName;
                    var toast = new bootstrap.Toast(document.getElementById('reshuffleToast'));
                    toast.show();
                } else {
                    alert(resp.message || 'Reshuffle gagal.');
                }
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            },
            error: function() {
                alert('Terjadi kesalahan saat reshuffle.');
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            }
        });
    }

    function reshuffleAll(event) {
        var pendingCount = @Model.PendingCount;
        if (!confirm('Reshuffle semua ' + pendingCount + ' peserta yang belum mulai ujian?')) return;

        var btn = event.target.closest('button');
        var originalHtml = btn.innerHTML;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Processing...';
        btn.disabled = true;

        $.ajax({
            url: '/Admin/ReshuffleAll',
            type: 'POST',
            data: {
                title: '@Html.Raw(Model.Title.Replace("'", "\\'"))',
                category: '@Model.Category',
                scheduleDate: '@Model.Schedule.ToString("yyyy-MM-dd")',
                __RequestVerificationToken: antiForgeryToken
            },
            success: function(resp) {
                btn.innerHTML = originalHtml;
                btn.disabled = false;

                if (resp.success) {
                    // Build result table
                    var html = '<table class="table table-sm mb-0"><thead><tr><th>Name</th><th>Result</th></tr></thead><tbody>';
                    resp.results.forEach(function(r) {
                        var badgeClass = r.status.indexOf('Reshuffled') === 0 ? 'text-success' : 'text-muted';
                        html += '<tr><td>' + r.name + '</td><td class="' + badgeClass + '">' + r.status + '</td></tr>';
                    });
                    html += '</tbody></table>';
                    html += '<p class="mt-2 mb-0 text-muted small">' + resp.reshuffledCount + ' peserta berhasil di-reshuffle.</p>';

                    document.getElementById('reshuffleResultBody').innerHTML = html;
                    var modal = new bootstrap.Modal(document.getElementById('reshuffleResultModal'));
                    modal.show();

                    // Reload page after modal is closed so package cells reflect new assignments
                    document.getElementById('reshuffleResultModal').addEventListener('hidden.bs.modal', function() {
                        location.reload();
                    }, { once: true });
                } else {
                    alert(resp.message || 'Reshuffle All gagal.');
                }
            },
            error: function() {
                alert('Terjadi kesalahan saat reshuffle.');
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            }
        });
    }
</script>
}

<script>
(function () {
    // ---- State ----
    var countdownMap = {}; // { sessionId: remainingSeconds | null }
    var pollingActive = true;
    var pollingTimer = null;
    var countdownTimer = null;

    // ---- Read page params from hidden fields ----
    var hTitle        = document.getElementById('hTitle').value;
    var hCategory     = document.getElementById('hCategory').value;
    var hScheduleDate = document.getElementById('hScheduleDate').value;

    // ---- Antiforgery token (for JS-rendered Reset / AkhiriUjian forms) ----
    function getToken() {
        var inp = document.querySelector('#antiforgeryForm input[name="__RequestVerificationToken"]');
        return inp ? inp.value : '';
    }

    // ---- Status badge class helper ----
    function statusBadgeClass(status) {
        if (status === 'Completed')  return 'badge bg-success';
        if (status === 'InProgress') return 'badge bg-warning text-dark';
        if (status === 'Abandoned')  return 'badge bg-secondary';
        if (status === 'Cancelled')  return 'badge bg-secondary';
        return 'badge bg-light text-dark border'; // Not started
    }

    // ---- Status display label ----
    function statusDisplayLabel(status) {
        if (status === 'Cancelled') return 'Dibatalkan';
        return status;
    }

    // ---- Build actions HTML per status ----
    function buildActionsHtml(session, isPackageMode) {
        var html = '';
        var token = getToken();

        // Cancelled -- no actions at all
        if (session.status === 'Cancelled') return html;

        // Reshuffle -- package mode, Not started or Abandoned only (always enabled)
        if (isPackageMode && (session.status === 'Not started' || session.status === 'Abandoned')) {
            html += '<button type="button"'
                + ' class="btn btn-outline-primary btn-sm me-1"'
                + ' data-session-id="' + session.sessionId + '"'
                + ' onclick="reshuffleWorker(' + session.sessionId + ')"'
                + '><i class="bi bi-shuffle me-1"></i>Reshuffle</button>';
        }

        // Akhiri Ujian -- InProgress only
        if (session.status === 'InProgress') {
            // Get worker name from the existing row (col 0)
            var tr = document.querySelector('tr[data-session-id="' + session.sessionId + '"]');
            var workerName = tr ? tr.querySelectorAll('td')[0].textContent.trim().replace(/'/g, "\\'") : '';
            html += '<form class="d-inline me-1" method="post" action="/Admin/AkhiriUjian"'
                + ' onsubmit="return confirm(\'Akhiri ujian untuk ' + workerName + '? Jawaban tersimpan akan dinilai otomatis.\')">'
                + '<input type="hidden" name="__RequestVerificationToken" value="' + token + '" />'
                + '<input type="hidden" name="id" value="' + session.sessionId + '" />'
                + '<button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-x-circle me-1"></i>Akhiri Ujian</button>'
                + '</form>';
        }

        // Reset -- all statuses except Cancelled
        html += '<form class="d-inline me-1" method="post" action="/Admin/ResetAssessment"'
            + ' onsubmit="return confirm(\'Reset sesi ini? Semua jawaban akan dihapus dan peserta dapat mengulang ujian.\')">'
            + '<input type="hidden" name="__RequestVerificationToken" value="' + token + '" />'
            + '<input type="hidden" name="id" value="' + session.sessionId + '" />'
            + '<button type="submit" class="btn btn-warning btn-sm"><i class="bi bi-arrow-counterclockwise me-1"></i>Reset</button>'
            + '</form>';

        // View Results -- Completed only (new tab)
        if (session.status === 'Completed') {
            html += '<a href="/CMP/Results/' + session.sessionId + '" target="_blank"'
                + ' class="btn btn-success btn-sm">View Results</a>';
        }

        // Activity Log button -- always shown
        // Worker name from DOM (col 0 of the row)
        var wn = '';
        var trRow = document.querySelector('tr[data-session-id="' + session.sessionId + '"]');
        if (trRow) { wn = trRow.querySelectorAll('td')[0].textContent.trim().replace(/'/g, "\\'"); }
        html += '<button type="button"'
            + ' class="btn btn-outline-secondary btn-sm ms-1"'
            + ' onclick="showActivityLog(' + session.sessionId + ', \'' + wn + '\')"'
            + ' title="Lihat activity log"><i class="bi bi-clock-history"></i></button>';

        return html;
    }

    // ---- Format time remaining ----
    function formatTime(secs) {
        if (secs === null || secs === undefined) return '\u2014';
        if (secs <= 0) return '00:00';
        var m = Math.floor(secs / 60);
        var s = secs % 60;
        return String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
    }

    // ---- Detect package mode from page (Reshuffle button presence) ----
    var isPackageMode = (document.getElementById('reshuffleForm') !== null);

    // ---- Update a single row ----
    function updateRow(session) {
        var tr = document.querySelector('tr[data-session-id="' + session.sessionId + '"]');
        if (!tr) return;

        var tds = tr.querySelectorAll('td');
        // Column order (0-indexed): Name=0, Progress=1, Status=2, Score=3, Result=4, CompletedAt=5, TimeRemaining=6, Actions=7

        // Progress (col 1)
        var total = session.totalQuestions || 0;
        tds[1].textContent = total > 0 ? (session.progress + '/' + total) : '\u2014';

        // Status (col 2)
        tds[2].innerHTML = '<span class="' + statusBadgeClass(session.status) + '">' + statusDisplayLabel(session.status) + '</span>';

        // Score (col 3)
        tds[3].textContent = session.score !== null && session.score !== undefined ? session.score + '%' : '\u2014';

        // Result (col 4)
        var resultText = session.result || '\u2014';
        var resultClass = session.result === 'Pass' ? 'text-success fw-semibold' : (session.result === 'Fail' ? 'text-danger fw-semibold' : 'text-muted');
        tds[4].textContent = resultText;
        tds[4].className = 'result-cell ' + resultClass;

        // Completed At (col 5)
        if (session.completedAt) {
            var d = new Date(session.completedAt);
            tds[5].textContent = d.toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' })
                + ' ' + d.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
        } else {
            tds[5].textContent = '\u2014';
        }

        // Time Remaining (col 6) -- re-sync countdownMap from server snapshot
        countdownMap[session.sessionId] = session.status === 'InProgress' ? session.remainingSeconds : null;
        tds[6].textContent = formatTime(countdownMap[session.sessionId]);

        // Actions (col 7)
        tds[7].innerHTML = buildActionsHtml(session, isPackageMode);
    }

    // ---- Tick countdown every second ----
    function tickCountdowns() {
        Object.keys(countdownMap).forEach(function (idStr) {
            var id = parseInt(idStr, 10);
            var secs = countdownMap[id];
            if (secs !== null && secs > 0) {
                countdownMap[id] = secs - 1;
                var tr = document.querySelector('tr[data-session-id="' + id + '"]');
                if (tr) {
                    var tds = tr.querySelectorAll('td');
                    if (tds[6]) tds[6].textContent = formatTime(countdownMap[id]);
                }
            }
        });
    }

    // ---- Update summary counts ----
    function updateSummary(sessions) {
        var total      = sessions.length;
        var completed  = sessions.filter(function (s) { return s.status === 'Completed'; }).length;
        var inProgress = sessions.filter(function (s) { return s.status === 'InProgress'; }).length;
        var notStarted = sessions.filter(function (s) { return s.status === 'Not started'; }).length;
        var cancelled  = sessions.filter(function (s) { return s.status === 'Cancelled'; }).length;

        var elTotal      = document.getElementById('count-total');
        var elCompleted  = document.getElementById('count-completed');
        var elInProgress = document.getElementById('count-inprogress');
        var elNotStarted = document.getElementById('count-notstarted');
        var elCancelled  = document.getElementById('count-cancelled');

        if (elTotal)      elTotal.textContent      = total;
        if (elCompleted)  elCompleted.textContent  = completed;
        if (elInProgress) elInProgress.textContent = inProgress;
        if (elNotStarted) elNotStarted.textContent = notStarted;
        if (elCancelled)  elCancelled.textContent  = cancelled;
    }

    // ---- Update "Last updated" timestamp ----
    function updateLastUpdated() {
        var el = document.getElementById('last-updated-time');
        if (el) el.textContent = new Date().toLocaleTimeString('id-ID');
        // Hide error indicator on success
        var errEl = document.getElementById('poll-error');
        if (errEl) errEl.style.display = 'none';
    }

    // ---- Show error indicator on fetch failure ----
    function showErrorIndicator() {
        var errEl = document.getElementById('poll-error');
        if (errEl) errEl.style.display = '';
    }

    // ---- Main poll function ----
    async function fetchProgress() {
        if (!pollingActive) return;
        try {
            var url = '/Admin/GetMonitoringProgress'
                + '?title=' + encodeURIComponent(hTitle)
                + '&category=' + encodeURIComponent(hCategory)
                + '&scheduleDate=' + encodeURIComponent(hScheduleDate);

            var resp = await fetch(url);
            if (!resp.ok) { showErrorIndicator(); return; }

            var sessions = await resp.json();
            sessions.forEach(updateRow);
            updateSummary(sessions);
            updateLastUpdated();

            // Stop polling when all sessions are in a terminal state (Completed, Cancelled, Abandoned)
            if (sessions.length > 0 && sessions.every(function (s) { return s.status === 'Completed' || s.status === 'Cancelled' || s.status === 'Abandoned'; })) {
                clearInterval(pollingTimer);
                clearInterval(countdownTimer);
                pollingActive = false;

                // Hide "Akhiri Semua Ujian" button
                var akhiriBtn = document.getElementById('akhiriSemuaBtn');
                if (akhiriBtn) akhiriBtn.style.display = 'none';
            }
        } catch (e) {
            showErrorIndicator();
        }
    }

    // ---- Start intervals ----
    pollingTimer   = setInterval(fetchProgress, 10000);
    countdownTimer = setInterval(tickCountdowns, 1000);

    // Run first poll immediately (don't wait 10s)
    fetchProgress();

    // ---- Akhiri Semua Modal: fetch counts on open ----
    var akhiriModal = document.getElementById('akhiriSemuaModal');
    if (akhiriModal) {
        akhiriModal.addEventListener('show.bs.modal', function () {
            var loading = document.getElementById('akhiriSemuaLoading');
            var content = document.getElementById('akhiriSemuaContent');
            loading.style.display = '';
            content.style.display = 'none';

            var url = '/Admin/GetAkhiriSemuaCounts'
                + '?title=' + encodeURIComponent(hTitle)
                + '&category=' + encodeURIComponent(hCategory)
                + '&scheduleDate=' + encodeURIComponent(hScheduleDate);

            fetch(url)
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    document.getElementById('akhiriInProgressCount').textContent = data.inProgressCount || 0;
                    document.getElementById('akhiriNotStartedCount').textContent = data.notStartedCount || 0;
                    loading.style.display = 'none';
                    content.style.display = '';
                })
                .catch(function () {
                    loading.innerHTML = '<span class="text-danger">Gagal memuat data. Tutup dan coba lagi.</span>';
                });
        });
    }
})();
</script>

@if (Model.IsTokenRequired)
{
    <script>
    function copyToken() {
        var tokenEl = document.getElementById('token-display');
        var labelEl = document.getElementById('copy-label');
        if (!tokenEl) return;
        navigator.clipboard.writeText(tokenEl.textContent.trim()).then(function () {
            labelEl.textContent = 'Copied!';
            setTimeout(function () { labelEl.textContent = 'Copy'; }, 2000);
        });
    }

    function regenToken(btn) {
        if (!confirm('Regenerate token untuk grup ini? Token lama tidak akan bisa digunakan.')) return;
        var id = btn.getAttribute('data-id');
        var token = document.querySelector('#antiforgeryForm input[name="__RequestVerificationToken"]').value;
        btn.disabled = true;
        var originalHtml = btn.innerHTML;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

        fetch('/Admin/RegenerateToken/' + id, {
            method: 'POST',
            headers: { 'RequestVerificationToken': token }
        })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            if (data.success) {
                document.getElementById('token-display').textContent = data.token;
                var labelEl = document.getElementById('copy-label');
                if (labelEl) { labelEl.textContent = 'Copy'; }
            } else {
                alert('Error: ' + (data.message || 'Gagal regenerate token.'));
            }
        })
        .catch(function () {
            alert('Terjadi kesalahan saat regenerate token.');
        })
        .finally(function () {
            btn.disabled = false;
            btn.innerHTML = originalHtml;
        });
    }
    </script>
}

<script>
// ---- Activity Log Modal ----
function showActivityLog(sessionId, workerName) {
    document.getElementById('logWorkerName').textContent = workerName;
    document.getElementById('logSummary').innerHTML = '';
    document.getElementById('logTimeline').innerHTML = '';

    var loadingEl = document.getElementById('logLoading');
    loadingEl.classList.remove('d-none');

    var modal = new bootstrap.Modal(document.getElementById('activityLogModal'));
    modal.show();

    fetch('/Admin/GetActivityLog?sessionId=' + sessionId)
        .then(function(r) { return r.json(); })
        .then(function(data) {
            loadingEl.classList.add('d-none');

            // Render summary
            var s = data.summary;
            var minutes = s.timeSpentSeconds != null ? Math.round(s.timeSpentSeconds / 60) : '--';
            document.getElementById('logSummary').innerHTML =
                '<i class="bi bi-bar-chart-fill me-1"></i>' +
                '<strong>Dijawab:</strong> ' + (s.answeredCount || 0) + ' &nbsp;|&nbsp; ' +
                '<strong>Waktu:</strong> ' + minutes + ' menit &nbsp;|&nbsp; ' +
                '<strong>Terputus:</strong> ' + (s.disconnectCount || 0) + 'x';

            // Render timeline
            var events = data.events || [];
            if (events.length === 0) {
                document.getElementById('logTimeline').innerHTML =
                    '<p class="text-muted text-center">Belum ada aktivitas tercatat.</p>';
                return;
            }

            var html = '<table class="table table-sm table-borderless">' +
                '<thead><tr><th style="width:90px">Waktu</th><th>Aktivitas</th></tr></thead><tbody>';
            events.forEach(function(e) {
                var label = eventLabel(e.eventType, e.detail);
                html += '<tr><td class="text-muted small font-monospace">' + e.timestamp + '</td>' +
                    '<td>' + label + '</td></tr>';
            });
            html += '</tbody></table>';
            document.getElementById('logTimeline').innerHTML = html;
        })
        .catch(function() {
            loadingEl.classList.add('d-none');
            document.getElementById('logSummary').innerHTML =
                '<span class="text-danger"><i class="bi bi-exclamation-triangle-fill me-1"></i>Gagal memuat log.</span>';
        });
}

function eventLabel(eventType, detail) {
    switch (eventType) {
        case 'started':      return '<i class="bi bi-play-circle-fill text-success me-1"></i>Memulai Ujian';
        case 'page_nav':     return '<i class="bi bi-arrow-right-circle text-primary me-1"></i>Pindah ke ' + (detail || 'halaman');
        case 'disconnected': return '<i class="bi bi-wifi-off text-danger me-1"></i>Terputus';
        case 'reconnected':  return '<i class="bi bi-wifi text-warning me-1"></i>Tersambung Kembali';
        case 'submitted':    return '<i class="bi bi-check-circle-fill text-success me-1"></i>Menyelesaikan Ujian';
        default:             return eventType + (detail ? ' — ' + detail : '');
    }
}
</script>

@section Scripts {
<link rel="stylesheet" href="~/css/assessment-hub.css" />
<script src="~/lib/signalr/signalr.min.js"></script>
<script>window.assessmentBatchKey = '@ViewBag.AssessmentBatchKey';</script>
<script src="~/js/assessment-hub.js"></script>
<script>
    // -------- Connection status badge --------
    var monBadge = document.getElementById('hubStatusBadge');
    window.assessmentHub.onreconnecting(function() {
        if (monBadge) { monBadge.className = 'badge bg-warning ms-1 small'; monBadge.textContent = 'Reconnecting...'; }
    });
    window.assessmentHub.onreconnected(function() {
        if (monBadge) { monBadge.className = 'badge bg-success ms-1 small'; monBadge.textContent = 'Live'; }
    });
    window.assessmentHub.onclose(function() {
        if (monBadge) { monBadge.className = 'badge bg-danger ms-1 small'; monBadge.textContent = 'Disconnected'; }
    });
    // Set initial "Live" state after hub connects, then join monitor group
    setTimeout(function() {
        if (monBadge && window.assessmentHub && window.assessmentHub.state === 'Connected') {
            monBadge.className = 'badge bg-success ms-1 small';
            monBadge.textContent = 'Live';
        }
        if (window.assessmentBatchKey && window.assessmentHub && window.assessmentHub.state === 'Connected') {
            window.assessmentHub.invoke('JoinMonitor', window.assessmentBatchKey)
                .catch(function(err) { console.warn('[monitor] JoinMonitor failed:', err); });
        }
    }, 2000);

    // Rejoin monitor group after reconnect
    window.assessmentHub.onreconnected(function() {
        if (window.assessmentBatchKey) {
            window.assessmentHub.invoke('JoinMonitor', window.assessmentBatchKey)
                .catch(function(err) { console.warn('[monitor] JoinMonitor after reconnect failed:', err); });
        }
    });

    // ---- Row flash helper ----
    function flashRow(tr, cssClass) {
        if (!tr) return;
        tr.classList.remove('flash-update', 'flash-complete');
        void tr.offsetWidth; // force reflow to restart animation
        tr.classList.add(cssClass);
        setTimeout(function() { tr.classList.remove(cssClass); }, 1300);
    }

    // ---- Update summary counts from DOM (used by push events) ----
    function updateSummaryFromDOM() {
        var rows = document.querySelectorAll('tbody tr[data-session-id]');
        var total = rows.length;
        var completed = 0, inProgress = 0, notStarted = 0, cancelled = 0;
        rows.forEach(function(tr) {
            var statusCell = tr.querySelector('.status-cell');
            if (!statusCell) return;
            var text = statusCell.textContent.trim();
            if (text === 'Completed') completed++;
            else if (text === 'InProgress') inProgress++;
            else if (text === 'Dibatalkan') cancelled++;
            else notStarted++;
        });
        var el;
        el = document.getElementById('count-total');      if (el) el.textContent = total;
        el = document.getElementById('count-completed');  if (el) el.textContent = completed;
        el = document.getElementById('count-inprogress'); if (el) el.textContent = inProgress;
        el = document.getElementById('count-notstarted'); if (el) el.textContent = notStarted;
        el = document.getElementById('count-cancelled');  if (el) el.textContent = cancelled;
    }

    // ---- SignalR push event handlers ----

    // progressUpdate: worker answered a question
    window.assessmentHub.on('progressUpdate', function(data) {
        var tr = document.querySelector('tr[data-session-id="' + data.sessionId + '"]');
        if (!tr) return;
        var progressCell = tr.querySelector('.progress-cell');
        if (progressCell) {
            progressCell.textContent = data.totalQuestions > 0
                ? (data.progress + '/' + data.totalQuestions)
                : '\u2014';
        }
        flashRow(tr, 'flash-update');
        // updateLastUpdated is already defined in the IIFE above (page scope accessible)
        var el = document.getElementById('last-updated-time');
        if (el) el.textContent = new Date().toLocaleTimeString('id-ID');
    });

    // workerStarted: worker opened exam for the first time
    window.assessmentHub.on('workerStarted', function(data) {
        var tr = document.querySelector('tr[data-session-id="' + data.sessionId + '"]');
        if (!tr) return;
        var statusCell = tr.querySelector('.status-cell');
        if (statusCell) {
            statusCell.innerHTML = '<span class="badge bg-warning text-dark">InProgress</span>';
        }
        flashRow(tr, 'flash-update');
        if (typeof window.showAssessmentToast === 'function') {
            window.showAssessmentToast(data.workerName + ' memulai ujian');
        }
        updateSummaryFromDOM();
        var el = document.getElementById('last-updated-time');
        if (el) el.textContent = new Date().toLocaleTimeString('id-ID');
    });

    // workerSubmitted: worker submitted exam
    window.assessmentHub.on('workerSubmitted', function(data) {
        var tr = document.querySelector('tr[data-session-id="' + data.sessionId + '"]');
        // Build session object matching updateRow() signature
        var session = {
            sessionId: data.sessionId,
            status: 'Completed',
            score: data.score,
            result: data.result,
            progress: data.totalQuestions,
            totalQuestions: data.totalQuestions,
            remainingSeconds: null,
            completedAt: new Date().toISOString()
        };
        // updateRow is defined in the IIFE; since it is inside an IIFE it is not directly accessible here.
        // Re-implement minimal row update for workerSubmitted:
        if (tr) {
            var tds = tr.querySelectorAll('td');
            // Progress (col 1)
            if (tds[1] && data.totalQuestions > 0) tds[1].textContent = data.totalQuestions + '/' + data.totalQuestions;
            // Status (col 2)
            if (tds[2]) tds[2].innerHTML = '<span class="badge bg-success">Completed</span>';
            // Score (col 3)
            if (tds[3]) tds[3].textContent = data.score !== null && data.score !== undefined ? data.score + '%' : '\u2014';
            // Result (col 4)
            if (tds[4]) {
                tds[4].textContent = data.result || '\u2014';
                tds[4].className = 'result-cell ' + (data.result === 'Pass' ? 'text-success fw-semibold' : (data.result === 'Fail' ? 'text-danger fw-semibold' : 'text-muted'));
            }
            // CompletedAt (col 5)
            if (tds[5]) {
                var d = new Date();
                tds[5].textContent = d.toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' })
                    + ' ' + d.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
            }
            flashRow(tr, 'flash-complete');
        }
        if (typeof window.showAssessmentToast === 'function') {
            window.showAssessmentToast(data.workerName + ' menyelesaikan ujian (Skor: ' + data.score + '%)');
        }
        updateSummaryFromDOM();
        var elLu = document.getElementById('last-updated-time');
        if (elLu) elLu.textContent = new Date().toLocaleTimeString('id-ID');

        // If all rows are terminal, hide Akhiri Semua button
        var rows = document.querySelectorAll('tbody tr[data-session-id]');
        var allDone = true;
        rows.forEach(function(row) {
            var sc = row.querySelector('.status-cell');
            if (sc) {
                var txt = sc.textContent.trim();
                if (txt !== 'Completed' && txt !== 'Dibatalkan' && txt !== 'Abandoned') allDone = false;
            }
        });
        if (allDone) {
            var akhiriBtn = document.getElementById('akhiriSemuaBtn');
            if (akhiriBtn) akhiriBtn.style.display = 'none';
        }
    });
</script>
}
