@if (Model.IsPackageMode)
{
<script>
    var antiForgeryEl = document.querySelector('#reshuffleForm input[name="__RequestVerificationToken"]');
    var antiForgeryToken = antiForgeryEl ? antiForgeryEl.value : '';

    function reshuffleWorker(btn) {
        // MAM-13: terima elemen button (this) — hindari querySelector ambigu yang match <tr> duluan.
        var sessionId = btn.dataset.sessionId;
        var originalHtml = btn.innerHTML;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
        btn.disabled = true;

        $.ajax({
            url: '@Url.Action("ReshufflePackage", "AssessmentAdmin")',
            type: 'POST',
            data: {
                sessionId: sessionId,
                __RequestVerificationToken: antiForgeryToken
            },
            success: function(resp) {
                if (resp.success) {
                    // Show toast
                    var toastBody = document.getElementById('reshuffleToastBody');
                    toastBody.textContent = 'Package berhasil di-reshuffle \u2192 ' + resp.packageName;
                    var toast = new bootstrap.Toast(document.getElementById('reshuffleToast'));
                    toast.show();
                } else {
                    alert(resp.message || 'Reshuffle gagal.');
                }
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            },
            error: function() {
                alert('Terjadi kesalahan saat reshuffle.');
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            }
        });
    }

    function reshuffleAll(event) {
        var pendingCount = @Model.PendingCount;
        if (!confirm('Reshuffle semua ' + pendingCount + ' peserta yang belum mulai ujian?')) return;

        var btn = event.target.closest('button');
        var originalHtml = btn.innerHTML;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Processing...';
        btn.disabled = true;

        $.ajax({
            url: '@Url.Action("ReshuffleAll", "AssessmentAdmin")',
            type: 'POST',
            data: {
                title: @Json.Serialize(Model.Title),
                category: '@Model.Category',
                scheduleDate: '@Model.Schedule.ToString("yyyy-MM-dd")',
                __RequestVerificationToken: antiForgeryToken
            },
            success: function(resp) {
                btn.innerHTML = originalHtml;
                btn.disabled = false;

                if (resp.success) {
                    // Build result table
                    var html = '<table class="table table-sm mb-0"><thead><tr><th>Nama</th><th>Hasil</th></tr></thead><tbody>';
                    resp.results.forEach(function(r) {
                        var badgeClass = r.status.indexOf('Reshuffled') === 0 ? 'text-success' : 'text-muted';
                        html += '<tr><td>' + r.name + '</td><td class="' + badgeClass + '">' + r.status + '</td></tr>';
                    });
                    html += '</tbody></table>';
                    html += '<p class="mt-2 mb-0 text-muted small">' + resp.reshuffledCount + ' peserta berhasil di-reshuffle.</p>';

                    document.getElementById('reshuffleResultBody').innerHTML = html;
                    var modal = new bootstrap.Modal(document.getElementById('reshuffleResultModal'));
                    modal.show();

                    // Reload page after modal is closed so package cells reflect new assignments
                    document.getElementById('reshuffleResultModal').addEventListener('hidden.bs.modal', function() {
                        location.reload();
                    }, { once: true });
                } else {
                    alert(resp.message || 'Reshuffle All gagal.');
                }
            },
            error: function() {
                alert('Terjadi kesalahan saat reshuffle.');
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            }
        });
    }
</script>
}

<script>
(function () {
    // ---- Read page params from hidden fields ----
    var hTitle        = document.getElementById('hTitle').value;
    var hCategory     = document.getElementById('hCategory').value;
    var hScheduleDate = document.getElementById('hScheduleDate').value;

    // ---- Antiforgery token (for JS-rendered Reset / AkhiriUjian forms) ----
    function getToken() {
        var inp = document.querySelector('#antiforgeryForm input[name="__RequestVerificationToken"]');
        return inp ? inp.value : '';
    }

    // ---- Status badge class helper ----
    function statusBadgeClass(status) {
        if (status === 'Completed')  return 'badge bg-success';
        if (status === 'InProgress') return 'badge bg-warning text-dark';
        if (status === 'Abandoned')  return 'badge bg-secondary';
        if (status === 'Cancelled')  return 'badge bg-secondary';
        return 'badge bg-light text-dark border'; // Not started
    }

    // ---- Status display label ----
    function statusDisplayLabel(status) {
        if (status === 'Cancelled') return 'Dibatalkan';
        return status;
    }

    // ---- Build actions HTML per status ----
    function buildActionsHtml(session, isPackageMode) {
        var html = '';
        var token = getToken();

        // Cancelled -- no actions at all
        if (session.status === 'Cancelled') return html;

        // Reshuffle -- package mode, Not started or Abandoned only (always enabled)
        if (isPackageMode && (session.status === 'Not started' || session.status === 'Abandoned')) {
            html += '<button type="button"'
                + ' class="btn btn-outline-primary btn-sm me-1"'
                + ' data-session-id="' + session.sessionId + '"'
                + ' onclick="reshuffleWorker(this)"'
                + '><i class="bi bi-shuffle me-1"></i>Reshuffle</button>';
        }

        // Akhiri Ujian -- InProgress only
        if (session.status === 'InProgress') {
            // Get worker name from the existing row (col 0)
            var tr = document.querySelector('tr[data-session-id="' + session.sessionId + '"]');
            var workerName = tr ? tr.querySelectorAll('td')[0].textContent.trim().replace(/'/g, "\\'") : '';
            html += '<form class="d-inline me-1" method="post" action="' + basePath + '/Admin/AkhiriUjian"'
                + ' onsubmit="return confirm(\'Akhiri ujian untuk ' + workerName + '? Jawaban tersimpan akan dinilai otomatis.\')">'
                + '<input type="hidden" name="__RequestVerificationToken" value="' + token + '" />'
                + '<input type="hidden" name="id" value="' + session.sessionId + '" />'
                + '<button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-x-circle me-1"></i>Akhiri Ujian</button>'
                + '</form>';
        }

        // Reset -- all statuses except Cancelled
        html += '<form class="d-inline me-1" method="post" action="' + basePath + '/Admin/ResetAssessment"'
            + ' onsubmit="return confirm(\'Reset sesi ini? Semua jawaban akan dihapus dan peserta dapat mengulang ujian.\')">'
            + '<input type="hidden" name="__RequestVerificationToken" value="' + token + '" />'
            + '<input type="hidden" name="id" value="' + session.sessionId + '" />'
            + '<button type="submit" class="btn btn-warning btn-sm"><i class="bi bi-arrow-counterclockwise me-1"></i>Reset</button>'
            + '</form>';

        // View Results -- Completed only (new tab)
        if (session.status === 'Completed') {
            html += '<a href="' + basePath + '/CMP/Results/' + session.sessionId + '" target="_blank"'
                + ' class="btn btn-success btn-sm">View Results</a>';
        }

        // Activity Log button -- always shown
        // Worker name from DOM (col 0 of the row)
        var wn = '';
        var trRow = document.querySelector('tr[data-session-id="' + session.sessionId + '"]');
        if (trRow) { wn = trRow.querySelectorAll('td')[0].textContent.trim(); }
        html += '<button type="button"'
            + ' class="btn btn-outline-secondary btn-sm ms-1 btn-activity-log"'
            + ' data-session-id="' + session.sessionId + '"'
            + ' data-worker-name="' + wn.replace(/"/g, '&quot;') + '"'
            + ' title="Lihat activity log"><i class="bi bi-clock-history"></i></button>';

        // Phase 412 PRMV-02: tombol Hapus Peserta untuk baris yang di-inject SignalR.
        // Guard Proton (panel/hapus tak relevan untuk Assessment Proton).
        if (hCategory !== 'Assessment Proton') {
            // status payload: session.status (workerSubmitted-shape) atau session.UserStatus (raw)
            var hpStatus = session.status || session.UserStatus || 'Not started';
            var hasCert = session.nomorSertifikat ? 'true' : 'false';
            var hpName = (wn || session.fullName || '').replace(/"/g, '&quot;');
            html += '<button type="button"'
                + ' class="btn btn-outline-danger btn-sm ms-1 btn-hapus-peserta"'
                + ' data-session-id="' + session.sessionId + '"'
                + ' data-worker-name="' + hpName + '"'
                + ' data-status="' + hpStatus + '"'
                + ' data-has-cert="' + hasCert + '"'
                + ' title="Hapus dari batch"><i class="bi bi-person-x"></i></button>';
        }

        return html;
    }

    // ---- Detect package mode from page (Reshuffle button presence) ----
    var isPackageMode = (document.getElementById('reshuffleForm') !== null);

    // ---- Update a single row ----
    function updateRow(session) {
        var tr = document.querySelector('tr[data-session-id="' + session.sessionId + '"]');
        if (!tr) return;

        var tds = tr.querySelectorAll('td');
        // Column order (0-indexed): Name=0, Progress=1, Status=2, Score=3, Result=4, CompletedAt=5, Actions=6

        // Progress (col 1)
        var total = session.totalQuestions || 0;
        tds[1].textContent = total > 0 ? (session.progress + '/' + total) : '\u2014';

        // Status (col 2)
        tds[2].innerHTML = '<span class="' + statusBadgeClass(session.status) + '">' + statusDisplayLabel(session.status) + '</span>';

        // Score (col 3)
        tds[3].textContent = session.score !== null && session.score !== undefined ? session.score + '%' : '\u2014';

        // Result (col 4)
        var resultText = session.result || '\u2014';
        var resultClass = session.result === 'Pass' ? 'text-success fw-semibold' : (session.result === 'Fail' ? 'text-danger fw-semibold' : 'text-muted');
        tds[4].textContent = resultText;
        tds[4].className = 'result-cell ' + resultClass;

        // Selesai Pada (col 5)
        if (session.completedAt) {
            var d = new Date(session.completedAt);
            tds[5].textContent = d.toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' })
                + ' ' + d.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
        } else {
            tds[5].textContent = '\u2014';
        }

        // Actions (col 6)
        tds[6].innerHTML = buildActionsHtml(session, isPackageMode);
    }

    // ---- Update summary counts ----
    function updateSummary(sessions) {
        var total      = sessions.length;
        var completed  = sessions.filter(function (s) { return s.status === 'Completed'; }).length;
        var inProgress = sessions.filter(function (s) { return s.status === 'InProgress'; }).length;
        var notStarted = sessions.filter(function (s) { return s.status === 'Not started'; }).length;
        var cancelled  = sessions.filter(function (s) { return s.status === 'Cancelled'; }).length;

        var elTotal      = document.getElementById('count-total');
        var elCompleted  = document.getElementById('count-completed');
        var elInProgress = document.getElementById('count-inprogress');
        var elNotStarted = document.getElementById('count-notstarted');
        var elCancelled  = document.getElementById('count-cancelled');

        if (elTotal)      elTotal.textContent      = total;
        if (elCompleted)  elCompleted.textContent  = completed;
        if (elInProgress) elInProgress.textContent = inProgress;
        if (elNotStarted) elNotStarted.textContent = notStarted;
        if (elCancelled)  elCancelled.textContent  = cancelled;
    }

    // ---- Delegate click for activity log buttons (avoids inline onclick / XSS) ----
    document.addEventListener('click', function (e) {
        var btn = e.target.closest('.btn-activity-log');
        if (btn) {
            var sid = parseInt(btn.getAttribute('data-session-id'), 10);
            var wname = btn.getAttribute('data-worker-name') || '';
            showActivityLog(sid, wname);
            // Phase 321: set modal currentSessionId + reset Edit History tab cache
            var modal = document.getElementById('activityLogModal');
            if (modal) modal.dataset.currentSessionId = sid;
            var ehBtn = document.getElementById('tab-edit-history-btn');
            if (ehBtn) ehBtn.dataset.loaded = '';
            var ehPane = document.getElementById('tab-edit-history');
            if (ehPane) ehPane.innerHTML = '<div class="edit-history-placeholder text-muted small">Memuat...</div>';
            // Reset to Timeline tab on open
            var tlBtn = document.getElementById('tab-timeline-btn');
            if (tlBtn && window.bootstrap && bootstrap.Tab) {
                bootstrap.Tab.getOrCreateInstance(tlBtn).show();
            }
        }
    });

    // Phase 321: Lazy-load Edit History tab on first show per session
    document.addEventListener('shown.bs.tab', function (event) {
        var btn = event.target;
        if (!btn || btn.id !== 'tab-edit-history-btn') return;
        if (btn.dataset.loaded === '1') return;

        var modal = document.getElementById('activityLogModal');
        var sessionId = modal ? modal.dataset.currentSessionId : null;
        var pane = document.getElementById('tab-edit-history');
        if (!sessionId) {
            if (pane) pane.innerHTML = '<p class="text-muted small">Sesi tidak diketahui.</p>';
            return;
        }

        var urlTemplate = btn.dataset.loadUrlTemplate;
        var url = urlTemplate + '?sessionId=' + sessionId;

        fetch(url)
            .then(function (resp) {
                if (!resp.ok) throw new Error('HTTP ' + resp.status);
                return resp.text();
            })
            .then(function (html) {
                pane.innerHTML = html;
                btn.dataset.loaded = '1';
            })
            .catch(function (err) {
                pane.innerHTML = '<p class="text-danger small">Gagal memuat edit history.</p>';
                console.error('EditHistory load failed:', err);
            });
    });

    // ---- Akhiri Semua Modal: fetch counts on open ----
    var akhiriModal = document.getElementById('akhiriSemuaModal');
    if (akhiriModal) {
        akhiriModal.addEventListener('show.bs.modal', function () {
            var loading = document.getElementById('akhiriSemuaLoading');
            var content = document.getElementById('akhiriSemuaContent');
            loading.style.display = '';
            content.style.display = 'none';

            var url = appUrl('/Admin/GetAkhiriSemuaCounts')
                + '?title=' + encodeURIComponent(hTitle)
                + '&category=' + encodeURIComponent(hCategory)
                + '&scheduleDate=' + encodeURIComponent(hScheduleDate);

            fetch(url)
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    document.getElementById('akhiriInProgressCount').textContent = data.inProgressCount || 0;
                    document.getElementById('akhiriNotStartedCount').textContent = data.notStartedCount || 0;
                    loading.style.display = 'none';
                    content.style.display = '';
                })
                .catch(function () {
                    loading.innerHTML = '<span class="text-danger">Gagal memuat data. Tutup dan coba lagi.</span>';
                });
        });
    }

    // ============================================================
    // Phase 412 — Flexible Add/Remove Participant (UI live)
    // ============================================================
    var REP_ID = @Model.RepresentativeId;          // representativeId untuk picker eligible
    var IS_PROTON = (hCategory === 'Assessment Proton');

    // Ekspos helper IIFE ke window agar handler SignalR (@@section Scripts, blok terpisah) bisa pakai.
    window.monBuildActionsHtml   = buildActionsHtml;
    window.monFlashRow           = flashRow;
    window.monStatusBadgeClass   = statusBadgeClass;
    window.monStatusDisplayLabel = statusDisplayLabel;
    window.monIsPackageMode      = isPackageMode;

    // ---- (c) Picker "Tambah Peserta" ----
    var tambahModalEl = document.getElementById('tambahPesertaModal');
    if (tambahModalEl) {
        var pendingAddedFallback = {};  // sessionId -> timeoutId (fallback inject bila echo SignalR tak datang)

        tambahModalEl.addEventListener('show.bs.modal', function () {
            var loadingEl = document.getElementById('tambahPesertaLoading');
            var contentEl = document.getElementById('tambahPesertaContent');
            var errorEl   = document.getElementById('tambahPesertaError');
            var footerEl  = document.getElementById('tambahPesertaFooter');
            var listEl    = document.getElementById('tambahPesertaList');
            var emptyEl   = document.getElementById('tambahPesertaEmpty');
            loadingEl.style.display = '';
            contentEl.style.display = 'none';
            errorEl.style.display = 'none';
            footerEl.style.display = 'none';
            listEl.innerHTML = '';
            emptyEl.style.display = 'none';
            updateTambahCount();

            fetch(appUrl('/Admin/GetEligibleParticipantsToAdd?sessionId=' + REP_ID), {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(function (r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
            .then(function (data) {
                loadingEl.style.display = 'none';
                contentEl.style.display = '';
                if (!Array.isArray(data) || data.length === 0) {
                    emptyEl.style.display = '';
                    footerEl.style.display = 'none';
                    return;
                }
                var html = '';
                data.forEach(function (p) {
                    var nm = (p.fullName || '').replace(/</g, '&lt;').replace(/>/g, '&gt;');
                    var nip = (p.nip || '').replace(/</g, '&lt;').replace(/>/g, '&gt;');
                    html += '<div class="form-check py-1 border-bottom">'
                        + '<input class="form-check-input tambah-peserta-check" type="checkbox" value="' + p.id + '" id="check_' + p.id + '" />'
                        + '<label class="form-check-label w-100" for="check_' + p.id + '">'
                        + '<span class="fw-semibold">' + nm + '</span>'
                        + '<span class="text-muted small ms-2">' + nip + '</span>'
                        + '</label></div>';
                });
                listEl.innerHTML = html;
                footerEl.style.display = '';
                listEl.querySelectorAll('.tambah-peserta-check').forEach(function (cb) {
                    cb.addEventListener('change', updateTambahCount);
                });
                updateTambahCount();
            })
            .catch(function () {
                loadingEl.style.display = 'none';
                contentEl.style.display = 'none';
                document.getElementById('tambahPesertaErrorMsg').textContent = 'Gagal memuat daftar peserta.';
                errorEl.style.display = '';
            });
        });

        function updateTambahCount() {
            var checks = document.querySelectorAll('.tambah-peserta-check:checked');
            var n = checks.length;
            var cntEl = document.getElementById('tambahCount');
            var selEl = document.getElementById('tambahPesertaSelectedCount');
            var btn   = document.getElementById('btnKonfirmasiTambah');
            if (cntEl) cntEl.textContent = n;
            if (selEl) selEl.textContent = n + ' dipilih';
            if (btn)   btn.disabled = (n === 0);
        }

        var btnKonfirmasiTambah = document.getElementById('btnKonfirmasiTambah');
        if (btnKonfirmasiTambah) {
            btnKonfirmasiTambah.addEventListener('click', function () {
                var checks = document.querySelectorAll('.tambah-peserta-check:checked');
                if (checks.length === 0) return;
                var token = getToken();
                var body = 'sessionId=' + REP_ID + '&__RequestVerificationToken=' + encodeURIComponent(token);
                checks.forEach(function (cb) { body += '&userIds=' + encodeURIComponent(cb.value); });

                var origHtml = btnKonfirmasiTambah.innerHTML;
                btnKonfirmasiTambah.disabled = true;
                btnKonfirmasiTambah.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Menambahkan...';

                fetch(appUrl('/Admin/AddParticipantsLive'), {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
                    body: body
                })
                .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, body: j }; }); })
                .then(function (res) {
                    btnKonfirmasiTambah.disabled = false;
                    btnKonfirmasiTambah.innerHTML = origHtml;
                    if (!res.ok) {
                        document.getElementById('tambahPesertaErrorMsg').textContent =
                            (res.body && (res.body.error || res.body.message)) || 'Terjadi kesalahan. Silakan coba lagi.';
                        document.getElementById('tambahPesertaError').style.display = '';
                        return;
                    }
                    var inst = bootstrap.Modal.getInstance(tambahModalEl);
                    if (inst) inst.hide();
                    var added = (res.body && res.body.added) || [];
                    var addedN = (res.body && res.body.addedCount != null) ? res.body.addedCount : added.length;
                    if (typeof window.showAssessmentToast === 'function') {
                        window.showAssessmentToast(addedN + ' peserta ditambahkan ke batch');
                    }
                    // Fallback: bila SignalR participantAdded tak datang 3 detik, inject dari added[] (dedup di handler inject).
                    added.forEach(function (a) {
                        pendingAddedFallback[a.id] = setTimeout(function () {
                            if (typeof window.monInjectParticipantRow === 'function') {
                                window.monInjectParticipantRow({
                                    sessionId: a.id, fullName: a.fullName, nip: a.nip,
                                    status: a.status || 'Not started', nomorSertifikat: null
                                });
                            }
                            delete pendingAddedFallback[a.id];
                        }, 3000);
                    });
                })
                .catch(function () {
                    btnKonfirmasiTambah.disabled = false;
                    btnKonfirmasiTambah.innerHTML = origHtml;
                    document.getElementById('tambahPesertaErrorMsg').textContent = 'Terjadi kesalahan. Silakan coba lagi.';
                    document.getElementById('tambahPesertaError').style.display = '';
                });
            });
        }
        // Ekspos pembersih fallback agar handler SignalR bisa batalkan saat echo datang.
        window.monClearAddedFallback = function (sessionId) {
            if (pendingAddedFallback[sessionId]) {
                clearTimeout(pendingAddedFallback[sessionId]);
                delete pendingAddedFallback[sessionId];
            }
        };
    }

    // ---- (d) Modal hapus (delegated) ----
    var hapusTargetSessionId = null;
    document.addEventListener('click', function (e) {
        var btn = e.target.closest('.btn-hapus-peserta');
        if (!btn) return;
        var sessionId = btn.getAttribute('data-session-id');
        var workerName = btn.getAttribute('data-worker-name') || '';
        var status = btn.getAttribute('data-status') || '';
        var hasCert = btn.getAttribute('data-has-cert') === 'true';
        hapusTargetSessionId = sessionId;

        // Tingkat modal (Pitfall 1): InProgress (English) ATAU Completed+cert → KERAS; lainnya → RINGAN.
        var isHard = (status === 'InProgress') || (status === 'Completed' && hasCert);
        if (isHard) {
            document.getElementById('hapusHardWorkerName').textContent = workerName;
            document.getElementById('hapusHardReason').value = '';
            document.getElementById('hapusHardReasonError').classList.add('d-none');
            // Warning block sesuai status
            document.getElementById('hapusHardWarnInProgress').style.display = (status === 'InProgress') ? '' : 'none';
            document.getElementById('hapusHardWarnCompleted').style.display = (status === 'Completed') ? '' : 'none';
            new bootstrap.Modal(document.getElementById('hapusPesertaHardModal')).show();
        } else {
            document.getElementById('hapusLightWorkerName').textContent = workerName;
            document.getElementById('hapusLightReason').value = '';
            document.getElementById('hapusLightReasonError').classList.add('d-none');
            new bootstrap.Modal(document.getElementById('hapusPesertaLightModal')).show();
        }
    });

    function submitHapusPeserta(modalId, reasonId, errorId, btnEl) {
        if (!hapusTargetSessionId) return;
        var reason = document.getElementById(reasonId).value || '';
        var token = getToken();
        var origHtml = btnEl.innerHTML;
        btnEl.disabled = true;
        btnEl.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Menghapus...';

        fetch(appUrl('/Admin/RemoveParticipantLive'), {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
            body: 'sessionId=' + encodeURIComponent(hapusTargetSessionId)
                + '&reason=' + encodeURIComponent(reason)
                + '&__RequestVerificationToken=' + encodeURIComponent(token)
        })
        .then(function (r) { return r.json().then(function (j) { return { status: r.status, ok: r.ok, body: j }; }); })
        .then(function (res) {
            btnEl.disabled = false;
            btnEl.innerHTML = origHtml;
            if (res.status === 400) {
                // reason wajib (server penjaga akhir D-03) — jangan tutup modal
                var errEl = document.getElementById(errorId);
                if (errEl) {
                    errEl.textContent = (res.body && (res.body.error || res.body.message)) || 'Alasan wajib diisi untuk peserta ini.';
                    errEl.classList.remove('d-none');
                }
                return;
            }
            if (!res.ok) {
                var errEl2 = document.getElementById(errorId);
                if (errEl2) {
                    errEl2.textContent = (res.body && (res.body.error || res.body.message)) || 'Terjadi kesalahan. Silakan coba lagi.';
                    errEl2.classList.remove('d-none');
                }
                return;
            }
            var inst = bootstrap.Modal.getInstance(document.getElementById(modalId));
            if (inst) inst.hide();
            // Sumber kebenaran perubahan baris = SignalR participantRemoved (fallback di handler).
            hapusTargetSessionId = null;
        })
        .catch(function () {
            btnEl.disabled = false;
            btnEl.innerHTML = origHtml;
            var errEl3 = document.getElementById(errorId);
            if (errEl3) { errEl3.textContent = 'Terjadi kesalahan. Silakan coba lagi.'; errEl3.classList.remove('d-none'); }
        });
    }

    var btnHapusLight = document.getElementById('btnHapusLightKonfirmasi');
    if (btnHapusLight) {
        btnHapusLight.addEventListener('click', function () {
            submitHapusPeserta('hapusPesertaLightModal', 'hapusLightReason', 'hapusLightReasonError', btnHapusLight);
        });
    }
    var btnHapusHard = document.getElementById('btnHapusHardKonfirmasi');
    if (btnHapusHard) {
        btnHapusHard.addEventListener('click', function () {
            submitHapusPeserta('hapusPesertaHardModal', 'hapusHardReason', 'hapusHardReasonError', btnHapusHard);
        });
    }

    // ---- (e) Restore 1-klik (D-04, tanpa konfirmasi) ----
    document.addEventListener('click', function (e) {
        var btn = e.target.closest('.btn-restore-peserta');
        if (!btn) return;
        var sessionId = btn.getAttribute('data-session-id');
        var workerName = btn.getAttribute('data-worker-name') || '';
        var origHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
        var token = getToken();

        fetch(appUrl('/Admin/RestoreParticipantLive'), {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
            body: 'sessionId=' + encodeURIComponent(sessionId) + '&__RequestVerificationToken=' + encodeURIComponent(token)
        })
        .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, body: j }; }); })
        .then(function (res) {
            if (!res.ok) {
                btn.disabled = false;
                btn.innerHTML = origHtml;
                alert('Gagal memulihkan peserta. Silakan coba lagi.');
                return;
            }
            // Sumber kebenaran = SignalR participantAdded (baris balik live; fallback di handler).
            // Biarkan tombol disabled+spinner sampai handler memindahkan baris.
            if (typeof window.showAssessmentToast === 'function') {
                window.showAssessmentToast(workerName + ' dipulihkan ke batch aktif');
            }
        })
        .catch(function () {
            btn.disabled = false;
            btn.innerHTML = origHtml;
            alert('Gagal memulihkan peserta. Silakan coba lagi.');
        });
    });

    // ---- (f) Chevron rotate panel "Peserta Dikeluarkan" ----
    var panelBody = document.getElementById('panelPesertaDikeluarkanBody');
    if (panelBody) {
        var chevron = document.getElementById('panelRemovedChevron');
        panelBody.addEventListener('shown.bs.collapse', function () {
            if (chevron) chevron.style.transform = 'rotate(180deg)';
        });
        panelBody.addEventListener('hidden.bs.collapse', function () {
            if (chevron) chevron.style.transform = 'rotate(0deg)';
        });
    }
})();
</script>


@if (Model.IsTokenRequired)
{
    <script>
    function copyToken() {
        var tokenEl = document.getElementById('token-display');
        var labelEl = document.getElementById('copy-label');
        if (!tokenEl) return;
        var text = tokenEl.textContent.trim();
        if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(function () {
                labelEl.textContent = 'Copied!';
                setTimeout(function () { labelEl.textContent = 'Copy'; }, 2000);
            }).catch(function () {
                // Clipboard API permission denied — fallback to execCommand
                copyTokenFallback(text, labelEl);
            });
        } else {
            copyTokenFallback(text, labelEl);
        }
    }
    function copyTokenFallback(text, labelEl) {
        try {
            var ta = document.createElement('textarea');
            ta.value = text;
            ta.style.position = 'fixed';
            ta.style.opacity = '0';
            document.body.appendChild(ta);
            ta.focus();
            ta.select();
            document.execCommand('copy');
            document.body.removeChild(ta);
            if (labelEl) { labelEl.textContent = 'Copied!'; setTimeout(function () { labelEl.textContent = 'Copy'; }, 2000); }
        } catch (e) {
            alert('Token: ' + text + '\nSalin manual dari dialog ini.');
        }
    }

    function regenToken(btn) {
        if (!confirm('Regenerate token untuk grup ini? Token lama tidak akan bisa digunakan.')) return;
        var id = btn.getAttribute('data-id');
        var token = document.querySelector('#antiforgeryForm input[name="__RequestVerificationToken"]').value;
        btn.disabled = true;
        var originalHtml = btn.innerHTML;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

        fetch(appUrl('/Admin/RegenerateToken/' + id), {
            method: 'POST',
            headers: { 'RequestVerificationToken': token }
        })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            if (data.success) {
                document.getElementById('token-display').textContent = data.token;
                var labelEl = document.getElementById('copy-label');
                if (labelEl) { labelEl.textContent = 'Copy'; }
            } else {
                alert('Error: ' + (data.message || 'Gagal regenerate token.'));
            }
        })
        .catch(function () {
            alert('Terjadi kesalahan saat regenerate token.');
        })
        .finally(function () {
            btn.disabled = false;
            btn.innerHTML = originalHtml;
        });
    }
    </script>
}

<script>
// ---- Activity Log Modal ----
var _activityLogInterval = null;
var _activityLogSessionId = null;

function showActivityLog(sessionId, workerName) {
    document.getElementById('logWorkerName').textContent = workerName;
    document.getElementById('logSummary').innerHTML = '';
    document.getElementById('logTimeline').innerHTML = '';

    var loadingEl = document.getElementById('logLoading');
    loadingEl.classList.remove('d-none');

    _activityLogSessionId = sessionId;

    var modal = new bootstrap.Modal(document.getElementById('activityLogModal'));
    modal.show();

    fetchActivityLog(sessionId, true);

    // Auto-refresh every 3 seconds while modal is open
    clearInterval(_activityLogInterval);
    _activityLogInterval = setInterval(function() {
        fetchActivityLog(sessionId, false);
    }, 3000);

    // Stop refreshing when modal closes
    document.getElementById('activityLogModal').addEventListener('hidden.bs.modal', function handler() {
        clearInterval(_activityLogInterval);
        _activityLogInterval = null;
        _activityLogSessionId = null;
        document.getElementById('activityLogModal').removeEventListener('hidden.bs.modal', handler);
    });
}

function fetchActivityLog(sessionId, showLoading) {
    var loadingEl = document.getElementById('logLoading');
    if (showLoading) loadingEl.classList.remove('d-none');

    fetch(appUrl('/Admin/GetActivityLog?sessionId=' + sessionId))
        .then(function(r) { return r.json(); })
        .then(function(data) {
            loadingEl.classList.add('d-none');

            // Render summary
            var s = data.summary;
            var minutes = s.timeSpentSeconds != null ? Math.round(s.timeSpentSeconds / 60) : '--';
            document.getElementById('logSummary').innerHTML =
                '<i class="bi bi-bar-chart-fill me-1"></i>' +
                '<strong>Dijawab:</strong> ' + (s.answeredCount || 0) + ' &nbsp;|&nbsp; ' +
                '<strong>Waktu:</strong> ' + minutes + ' menit &nbsp;|&nbsp; ' +
                '<strong>Terputus:</strong> ' + (s.disconnectCount || 0) + 'x';

            // Render timeline
            var events = data.events || [];
            if (events.length === 0) {
                document.getElementById('logTimeline').innerHTML =
                    '<p class="text-muted text-center">Belum ada aktivitas tercatat.</p>';
                return;
            }

            var html = '<table class="table table-sm table-borderless">' +
                '<thead><tr><th style="width:90px">Waktu</th><th>Aktivitas</th></tr></thead><tbody>';
            events.forEach(function(e) {
                var label = eventLabel(e.eventType, e.detail);
                html += '<tr><td class="text-muted small font-monospace">' + e.timestamp + '</td>' +
                    '<td>' + label + '</td></tr>';
            });
            html += '</tbody></table>';
            document.getElementById('logTimeline').innerHTML = html;
        })
        .catch(function() {
            loadingEl.classList.add('d-none');
            document.getElementById('logSummary').innerHTML =
                '<span class="text-danger"><i class="bi bi-exclamation-triangle-fill me-1"></i>Gagal memuat log.</span>';
        });
}

function eventLabel(eventType, detail) {
    switch (eventType) {
        case 'started':      return '<i class="bi bi-play-circle-fill text-success me-1"></i>Memulai Ujian';
        case 'page_nav':     return '<i class="bi bi-arrow-right-circle text-primary me-1"></i>Pindah ke ' + (detail || 'halaman');
        case 'disconnected': return '<i class="bi bi-wifi-off text-danger me-1"></i>Terputus';
        case 'reconnected':  return '<i class="bi bi-wifi text-warning me-1"></i>Tersambung Kembali';
        case 'submitted':    return '<i class="bi bi-check-circle-fill text-success me-1"></i>Menyelesaikan Ujian';
        default:             return eventType + (detail ? ' — ' + detail : '');
    }
}
</script>

