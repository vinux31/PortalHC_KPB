@model HcPortal.Models.MonitoringGroupViewModel

@{
    ViewData["Title"] = "Assessment Detail — " + Model.Title;

    var catBadgeClass = Model.Category switch
    {
        "OJT"                     => "bg-primary",
        "IHT"                     => "bg-success",
        "Training Licencor"        => "bg-danger",
        "OTS"                     => "bg-warning text-dark",
        "Mandatory HSSE Training"  => "bg-info",
        "Proton"                  => "bg-purple",
        "Assessment Proton"        => "bg-purple",
        _                         => "bg-secondary"
    };

    var statusBadgeClass = Model.GroupStatus switch
    {
        "Open"     => "bg-success",
        "Upcoming" => "bg-warning text-dark",
        "Closed"   => "bg-secondary",
        _          => "bg-secondary"
    };

    bool isProtonInterview = Model.Category == "Assessment Proton" && (ViewBag.GroupTahunKe as string) == "Tahun 3";
    var interviewAspects = new List<string>
    {
        "Pengetahuan Teknis", "Kemampuan Operasional", "Keselamatan Kerja",
        "Komunikasi & Kerjasama", "Sikap Profesional"
    };

    // MAP-11: dua variabel persentase yang tidak terpakai dibuang (D minimal-risk, tidak di-surface jadi progress bar baru)
}

<div class="container-fluid px-4 py-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* 90-review: breadcrumb verified *@
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Admin")">Kelola Data</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("AssessmentMonitoring", "AssessmentAdmin")">Assessment Monitoring</a></li>
            <li class="breadcrumb-item active">@Model.Title</li>
        </ol>
    </nav>

    <!-- Back link -->
    <div class="mb-4">
        <a href="@ViewBag.BackUrl" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Kembali ke Monitoring
        </a>
    </div>

    <!-- Header -->
    <div class="mb-4">
        <div class="d-flex align-items-center gap-2 mb-1">
            <span class="badge @catBadgeClass">@Model.Category</span>
            <span class="badge @statusBadgeClass">@Model.GroupStatus</span>
            <span id="hubStatusBadge" class="badge bg-secondary ms-1 small">Connecting...</span>
        </div>
        <h2 class="fw-bold mb-1">@Model.Title</h2>
        <p class="text-muted mb-0">
            <i class="bi bi-calendar3 me-1"></i>@Model.Schedule.ToString("dd MMM yyyy")
        </p>
    </div>

    @if (Model.IsTokenRequired)
    {
        <!-- Token Card -->
        <div class="card border-0 shadow-sm mb-4" style="border-left: 4px solid #0d6efd !important;">
            <div class="card-body py-3">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-key-fill text-primary fs-5"></i>
                        <span class="fw-semibold">Access Token:</span>
                        <code id="token-display" class="fs-6 text-primary">@Model.AccessToken</code>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button"
                                class="btn btn-outline-secondary btn-sm"
                                id="btn-copy-token"
                                onclick="copyToken()"
                                title="Copy token">
                            <i class="bi bi-clipboard me-1"></i><span id="copy-label">Copy</span>
                        </button>
                        <button type="button"
                                class="btn btn-outline-warning btn-sm"
                                id="btn-regen-token"
                                data-id="@Model.RepresentativeId"
                                onclick="regenToken(this)"
                                title="Regenerate token">
                            <i class="bi bi-arrow-repeat me-1"></i>Regenerate Token
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @* FIX ISS-08: tombol Tambah Waktu dipindah keluar dari @if (IsTokenRequired) — fitur
       aksesibilitas A11Y-05 harus tersedia untuk semua assessment, termasuk yang tanpa token. *@
    <div class="card border-0 shadow-sm mb-4" style="border-left: 4px solid #ffc107 !important;">
        <div class="card-body py-3">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-clock-history text-warning fs-5"></i>
                    <span class="fw-semibold">Waktu Tambahan (Aksesibilitas)</span>
                    <span class="text-muted small">Untuk peserta dengan kebutuhan khusus</span>
                </div>
                <div class="d-flex gap-2">
                    <button type="button"
                            class="btn btn-warning btn-sm"
                            data-bs-toggle="modal"
                            data-bs-target="#extraTimeModal"
                            title="Tambah waktu ujian untuk semua peserta aktif">
                        <i class="bi bi-clock-history me-1"></i>Tambah Waktu
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary cards (MAP-10: 7 kartu, invariant Total Ditugaskan = Selesai + Sedang Mengerjakan + Belum Mulai + Dibatalkan + Abandoned + Menunggu Penilaian) -->
    <div class="row g-3 mb-4 row-cols-2 row-cols-md-4 row-cols-xl-7">
        <div class="col">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-primary" id="count-total">@Model.TotalCount</div>
                <div class="text-muted small">Total Ditugaskan</div>
            </div>
        </div>
        <div class="col">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-success" id="count-completed">@Model.CompletedCount</div>
                <div class="text-muted small">Selesai</div>
            </div>
        </div>
        <div class="col">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-warning" id="count-inprogress">@Model.InProgressCount</div>
                <div class="text-muted small">Sedang Mengerjakan</div>
            </div>
        </div>
        <div class="col">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-secondary" id="count-notstarted">@Model.PendingCount</div>
                <div class="text-muted small">Belum Mulai</div>
            </div>
        </div>
        <div class="col">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-secondary" id="count-cancelled">@Model.CancelledCount</div>
                <div class="text-muted small">Dibatalkan</div>
            </div>
        </div>
        <div class="col">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-dark" id="count-abandoned">@Model.AbandonedCount</div>
                <div class="text-muted small">Abandoned</div>
            </div>
        </div>
        <div class="col">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="fs-3 fw-bold text-warning" id="count-pending">@Model.MenungguPenilaianCount</div>
                <div class="text-muted small">Menunggu Penilaian</div>
            </div>
        </div>
    </div>

    <!-- Per-user table -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-semibold">
                <i class="bi bi-people me-2 text-primary"></i>Status Per-Peserta
            </h5>
            <div class="d-flex gap-2 align-items-center">
                @* Phase 412 PART-05: Tambah Peserta live — picker modal. Proton dikecualikan (spec §F). *@
                @if (Model.Category != "Assessment Proton")
                {
                    <button type="button"
                            class="btn btn-outline-primary btn-sm"
                            id="btnTambahPeserta"
                            data-bs-toggle="modal"
                            data-bs-target="#tambahPesertaModal"
                            title="Tambah peserta ke batch ujian ini">
                        <i class="bi bi-person-plus me-1"></i>Tambah Peserta
                    </button>
                }
                <!-- Ekspor Hasil: GET download, no antiforgery needed -->
                <form asp-action="ExportAssessmentResults" asp-controller="AssessmentAdmin" method="get" class="d-inline">
                    <input type="hidden" name="title" value="@Model.Title" />
                    <input type="hidden" name="category" value="@Model.Category" />
                    <input type="hidden" name="scheduleDate" value="@Model.Schedule.ToString("yyyy-MM-dd")" />
                    <button type="submit" class="btn btn-outline-success btn-sm">
                        <i class="bi bi-download me-1"></i>Ekspor Hasil
                    </button>
                </form>
                @* Akhiri Semua Ujian: triggers Bootstrap modal confirmation. MAP-12: conditional render. *@
                @if (Model.InProgressCount > 0 || Model.GroupStatus == "Open")
                {
                    <button type="button" class="btn btn-danger btn-sm" id="akhiriSemuaBtn"
                            data-bs-toggle="modal" data-bs-target="#akhiriSemuaModal">
                        <i class="bi bi-x-circle me-1"></i>Akhiri Semua Ujian
                    </button>
                }
                @if (Model.IsPackageMode && Model.PendingCount > 0)
                {
                    <button type="button" class="btn btn-outline-primary btn-sm"
                            onclick="reshuffleAll(event)">
                        <i class="bi bi-shuffle me-1"></i>Reshuffle All (@Model.PendingCount pending)
                    </button>
                }
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Nama</th>
                            <th>Progres</th>
                            <th>Status</th>
                            <th>Nilai</th>
                            <th>Hasil</th>
                            <th>Selesai Pada</th>
                            <th>Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Sessions.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">Belum ada sesi untuk grup ini.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var session in Model.Sessions)
                            {
                                var statusClass = session.UserStatus switch
                                {
                                    "Completed"         => "bg-success",
                                    "InProgress"        => "bg-warning text-dark",
                                    "Cancelled"         => "bg-secondary",
                                    "Menunggu Penilaian" => "bg-warning text-dark",
                                    _                   => "bg-light text-dark border"
                                };

                                var statusLabel = session.UserStatus switch
                                {
                                    "Cancelled" => "Dibatalkan",
                                    "Menunggu Penilaian" => "Menunggu Penilaian",
                                    _ => session.UserStatus
                                };

                                string resultText;
                                string resultClass;
                                if (session.IsPassed == true)
                                {
                                    resultText  = "Pass";
                                    resultClass = "text-success fw-semibold";
                                }
                                else if (session.IsPassed == false)
                                {
                                    resultText  = "Fail";
                                    resultClass = "text-danger fw-semibold";
                                }
                                else
                                {
                                    resultText  = "\u2014";
                                    resultClass = "text-muted";
                                }

                                <tr data-session-id="@session.Id">
                                    <td class="fw-semibold">@session.UserFullName</td>
                                    <td class="text-center progress-cell">@(session.QuestionCount > 0 ? $"\u2014/{session.QuestionCount}" : "\u2014")</td>
                                    <td class="status-cell"><span class="badge @statusClass">@statusLabel</span></td>
                                    <td class="score-cell">
                                        @if (session.Score.HasValue)
                                        {
                                            <span>@session.Score%</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td class="result-cell @resultClass">@resultText</td>
                                    <td class="completedat-cell text-muted small">
                                        @(session.CompletedAt.HasValue ? session.CompletedAt.Value.ToString("dd MMM yyyy HH:mm") : "\u2014")
                                    </td>
                                    <td>
                                        @{ var canEdit = HcPortal.Helpers.AssessmentEditEligibility.IsEditableShallow(session); }
                                        <div class="d-flex gap-1 align-items-center">
                                            @* Inline: View Results (Completed only) *@
                                            @if (session.UserStatus == "Completed")
                                            {
                                                <a href="@Url.Action("Results", "CMP", new { id = session.Id })" target="_blank"
                                                   class="btn btn-success btn-sm">View Results</a>
                                            }
                                            @* Inline: Activity Log (always) *@
                                            <button type="button"
                                                    class="btn btn-outline-secondary btn-sm btn-activity-log"
                                                    data-session-id="@session.Id"
                                                    data-worker-name="@session.UserFullName"
                                                    title="Lihat activity log">
                                                <i class="bi bi-clock-history"></i>
                                            </button>

                                            @* Dropdown ⋮ *@
                                            <div class="dropdown">
                                                <button class="btn btn-sm btn-outline-secondary"
                                                        type="button"
                                                        data-bs-toggle="dropdown"
                                                        aria-expanded="false"
                                                        aria-haspopup="true"
                                                        aria-label="Aksi lain untuk @session.UserFullName"
                                                        style="min-height:40px;">⋮</button>
                                                <ul class="dropdown-menu dropdown-menu-end">
                                                    @if (canEdit)
                                                    {
                                                        <li>
                                                            <a class="dropdown-item" asp-action="EditPesertaAnswers" asp-controller="AssessmentAdmin" asp-route-id="@session.Id">
                                                                <i class="bi bi-pencil-square me-1"></i>Edit Jawaban
                                                            </a>
                                                        </li>
                                                    }
                                                    @if (session.UserStatus != "Cancelled")
                                                    {
                                                        <li>
                                                            <form asp-action="ResetAssessment" asp-controller="AssessmentAdmin" method="post" class="m-0"
                                                                  onsubmit="return confirm('Reset sesi ini? Semua jawaban akan dihapus dan peserta dapat mengulang ujian.')">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="id" value="@session.Id" />
                                                                <button type="submit" class="dropdown-item">
                                                                    <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
                                                                </button>
                                                            </form>
                                                        </li>
                                                    }
                                                    @* Phase 412 PRMV-02: Hapus Peserta per-baris (modal keras/ringan). Proton dikecualikan. *@
                                                    @if (Model.Category != "Assessment Proton")
                                                    {
                                                        <li>
                                                            <button type="button" class="dropdown-item text-danger btn-hapus-peserta"
                                                                    data-session-id="@session.Id"
                                                                    data-worker-name="@session.UserFullName"
                                                                    data-status="@session.UserStatus"
                                                                    data-has-cert="@((!string.IsNullOrEmpty(session.NomorSertifikat)).ToString().ToLower())"
                                                                    title="Hapus @session.UserFullName dari batch"
                                                                    style="min-height:40px;">
                                                                <i class="bi bi-person-x me-1"></i>Hapus Peserta
                                                            </button>
                                                        </li>
                                                    }
                                                    @if (session.UserStatus == "InProgress")
                                                    {
                                                        <li>
                                                            <form asp-action="AkhiriUjian" asp-controller="AssessmentAdmin" method="post" class="m-0"
                                                                  onsubmit="return confirm('Akhiri ujian untuk @(session.UserFullName)? Jawaban tersimpan akan dinilai otomatis.')">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="id" value="@session.Id" />
                                                                <button type="submit" class="dropdown-item text-danger">
                                                                    <i class="bi bi-x-octagon me-1"></i>Akhiri Ujian
                                                                </button>
                                                            </form>
                                                        </li>
                                                    }
                                                    @if (Model.IsPackageMode && (session.UserStatus == "Not started" || session.UserStatus == "Abandoned"))
                                                    {
                                                        <li>
                                                            <button type="button"
                                                                    class="dropdown-item"
                                                                    data-session-id="@session.Id"
                                                                    onclick="reshuffleWorker(this)">
                                                                <i class="bi bi-shuffle me-1"></i>Reshuffle
                                                            </button>
                                                        </li>
                                                    }
                                                </ul>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* ===== PANEL "PESERTA DIKELUARKAN" (Phase 412 PLIV-01) ===== *@
    @* Pitfall 5: SELALU render untuk batch non-Proton (collapsed default) supaya handler SignalR
       tak perlu bangun panel dari scratch. Visible hanya bila ada >=1 baris removed. *@
    @if (Model.Category != "Assessment Proton")
    {
        var removedList = ViewBag.RemovedSessions as List<HcPortal.Models.RemovedParticipantViewModel> ?? new List<HcPortal.Models.RemovedParticipantViewModel>();
        <div class="card border-0 shadow-sm mt-4" style="border-left: 4px solid #dc3545 !important;@(removedList.Count == 0 ? " display:none;" : "")"
             id="panelPesertaDikeluarkan">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center"
                 id="panelPesertaDikeluarkanHeader"
                 style="cursor:pointer;"
                 data-bs-toggle="collapse"
                 data-bs-target="#panelPesertaDikeluarkanBody"
                 aria-expanded="false"
                 aria-controls="panelPesertaDikeluarkanBody">
                <h5 class="mb-0 fw-semibold">
                    <i class="bi bi-person-slash me-2 text-danger"></i>
                    Peserta Dikeluarkan
                    <span class="badge bg-secondary ms-2 small fw-normal" id="countRemoved">@removedList.Count</span>
                </h5>
                <i class="bi bi-chevron-down text-muted" id="panelRemovedChevron"></i>
            </div>
            <div class="collapse" id="panelPesertaDikeluarkanBody"
                 aria-labelledby="panelPesertaDikeluarkanHeader">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" id="tblRemoved">
                            <thead class="table-light">
                                <tr>
                                    <th>Nama</th>
                                    <th>Waktu Dikeluarkan</th>
                                    <th>Oleh</th>
                                    <th>Alasan</th>
                                    <th>Aksi</th>
                                </tr>
                            </thead>
                            <tbody id="tbodyRemoved">
                                @foreach (var r in removedList)
                                {
                                    <tr data-session-id="@r.Id" data-removed="true">
                                        <td class="fw-semibold">@r.FullName
                                            <br><small class="text-muted">@r.Nip</small>
                                        </td>
                                        <td class="text-muted small">@(r.RemovedAt.HasValue ? r.RemovedAt.Value.ToString("dd MMM yyyy HH:mm") + " WIB" : "—")</td>
                                        <td class="text-muted small">@(string.IsNullOrEmpty(r.RemovedByName) ? "—" : r.RemovedByName)</td>
                                        <td class="text-muted small" style="max-width:200px; word-break:break-word;">@(string.IsNullOrEmpty(r.RemovalReason) ? "—" : r.RemovalReason)</td>
                                        <td>
                                            <button type="button"
                                                    class="btn btn-outline-success btn-sm btn-restore-peserta"
                                                    data-session-id="@r.Id"
                                                    data-worker-name="@r.FullName"
                                                    style="min-height:40px;"
                                                    title="Pulihkan @r.FullName ke batch aktif">
                                                <i class="bi bi-arrow-counterclockwise me-1"></i>Restore
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }

    @* ===== ESSAY GRADING SECTION (Phase 298-05) ===== *@
    @{
        var essayGradingMap = ViewBag.EssayGradingMap as Dictionary<int, List<HcPortal.Models.EssayGradingItemViewModel>>;
    }
    @if (essayGradingMap != null && essayGradingMap.Any())
    {
        <div class="mt-4">
            <h5 class="fw-semibold mb-3"><i class="bi bi-pencil-square me-2 text-warning"></i>Penilaian Essay</h5>
            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Worker</th>
                                    <th class="text-center">Essay Belum Dinilai</th>
                                    <th class="text-center">Status</th>
                                    <th class="text-end">Aksi</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var s in Model.Sessions.Where(x => x.HasManualGrading).OrderBy(x => x.UserNIP))
                            {
                                // Phase 310 D-02 gate (REUSE verbatim) — badge 🟢 "Selesai"
                                var isFinalized = s.Status == AssessmentConstants.AssessmentStatus.Completed
                                                  && !string.IsNullOrEmpty(s.NomorSertifikat);
                                <tr>
                                    <td class="fw-semibold">
                                        @s.UserFullName<br>
                                        <small class="text-muted">@s.UserNIP</small>
                                    </td>
                                    <td class="text-center">@(s.EssayPendingCount > 0 ? s.EssayPendingCount.ToString() : "—")</td>
                                    <td class="text-center">
                                        @if (s.EssayPendingCount > 0)
                                        {
                                            <span class="badge bg-warning text-dark">@s.EssayPendingCount belum dinilai</span>
                                        }
                                        else if (!isFinalized)
                                        {
                                            <span class="badge bg-info">Siap difinalisasi</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Selesai</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a class="btn btn-primary btn-sm" style="min-height:40px;"
                                           href="@Url.Action("EssayGrading", new {
                                               sessionId = s.Id,
                                               title = Model.Title,
                                               category = Model.Category,
                                               scheduleDate = Model.Schedule.ToString("yyyy-MM-dd"),
                                               assessmentType = ViewBag.AssessmentType })">
                                            <i class="bi bi-pencil-square me-1"></i>Tinjau Essay
                                        </a>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Global antiforgery token for JS-rendered action buttons -->
    <form id="antiforgeryForm" style="display:none">@Html.AntiForgeryToken()</form>

    <!-- Hidden fields for polling endpoint params -->
    <input type="hidden" id="hTitle" value="@Model.Title" />
    <input type="hidden" id="hCategory" value="@Model.Category" />
    <input type="hidden" id="hScheduleDate" value="@Model.Schedule.ToString("yyyy-MM-dd")" />

    <!-- Last updated + error indicator -->
    <div class="d-flex align-items-center gap-3 mt-2 px-1">
        <small class="text-muted">
            Last updated: <span id="last-updated-time">—</span>
        </small>
    </div>

    @if (Model.IsPackageMode)
    {
        <!-- Hidden form for antiforgery token (used by AJAX reshuffle calls) -->
        <form id="reshuffleForm" style="display:none">@Html.AntiForgeryToken()</form>

        <!-- Toast container (top-right, Bootstrap 5) -->
        <div class="position-fixed top-0 end-0 p-3" style="z-index: 1080;">
            <div id="reshuffleToast" class="toast align-items-center text-bg-success border-0" role="alert">
                <div class="d-flex">
                    <div class="toast-body" id="reshuffleToastBody">
                        Package reshuffled successfully.
