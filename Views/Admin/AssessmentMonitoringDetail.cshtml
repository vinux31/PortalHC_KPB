@section Scripts {
<link rel="stylesheet" href="~/css/assessment-hub.css" />
<script src="~/lib/signalr/signalr.min.js"></script>
<script>window.assessmentBatchKey = '@ViewBag.AssessmentBatchKey';</script>
<script src="~/js/assessment-hub.js"></script>
<script>
    // -------- Connection status badge --------
    var monBadge = document.getElementById('hubStatusBadge');
    window.assessmentHub.onreconnecting(function() {
        if (monBadge) { monBadge.className = 'badge bg-warning ms-1 small'; monBadge.textContent = 'Reconnecting...'; }
    });
    window.assessmentHub.onreconnected(function() {
        if (monBadge) { monBadge.className = 'badge bg-success ms-1 small'; monBadge.textContent = 'Live'; }
    });
    window.assessmentHub.onclose(function() {
        if (monBadge) { monBadge.className = 'badge bg-danger ms-1 small'; monBadge.textContent = 'Disconnected'; }
    });
    // Set initial "Live" state after hub connects, then join monitor group
    // Use promise-based approach instead of fragile setTimeout to detect connection state
    if (window.assessmentHubStartPromise) {
        window.assessmentHubStartPromise.then(function() {
            if (monBadge) { monBadge.className = 'badge bg-success ms-1 small'; monBadge.textContent = 'Live'; }
            if (window.assessmentBatchKey) {
                window.assessmentHub.invoke('JoinMonitor', window.assessmentBatchKey)
                    .catch(function(err) { console.warn('[monitor] JoinMonitor failed:', err); });
            }
        }).catch(function() {
            if (monBadge) { monBadge.className = 'badge bg-danger ms-1 small'; monBadge.textContent = 'Disconnected'; }
        });
    } else {
        // Fallback: assessmentHubStartPromise not exposed — use state check after short delay
        setTimeout(function() {
            if (monBadge && window.assessmentHub && window.assessmentHub.state === 'Connected') {
                monBadge.className = 'badge bg-success ms-1 small';
                monBadge.textContent = 'Live';
            }
            if (window.assessmentBatchKey && window.assessmentHub && window.assessmentHub.state === 'Connected') {
                window.assessmentHub.invoke('JoinMonitor', window.assessmentBatchKey)
                    .catch(function(err) { console.warn('[monitor] JoinMonitor failed:', err); });
            }
        }, 2000);
    }

    // Rejoin monitor group after reconnect
    window.assessmentHub.onreconnected(function() {
        if (window.assessmentBatchKey) {
            window.assessmentHub.invoke('JoinMonitor', window.assessmentBatchKey)
                .catch(function(err) { console.warn('[monitor] JoinMonitor after reconnect failed:', err); });
        }
    });

    // ---- Row flash helper ----
    function flashRow(tr, cssClass) {
        if (!tr) return;
        tr.classList.remove('flash-update', 'flash-complete');
        void tr.offsetWidth; // force reflow to restart animation
        tr.classList.add(cssClass);
        setTimeout(function() { tr.classList.remove(cssClass); }, 1300);
    }

    // ---- Update summary counts from DOM (used by push events) ----
    function updateSummaryFromDOM() {
        // Phase 412 Pitfall 2: exclude baris #tbodyRemoved (peserta dikeluarkan) dari hitungan aktif.
        var rows = document.querySelectorAll('tbody:not(#tbodyRemoved) tr[data-session-id]');
        var total = rows.length;
        var completed = 0, inProgress = 0, notStarted = 0, cancelled = 0, abandoned = 0, pending = 0;
        rows.forEach(function(tr) {
            var statusCell = tr.querySelector('.status-cell');
            if (!statusCell) return;
            var text = statusCell.textContent.trim();
            if (text === 'Completed') completed++;
            else if (text === 'InProgress') inProgress++;
            else if (text === 'Dibatalkan') cancelled++;
            else if (text === 'Abandoned') abandoned++;
            else if (text === '@AssessmentConstants.AssessmentStatus.PendingGrading') pending++;
            else notStarted++;
        });
        var el;
        el = document.getElementById('count-total');      if (el) el.textContent = total;
        el = document.getElementById('count-completed');  if (el) el.textContent = completed;
        el = document.getElementById('count-inprogress'); if (el) el.textContent = inProgress;
        el = document.getElementById('count-notstarted'); if (el) el.textContent = notStarted;
        el = document.getElementById('count-cancelled');  if (el) el.textContent = cancelled;
        el = document.getElementById('count-abandoned');  if (el) el.textContent = abandoned;
        el = document.getElementById('count-pending');    if (el) el.textContent = pending;
    }

    // ---- SignalR push event handlers ----

    // progressUpdate: worker answered a question
    window.assessmentHub.on('progressUpdate', function(data) {
        var tr = document.querySelector('tr[data-session-id="' + data.sessionId + '"]');
        if (!tr) return;
        var progressCell = tr.querySelector('.progress-cell');
        if (progressCell) {
            progressCell.textContent = data.totalQuestions > 0
                ? (data.progress + '/' + data.totalQuestions)
                : '\u2014';
        }
        flashRow(tr, 'flash-update');
        var el = document.getElementById('last-updated-time');
        if (el) el.textContent = new Date().toLocaleTimeString('id-ID');
    });

    // workerStarted: worker opened exam for the first time
    window.assessmentHub.on('workerStarted', function(data) {
        var tr = document.querySelector('tr[data-session-id="' + data.sessionId + '"]');
        if (!tr) return;
        var statusCell = tr.querySelector('.status-cell');
        if (statusCell) {
            statusCell.innerHTML = '<span class="badge bg-warning text-dark">InProgress</span>';
        }
        flashRow(tr, 'flash-update');
        if (typeof window.showAssessmentToast === 'function') {
            window.showAssessmentToast(data.workerName + ' memulai ujian');
        }
        updateSummaryFromDOM();
        var el = document.getElementById('last-updated-time');
        if (el) el.textContent = new Date().toLocaleTimeString('id-ID');
    });

    // workerSubmitted: worker submitted exam
    window.assessmentHub.on('workerSubmitted', function(data) {
        var tr = document.querySelector('tr[data-session-id="' + data.sessionId + '"]');
        // Build session object matching updateRow() signature
        var session = {
            sessionId: data.sessionId,
            status: 'Completed',
            score: data.score,
            result: data.result,
            progress: data.totalQuestions,
            totalQuestions: data.totalQuestions,
            completedAt: new Date().toISOString()
        };
        // updateRow is defined in the IIFE; since it is inside an IIFE it is not directly accessible here.
        // Re-implement minimal row update for workerSubmitted:
        if (tr) {
            var tds = tr.querySelectorAll('td');
            // Progress (col 1)
            if (tds[1] && data.totalQuestions > 0) tds[1].textContent = data.totalQuestions + '/' + data.totalQuestions;
            // Status (col 2) — MAM-05: render dari payload (essay-pending → badge pending, bukan hijau Completed)
            if (tds[2]) {
                if (data.status === 'Menunggu Penilaian') {
                    tds[2].innerHTML = '<span class="badge bg-warning text-dark">Menunggu Penilaian</span>';
                } else {
                    tds[2].innerHTML = '<span class="badge bg-success">Completed</span>';
                }
            }
            // Score (col 3)
            if (tds[3]) tds[3].textContent = data.score !== null && data.score !== undefined ? data.score + '%' : '\u2014';
            // Result (col 4)
            if (tds[4]) {
                tds[4].textContent = data.result || '\u2014';
                tds[4].className = 'result-cell ' + (data.result === 'Pass' ? 'text-success fw-semibold' : (data.result === 'Fail' ? 'text-danger fw-semibold' : 'text-muted'));
            }
            // CompletedAt (col 5)
            if (tds[5]) {
                var d = new Date();
                tds[5].textContent = d.toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' })
                    + ' ' + d.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
            }
            flashRow(tr, 'flash-complete');
        }
        if (typeof window.showAssessmentToast === 'function') {
            window.showAssessmentToast(data.workerName + ' menyelesaikan ujian (Skor: ' + data.score + '%)');
        }
        updateSummaryFromDOM();
        var elLu = document.getElementById('last-updated-time');
        if (elLu) elLu.textContent = new Date().toLocaleTimeString('id-ID');

        // If all rows are terminal, hide Akhiri Semua button
        var rows = document.querySelectorAll('tbody tr[data-session-id]');
        var allDone = true;
        rows.forEach(function(row) {
            var sc = row.querySelector('.status-cell');
            if (sc) {
                var txt = sc.textContent.trim();
                if (txt !== 'Completed' && txt !== 'Dibatalkan' && txt !== 'Abandoned') allDone = false;
            }
        });
        if (allDone) {
            var akhiriBtn = document.getElementById('akhiriSemuaBtn');
            if (akhiriBtn) akhiriBtn.style.display = 'none';
        }
    });

    // workerAnswerEdited: admin/HC edited a session's answers (Phase 321 EDIT-09)
    window.assessmentHub.on('workerAnswerEdited', function (data) {
        var row = document.querySelector('tr[data-session-id="' + data.sessionId + '"]');
        if (row) {
            var scoreCell = row.querySelector('.score-cell');
            var resultCell = row.querySelector('.result-cell');
            if (scoreCell) scoreCell.textContent = data.newScore + '%';
            if (resultCell) {
                resultCell.textContent = data.newIsPassed ? 'Pass' : 'Fail';
                resultCell.className = 'result-cell ' + (data.newIsPassed ? 'text-success fw-semibold' : 'text-danger fw-semibold');
            }
        }

        // D-07 toast verbose template (8 detik per D-07 LOCKED)
        var oldResult = (data.oldIsPassed === true) ? 'Pass' : (data.oldIsPassed === false) ? 'Fail' : '—';
        var newResult = data.newIsPassed ? 'Pass' : 'Fail';
        var flipSegment = (data.oldIsPassed !== data.newIsPassed)
            ? ', ' + oldResult + '→' + newResult
            : '';
        var msg = data.actorRole + ' ' + data.actorName +
                  ' edit jawaban ' + data.workerName +
                  ': Score ' + (data.oldScore !== null && data.oldScore !== undefined ? data.oldScore : '—') + '→' + data.newScore +
                  flipSegment;
        if (typeof window.showAssessmentToast === 'function') {
            window.showAssessmentToast(msg, null, null, 8000);
        } else {
            console.log('[toast]', msg);
        }
    });

    // ============================================================
    // Phase 412 — Handler SignalR participantAdded / participantRemoved
    // ============================================================

    // Inject baris peserta baru (atau pulihkan dari panel) ke tbody aktif.
    // Dipakai handler participantAdded + fallback POST (window.monInjectParticipantRow).
    window.monInjectParticipantRow = function (data) {
        var activeBody = document.querySelector('table.table tbody:not(#tbodyRemoved)');
        if (!activeBody) return;

        // Dedup: skip bila baris aktif sudah ada.
        if (document.querySelector('tbody:not(#tbodyRemoved) tr[data-session-id="' + data.sessionId + '"]')) {
            if (typeof window.monClearAddedFallback === 'function') window.monClearAddedFallback(data.sessionId);
            return;
        }

        // Batalkan placeholder "kosong" bila ada.
        var emptyRow = activeBody.querySelector('td[colspan]');
        if (emptyRow && emptyRow.parentElement) emptyRow.parentElement.remove();

        var status = data.status || 'Not started';
        if (status === 'Open' || status === 'Upcoming') status = 'Not started';

        var tr = document.createElement('tr');
        tr.setAttribute('data-session-id', data.sessionId);

        var tdName = document.createElement('td');
        tdName.className = 'fw-semibold';
        tdName.textContent = data.fullName || '';   // XSS-safe (Pitfall 3)
        tr.appendChild(tdName);

        var tdProg = document.createElement('td');
        tdProg.className = 'text-center progress-cell';
        tdProg.textContent = '—';
        tr.appendChild(tdProg);

        var tdStatus = document.createElement('td');
        tdStatus.className = 'status-cell';
        var badgeCls = (typeof window.monStatusBadgeClass === 'function') ? window.monStatusBadgeClass(status) : 'badge bg-light text-dark border';
        var badgeLbl = (typeof window.monStatusDisplayLabel === 'function') ? window.monStatusDisplayLabel(status) : status;
        var spanBadge = document.createElement('span');
        spanBadge.className = badgeCls;
        spanBadge.textContent = badgeLbl;   // XSS-safe
        tdStatus.appendChild(spanBadge);
        tr.appendChild(tdStatus);

        var tdScore = document.createElement('td');
        tdScore.className = 'score-cell';
        tdScore.innerHTML = '<span class="text-muted">—</span>';
        tr.appendChild(tdScore);

        var tdResult = document.createElement('td');
        tdResult.className = 'result-cell text-muted';
        tdResult.textContent = '—';
        tr.appendChild(tdResult);

        var tdDone = document.createElement('td');
        tdDone.className = 'completedat-cell text-muted small';
        tdDone.textContent = '—';
        tr.appendChild(tdDone);

        var tdAct = document.createElement('td');
        if (typeof window.monBuildActionsHtml === 'function') {
            tdAct.innerHTML = window.monBuildActionsHtml(
                { sessionId: data.sessionId, status: status, UserStatus: status, fullName: data.fullName, nomorSertifikat: data.nomorSertifikat || null },
                window.monIsPackageMode
            );
        }
        tr.appendChild(tdAct);

        activeBody.appendChild(tr);
        if (typeof window.monFlashRow === 'function') window.monFlashRow(tr, 'flash-update');
        if (typeof window.monClearAddedFallback === 'function') window.monClearAddedFallback(data.sessionId);
    };

    // participantAdded: peserta ditambah ATAU dipulihkan (Restore) — baris muncul live.
    window.assessmentHub.on('participantAdded', function (data) {
        // 1. Dedup baris aktif.
        if (document.querySelector('tbody:not(#tbodyRemoved) tr[data-session-id="' + data.sessionId + '"]')) {
            if (typeof window.monClearAddedFallback === 'function') window.monClearAddedFallback(data.sessionId);
            return;
        }
        // 2. Kasus Restore: baris ada di #tbodyRemoved → hapus dari panel, lalu inject ulang ke aktif.
        var removedTr = document.querySelector('#tbodyRemoved tr[data-session-id="' + data.sessionId + '"][data-removed="true"]');
        if (removedTr) {
            removedTr.remove();
            decrementRemovedCount();
        }
        // 3. Inject baris aktif (baru atau hasil restore).
        window.monInjectParticipantRow({
            sessionId: data.sessionId,
            fullName: data.fullName,
            nip: data.nip,
            status: data.status || 'Not started',
            nomorSertifikat: data.nomorSertifikat || null
        });
        updateSummaryFromDOM();
        if (typeof window.showAssessmentToast === 'function') {
            window.showAssessmentToast((data.fullName || 'Peserta') + ' ditambahkan ke batch');
        }
        var el = document.getElementById('last-updated-time');
        if (el) el.textContent = new Date().toLocaleTimeString('id-ID');
    });

    // participantRemoved: mode hard → hapus baris; soft → pindah ke panel "Peserta Dikeluarkan".
    window.assessmentHub.on('participantRemoved', function (data) {
        var tr = document.querySelector('tbody:not(#tbodyRemoved) tr[data-session-id="' + data.sessionId + '"]');
        if (!tr) return;

        if (data.mode === 'hard') {
            tr.remove();   // hard-delete tak masuk panel (Pitfall 6)
        } else {
            // soft → bangun baris removed (XSS-safe via textContent — Pitfall 3)
            var newTr = document.createElement('tr');
            newTr.setAttribute('data-session-id', data.sessionId);
            newTr.setAttribute('data-removed', 'true');

            var tdName = document.createElement('td');
            tdName.className = 'fw-semibold';
            tdName.textContent = data.fullName || '';
            if (data.nip) {
                var brEl = document.createElement('br');
                var smEl = document.createElement('small');
                smEl.className = 'text-muted';
                smEl.textContent = data.nip;
                tdName.appendChild(brEl);
                tdName.appendChild(smEl);
            }
            newTr.appendChild(tdName);

            var tdWaktu = document.createElement('td');
            tdWaktu.className = 'text-muted small';
            tdWaktu.textContent = formatRemovedAt(data.removedAt);
            newTr.appendChild(tdWaktu);

            var tdOleh = document.createElement('td');
            tdOleh.className = 'text-muted small';
            tdOleh.textContent = data.removedBy || '—';
            newTr.appendChild(tdOleh);

            var tdReason = document.createElement('td');
            tdReason.className = 'text-muted small';
            tdReason.style.maxWidth = '200px';
            tdReason.style.wordBreak = 'break-word';
            tdReason.textContent = data.removalReason ? data.removalReason : '—';   // XSS-safe
            newTr.appendChild(tdReason);

            var tdAksi = document.createElement('td');
            var btnRestore = document.createElement('button');
            btnRestore.type = 'button';
            btnRestore.className = 'btn btn-outline-success btn-sm btn-restore-peserta';
            btnRestore.setAttribute('data-session-id', data.sessionId);
            btnRestore.setAttribute('data-worker-name', data.fullName || '');
            btnRestore.style.minHeight = '40px';
            btnRestore.title = 'Pulihkan ke batch aktif';
            btnRestore.innerHTML = '<i class="bi bi-arrow-counterclockwise me-1"></i>Restore';
            tdAksi.appendChild(btnRestore);
            newTr.appendChild(tdAksi);

            var tbodyRemoved = document.getElementById('tbodyRemoved');
            if (tbodyRemoved) {
                tbodyRemoved.prepend(newTr);
                incrementRemovedCount();
                var panel = document.getElementById('panelPesertaDikeluarkan');
                if (panel) panel.style.display = '';
            }
            tr.remove();
        }
        updateSummaryFromDOM();
        if (typeof window.showAssessmentToast === 'function') {
            window.showAssessmentToast((data.fullName || 'Peserta') + ' dikeluarkan dari batch');
        }
        var elLu = document.getElementById('last-updated-time');
        if (elLu) elLu.textContent = new Date().toLocaleTimeString('id-ID');
    });

    function formatRemovedAt(iso) {
        if (!iso) return '—';
        var d = new Date(iso);
        if (isNaN(d.getTime())) return '—';
        return d.toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' })
            + ' ' + d.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) + ' WIB';
    }
    function incrementRemovedCount() {
        var el = document.getElementById('countRemoved');
        if (el) el.textContent = (parseInt(el.textContent, 10) || 0) + 1;
    }
    function decrementRemovedCount() {
        var el = document.getElementById('countRemoved');
        if (el) el.textContent = Math.max(0, (parseInt(el.textContent, 10) || 0) - 1);
    }
</script>

<script>
    // Phase 384 UIG-01: handler essay grading inline DIHAPUS (pindah ke wwwroot/js/essay-grading.js,
    // dipakai page per-worker /Admin/EssayGrading). showAlert juga dihapus — hanya dipakai 2 handler essay.

    // -------- Extra Time Modal (Phase 302) --------
    function addExtraTime() {
        var minutes = parseInt(document.getElementById('extraTimeSelect').value, 10);
        var assessmentId = @Model.RepresentativeId;
        var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        var btn = document.getElementById('btnConfirmExtraTime');
        btn.disabled = true;
        btn.textContent = 'Menambahkan...';

        fetch(appUrl('/Admin/AddExtraTime'), {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: 'assessmentId=' + assessmentId + '&minutes=' + minutes + '&__RequestVerificationToken=' + encodeURIComponent(token)
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            bootstrap.Modal.getInstance(document.getElementById('extraTimeModal')).hide();
            btn.disabled = false;
            btn.textContent = 'Tambah Waktu';
            var alertClass = data.success ? 'alert-success' : 'alert-danger';
            var iconClass = data.success ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill';
            var alertHtml = '<div class="alert ' + alertClass + ' alert-dismissible fade show mb-3" role="alert">'
                + '<i class="bi ' + iconClass + ' me-2"></i>' + data.message
                + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
            var alertContainer = document.querySelector('.container-fluid');
            alertContainer.insertAdjacentHTML('afterbegin', alertHtml);
        })
        .catch(function() {
            btn.disabled = false;
            btn.textContent = 'Tambah Waktu';
            bootstrap.Modal.getInstance(document.getElementById('extraTimeModal')).hide();
            alert('Gagal menambah waktu. Silakan coba lagi.');
        });
    }

    // Phase 310 D-02 — Bootstrap tooltip activation untuk button disabled state
    // Canonical pattern dari Views/Admin/AddTraining.cshtml L394-397
    document.addEventListener('DOMContentLoaded', function() {
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        tooltipTriggerList.forEach(function(el) { new bootstrap.Tooltip(el); });
    });
</script>

<!-- Extra Time Modal (Phase 302) -->
<div class="modal fade" id="extraTimeModal" tabindex="-1" aria-labelledby="extraTimeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="extraTimeModalLabel">
                    <i class="bi bi-clock-history me-2 text-warning"></i>Tambah Waktu Ujian
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-3">Waktu tambahan akan diberikan ke semua peserta yang sedang mengerjakan ujian ini.</p>
                <label for="extraTimeSelect" class="form-label fw-semibold">Tambah waktu (menit)</label>
                <select id="extraTimeSelect" class="form-select">
                    <option value="5">5 menit</option>
                    <option value="10">10 menit</option>
                    <option value="15" selected>15 menit</option>
                    <option value="20">20 menit</option>
                    <option value="25">25 menit</option>
                    <option value="30">30 menit</option>
                    <option value="45">45 menit</option>
                    <option value="60">60 menit</option>
                    <option value="90">90 menit</option>
                    <option value="120">120 menit</option>
                </select>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                <button type="button" class="btn btn-warning" id="btnConfirmExtraTime" onclick="addExtraTime()">
                    <i class="bi bi-clock-history me-1"></i>Tambah Waktu
                </button>
            </div>
        </div>
    </div>
</div>
}
