@{
    ViewData["Title"] = "Cleanup AttemptHistory Orphan";
    var orphanCount = (int)(ViewData["OrphanCount"] ?? 0);
}

<div class="container-fluid px-4 py-4">

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb small">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Admin")">Admin</a></li>
            <li class="breadcrumb-item active">Cleanup AttemptHistory Orphan</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-trash3"></i> Cleanup AttemptHistory Orphan</h2>
            <p class="text-muted mb-0">Hapus baris riwayat percobaan (AttemptHistory) yang sesi induknya sudah terhapus — sisa data lama sebelum cascade delete otomatis.</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-1"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            @if (orphanCount > 0)
            {
                <p class="mb-3">
                    Ditemukan <span class="fw-bold text-danger">@orphanCount</span> baris AttemptHistory orphan
                    (sesi induk sudah terhapus). Tindakan ini permanen dan tidak bisa di-undo.
                </p>
                <form method="post" asp-action="CleanupAttemptHistoryExecute"
                      onsubmit="return confirm('Hapus @orphanCount orphan AttemptHistory? Tidak bisa di-undo.');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash3 me-1"></i> Hapus @orphanCount Orphan
                    </button>
                </form>
            }
            else
            {
                <p class="mb-0 text-success">
                    <i class="bi bi-check-circle me-1"></i> Tidak ada orphan AttemptHistory — DB bersih.
                </p>
            }
        </div>
    </div>

</div>
