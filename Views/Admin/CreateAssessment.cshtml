@model HcPortal.Models.AssessmentSession

@{
    ViewData["Title"] = "Buat Assessment";
    ViewData["ContainerClass"] = "container-fluid";
}

<div class="container-fluid px-4 py-4">

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Kelola Data</a></li>
            <li class="breadcrumb-item"><a asp-action="ManageAssessment">Manage Assessment &amp; Training</a></li>
            <li class="breadcrumb-item active" aria-current="page">Buat Assessment</li>
        </ol>
    </nav>

    <!-- Page Header -->
    <h2 class="fw-bold mb-1">Buat Assessment Baru</h2>
    <p class="text-muted mb-4">Buat assessment kompetensi baru untuk karyawan</p>

    <!-- Server-side alerts (re-render on validation failure) -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["Warning"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <strong>Mohon perbaiki kesalahan berikut:</strong>
            <ul class="mb-0 mt-2">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (ViewBag.IsRenewalMode == true)
    {
        <div class="alert alert-info d-flex align-items-center justify-content-between mb-3" role="alert">
            <div>
                <i class="bi bi-arrow-repeat me-2"></i>
                <strong>Mode Renewal:</strong> @ViewBag.RenewalSourceTitle
                @if (!string.IsNullOrEmpty(ViewBag.RenewalSourceUserName as string))
                {
                    <span> &mdash; @ViewBag.RenewalSourceUserName</span>
                }
            </div>
            <a href="@Url.Action("CreateAssessment", "AssessmentAdmin")" class="btn btn-sm btn-outline-secondary ms-3">
                Batalkan Renewal
            </a>
        </div>
    }

    <!-- Step Indicator Nav-Pills -->
    <nav class="mb-4">
        <ul class="nav nav-pills nav-fill gap-2" id="wizardStepNav">
            <li class="nav-item">
                <button type="button" class="nav-link bg-primary text-white active" id="pill-1">
                    <i class="bi bi-circle-fill me-1"></i>1. Kategori
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link text-muted border" id="pill-2" disabled>
                    <i class="bi bi-circle me-1"></i>2. Peserta
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link text-muted border" id="pill-3" disabled>
                    <i class="bi bi-circle me-1"></i>3. Settings
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link text-muted border" id="pill-4" disabled>
                    <i class="bi bi-circle me-1"></i>4. Konfirmasi
                </button>
            </li>
        </ul>
    </nav>

    <!-- Single form wrapping all steps -->
    <form asp-action="CreateAssessment" asp-controller="AssessmentAdmin" method="post" id="createAssessmentForm" novalidate>
        @Html.AntiForgeryToken()
        @if (ViewBag.RenewsSessionId != null)
        {
            <input type="hidden" name="RenewsSessionId" value="@ViewBag.RenewsSessionId" />
        }
        @if (ViewBag.RenewsTrainingId != null)
        {
            <input type="hidden" name="RenewsTrainingId" value="@ViewBag.RenewsTrainingId" />
        }
        @if (ViewBag.RenewalFkMap != null)
        {
            <input type="hidden" name="RenewalFkMap" value="@ViewBag.RenewalFkMap" />
            <input type="hidden" name="RenewalFkMapType" value="@ViewBag.RenewalFkMapType" />
        }

        <!-- ===================== STEP 1: KATEGORI ===================== -->
        <div id="step-1" class="step-panel">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4"><i class="bi bi-tag me-2 text-primary"></i>Langkah 1: Kategori &amp; Judul</h5>

                    <div class="row g-3">
                        <!-- Category -->
                        <div class="col-md-8">
                            <label asp-for="Category" class="form-label fw-bold">
                                Kategori Assessment <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Category" class="form-select" id="Category">
                                <option value="">-- Pilih Kategori --</option>
                                @if (ViewBag.ParentCategories != null)
                                {
                                    var parents = (IEnumerable<HcPortal.Models.AssessmentCategory>)ViewBag.ParentCategories;
                                    var standalone = parents.Where(p => !p.Children.Any());
                                    var withChildren = parents.Where(p => p.Children.Any());
                                    foreach (var cat in standalone)
                                    {
                                        <option value="@cat.Name"
                                                data-pass-percentage="@cat.DefaultPassPercentage"
                                                selected="@(Model.Category == cat.Name)">
                                            @cat.Name
                                        </option>
                                    }
                                    foreach (var parent in withChildren)
                                    {
                                        <optgroup label="@parent.Name">
                                            <option value="@parent.Name"
                                                    data-pass-percentage="@parent.DefaultPassPercentage"
                                                    selected="@(Model.Category == parent.Name)">
                                                @parent.Name (Induk)
                                            </option>
                                            @foreach (var child in parent.Children.OrderBy(c => c.SortOrder).ThenBy(c => c.Name))
                                            {
                                                <option value="@child.Name"
                                                        data-pass-percentage="@child.DefaultPassPercentage"
                                                        selected="@(Model.Category == child.Name)">
                                                    &nbsp;&nbsp;@child.Name
                                                </option>
                                            }
                                        </optgroup>
                                    }
                                }
                                else if (ViewBag.Categories != null)
                                {
                                    foreach (var cat in (IEnumerable<HcPortal.Models.AssessmentCategory>)ViewBag.Categories)
                                    {
                                        <option value="@cat.Name"
                                                data-pass-percentage="@cat.DefaultPassPercentage"
                                                selected="@(Model.Category == cat.Name)">
                                            @cat.Name
                                        </option>
                                    }
                                }
                            </select>
                            <div class="invalid-feedback">Pilih kategori assessment.</div>
                            <span asp-validation-for="Category" class="text-danger small"></span>
                            <div id="category-description" class="mt-2" style="display:none;">
                                <small class="text-muted"><i class="bi bi-info-circle me-1"></i><span id="category-description-text"></span></small>
                            </div>
                        </div>

                        <!-- Title -->
                        <div class="col-md-8">
                            <label asp-for="Title" class="form-label fw-bold">
                                Judul Assessment <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Title" class="form-control" id="Title" placeholder="Masukkan judul assessment" maxlength="255" oninput="document.getElementById('titleCounter').textContent=this.value.length+'/255'" />
                            <div class="d-flex justify-content-between">
                                <div class="invalid-feedback">Judul assessment wajib diisi.</div>
                                <small class="text-muted" id="titleCounter">0/255</small>
                            </div>
                        </div>

                        <!-- Assessment Type (Standard / Pre-Post Test) -->
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Tipe Assessment</label>
                            <select name="AssessmentTypeInput" id="assessmentTypeInput" class="form-select">
                                <option value="Standard" selected>Standard</option>
                                <option value="PrePostTest">Pre-Post Test</option>
                            </select>
                            <div id="assessment-type-description" class="form-text text-muted mt-1">
                                <i class="bi bi-info-circle me-1"></i>
                                <span id="assessment-type-desc-text">Assessment standar dengan satu sesi ujian. Peserta mengerjakan soal satu kali dan langsung mendapat hasil.</span>
                            </div>
                        </div>

                        <!-- Proton Fields (conditional) -->
                        <div class="col-12 d-none" id="protonFieldsSection">
                            <div class="card border-warning">
                                <div class="card-header bg-warning text-dark">
                                    <h6 class="mb-0"><i class="bi bi-award me-2"></i>Pengaturan Assessment Proton</h6>
                                </div>
                                <div class="card-body">
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold">Track <span class="text-danger">*</span></label>
                                            <select id="protonTrackSelect" name="ProtonTrackId" class="form-select">
                                                <option value="">-- Pilih Track --</option>
                                                @if (ViewBag.ProtonTracks != null)
                                                {
                                                    foreach (var track in (List<HcPortal.Models.ProtonTrack>)ViewBag.ProtonTracks)
                                                    {
                                                        <option value="@track.Id" data-tahun="@track.TahunKe">@track.DisplayName</option>
                                                    }
                                                }
                                            </select>
                                            <div class="form-text text-muted">Pilih track sesuai penugasan coachee (Operator/Panelman, Tahun 1/2/3).</div>
                                            <div class="invalid-feedback" id="protonTrackError">Pilih track untuk Assessment Proton.</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Navigation -->
                    <div class="d-flex justify-content-between mt-4">
                        <div></div>
                        <div class="d-flex flex-column align-items-end gap-2">
                            <button type="button" class="btn btn-primary btn-next" id="btnNext1">
                                Selanjutnya <i class="bi bi-arrow-right ms-1"></i>
                            </button>
                            <button type="button" class="btn btn-outline-primary btnBackToConfirm d-none" id="btnBackToConfirm-1">
                                <i class="bi bi-arrow-left me-1"></i>Kembali ke Konfirmasi
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===================== STEP 2: PESERTA ===================== -->
        <div id="step-2" class="step-panel d-none">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4"><i class="bi bi-people me-2 text-primary"></i>Langkah 2: Pilih Peserta</h5>

                    <!-- Filter bar (normal mode) -->
                    <div id="normalFilterBar" class="row g-2 mb-3">
                        <div class="col-auto">
                            <select id="sectionFilter" class="form-select form-select-sm" style="max-width:220px;">
                                <option value="">Semua Bagian</option>
                                @if (ViewBag.Sections != null)
                                {
                                    foreach (var sec in (List<string>)ViewBag.Sections)
                                    {
                                        <option value="@sec">@sec</option>
                                    }
                                }
                                <option value="__none__">Lainnya (Tanpa Bagian)</option>
                            </select>
                        </div>
                        <div class="col-auto">
                            <div class="input-group input-group-sm" style="max-width:300px;">
                                <input type="text" id="userSearchInput" class="form-control" placeholder="Cari nama atau email..." />
                                <button type="button" class="btn btn-outline-secondary" id="clearSearchBtn" title="Clear search">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-auto">
                            <button type="button" class="btn btn-outline-primary btn-sm" id="selectAllBtn">Pilih Semua</button>
                        </div>
                        <div class="col-auto">
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="deselectAllBtn">Batalkan Semua</button>
                        </div>
                        <div class="col-auto ms-auto">
                            <span class="badge bg-primary" id="selectedCountBadge">0 terpilih</span>
                        </div>
                    </div>

                    <!-- Normal user list -->
                    <div id="userCheckboxContainer" class="border rounded p-3" style="max-height:320px;overflow-y:auto;">
                        @if (ViewBag.Users != null)
                        {
                            var selectedIds = (List<string>)ViewBag.SelectedUserIds;
                            @foreach (var user in ViewBag.Users)
                            {
                                var isChecked = selectedIds != null && selectedIds.Contains((string)user.Id);
                                <div class="form-check user-check-item mb-1" data-name="@user.FullName" data-email="@user.Email" data-section="@user.Section">
                                    <input class="form-check-input user-checkbox" type="checkbox" name="UserIds" value="@user.Id" id="user_@user.Id" @(isChecked ? "checked" : "") />
                                    <label class="form-check-label" for="user_@user.Id">
                                        <strong>@user.FullName</strong> <span class="text-muted">(@user.Email) — @user.Section</span>
                                    </label>
                                </div>
                            }
                        }
                    </div>

                    <!-- Proton eligible section -->
                    <div id="protonEligibleSection" class="d-none">
                        <div class="alert alert-info py-2 px-3 mb-2" id="protonEligibleStatus">
                            <i class="bi bi-hourglass-split me-1"></i>Pilih track di Langkah 1 untuk memuat daftar coachee eligible...
                        </div>
                        <div id="protonUserCheckboxContainer" class="border rounded p-3 d-none" style="max-height:320px;overflow-y:auto;"></div>
                        <div class="form-text text-muted mt-1">Hanya coachee dengan 100% deliverable Approved yang dapat dipilih.</div>
                    </div>

                    <!-- Step 2 error -->
                    <div id="step2Error" class="alert alert-danger d-none mt-3">Pilih minimal 1 peserta untuk melanjutkan.</div>

                    <!-- Navigation -->
                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn btn-outline-secondary btn-prev" id="btnPrev2">
                            <i class="bi bi-arrow-left me-1"></i>Sebelumnya
                        </button>
                        <div class="d-flex flex-column align-items-end gap-2">
                            <button type="button" class="btn btn-primary btn-next" id="btnNext2">
                                Selanjutnya <i class="bi bi-arrow-right ms-1"></i>
                            </button>
                            <button type="button" class="btn btn-outline-primary btnBackToConfirm d-none" id="btnBackToConfirm-2">
                                <i class="bi bi-arrow-left me-1"></i>Kembali ke Konfirmasi
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===================== STEP 3: SETTINGS ===================== -->
        <div id="step-3" class="step-panel d-none">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4"><i class="bi bi-gear me-2 text-primary"></i>Langkah 3: Settings</h5>

                    <!-- ========== GROUP A: Jadwal & Waktu ========== -->
                    <div class="card mb-4">
                        <div class="card-header bg-light">
                            <h6 class="mb-0"><i class="bi bi-calendar-event me-2"></i>Jadwal & Waktu</h6>
                        </div>
                        <div class="card-body">
                            <!-- Standard Jadwal Section -->
                            <div id="standard-jadwal-section">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">Tanggal Jadwal <span class="text-danger">*</span></label>
                                        <input type="date" id="schedDateInput" name="ScheduleDate" class="form-control" />
                                        <div class="invalid-feedback" id="schedDateError">Tanggal jadwal wajib diisi.</div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">Waktu Jadwal <span class="text-danger">*</span></label>
                                        <input type="time" id="schedTimeInput" name="ScheduleTime" class="form-control" value="08:00" />
                                        <div class="invalid-feedback" id="schedTimeError">Waktu jadwal wajib diisi.</div>
                                    </div>
                                    <div class="col-md-6" id="durationFieldWrapper">
                                        <label asp-for="DurationMinutes" class="form-label fw-bold">
                                            Durasi (Menit) <span class="text-danger">*</span>
                                        </label>
                                        <input asp-for="DurationMinutes" type="number" class="form-control" min="1" max="480" />
                                        <div class="form-text text-muted">1–480 menit (maks 8 jam)</div>
                                        <div class="invalid-feedback">Durasi (menit) wajib diisi.</div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">
                                            <i class="bi bi-calendar-x text-danger me-1"></i>Tanggal Tutup Ujian <span class="text-danger">*</span>
                                        </label>
                                        <input type="date" id="ewcdDateInput" class="form-control" />
                                        <div class="invalid-feedback" id="ewcdDateError">Tanggal tutup ujian wajib diisi.</div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">
                                            <i class="bi bi-clock text-danger me-1"></i>Waktu Tutup Ujian <span class="text-danger">*</span>
                                        </label>
                                        <input type="time" id="ewcdTimeInput" class="form-control" value="23:59" />
                                        <div class="invalid-feedback" id="ewcdTimeError">Waktu tutup ujian wajib diisi.</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Hidden schedule/EWCD combiners -->
                            <input type="hidden" asp-for="Schedule" id="schedHidden" />
                            <input type="hidden" asp-for="ExamWindowCloseDate" id="ewcdHidden" />

                            <!-- Pre-Post Test Jadwal Section -->
                            <div id="ppt-jadwal-section" class="collapse">
                                <div class="card mb-3">
                                    <div class="card-header bg-light fw-semibold">
                                        <i class="bi bi-clock"></i> Jadwal Pre-Test
                                    </div>
                                    <div class="card-body">
                                        <div class="row g-2">
                                            <div class="col-md-4">
                                                <label class="form-label small fw-semibold text-muted">Tanggal &amp; Waktu <span class="text-danger">*</span></label>
                                                <input type="datetime-local" name="PreSchedule" id="preSchedule" class="form-control" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small fw-semibold text-muted">Durasi (menit) <span class="text-danger">*</span></label>
                                                <input type="number" name="PreDurationMinutes" id="preDurationMinutes" class="form-control" min="1" max="480" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small fw-semibold text-muted">Batas Waktu Pengerjaan <span class="text-danger">*</span></label>
                                                <input type="datetime-local" name="PreExamWindowCloseDate" id="preExamWindowCloseDate" class="form-control" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="card mb-3">
                                    <div class="card-header bg-light fw-semibold">
                                        <i class="bi bi-clock-history"></i> Jadwal Post-Test
                                    </div>
                                    <div class="card-body">
                                        <div class="row g-2">
                                            <div class="col-md-4">
                                                <label class="form-label small fw-semibold text-muted">Tanggal &amp; Waktu <span class="text-danger">*</span></label>
                                                <input type="datetime-local" name="PostSchedule" id="postSchedule" class="form-control" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small fw-semibold text-muted">Durasi (menit) <span class="text-danger">*</span></label>
                                                <input type="number" name="PostDurationMinutes" id="postDurationMinutes" class="form-control" min="1" max="480" />
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label small fw-semibold text-muted">Batas Waktu Pengerjaan <span class="text-danger">*</span></label>
                                                <input type="datetime-local" name="PostExamWindowCloseDate" id="postExamWindowCloseDate" class="form-control" />
                                            </div>
                                        </div>
                                        <div class="mt-3">
                                            <div class="form-check">
                                                <input type="checkbox" name="SamePackage" value="true" id="samePackageCheck" class="form-check-input" />
                                                <label class="form-check-label" for="samePackageCheck">Gunakan paket soal yang sama untuk Pre dan Post</label>
                                            </div>
                                            <div id="samePackageBadge" class="mt-2 d-none">
                                                <span class="badge bg-info"><i class="bi bi-info-circle"></i> Paket soal Post-Test akan otomatis disinkronkan dari Pre-Test</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ========== GROUP B: Pengaturan Ujian ========== -->
                    <div class="card mb-4">
                        <div class="card-header bg-light">
                            <h6 class="mb-0"><i class="bi bi-sliders me-2"></i>Pengaturan Ujian</h6>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <!-- Status -->
                                <div class="col-md-6" id="statusFieldWrapper">
                                    <label asp-for="Status" class="form-label fw-bold">Status <span class="text-danger">*</span></label>
                                    <select asp-for="Status" class="form-select" id="Status">
                                        <option value="">-- Pilih Status --</option>
                                        <option value="Open">Open</option>
                                        <option value="Upcoming">Upcoming</option>
                                    </select>
                                    <div class="form-text text-muted">Default: Open (tersedia langsung)</div>
                                    <div class="invalid-feedback">Status wajib dipilih.</div>
                                </div>

                                <!-- Pass Percentage -->
                                <div class="col-md-6" id="passPercentageWrapper">
                                    <label asp-for="PassPercentage" class="form-label fw-bold">
                                        Pass Percentage (%) <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="PassPercentage" type="number" class="form-control" min="0" max="100" id="PassPercentage" />
                                    <div class="form-text text-muted">Nilai minimum untuk lulus (0–100)</div>
                                </div>

                                <!-- Token -->
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">
                                        <i class="bi bi-shield-lock text-primary me-1"></i>Security Token
                                    </label>
                                    <div class="form-check form-switch mb-2">
                                        <input class="form-check-input" type="checkbox" asp-for="IsTokenRequired" id="IsTokenRequired" />
                                        <label class="form-check-label" for="IsTokenRequired">Wajib token untuk memulai ujian</label>
                                    </div>
                                    <div id="tokenSection" class="d-none">
                                        <label asp-for="AccessToken" class="form-label fw-bold">Access Token</label>
                                        <div class="input-group">
                                            <input asp-for="AccessToken" class="form-control font-monospace" placeholder="Contoh: A1B2C3" maxlength="6" id="AccessToken" pattern="[A-Za-z0-9]{6}" title="6 karakter alfanumerik" style="text-transform:uppercase;" />
                                            <button class="btn btn-outline-secondary" type="button" onclick="generateToken()">
                                                <i class="bi bi-shuffle"></i> Generate
                                            </button>
                                        </div>
                                        <span asp-validation-for="AccessToken" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ========== GROUP C: Sertifikat ========== -->
                    <div class="card mb-4">
                        <div class="card-header bg-light">
                            <h6 class="mb-0"><i class="bi bi-award me-2"></i>Sertifikat</h6>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Terbitkan Sertifikat</label>
                                    <div class="form-check form-switch">
                                        <input asp-for="GenerateCertificate" class="form-check-input" type="checkbox" id="GenerateCertificate" />
                                        <label class="form-check-label" for="GenerateCertificate">Aktifkan</label>
                                    </div>
                                    <div class="form-text text-muted">Peserta yang lulus dapat melihat dan mencetak sertifikat</div>
                                    <div id="preTestWarning" class="alert alert-warning py-2 px-3 mt-2 d-none" role="alert">
                                        <i class="bi bi-exclamation-triangle-fill me-1"></i>
                                        Judul mengandung "Pre Test". Pre Test biasanya tidak menerbitkan sertifikat.
                                    </div>
                                    <div id="prePostCertNote" class="form-text text-info d-none">
                                        <i class="bi bi-info-circle me-1"></i>Sertifikat hanya diterbitkan untuk peserta yang lulus Post-Test
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    @if (ViewBag.RenewalValidUntilWarning != null)
                                    {
                                        <div class="alert alert-warning py-2 mb-2">
                                            <i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.RenewalValidUntilWarning
                                        </div>
                                    }
                                    <label asp-for="ValidUntil" class="form-label fw-bold">
                                        Tanggal Expired Sertifikat
                                        @if (ViewBag.IsRenewalMode == true)
                                        {
                                            <span class="text-danger">*</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">(opsional)</span>
                                        }
                                    </label>
                                    <input asp-for="ValidUntil" type="date" class="form-control" id="ValidUntil"
                                           min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                                    <div class="form-text">Kosongkan jika sertifikat tidak memiliki batas waktu.</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ========== GROUP D: Opsi Lainnya ========== -->
                    <div class="card mb-4">
                        <div class="card-header bg-light">
                            <h6 class="mb-0"><i class="bi bi-toggles me-2"></i>Opsi Lainnya</h6>
                        </div>
                        <div class="card-body">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Izinkan Review Jawaban</label>
                                <div class="form-check form-switch">
                                    <input asp-for="AllowAnswerReview" class="form-check-input" type="checkbox" id="AllowAnswerReview" />
                                    <label class="form-check-label" for="AllowAnswerReview">Aktifkan review jawaban setelah selesai</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Navigation -->
                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn btn-outline-secondary btn-prev" id="btnPrev3">
                            <i class="bi bi-arrow-left me-1"></i>Sebelumnya
                        </button>
                        <div class="d-flex flex-column align-items-end gap-2">
                            <button type="button" class="btn btn-primary btn-next" id="btnNext3">
                                Selanjutnya <i class="bi bi-arrow-right ms-1"></i>
                            </button>
                            <button type="button" class="btn btn-outline-primary btnBackToConfirm d-none" id="btnBackToConfirm-3">
                                <i class="bi bi-arrow-left me-1"></i>Kembali ke Konfirmasi
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===================== STEP 4: KONFIRMASI ===================== -->
        <div id="step-4" class="step-panel d-none">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4"><i class="bi bi-check2-circle me-2 text-success"></i>Langkah 4: Konfirmasi</h5>
                    <p class="text-muted mb-4">Periksa kembali data yang telah diisi sebelum membuat assessment.</p>

                    <!-- Card 1: Kategori & Judul -->
                    <div class="card mb-3">
                        <div class="card-header d-flex align-items-center">
                            <strong>Kategori &amp; Judul</strong>
                            <button type="button" class="btn btn-sm btn-outline-secondary ms-auto edit-from-confirm" data-step="1">
                                <i class="bi bi-pencil me-1"></i>Edit
                            </button>
                        </div>
                        <div class="card-body">
                            <p class="mb-1"><strong>Kategori:</strong> <span id="summary-category"></span></p>
                            <p class="mb-0"><strong>Judul:</strong> <span id="summary-title"></span></p>
                        </div>
                    </div>

                    <!-- Card 2: Peserta -->
                    <div class="card mb-3">
                        <div class="card-header d-flex align-items-center">
                            <strong>Peserta</strong>
                            <span class="badge bg-secondary ms-2" id="summary-peserta-count"></span>
                            <button type="button" class="btn btn-sm btn-outline-secondary ms-auto edit-from-confirm" data-step="2">
                                <i class="bi bi-pencil me-1"></i>Edit
                            </button>
                        </div>
                        <div class="card-body">
                            <span id="summary-peserta-list"></span>
                            <button type="button" id="summary-peserta-expand" class="btn btn-link btn-sm p-0 d-none ms-1"></button>
                            <span id="summary-peserta-extra" class="d-none"></span>
                        </div>
                    </div>

                    <!-- Card 3: Settings -->
                    <div class="card mb-3">
                        <div class="card-header d-flex align-items-center">
                            <strong>Settings</strong>
                            <button type="button" class="btn btn-sm btn-outline-secondary ms-auto edit-from-confirm" data-step="3">
                                <i class="bi bi-pencil me-1"></i>Edit
                            </button>
                        </div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-sm-4">Jadwal</dt><dd class="col-sm-8" id="summary-schedule"></dd>
                                <dt class="col-sm-4">Durasi</dt><dd class="col-sm-8" id="summary-duration"></dd>
                                <dt class="col-sm-4">Status</dt><dd class="col-sm-8" id="summary-status"></dd>
                                <dt class="col-sm-4">Token</dt><dd class="col-sm-8" id="summary-token"></dd>
                                <dt class="col-sm-4">Pass Percentage</dt><dd class="col-sm-8" id="summary-pass"></dd>
                                <dt class="col-sm-4">Tutup Ujian</dt><dd class="col-sm-8" id="summary-ewcd"></dd>
                                <dt class="col-sm-4">Valid Until</dt><dd class="col-sm-8" id="summary-validuntil"></dd>
                            </dl>
                        </div>
                    </div>

                    <!-- Navigation -->
                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn btn-outline-secondary btn-prev" id="btnPrev4">
                            <i class="bi bi-arrow-left me-1"></i>Sebelumnya
                        </button>
                        <div></div>
                    </div>

                    <!-- Submit -->
                    <button type="submit" class="btn btn-success btn-lg w-100 mt-3" id="btnSubmit">
                        <i class="bi bi-check-circle-fill me-2"></i>Buat Assessment
                    </button>
                </div>
            </div>
        </div>

    </form>

    <!-- Success Modal -->
    <div class="modal fade" id="successModal" tabindex="-1" aria-labelledby="successModalLabel" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title" id="successModalLabel">
                        <i class="bi bi-check-circle-fill me-2"></i> <span id="modal-header-text">Assessment Created Successfully</span>
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <table class="table table-borderless mb-3">
                        <tbody>
                            <tr>
                                <td class="fw-semibold text-muted" style="width:140px;">Title</td>
                                <td id="modal-title"></td>
                            </tr>
                            <tr>
                                <td class="fw-semibold text-muted">Category</td>
                                <td id="modal-category"></td>
                            </tr>
                            <tr>
                                <td class="fw-semibold text-muted">Schedule</td>
                                <td id="modal-schedule"></td>
                            </tr>
                            <tr>
                                <td class="fw-semibold text-muted">Duration</td>
                                <td id="modal-duration"></td>
                            </tr>
                            <tr>
                                <td class="fw-semibold text-muted">Status</td>
                                <td id="modal-status"></td>
                            </tr>
                            <tr>
                                <td class="fw-semibold text-muted">Token</td>
                                <td id="modal-token"></td>
                            </tr>
                        </tbody>
                    </table>
                    <h6 class="fw-semibold mb-2"><i class="bi bi-people-fill me-1"></i> Assigned Users</h6>
                    <div style="max-height:200px;overflow-y:auto;">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr><th>#</th><th>Name</th><th>Email</th><th>Action</th></tr>
                            </thead>
                            <tbody id="modal-users-tbody"></tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer d-flex justify-content-between">
                    <div>
                        <a id="modal-manage-btn" href="#" class="btn btn-primary">
                            <i class="bi bi-list-check me-1"></i> Manage Questions
                        </a>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" id="modal-create-another-btn">
                            <i class="bi bi-plus-circle me-1"></i> Create Another
                        </button>
                        <a href="@Url.Action("ManageAssessment", "AssessmentAdmin")" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Back to Manage Assessment &amp; Training
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div class="position-fixed top-0 end-0 p-3" style="z-index:1090;">
        <div id="successToast" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi bi-check-circle-fill me-1"></i> Assessment created successfully!
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

</div>

<script type="application/json" id="createdAssessmentData">@Html.Raw(ViewBag.CreatedAssessment ?? "")</script>

@section Scripts {
<script src="~/js/shared-loading.js"></script>
<script>
initFormLoading('createAssessmentForm', 'Menyimpan...');

// Helper: reset submit button loading state when validation fails
function resetCreateSubmitButton() {
    var btn = document.querySelector('#createAssessmentForm button[type="submit"]');
    if (btn) {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-check-circle me-1"></i> Buat Assessment';
    }
}

// ===== generateToken (global — used by inline onclick) =====
function generateToken() {
    var chars = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
    var token = "";
    for (var i = 0; i < 6; i++) {
        token += chars.charAt(Math.floor(Math.random() * chars.length));
    }
    document.getElementById('AccessToken').value = token;
}

// ===== Wizard Controller =====
(function WizardController() {
    var currentStep = 1;
    var visitedSteps = new Set([1]);
    var returnToConfirm = false;
    var passPercentageManuallySet = false;

    // ---- goToStep ----
    function goToStep(n) {
        currentStep = n;
        visitedSteps.add(n);

        // Show/hide panels
        document.querySelectorAll('.step-panel').forEach(function(panel) {
            panel.classList.add('d-none');
        });
        var target = document.getElementById('step-' + n);
        if (target) target.classList.remove('d-none');

        updatePills();
        updateBackToConfirmButton();

        if (n === 4) populateSummary();

        // Scroll to top of wizard
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // ---- updatePills ----
    function updatePills() {
        for (var i = 1; i <= 4; i++) {
            var pill = document.getElementById('pill-' + i);
            if (!pill) continue;

            // Reset classes
            pill.className = 'nav-link';
            pill.disabled = true;

            var icon = pill.querySelector('i');

            if (i === currentStep) {
                pill.classList.add('bg-primary', 'text-white', 'active');
                pill.disabled = false;
                if (icon) { icon.className = 'bi bi-circle-fill me-1'; }
            } else if (visitedSteps.has(i) && i < currentStep) {
                // Completed
                pill.classList.add('bg-success', 'text-white');
                pill.disabled = false;
                if (icon) { icon.className = 'bi bi-check-circle-fill me-1'; }
            } else if (visitedSteps.has(i)) {
                // Visited but not active
                pill.classList.add('text-primary', 'border', 'border-primary');
                pill.disabled = false;
                if (icon) { icon.className = 'bi bi-circle me-1'; }
            } else {
                // Pending
                pill.classList.add('text-muted', 'border');
                pill.disabled = true;
                if (icon) { icon.className = 'bi bi-circle me-1'; }
            }
        }
    }

    // ---- validateStep ----
    function validateStep(n) {
        var panel = document.getElementById('step-' + n);
        var valid = true;

        // Clear previous errors in this panel
        panel.querySelectorAll('.is-invalid').forEach(function(el) {
            el.classList.remove('is-invalid');
        });
        var step2err = document.getElementById('step2Error');
        if (step2err) step2err.classList.add('d-none');

        if (n === 1) {
            var cat = document.getElementById('Category');
            var title = document.getElementById('Title');
            if (!cat || !cat.value) {
                if (cat) cat.classList.add('is-invalid');
                valid = false;
            }
            if (!title || !title.value.trim()) {
                if (title) title.classList.add('is-invalid');
                valid = false;
            }
            // If Proton: track required
            var protonSection = document.getElementById('protonFieldsSection');
            if (protonSection && !protonSection.classList.contains('d-none')) {
                var track = document.getElementById('protonTrackSelect');
                if (!track || !track.value) {
                    if (track) track.classList.add('is-invalid');
                    valid = false;
                }
            }
        }

        if (n === 2) {
            var isProton = document.getElementById('Category') && document.getElementById('Category').value === 'Assessment Proton';
            var checkedBoxes;
            if (isProton) {
                checkedBoxes = document.querySelectorAll('#protonUserCheckboxContainer .user-checkbox:checked');
            } else {
                checkedBoxes = document.querySelectorAll('#userCheckboxContainer .user-checkbox:checked');
            }
            if (checkedBoxes.length === 0) {
                if (step2err) step2err.classList.remove('d-none');
                valid = false;
            }
        }

        if (n === 3) {
            var typeSelect = document.getElementById('assessmentTypeInput');
            var isPrePost = typeSelect && typeSelect.value === 'PrePostTest';

            if (isPrePost) {
                // Validate Pre-Post jadwal fields
                var preSchedule = document.getElementById('preSchedule');
                var preDuration = document.getElementById('preDurationMinutes');
                var preEwcd = document.getElementById('preExamWindowCloseDate');
                var postSchedule = document.getElementById('postSchedule');
                var postDuration = document.getElementById('postDurationMinutes');
                var postEwcd = document.getElementById('postExamWindowCloseDate');

                if (!preSchedule || !preSchedule.value) {
                    if (preSchedule) preSchedule.classList.add('is-invalid');
                    valid = false;
                }
                if (!preDuration || !preDuration.value || parseInt(preDuration.value) <= 0) {
                    if (preDuration) preDuration.classList.add('is-invalid');
                    valid = false;
                }
                if (!preEwcd || !preEwcd.value) {
                    if (preEwcd) preEwcd.classList.add('is-invalid');
                    valid = false;
                }
                if (!postSchedule || !postSchedule.value) {
                    if (postSchedule) postSchedule.classList.add('is-invalid');
                    valid = false;
                }
                if (!postDuration || !postDuration.value || parseInt(postDuration.value) <= 0) {
                    if (postDuration) postDuration.classList.add('is-invalid');
                    valid = false;
                }
                if (!postEwcd || !postEwcd.value) {
                    if (postEwcd) postEwcd.classList.add('is-invalid');
                    valid = false;
                }

                // D-06: PostSchedule must be after PreSchedule
                if (preSchedule && preSchedule.value && postSchedule && postSchedule.value) {
                    if (postSchedule.value <= preSchedule.value) {
                        postSchedule.classList.add('is-invalid');
                        valid = false;
                    }
                }

                // Status still required
                var status = document.getElementById('Status');
                if (!status || !status.value) {
                    if (status) status.classList.add('is-invalid');
                    valid = false;
                }
            } else {
                // Standard jadwal validation
                var schedDate = document.getElementById('schedDateInput');
                var schedTime = document.getElementById('schedTimeInput');
                var duration = document.getElementById('DurationMinutes');
                var status = document.getElementById('Status');
                var durWrapper = document.getElementById('durationFieldWrapper');

                if (!schedDate || !schedDate.value) {
                    if (schedDate) schedDate.classList.add('is-invalid');
                    valid = false;
                }
                if (!schedTime || !schedTime.value) {
                    if (schedTime) schedTime.classList.add('is-invalid');
                    valid = false;
                }
                // Skip duration for Tahun 3
                var isDurHidden = durWrapper && durWrapper.classList.contains('d-none');
                if (!isDurHidden) {
                    if (!duration || !duration.value || parseInt(duration.value) <= 0) {
                        if (duration) duration.classList.add('is-invalid');
                        valid = false;
                    }
                }
                if (!status || !status.value) {
                    if (status) status.classList.add('is-invalid');
                    valid = false;
                }

                // ExamWindowCloseDate validation
                var ewcdDate = document.getElementById('ewcdDateInput');
                var ewcdTime = document.getElementById('ewcdTimeInput');
                if (!ewcdDate || !ewcdDate.value) {
                    if (ewcdDate) ewcdDate.classList.add('is-invalid');
                    valid = false;
                }
                if (!ewcdTime || !ewcdTime.value) {
                    if (ewcdTime) ewcdTime.classList.add('is-invalid');
                    valid = false;
                }
            }
        }

        return valid;
    }

    // ---- populateSummary ----
    function populateSummary() {
        // Category & Title
        var catEl = document.getElementById('Category');
        var titleEl = document.getElementById('Title');
        var summCat = document.getElementById('summary-category');
        var summTitle = document.getElementById('summary-title');
        if (summCat) summCat.textContent = catEl ? (catEl.options[catEl.selectedIndex] ? catEl.options[catEl.selectedIndex].text : '') : '';
        if (summTitle) summTitle.textContent = titleEl ? titleEl.value : '';

        // Peserta
        var isProton = catEl && catEl.value === 'Assessment Proton';
        var checkboxes;
        if (isProton) {
            checkboxes = Array.from(document.querySelectorAll('#protonUserCheckboxContainer .user-checkbox:checked'));
        } else {
            checkboxes = Array.from(document.querySelectorAll('#userCheckboxContainer .user-checkbox:checked'));
        }

        var names = checkboxes.map(function(cb) {
            var label = document.querySelector('label[for="' + cb.id + '"]');
            if (label) {
                var strong = label.querySelector('strong');
                return strong ? strong.textContent : label.textContent.trim();
            }
            return cb.value;
        });

        var countBadge = document.getElementById('summary-peserta-count');
        if (countBadge) countBadge.textContent = names.length + ' peserta';

        var listEl = document.getElementById('summary-peserta-list');
        var expandBtn = document.getElementById('summary-peserta-expand');
        var extraEl = document.getElementById('summary-peserta-extra');

        if (listEl) {
            var first5 = names.slice(0, 5);
            listEl.textContent = first5.join(', ');
        }

        if (names.length > 5) {
            var remaining = names.slice(5);
            if (expandBtn) {
                expandBtn.classList.remove('d-none');
                expandBtn.textContent = '...dan ' + remaining.length + ' lainnya';
                expandBtn.onclick = function() {
                    if (extraEl) {
                        if (extraEl.classList.contains('d-none')) {
                            extraEl.textContent = ', ' + remaining.join(', ');
                            extraEl.classList.remove('d-none');
                            expandBtn.textContent = 'Sembunyikan';
                        } else {
                            extraEl.classList.add('d-none');
                            expandBtn.textContent = '...dan ' + remaining.length + ' lainnya';
                        }
                    }
                };
            }
        } else {
            if (expandBtn) expandBtn.classList.add('d-none');
            if (extraEl) extraEl.classList.add('d-none');
        }

        // Settings
        var typeSelect = document.getElementById('assessmentTypeInput');
        var isPrePost = typeSelect && typeSelect.value === 'PrePostTest';

        var summSchedule = document.getElementById('summary-schedule');
        var summDur = document.getElementById('summary-duration');
        var summEwcd = document.getElementById('summary-ewcd');

        if (isPrePost) {
            var preSched = document.getElementById('preSchedule');
            var postSched = document.getElementById('postSchedule');
            var preDur = document.getElementById('preDurationMinutes');
            var postDur = document.getElementById('postDurationMinutes');
            var preEwcd = document.getElementById('preExamWindowCloseDate');
            var postEwcd = document.getElementById('postExamWindowCloseDate');

            if (summSchedule) summSchedule.textContent =
                'Pre: ' + (preSched && preSched.value ? preSched.value.replace('T', ' ') : '-') +
                ' | Post: ' + (postSched && postSched.value ? postSched.value.replace('T', ' ') : '-');
            if (summDur) summDur.textContent =
                'Pre: ' + (preDur && preDur.value ? preDur.value + ' menit' : '-') +
                ' | Post: ' + (postDur && postDur.value ? postDur.value + ' menit' : '-');
            if (summEwcd) summEwcd.textContent =
                'Pre: ' + (preEwcd && preEwcd.value ? preEwcd.value.replace('T', ' ') : '-') +
                ' | Post: ' + (postEwcd && postEwcd.value ? postEwcd.value.replace('T', ' ') : '-');
        } else {
            var schedDate = document.getElementById('schedDateInput');
            var schedTime = document.getElementById('schedTimeInput');
            var schedVal = (schedDate && schedDate.value) ? schedDate.value : '';
            var timeVal = (schedTime && schedTime.value) ? schedTime.value : '08:00';
            if (summSchedule) summSchedule.textContent = schedVal ? (schedVal + ' ' + timeVal + ' WIB') : '-';

            var durEl = document.getElementById('DurationMinutes');
            if (summDur) summDur.textContent = (durEl && durEl.value) ? (durEl.value + ' menit') : '-';

            var ewcdDateEl = document.getElementById('ewcdDateInput');
            var ewcdTimeEl = document.getElementById('ewcdTimeInput');
            if (summEwcd) {
                summEwcd.textContent = (ewcdDateEl && ewcdDateEl.value) ? (ewcdDateEl.value + ' ' + (ewcdTimeEl ? ewcdTimeEl.value : '23:59')) : '-';
            }
        }

        var statusEl = document.getElementById('Status');
        var summStatus = document.getElementById('summary-status');
        if (summStatus) summStatus.textContent = statusEl ? statusEl.value : '-';

        var tokenEl = document.getElementById('IsTokenRequired');
        var accessTokenEl = document.getElementById('AccessToken');
        var summToken = document.getElementById('summary-token');
        if (summToken) {
            if (tokenEl && tokenEl.checked) {
                summToken.textContent = 'Ya — ' + (accessTokenEl ? accessTokenEl.value : '');
            } else {
                summToken.textContent = 'Tidak';
            }
        }

        var passEl = document.getElementById('PassPercentage');
        var summPass = document.getElementById('summary-pass');
        if (summPass) summPass.textContent = (passEl && passEl.value) ? (passEl.value + '%') : '-';

        var validUntilEl = document.getElementById('ValidUntil');
        var summValidUntil = document.getElementById('summary-validuntil');
        if (summValidUntil) {
            summValidUntil.textContent = (validUntilEl && validUntilEl.value) ? validUntilEl.value : 'Tidak ada';
        }
    }

    // ---- updateBackToConfirmButton ----
    function updateBackToConfirmButton() {
        document.querySelectorAll('.btnBackToConfirm').forEach(function(btn) {
            if (returnToConfirm) {
                btn.classList.remove('d-none');
            } else {
                btn.classList.add('d-none');
            }
        });
    }

    // ---- Event: Selanjutnya buttons ----
    document.getElementById('btnNext1').addEventListener('click', function() {
        if (validateStep(1)) goToStep(2);
    });
    document.getElementById('btnNext2').addEventListener('click', function() {
        if (validateStep(2)) goToStep(3);
    });
    document.getElementById('btnNext3').addEventListener('click', function() {
        if (validateStep(3)) goToStep(4);
    });

    // ---- Event: Sebelumnya buttons ----
    document.getElementById('btnPrev2').addEventListener('click', function() { goToStep(1); });
    document.getElementById('btnPrev3').addEventListener('click', function() { goToStep(2); });
    document.getElementById('btnPrev4').addEventListener('click', function() { goToStep(3); });

    // ---- Event: Kembali ke Konfirmasi ----
    document.querySelectorAll('.btnBackToConfirm').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var stepId = btn.id.replace('btnBackToConfirm-', '');
            if (validateStep(parseInt(stepId))) {
                returnToConfirm = false;
                goToStep(4);
            }
        });
    });

    // ---- Event: Edit from Konfirmasi ----
    document.querySelectorAll('.edit-from-confirm').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var step = parseInt(btn.getAttribute('data-step'));
            returnToConfirm = true;
            goToStep(step);
        });
    });

    // ---- Event: Pill clicks ----
    for (var pi = 1; pi <= 4; pi++) {
        (function(stepNum) {
            var pill = document.getElementById('pill-' + stepNum);
            if (pill) {
                pill.addEventListener('click', function() {
                    if (visitedSteps.has(stepNum) && stepNum !== currentStep) {
                        goToStep(stepNum);
                    }
                });
            }
        })(pi);
    }

    // ---- Event: Category change ----
    var categorySelect = document.getElementById('Category');
    var passPercentageInput = document.getElementById('PassPercentage');

    function applyProtonMode(isProton) {
        var protonSection = document.getElementById('protonFieldsSection');
        var userContainer = document.getElementById('userCheckboxContainer');
        var normalFilterBar = document.getElementById('normalFilterBar');
        var protonEligibleSection = document.getElementById('protonEligibleSection');
        var protonTrackSelect = document.getElementById('protonTrackSelect');
        var protonCbContainer = document.getElementById('protonUserCheckboxContainer');
        var durationWrapper = document.getElementById('durationFieldWrapper');
        var passWrapper = document.getElementById('passPercentageWrapper');

        if (isProton) {
            if (protonSection) protonSection.classList.remove('d-none');
            if (userContainer) userContainer.classList.add('d-none');
            if (normalFilterBar) normalFilterBar.classList.add('d-none');
            if (protonEligibleSection) protonEligibleSection.classList.remove('d-none');
        } else {
            if (protonSection) protonSection.classList.add('d-none');
            if (userContainer) userContainer.classList.remove('d-none');
            if (normalFilterBar) normalFilterBar.classList.remove('d-none');
            if (protonEligibleSection) protonEligibleSection.classList.add('d-none');
            if (durationWrapper) {
                durationWrapper.classList.remove('d-none');
                var durInput = durationWrapper.querySelector('input');
                if (durInput) durInput.removeAttribute('disabled');
            }
            if (passWrapper) passWrapper.classList.remove('d-none');
            // Reset proton state
            if (protonTrackSelect) protonTrackSelect.value = '';
            if (protonCbContainer) { protonCbContainer.innerHTML = ''; protonCbContainer.classList.add('d-none'); }
            // Uncheck all proton checkboxes
            if (protonCbContainer) {
                protonCbContainer.querySelectorAll('.user-checkbox').forEach(function(cb) { cb.checked = false; });
            }
        }
        // Uncheck normal checkboxes when switching to proton and vice versa
        if (isProton) {
            document.querySelectorAll('#userCheckboxContainer .user-checkbox').forEach(function(cb) { cb.checked = false; });
        } else {
            if (protonCbContainer) {
                protonCbContainer.querySelectorAll('.user-checkbox').forEach(function(cb) { cb.checked = false; });
            }
        }
    }

    if (categorySelect) {
        categorySelect.addEventListener('change', function() {
            var isProton = this.value === 'Assessment Proton';
            applyProtonMode(isProton);

            // Update PassPercentage default from data-pass-percentage
            var selected = this.options[this.selectedIndex];
            var defaultPct = selected ? parseInt(selected.getAttribute('data-pass-percentage') || '0') : 0;
            if (!passPercentageManuallySet && defaultPct > 0 && passPercentageInput) {
                passPercentageInput.value = defaultPct;
            }
        });

        // On load, apply if already selected
        if (categorySelect.value === 'Assessment Proton') {
            applyProtonMode(true);
        }
    }

    // ---- Event: PassPercentage manual change ----
    if (passPercentageInput) {
        passPercentageInput.addEventListener('input', function() {
            passPercentageManuallySet = true;
        });
    }

    // ---- Event: Token toggle ----
    var tokenCheckbox = document.getElementById('IsTokenRequired');
    var tokenSection = document.getElementById('tokenSection');

    function toggleTokenSection() {
        if (!tokenCheckbox || !tokenSection) return;
        var accessToken = document.getElementById('AccessToken');
        if (tokenCheckbox.checked) {
            tokenSection.classList.remove('d-none');
            if (accessToken) accessToken.required = true;
        } else {
            tokenSection.classList.add('d-none');
            if (accessToken) { accessToken.value = ''; accessToken.required = false; }
        }
    }

    if (tokenCheckbox) {
        tokenCheckbox.addEventListener('change', toggleTokenSection);
        toggleTokenSection(); // Init on load
    }

    // ---- Event: Section filter + text search ----
    var sectionFilter = document.getElementById('sectionFilter');
    var searchInput = document.getElementById('userSearchInput');

    function applyFilters() {
        if (!searchInput || !sectionFilter) return;
        var query = searchInput.value.toLowerCase();
        var selectedSection = sectionFilter.value;

        document.querySelectorAll('#userCheckboxContainer .user-check-item').forEach(function(item) {
            var name = (item.dataset.name || '').toLowerCase();
            var email = (item.dataset.email || '').toLowerCase();
            var section = item.dataset.section || '';

            var sectionMatch = true;
            if (selectedSection === '__none__') {
                sectionMatch = (section === '');
            } else if (selectedSection !== '') {
                sectionMatch = (section === selectedSection);
            }

            var textMatch = (query === '') || name.includes(query) || email.includes(query);
            item.style.display = (sectionMatch && textMatch) ? '' : 'none';
        });
    }

    if (searchInput) searchInput.addEventListener('input', applyFilters);
    if (sectionFilter) sectionFilter.addEventListener('change', applyFilters);

    var clearBtn = document.getElementById('clearSearchBtn');
    if (clearBtn) clearBtn.addEventListener('click', function() {
        if (searchInput) searchInput.value = '';
        applyFilters();
    });

    // ---- Event: Select All / Deselect All ----
    var selectAllBtn = document.getElementById('selectAllBtn');
    var deselectAllBtn = document.getElementById('deselectAllBtn');

    if (selectAllBtn) selectAllBtn.addEventListener('click', function() {
        document.querySelectorAll('#userCheckboxContainer .user-check-item').forEach(function(item) {
            if (item.style.display !== 'none') {
                item.querySelector('.user-checkbox').checked = true;
            }
        });
        updateSelectedCount();
    });

    if (deselectAllBtn) deselectAllBtn.addEventListener('click', function() {
        document.querySelectorAll('#userCheckboxContainer .user-check-item').forEach(function(item) {
            if (item.style.display !== 'none') {
                item.querySelector('.user-checkbox').checked = false;
            }
        });
        updateSelectedCount();
    });

    // ---- Selected count badge ----
    function updateSelectedCount() {
        var catEl = document.getElementById('Category');
        var isProton = catEl && catEl.value === 'Assessment Proton';
        var count;
        if (isProton) {
            count = document.querySelectorAll('#protonUserCheckboxContainer .user-checkbox:checked').length;
        } else {
            count = document.querySelectorAll('#userCheckboxContainer .user-checkbox:checked').length;
        }
        var badge = document.getElementById('selectedCountBadge');
        if (badge) badge.textContent = count + ' terpilih';
    }

    var userContainer = document.getElementById('userCheckboxContainer');
    if (userContainer) userContainer.addEventListener('change', updateSelectedCount);
    updateSelectedCount();

    // ---- Form submit: schedule combiner + Proton Tahun 3 duration ----
    var form = document.getElementById('createAssessmentForm');
    if (form) {
        form.addEventListener('submit', function(e) {
            // Proton Tahun 3: set DurationMinutes=0
            var catEl = document.getElementById('Category');
            if (catEl && catEl.value === 'Assessment Proton') {
                var durWrapper = document.getElementById('durationFieldWrapper');
                if (durWrapper && durWrapper.classList.contains('d-none')) {
                    var durInput = durWrapper.querySelector('input[name="DurationMinutes"]');
                    if (durInput) durInput.value = '0';
                }
            }
            // Combine schedule date + time
            var schedDateInput = document.getElementById('schedDateInput');
            var schedTimeInput = document.getElementById('schedTimeInput');
            var schedHidden = document.getElementById('schedHidden');
            if (schedDateInput && schedDateInput.value && schedTimeInput && schedHidden) {
                schedHidden.value = schedDateInput.value + 'T' + (schedTimeInput.value || '08:00') + ':00';
            }

            // Combine ExamWindowCloseDate date + time
            var ewcdDateInput = document.getElementById('ewcdDateInput');
            var ewcdTimeInput = document.getElementById('ewcdTimeInput');
            var ewcdHidden = document.getElementById('ewcdHidden');
            if (ewcdDateInput && ewcdDateInput.value && ewcdTimeInput && ewcdHidden) {
                ewcdHidden.value = ewcdDateInput.value + 'T' + (ewcdTimeInput.value || '23:59') + ':00';
            }

            // Validate ExamWindowCloseDate >= Schedule (skip for Pre-Post — has per-phase EWCD)
            var typeSelect = document.getElementById('assessmentTypeInput');
            var isPrePost = typeSelect && typeSelect.value === 'PrePostTest';
            if (!isPrePost) {
                var schedVal = schedHidden ? schedHidden.value : '';
                var ewcdVal = ewcdHidden ? ewcdHidden.value : '';
                if (schedVal && ewcdVal && new Date(ewcdVal) < new Date(schedVal)) {
                    alert('Tanggal tutup ujian tidak boleh sebelum tanggal jadwal.');
                    resetCreateSubmitButton();
                    e.preventDefault();
                    e.stopPropagation();
                    return false;
                }
            }
        }, true); // capture phase
    }

    // ---- Init ----
    goToStep(1);
})();

// ===== Proton Track AJAX =====
(function() {
    var protonTrackSelect = document.getElementById('protonTrackSelect');
    var protonEligibleStatus = document.getElementById('protonEligibleStatus');
    var protonCbContainer = document.getElementById('protonUserCheckboxContainer');
    var durationWrapper = document.getElementById('durationFieldWrapper');
    var passWrapper = document.getElementById('passPercentageWrapper');

    if (!protonTrackSelect) return;

    // Event delegation: listen once on container, works for dynamically added checkboxes
    if (protonCbContainer) {
        protonCbContainer.addEventListener('change', function() {
            var count = protonCbContainer.querySelectorAll('.user-checkbox:checked').length;
            var badge = document.getElementById('selectedCountBadge');
            if (badge) badge.textContent = count + ' terpilih';
        });
    }

    protonTrackSelect.addEventListener('change', function() {
        var trackId = parseInt(this.value) || 0;
        var selectedOption = this.options[this.selectedIndex];
        var tahun = selectedOption ? (selectedOption.dataset.tahun || '') : '';

        // Tahun 3 = interview: hide Duration + PassPercentage
        var isTahun3 = tahun === 'Tahun 3';
        if (durationWrapper) {
            durationWrapper.classList.toggle('d-none', isTahun3);
            var durInput = durationWrapper.querySelector('input');
            if (durInput) {
                if (isTahun3) durInput.removeAttribute('required');
                else durInput.removeAttribute('required'); // wizard handles validation
            }
        }
        if (passWrapper) {
            passWrapper.classList.toggle('d-none', isTahun3);
        }

        if (!trackId) {
            if (protonEligibleStatus) protonEligibleStatus.parentElement.classList.add('d-none');
            return;
        }

        // Show eligible section and load
        var protonEligibleSection = document.getElementById('protonEligibleSection');
        if (protonEligibleSection) protonEligibleSection.classList.remove('d-none');
        if (protonEligibleStatus) {
            protonEligibleStatus.classList.remove('d-none');
            protonEligibleStatus.innerHTML = '<i class="bi bi-hourglass-split me-1"></i>Memuat coachee eligible...';
        }
        if (protonCbContainer) { protonCbContainer.innerHTML = ''; protonCbContainer.classList.add('d-none'); }

        fetch(appUrl('/Admin/GetEligibleCoachees?protonTrackId=' + trackId))
            .then(function(r) { return r.json(); })
            .then(function(users) {
                if (!protonCbContainer || !protonEligibleStatus) return;
                if (!users || users.length === 0) {
                    protonEligibleStatus.innerHTML = '<i class="bi bi-info-circle me-1"></i>Tidak ada coachee eligible untuk track ini. Semua deliverable harus Approved.';
                    protonCbContainer.classList.add('d-none');
                } else {
                    protonEligibleStatus.innerHTML = '<i class="bi bi-check-circle text-success me-1"></i>' + users.length + ' coachee eligible ditemukan.';
                    protonCbContainer.innerHTML = '';
                    users.forEach(function(u) {
                        var div = document.createElement('div');
                        div.className = 'form-check user-check-item mb-1';
                        div.dataset.name = u.fullName || '';
                        div.dataset.section = u.section || '';
                        div.innerHTML = '<input class="form-check-input user-checkbox" type="checkbox" name="UserIds" value="' + u.id + '" id="pu_' + u.id + '" />'
                            + '<label class="form-check-label" for="pu_' + u.id + '"><strong>' + (u.fullName || '-') + '</strong> <span class="text-muted">(' + (u.email || '') + ')</span></label>';
                        protonCbContainer.appendChild(div);
                    });
                    protonCbContainer.classList.remove('d-none');
                }
            })
            .catch(function() {
                if (protonEligibleStatus) protonEligibleStatus.innerHTML = '<i class="bi bi-exclamation-triangle text-danger me-1"></i>Gagal memuat daftar coachee.';
            });
    });
})();

// ===== Auto-show success modal =====
(function() {
    var el = document.getElementById('createdAssessmentData');
    var createdData = el ? el.textContent.trim() : '';
    if (!createdData) return;
    try {
        var a = JSON.parse(createdData);

        document.getElementById('modal-header-text').textContent = a.Count + ' assessment(s) created successfully';
        document.getElementById('modal-title').textContent = a.Title;

        var categoryBadge = document.createElement('span');
        categoryBadge.className = 'badge bg-primary';
        categoryBadge.textContent = a.Category;
        var categoryEl = document.getElementById('modal-category');
        categoryEl.textContent = '';
        categoryEl.appendChild(categoryBadge);

        document.getElementById('modal-schedule').textContent = a.Schedule;
        document.getElementById('modal-duration').textContent = a.DurationMinutes + ' minutes';

        var statusBadge = document.createElement('span');
        statusBadge.className = 'badge bg-success';
        statusBadge.textContent = a.Status;
        var statusEl = document.getElementById('modal-status');
        statusEl.textContent = '';
        statusEl.appendChild(statusBadge);

        var tokenEl = document.getElementById('modal-token');
        tokenEl.textContent = '';
        if (a.IsTokenRequired && a.AccessToken) {
            var icon = document.createElement('i');
            icon.className = 'bi bi-shield-lock-fill text-primary me-1';
            var code = document.createElement('code');
            code.className = 'fs-6';
            code.textContent = a.AccessToken;
            tokenEl.appendChild(icon);
            tokenEl.appendChild(document.createTextNode(' '));
            tokenEl.appendChild(code);
        } else {
            var span = document.createElement('span');
            span.className = 'text-muted';
            span.textContent = 'Not Required';
            tokenEl.appendChild(span);
        }

        var tbody = document.getElementById('modal-users-tbody');
        tbody.textContent = '';
        if (a.Sessions && a.Sessions.length > 0) {
            a.Sessions.forEach(function(s, idx) {
                var tr = document.createElement('tr');
                var tdNum = document.createElement('td'); tdNum.textContent = idx + 1; tr.appendChild(tdNum);
                var tdName = document.createElement('td'); tdName.textContent = s.UserName; tr.appendChild(tdName);
                var tdEmail = document.createElement('td'); tdEmail.className = 'text-muted'; tdEmail.textContent = s.UserEmail; tr.appendChild(tdEmail);
                var tdAction = document.createElement('td');
                var link = document.createElement('a');
                link.href = basePath + '/Admin/ManageQuestions?id=' + s.Id;
                link.className = 'btn btn-sm btn-outline-primary';
                link.textContent = 'Manage Questions';
                tdAction.appendChild(link); tr.appendChild(tdAction);
                tbody.appendChild(tr);
            });
            var firstId = a.Sessions[0].Id;
            var manageBtn = document.getElementById('modal-manage-btn');
            manageBtn.href = basePath + '/Admin/ManageQuestions?id=' + firstId;
            if (a.Sessions.length > 1) {
                manageBtn.innerHTML = '<i class="bi bi-list-check me-1"></i> Manage Questions (First)';
            }
        }

        var modal = new bootstrap.Modal(document.getElementById('successModal'));
        modal.show();

        var toast = new bootstrap.Toast(document.getElementById('successToast'), { delay: 4000 });
        toast.show();

        document.getElementById('modal-create-another-btn').addEventListener('click', function() {
            var form = document.getElementById('createAssessmentForm');
            if (form) form.reset();
            var tokenSec = document.getElementById('tokenSection');
            if (tokenSec) tokenSec.classList.add('d-none');
            document.querySelectorAll('.user-checkbox').forEach(function(cb) { cb.checked = false; });
            var badge = document.getElementById('selectedCountBadge');
            if (badge) badge.textContent = '0 terpilih';
            var si = document.getElementById('userSearchInput');
            if (si) si.value = '';
            var sf = document.getElementById('sectionFilter');
            if (sf) sf.value = '';
            document.querySelectorAll('#userCheckboxContainer .user-check-item').forEach(function(item) { item.style.display = ''; });
        });
    } catch(e) {
        console.error('Error parsing created assessment data:', e);
    }
})();
</script>
