@model HcPortal.Models.ManageUserViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Config

@{
    ViewData["Title"] = "Tambah Pekerja Baru";
    var isAdMode = Config.GetValue<bool>("Authentication:UseActiveDirectory", false);
}

<div class="container py-4" style="max-width: 800px;">

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Admin")">Kelola Data</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("ManageWorkers", "Admin")">Manajemen Pekerja</a></li>
            <li class="breadcrumb-item active" aria-current="page">Tambah Pekerja</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-person-plus-fill me-2 text-primary"></i>Tambah Pekerja Baru
            </h2>
            <p class="text-muted mb-0">Isi data lengkap untuk membuat akun pekerja baru</p>
        </div>
        <a href="@Url.Action("ManageWorkers", "Admin")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Kembali
        </a>
    </div>

    <!-- Validation Summary -->
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <strong>Terdapat kesalahan:</strong>
            <ul class="mb-0 mt-1">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form asp-action="CreateWorker" asp-controller="Admin" method="post" id="createWorkerForm">
        @Html.AntiForgeryToken()

        <!-- Personal Information -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-primary bg-opacity-10 border-0">
                <h6 class="mb-0 fw-bold text-primary">
                    <i class="bi bi-person me-2"></i>Informasi Pribadi
                </h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="FullName" class="form-label fw-semibold"></label>
                        <input asp-for="FullName" class="form-control @(isAdMode ? "bg-light" : "")"
                               placeholder="Masukkan nama lengkap"
                               readonly="@(isAdMode ? "readonly" : null)" />
                        @if (isAdMode)
                        {
                            <div class="form-text text-info"><i class="bi bi-info-circle me-1"></i>Dikelola oleh AD — akan disinkronkan saat login</div>
                        }
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" class="form-control @(isAdMode ? "bg-light" : "")"
                               placeholder="contoh@pertamina.com"
                               readonly="@(isAdMode ? "readonly" : null)" />
                        @if (isAdMode)
                        {
                            <div class="form-text text-info"><i class="bi bi-info-circle me-1"></i>Dikelola oleh AD — akan disinkronkan saat login</div>
                        }
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="NIP" class="form-label fw-semibold"></label>
                        <input asp-for="NIP" class="form-control" placeholder="Nomor Induk Pekerja" />
                        <span asp-validation-for="NIP" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="JoinDate" class="form-label fw-semibold"></label>
                        <input asp-for="JoinDate" type="date" class="form-control" />
                        <span asp-validation-for="JoinDate" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Organization -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-success bg-opacity-10 border-0">
                <h6 class="mb-0 fw-bold text-success">
                    <i class="bi bi-building me-2"></i>Organisasi
                </h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Position" class="form-label fw-semibold"></label>
                        <input asp-for="Position" class="form-control" placeholder="Contoh: Operator, Supervisor, dll" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Directorate" class="form-label fw-semibold"></label>
                        <input asp-for="Directorate" class="form-control" placeholder="Contoh: CSU Process" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Section" class="form-label fw-semibold"></label>
                        <select asp-for="Section" class="form-select" id="sectionSelect">
                            <option value="">-- Pilih Bagian --</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Unit" class="form-label fw-semibold"></label>
                        <select asp-for="Unit" class="form-select" id="unitSelect">
                            <option value="">-- Pilih Unit --</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Role & Credentials -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-warning bg-opacity-10 border-0">
                <h6 class="mb-0 fw-bold text-warning">
                    <i class="bi bi-shield-lock me-2"></i>Role & Kredensial
                </h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-12">
                        <label asp-for="Role" class="form-label fw-semibold"></label>
                        <select asp-for="Role" class="form-select">
                            @foreach (var role in HcPortal.Models.UserRoles.AllRoles)
                            {
                                <option value="@role">@role (Level @HcPortal.Models.UserRoles.GetRoleLevel(role))</option>
                            }
                        </select>
                        <div class="form-text">Role menentukan hak akses dan tampilan default user</div>
                    </div>
                    @if (!isAdMode)
                    {
                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="Password" type="password" class="form-control" id="passwordField" placeholder="Minimal 6 karakter" />
                                <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('passwordField', this)">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="ConfirmPassword" type="password" class="form-control" id="confirmPasswordField" placeholder="Ketik ulang password" />
                                <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('confirmPasswordField', this)">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    }
                    else
                    {
                        <div class="col-12">
                            <div class="alert alert-info py-2 mb-0">
                                <i class="bi bi-info-circle me-2"></i>
                                <small>Password dikelola melalui portal Pertamina. Sistem akan membuat password acak untuk akun ini.</small>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Submit Buttons -->
        <div class="d-flex justify-content-end gap-2">
            <a href="@Url.Action("ManageWorkers", "Admin")" class="btn btn-light px-4">Batal</a>
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-check-lg me-2"></i>Simpan Pekerja
            </button>
        </div>
    </form>
</div>

<script>
    // --- Section → Unit Cascading ---
    const sectionUnits = @Html.Raw(ViewBag.SectionUnitsJson ?? "{}");

    const sectionSelect = document.getElementById('sectionSelect');
    const unitSelect = document.getElementById('unitSelect');
    const currentUnit = "@(Model.Unit ?? "")";

    // Populate Bagian dropdown dari DB
    Object.keys(sectionUnits).forEach(section => {
        const opt = document.createElement('option');
        opt.value = section;
        opt.textContent = section;
        sectionSelect.appendChild(opt);
    });

    // Restore selected section if returning from validation error
    const currentSection = "@(Model.Section ?? "")";
    if (currentSection) {
        sectionSelect.value = currentSection;
        updateUnits(currentSection);
    }

    sectionSelect.addEventListener('change', function () {
        updateUnits(this.value);
    });

    function updateUnits(section) {
        unitSelect.innerHTML = '<option value="">-- Pilih Unit --</option>';
        if (section && sectionUnits[section]) {
            sectionUnits[section].forEach(unit => {
                const opt = document.createElement('option');
                opt.value = unit;
                opt.textContent = unit;
                if (unit === currentUnit) opt.selected = true;
                unitSelect.appendChild(opt);
            });
        }
    }

    // Toggle password visibility
    function togglePassword(fieldId, btn) {
        const field = document.getElementById(fieldId);
        const icon = btn.querySelector('i');
        if (field.type === 'password') {
            field.type = 'text';
            icon.className = 'bi bi-eye-slash';
        } else {
            field.type = 'password';
            icon.className = 'bi bi-eye';
        }
    }
</script>
