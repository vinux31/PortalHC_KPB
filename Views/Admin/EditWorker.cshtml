@model HcPortal.Models.ManageUserViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Config

@{
    ViewData["Title"] = "Edit Data Pekerja";
    var isAdMode = Config.GetValue<bool>("Authentication:UseActiveDirectory", false);
}

<div class="container py-4" style="max-width: 800px;">

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Admin")">Kelola Data</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("ManageWorkers", "Worker")">Manajemen Pekerja</a></li>
            <li class="breadcrumb-item active" aria-current="page">Edit Pekerja</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-pencil-square me-2 text-primary"></i>Edit Data Pekerja
            </h2>
            <p class="text-muted mb-0">Perbarui informasi pekerja <strong>@Model.FullName</strong></p>
        </div>
        <a href="@Url.Action("ManageWorkers", "Worker")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Kembali
        </a>
    </div>

    <!-- Validation Summary -->
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <strong>Terdapat kesalahan:</strong>
            <ul class="mb-0 mt-1">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form asp-action="EditWorker" asp-controller="Worker" method="post" id="editWorkerForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <!-- User ID Badge -->
        <div class="alert alert-light border d-flex align-items-center mb-4">
            <i class="bi bi-fingerprint me-2 text-muted"></i>
            <span class="small text-muted">User ID: <code>@Model.Id</code></span>
        </div>

        <!-- Personal Information -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-primary bg-opacity-10 border-0">
                <h6 class="mb-0 fw-bold text-primary">
                    <i class="bi bi-person me-2"></i>Informasi Pribadi
                </h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="FullName" class="form-label fw-semibold"></label>
                        <input asp-for="FullName" class="form-control @(isAdMode ? "bg-light" : "")"
                               readonly="@(isAdMode ? "readonly" : null)" />
                        @if (isAdMode)
                        {
                            <div class="form-text text-info"><i class="bi bi-info-circle me-1"></i>Dikelola oleh AD — akan disinkronkan saat login</div>
                        }
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" class="form-control @(isAdMode ? "bg-light" : "")"
                               readonly="@(isAdMode ? "readonly" : null)" />
                        @if (isAdMode)
                        {
                            <div class="form-text text-info"><i class="bi bi-info-circle me-1"></i>Dikelola oleh AD — akan disinkronkan saat login</div>
                        }
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="NIP" class="form-label fw-semibold"></label>
                        <input asp-for="NIP" class="form-control" />
                        <span asp-validation-for="NIP" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="JoinDate" class="form-label fw-semibold"></label>
                        <input asp-for="JoinDate" type="date" class="form-control" />
                        <span asp-validation-for="JoinDate" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Organization -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-success bg-opacity-10 border-0">
                <h6 class="mb-0 fw-bold text-success">
                    <i class="bi bi-building me-2"></i>Organisasi
                </h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Position" class="form-label fw-semibold"></label>
                        <input asp-for="Position" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Directorate" class="form-label fw-semibold"></label>
                        <input asp-for="Directorate" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Section" class="form-label fw-semibold"></label>
                        <select asp-for="Section" class="form-select" id="sectionSelect">
                            <option value="">-- Pilih Bagian --</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Unit" class="form-label fw-semibold"></label>
                        <select asp-for="Unit" class="form-select" id="unitSelect">
                            <option value="">-- Pilih Unit --</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Role & Password -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-warning bg-opacity-10 border-0">
                <h6 class="mb-0 fw-bold text-warning">
                    <i class="bi bi-shield-lock me-2"></i>Role & Password
                </h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-12">
                        <label asp-for="Role" class="form-label fw-semibold"></label>
                        <select asp-for="Role" class="form-select">
                            @foreach (var role in HcPortal.Models.UserRoles.AllRoles)
                            {
                                <option value="@role">@role (Level @HcPortal.Models.UserRoles.GetRoleLevel(role))</option>
                            }
                        </select>
                        <div class="form-text">Mengubah role akan otomatis mengubah level akses dan tampilan default user</div>
                    </div>
                    @if (!isAdMode)
                    {
                        <div class="col-12">
                            <hr class="my-2" />
                            <div class="form-text text-info mb-2">
                                <i class="bi bi-info-circle me-1"></i>
                                Kosongkan kolom password jika tidak ingin mengubah password saat ini
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label fw-semibold">Password Baru</label>
                            <div class="input-group">
                                <input asp-for="Password" type="password" class="form-control" id="passwordField" placeholder="Biarkan kosong jika tidak diubah" autocomplete="new-password" />
                                <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('passwordField', this)">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold">Konfirmasi Password Baru</label>
                            <div class="input-group">
                                <input asp-for="ConfirmPassword" type="password" class="form-control" id="confirmPasswordField" placeholder="Ketik ulang password baru" autocomplete="new-password" />
                                <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('confirmPasswordField', this)">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    }
                    else
                    {
                        <div class="col-12">
                            <div class="alert alert-info py-2 mb-0">
                                <i class="bi bi-info-circle me-2"></i>
                                <small>Password dikelola melalui portal Pertamina. Sistem akan membuat password acak untuk akun ini.</small>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Submit Buttons -->
        <div class="d-flex justify-content-end gap-2">
            <a href="@Url.Action("ManageWorkers", "Worker")" class="btn btn-light px-4">Batal</a>
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-check-lg me-2"></i>Simpan Perubahan
            </button>
        </div>
    </form>
</div>

<script src="~/js/shared-cascade.js"></script>
<script src="~/js/shared-loading.js"></script>
<script>
    initSectionUnitCascade({
        sectionUnits: @Html.Raw(ViewBag.SectionUnitsJson ?? "{}"),
        sectionId: 'sectionSelect',
        unitId: 'unitSelect',
        currentSection: "@(Model.Section ?? "")",
        currentUnit: "@(Model.Unit ?? "")"
    });
    initFormLoading('editWorkerForm', 'Menyimpan...');

    // Password opsional saat edit:
    // 1. Hapus client-side validation attributes
    // 2. Kosongkan password fields saat submit jika user tidak sengaja edit (autofill protection)
    (function () {
        var pwd = document.getElementById('passwordField');
        var cpwd = document.getElementById('confirmPasswordField');
        if (!pwd || !cpwd) return;

        // Hapus data-val-* agar client-side validation tidak blokir submit
        [pwd, cpwd].forEach(function (el) {
            var toRemove = [];
            for (var i = 0; i < el.attributes.length; i++) {
                if (el.attributes[i].name.startsWith('data-val')) {
                    toRemove.push(el.attributes[i].name);
                }
            }
            toRemove.forEach(function (a) { el.removeAttribute(a); });
        });

        // Track apakah user sengaja mengetik di password fields
        var userTouchedPassword = false;
        pwd.addEventListener('input', function () { userTouchedPassword = true; });
        cpwd.addEventListener('input', function () { userTouchedPassword = true; });

        // Saat submit: jika user tidak pernah mengetik password, kosongkan fields
        // (mencegah browser autofill yang diam-diam mengisi password)
        document.getElementById('editWorkerForm').addEventListener('submit', function () {
            if (!userTouchedPassword) {
                pwd.value = '';
                cpwd.value = '';
            }
        });
    })();
</script>
