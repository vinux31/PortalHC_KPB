@model List<HcPortal.Models.AuditLog>
@{
    ViewData["Title"] = "Impersonate";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">Kelola Data</a></li>
        <li class="breadcrumb-item active">Impersonate</li>
    </ol>
</nav>

<h4 class="mb-4"><i class="bi bi-incognito me-2"></i>Impersonate</h4>

<div class="row g-4">
    <!-- Kolom Kiri: Role Cards + Info Panel -->
    <div class="col-lg-5">
        <!-- Card: View As HC -->
        <form asp-action="StartImpersonation" asp-controller="Admin" method="post" class="mb-3">
            @Html.AntiForgeryToken()
            <input type="hidden" name="mode" value="role" />
            <input type="hidden" name="targetRole" value="HC" />
            <div class="card border-primary" role="button" onclick="if(confirm('Mulai impersonation sebagai HC?')) this.closest('form').submit();" style="cursor:pointer;">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-person-badge fs-2 text-primary me-3"></i>
                    <div>
                        <h6 class="card-title mb-0">View As HC</h6>
                        <small class="text-muted">Lihat portal sebagai peran HC</small>
                    </div>
                    <i class="bi bi-chevron-right ms-auto text-muted"></i>
                </div>
            </div>
        </form>

        <!-- Card: View As User -->
        <form asp-action="StartImpersonation" asp-controller="Admin" method="post" class="mb-3">
            @Html.AntiForgeryToken()
            <input type="hidden" name="mode" value="role" />
            <input type="hidden" name="targetRole" value="User" />
            <div class="card border-success" role="button" onclick="if(confirm('Mulai impersonation sebagai User?')) this.closest('form').submit();" style="cursor:pointer;">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-person fs-2 text-success me-3"></i>
                    <div>
                        <h6 class="card-title mb-0">View As User</h6>
                        <small class="text-muted">Lihat portal sebagai peran User</small>
                    </div>
                    <i class="bi bi-chevron-right ms-auto text-muted"></i>
                </div>
            </div>
        </form>

        <!-- Info Panel -->
        <div class="card">
            <div class="card-body">
                <h6 class="card-title"><i class="bi bi-info-circle me-1"></i> Informasi Impersonation</h6>

                <div class="alert alert-info small mb-3">
                    <ul class="mb-0 ps-3">
                        <li>Mode <strong>read-only</strong> — tidak bisa mengubah data</li>
                        <li>Sesi impersonation maksimal <strong>30 menit</strong></li>
                        <li>Tidak bisa impersonate sesama Admin</li>
                        <li>Semua aktivitas dicatat di audit log</li>
                    </ul>
                </div>

                <h6 class="small fw-bold text-muted mb-2">Riwayat Impersonation</h6>
                @if (Model.Count == 0)
                {
                    <p class="text-muted small fst-italic">Belum ada riwayat impersonation.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover small mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Admin</th>
                                    <th>Aksi</th>
                                    <th>Keterangan</th>
                                    <th>Waktu</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in Model)
                                {
                                    <tr>
                                        <td>@log.ActorName</td>
                                        <td>
                                            @if (log.ActionType == "ImpersonateStart")
                                            {
                                                <span class="badge bg-primary">Start</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">End</span>
                                            }
                                        </td>
                                        <td>@log.Description</td>
                                        <td class="text-nowrap">@log.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Kolom Kanan: Search User -->
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-search me-1"></i> Impersonate User Tertentu</h6>
            </div>
            <div class="card-body">
                <input type="text" id="imp-search" class="form-control"
                       placeholder="Ketik nama atau NIP..." autocomplete="off" />
                <div id="imp-results" class="list-group mt-2" style="max-height:400px; overflow-y:auto;"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function() {
    function esc(s) {
        var d = document.createElement('div');
        d.appendChild(document.createTextNode(s || ''));
        return d.innerHTML;
    }
    var searchInput = document.getElementById('imp-search');
    if (!searchInput) return;
    var resultsDiv = document.getElementById('imp-results');
    var debounceTimer;

    searchInput.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        var q = this.value.trim();
        if (q.length < 2) { resultsDiv.innerHTML = ''; return; }
        debounceTimer = setTimeout(function() {
            fetch(appUrl('/Admin/SearchUsersApi?q=' + encodeURIComponent(q)))
                .then(function(r) { return r.json(); })
                .then(function(users) {
                    if (users.length === 0) {
                        resultsDiv.innerHTML = '<div class="list-group-item text-muted fst-italic small">Tidak ada user ditemukan — coba kata kunci atau NIP lain</div>';
                        return;
                    }
                    resultsDiv.innerHTML = users.map(function(u) {
                        return '<button type="button" class="list-group-item list-group-item-action py-2 px-3" data-userid="' + esc(u.id) + '">'
                            + '<strong>' + esc(u.fullName) + '</strong>' + (u.nip ? ' <small class="text-muted">' + esc(u.nip) + '</small>' : '')
                            + ' <span class="badge bg-secondary">' + esc(u.selectedView) + '</span></button>';
                    }).join('');
                });
        }, 300);
    });

    resultsDiv.addEventListener('click', function(e) {
        var btn = e.target.closest('[data-userid]');
        if (!btn) return;
        if (!confirm('Impersonate user ' + btn.textContent.trim() + '?')) return;
        var form = document.createElement('form');
        form.method = 'POST';
        form.action = appUrl('/Admin/StartImpersonation');
        form.innerHTML = '<input name="mode" value="user"><input name="targetUserId" value="' + btn.dataset.userid + '">'
            + '<input name="__RequestVerificationToken" value="' + document.querySelector('input[name=__RequestVerificationToken]').value + '">';
        document.body.appendChild(form);
        form.submit();
    });
})();
</script>
}
