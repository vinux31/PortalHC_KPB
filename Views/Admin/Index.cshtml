@{
    ViewData["Title"] = "Kelola Data";
    ViewData["ContainerClass"] = "container";
}

<div class="d-flex align-items-start mb-4">
    <div>
        <h2 class="fw-bold text-dark mb-1"><i class="bi bi-gear-fill me-2 text-primary"></i>Kelola Data</h2>
        <p class="text-muted">Panel untuk mengelola data master, proton, dan assessment &amp; training.</p>
    </div>
</div>

@* Section A: Data Management *@
<div class="d-flex align-items-center mb-3">
    <span class="badge bg-primary me-2">A</span>
    <h5 class="fw-bold text-primary mb-0">Data Management</h5>
</div>
<div class="row g-3 mb-2">
    @if (User.IsInRole("Admin") || User.IsInRole("HC"))
    {
    <div class="col-md-4">
        <a href="@Url.Action("ManageWorkers", "Worker")" class="text-decoration-none">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-person-lines-fill fs-5 text-primary"></i>
                        <span class="fw-bold">Worker Management</span>
                    </div>
                    <small class="text-muted">Tambah, edit, hapus, dan kelola data pekerja — termasuk import/export Excel</small>
                </div>
            </div>
        </a>
    </div>
    }
    @if (User.IsInRole("Admin") || User.IsInRole("HC"))
    {
    <div class="col-md-4">
        <a href="@Url.Action("ManageOrganization", "Organization")" class="text-decoration-none">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-diagram-3 fs-5 text-primary"></i>
                        <span class="fw-bold">Organization Structure</span>
                    </div>
                    <small class="text-muted">Kelola hierarki Bagian dan Unit kerja dengan tampilan tree</small>
                </div>
            </div>
        </a>
    </div>
    }
    @if (User.IsInRole("Admin") || User.IsInRole("HC"))
    {
    <div class="col-md-4">
        <a href="@Url.Action("KkjMatrix", "DocumentAdmin")" class="text-decoration-none">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-table fs-5 text-primary"></i>
                        <span class="fw-bold">Kebutuhan Kompetensi Jabatan</span>
                    </div>
                    <small class="text-muted">Upload dan kelola dokumen KKJ (PDF/Excel) per bagian</small>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="@Url.Action("CpdpFiles", "DocumentAdmin")" class="text-decoration-none">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-file-earmark-richtext fs-5 text-primary"></i>
                        <span class="fw-bold">CPDP File Management</span>
                    </div>
                    <small class="text-muted">Upload dan kelola dokumen CPDP per bagian (PDF/Excel)</small>
                </div>
            </div>
        </a>
    </div>
    }
</div>

<hr class="my-4">

@* Section B: Proton *@
<div class="d-flex align-items-center mb-3">
    <span class="badge bg-warning text-dark me-2">B</span>
    <h5 class="fw-bold text-warning mb-0">Proton</h5>
</div>
<div class="row g-3 mb-2">
    @if (User.IsInRole("Admin") || User.IsInRole("HC"))
    {
    <div class="col-md-4">
        <a href="@Url.Action("Index", "ProtonData")" class="text-decoration-none">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-book fs-5 text-primary"></i>
                        <span class="fw-bold">Silabus &amp; Coaching Guidance</span>
                    </div>
                    <small class="text-muted">Kelola silabus Proton dan file coaching guidance per track</small>
                </div>
            </div>
        </a>
    </div>
    }
    @if (User.IsInRole("Admin") || User.IsInRole("HC"))
    {
    <div class="col-md-4">
        <a href="@Url.Action("CoachCoacheeMapping", "CoachMapping")" class="text-decoration-none">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-people fs-5 text-primary"></i>
                        <span class="fw-bold">Coach-Coachee Mapping</span>
                    </div>
                    <small class="text-muted">Atur assignment coach ke coachee per unit dan bagian</small>
                </div>
            </div>
        </a>
    </div>
    }
    @if (User.IsInRole("Admin") || User.IsInRole("HC"))
    {
    <div class="col-md-4">
        <a href="@Url.Action("CoachWorkload", "CoachMapping")" class="text-decoration-none">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-bar-chart-line fs-5 text-primary"></i>
                        <span class="fw-bold">Coach Workload</span>
                    </div>
                    <small class="text-muted">Pantau beban coach, rasio coachee, dan saran penyeimbangan</small>
                </div>
            </div>
        </a>
    </div>
    }
    @if (User.IsInRole("Admin") || User.IsInRole("HC"))
    {
    <div class="col-md-4">
        <a href="@Url.Action("Override", "ProtonData")" class="text-decoration-none">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-pencil-square fs-5 text-primary"></i>
                        <span class="fw-bold">Deliverable Progress Override</span>
                    </div>
                    <small class="text-muted">Override status progress deliverable pekerja secara manual</small>
                </div>
            </div>
        </a>
    </div>
    }
</div>

<hr class="my-4">

@* Section C: Assessment & Training *@
<div class="d-flex align-items-center mb-3">
    <span class="badge bg-success me-2">C</span>
    <h5 class="fw-bold text-success mb-0">Assessment &amp; Training</h5>
</div>
<div class="row g-3 mb-2">
    @if (User.IsInRole("Admin") || User.IsInRole("HC"))
    {
    <div class="col-md-4">
        <a href="@Url.Action("ManageAssessment", "AssessmentAdmin")" class="text-decoration-none">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-sliders fs-5 text-primary"></i>
                        <span class="fw-bold">Manage Assessment &amp; Training</span>
                    </div>
                    <small class="text-muted">Buat, edit, hapus, dan kelola assessment serta training record pekerja</small>
                </div>
            </div>
        </a>
    </div>
    }
    @if (User.IsInRole("Admin") || User.IsInRole("HC"))
    {
    <div class="col-md-4">
        <a href="@Url.Action("AssessmentMonitoring", "AssessmentAdmin")" class="text-decoration-none">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-binoculars fs-5 text-success"></i>
                        <span class="fw-bold">Assessment Monitoring</span>
                    </div>
                    <small class="text-muted">Pantau progress assessment real-time — lihat status grup dan peserta</small>
                </div>
            </div>
        </a>
    </div>
    }
    @if (User.IsInRole("Admin") || User.IsInRole("HC"))
    {
    <div class="col-md-4">
        <a href="@Url.Action("AuditLog", "AssessmentAdmin")" class="text-decoration-none">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-journal-text fs-5 text-primary"></i>
                        <span class="fw-bold">Audit Log</span>
                    </div>
                    <small class="text-muted">Lihat riwayat aktivitas pengelolaan assessment oleh Admin dan HC</small>
                </div>
            </div>
        </a>
    </div>
    }
    @if (User.IsInRole("Admin") || User.IsInRole("HC"))
    {
    <div class="col-md-4">
        <a href="@Url.Action("ManageCategories", "AssessmentAdmin")" class="text-decoration-none">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-tags fs-5 text-primary"></i>
                        <span class="fw-bold">Assessment Categories</span>
                    </div>
                    <small class="text-muted">Kelola kategori assessment dan nilai lulus default per kategori</small>
                </div>
            </div>
        </a>
    </div>
    }
    @if (User.IsInRole("Admin") || User.IsInRole("HC"))
    {
    <div class="col-md-4">
        <a href="@Url.Action("RenewalCertificate", "Renewal")" class="text-decoration-none">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-arrow-repeat fs-5 text-warning"></i>
                        <span class="fw-bold">Certificate Renewal</span>
                        @if (ViewBag.RenewalCount != null && (int)ViewBag.RenewalCount > 0)
                        {
                            <span class="badge bg-warning text-dark ms-auto">@ViewBag.RenewalCount</span>
                        }
                    </div>
                    <small class="text-muted">Kelola sertifikat expired dan akan expired yang perlu di-renew</small>
                </div>
            </div>
        </a>
    </div>
    }
</div>

<hr class="my-4">

@* Section D: System *@
<div class="d-flex align-items-center mb-3">
    <span class="badge bg-secondary me-2">D</span>
    <h5 class="fw-bold text-secondary mb-0">System</h5>
</div>
<div class="row g-3 mb-2">
    @if (User.IsInRole("Admin") || User.IsInRole("HC"))
    {
    <div class="col-md-4">
        <a href="@Url.Action("Maintenance", "Admin")" class="text-decoration-none">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-cone-striped fs-5 text-warning"></i>
                        <span class="fw-bold">Maintenance Mode</span>
                    </div>
                    <small class="text-muted">Aktifkan mode maintenance untuk seluruh atau sebagian halaman</small>
                </div>
            </div>
        </a>
    </div>
    }
</div>
