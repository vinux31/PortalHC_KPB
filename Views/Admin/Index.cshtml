@{
    ViewData["Title"] = "Kelola Data";
    ViewData["ContainerClass"] = "container";
}

<div class="d-flex align-items-start mb-4">
    <div>
        <h2 class="fw-bold text-dark mb-1"><i class="bi bi-gear-fill me-2 text-primary"></i>Kelola Data</h2>
        <p class="text-muted">Panel untuk mengelola data master, proton, dan assessment &amp; training.</p>
    </div>
</div>

@* Section A: Data Management *@
<div class="d-flex align-items-center mb-3">
    <span class="badge bg-primary me-2">A</span>
    <h5 class="fw-bold text-primary mb-0">Data Management</h5>
</div>
<div class="row g-3 mb-2">
    <div class="col-md-4">
        <a href="@Url.Action("ManageWorkers", "Admin")" class="text-decoration-none">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-person-lines-fill fs-5 text-primary"></i>
                        <span class="fw-bold">Manajemen Pekerja</span>
                    </div>
                    <small class="text-muted">Tambah, edit, hapus, dan kelola data pekerja sistem</small>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="@Url.Action("KkjMatrix", "Admin")" class="text-decoration-none">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-table fs-5 text-primary"></i>
                        <span class="fw-bold">KKJ Matrix</span>
                    </div>
                    <small class="text-muted">Kelola item KKJ Matrix (master kompetensi)</small>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="@Url.Action("CpdpItems", "Admin")" class="text-decoration-none">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-list-check fs-5 text-primary"></i>
                        <span class="fw-bold">KKJ-IDP Mapping</span>
                    </div>
                    <small class="text-muted">Kelola item CPDP (kompetensi-deliverable mapping)</small>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="@Url.Action("Index", "ProtonData")" class="text-decoration-none">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-book fs-5 text-primary"></i>
                        <span class="fw-bold">Silabus &amp; Coaching Guidance</span>
                    </div>
                    <small class="text-muted">Kelola silabus Proton dan file coaching guidance</small>
                </div>
            </div>
        </a>
    </div>
</div>

<hr class="my-4">

@* Section B: Proton *@
<div class="d-flex align-items-center mb-3">
    <span class="badge bg-warning text-dark me-2">B</span>
    <h5 class="fw-bold text-warning mb-0">Proton</h5>
</div>
<div class="row g-3 mb-2">
    <div class="col-md-4">
        <a href="@Url.Action("CoachCoacheeMapping", "Admin")" class="text-decoration-none">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-people fs-5 text-primary"></i>
                        <span class="fw-bold">Coach-Coachee Mapping</span>
                    </div>
                    <small class="text-muted">Atur assignment coach ke coachee</small>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/ProtonData/Index#override" class="text-decoration-none">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-pencil-square fs-5 text-primary"></i>
                        <span class="fw-bold">Deliverable Progress Override</span>
                    </div>
                    <small class="text-muted">Override status progress deliverable</small>
                </div>
            </div>
        </a>
    </div>
</div>

<hr class="my-4">

@* Section C: Assessment & Training *@
<div class="d-flex align-items-center mb-3">
    <span class="badge bg-success me-2">C</span>
    <h5 class="fw-bold text-success mb-0">Assessment &amp; Training</h5>
</div>
<div class="row g-3 mb-2">
    <div class="col-md-4">
        <a href="@Url.Action("ManageAssessment", "Admin")" class="text-decoration-none">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-sliders fs-5 text-primary"></i>
                        <span class="fw-bold">Manage Assessments</span>
                    </div>
                    <small class="text-muted">Kelola assessment (buat, edit, hapus, monitoring)</small>
                </div>
            </div>
        </a>
    </div>
</div>
