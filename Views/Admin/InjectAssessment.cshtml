@model HcPortal.ViewModels.InjectAssessmentViewModel
@{
    ViewData["Title"] = "Inject Assessment Manual";
    ViewData["ContainerClass"] = "container-fluid";
}

@*
    Phase 394 — Wizard Inject Assessment Manual (scaffold, Plan 01).
    6 pills + 6 step-panel + single <form> + WizardController IIFE (port CreateAssessment.cshtml:877-937 → loop 1..6).
    Step bodies = placeholder; diisi Plan 02 (Setup+Picker) / 03 (Authoring+Sertifikat) / 04 (Jawaban placeholder + Konfirmasi + POST map).
    Razor di-embed saat build → verifikasi runtime WAJIB Playwright (lesson Phase 354).
*@

<div class="container-fluid px-4 py-4">

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Admin")">Kelola Data</a></li>
            <li class="breadcrumb-item active" aria-current="page">Inject Assessment Manual</li>
        </ol>
    </nav>

    <!-- Page Header -->
    <h2 class="fw-bold mb-1">Inject Assessment Manual</h2>
    <p class="text-muted mb-4">Catat hasil assessment luring (offline) agar tampil identik dengan assessment online di riwayat pekerja.</p>

    <!-- Mode banner -->
    <div class="alert alert-info" role="alert">
        <i class="bi bi-info-circle me-2"></i>
        <strong>Mode Inject</strong> — data yang Anda isi dicatat sebagai assessment historis (luring). Skor, kelulusan, dan sertifikat dihitung otomatis oleh sistem, identik dengan jalur online.
    </div>

    <!-- Server-side alerts (re-render on validation failure) -->
    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="bi bi-info-circle me-2"></i>@TempData["Info"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["Warning"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <strong><i class="bi bi-exclamation-triangle-fill me-2"></i>Mohon perbaiki kesalahan berikut:</strong>
            <ul class="mb-0 mt-2">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Step Indicator Nav-Pills -->
    <nav class="mb-4">
        <ul class="nav nav-pills nav-fill gap-2" id="wizardStepNav">
            <li class="nav-item">
                <button type="button" class="nav-link bg-primary text-white active" id="pill-1">
                    <i class="bi bi-circle-fill me-1"></i>1. Setup Room
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link text-muted border" id="pill-2" disabled>
                    <i class="bi bi-circle me-1"></i>2. Pilih Pekerja
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link text-muted border" id="pill-3" disabled>
                    <i class="bi bi-circle me-1"></i>3. Authoring Soal
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link text-muted border" id="pill-4" disabled>
                    <i class="bi bi-circle me-1"></i>4. Sertifikat
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link text-muted border" id="pill-5" disabled>
                    <i class="bi bi-circle me-1"></i>5. Jawaban
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link text-muted border" id="pill-6" disabled>
                    <i class="bi bi-circle me-1"></i>6. Konfirmasi
                </button>
            </li>
        </ul>
    </nav>

    <!-- Single form wrapping all 6 step panels -->
    <form asp-action="InjectAssessment" asp-controller="InjectAssessment" method="post" id="injectAssessmentForm" novalidate>
        @Html.AntiForgeryToken()

        <!-- ===================== STEP 1: SETUP ROOM ===================== -->
        <div id="step-1" class="step-panel">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4"><i class="bi bi-gear text-primary me-2"></i>Langkah 1: Setup Room</h5>

                    <div class="row g-3">
                        <!-- Kategori -->
                        <div class="col-md-8">
                            <label asp-for="Category" class="form-label fw-bold">Kategori Assessment <span class="text-danger">*</span></label>
                            <select asp-for="Category" class="form-select" id="Category">
                                <option value="">-- Pilih Kategori --</option>
                                @if (ViewBag.Categories != null)
                                {
                                    foreach (var cat in (IEnumerable<HcPortal.Models.AssessmentCategory>)ViewBag.Categories)
                                    {
                                        <option value="@cat.Name" data-pass-percentage="@cat.DefaultPassPercentage">@cat.Name</option>
                                    }
                                }
                            </select>
                            <div class="invalid-feedback">Pilih kategori assessment.</div>
                        </div>

                        <!-- Judul + Cek -->
                        <div class="col-md-8">
                            <label asp-for="Title" class="form-label fw-bold">Judul Assessment <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="Title" class="form-control" id="Title" placeholder="Masukkan judul assessment" maxlength="255" />
                                <button type="button" class="btn btn-outline-secondary" id="btnCheckTitle"
                                        data-check-url="@Url.Action("CheckTitleAvailability", "AssessmentAdmin")">
                                    <i class="bi bi-search me-1"></i>Cek Judul
                                </button>
                            </div>
                            <div class="invalid-feedback">Judul assessment wajib diisi.</div>
                            <div id="titleCheckResult" class="mt-2" style="display:none;"></div>
                        </div>

                        <!-- Tipe Assessment -->
                        <div class="col-md-8">
                            <label asp-for="AssessmentType" class="form-label fw-bold">Tipe Assessment</label>
                            <select asp-for="AssessmentType" class="form-select" id="assessmentTypeInput">
                                <option value="Standard">Standard</option>
                                <option value="PreTest">Pre-Test</option>
                                <option value="PostTest">Post-Test</option>
                            </select>
                            <div class="form-text text-muted"><i class="bi bi-info-circle me-1"></i>Penautan Pre/Post ke room existing tersedia pada fase berikutnya.</div>
                        </div>

                        <!-- Tanggal Ujian (backdate) -->
                        <div class="col-md-4">
                            <label for="CompletedAt" class="form-label fw-bold">Tanggal Ujian (Backdate) <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="CompletedAt" name="CompletedAt"
                                   value="@DateTime.Today.ToString("yyyy-MM-dd")" max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                            <div class="form-text text-muted">Tanggal ujian luring (di-backdate). Wajib hari ini atau sebelumnya.</div>
                            <div class="invalid-feedback">Tanggal wajib hari ini atau sebelumnya.</div>
                        </div>

                        <!-- Durasi -->
                        <div class="col-md-4">
                            <label asp-for="DurationMinutes" class="form-label fw-bold">Durasi (menit)</label>
                            <input asp-for="DurationMinutes" type="number" class="form-control" min="1" max="480" id="DurationMinutes" />
                        </div>

                        <!-- Pass Percentage -->
                        <div class="col-md-4">
                            <label asp-for="PassPercentage" class="form-label fw-bold">Pass Percentage (%)</label>
                            <input asp-for="PassPercentage" type="number" class="form-control" min="0" max="100" id="PassPercentage" />
                            <div class="form-text text-muted">Nilai minimum untuk lulus (0–100).</div>
                        </div>

                        <!-- Allow Answer Review -->
                        <div class="col-md-8">
                            <label class="form-label fw-bold">Izinkan Review Jawaban</label>
                            <div class="form-check form-switch">
                                <input asp-for="AllowAnswerReview" class="form-check-input" type="checkbox" id="AllowAnswerReview" />
                                <label class="form-check-label" for="AllowAnswerReview">Aktifkan rincian jawaban per-soal setelah selesai</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <div></div>
                        <button type="button" class="btn btn-primary btn-next" id="btnNext1">
                            Selanjutnya <i class="bi bi-arrow-right ms-1"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===================== STEP 2: PILIH PEKERJA ===================== -->
        <div id="step-2" class="step-panel d-none">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4"><i class="bi bi-people text-primary me-2"></i>Langkah 2: Pilih Pekerja</h5>

                    <!-- Filter bar -->
                    <div class="row g-2 mb-3">
                        <div class="col-auto">
                            <select id="sectionFilter" class="form-select form-select-sm" style="max-width:220px;">
                                <option value="">Semua @OrgLabels.GetLabel(0)</option>
                                @if (ViewBag.Sections != null)
                                {
                                    foreach (var sec in (List<string>)ViewBag.Sections)
                                    {
                                        <option value="@sec">@sec</option>
                                    }
                                }
                                <option value="__none__">Lainnya (Tanpa @OrgLabels.GetLabel(0))</option>
                            </select>
                        </div>
                        <div class="col-auto">
                            <div class="input-group input-group-sm" style="max-width:300px;">
                                <input type="text" id="userSearchInput" class="form-control" placeholder="Cari nama atau email..." />
                                <button type="button" class="btn btn-outline-secondary" id="clearSearchBtn" title="Clear search"><i class="bi bi-x"></i></button>
                            </div>
                        </div>
                        <div class="col-auto">
                            <button type="button" class="btn btn-outline-primary btn-sm" id="selectAllBtn">Pilih Semua</button>
                        </div>
                        <div class="col-auto">
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="deselectAllBtn">Batalkan Semua</button>
                        </div>
                        <div class="col-auto ms-auto">
                            <span class="badge bg-primary" id="selectedCountBadge">0 terpilih</span>
                        </div>
                    </div>

                    <!-- Worker list -->
                    <div id="userCheckboxContainer" class="border rounded p-3" style="max-height:320px;overflow-y:auto;">
                        @if (ViewBag.Users != null)
                        {
                            var selectedIds = (List<string>)ViewBag.SelectedUserIds;
                            @foreach (var user in ViewBag.Users)
                            {
                                var isChecked = selectedIds != null && selectedIds.Contains((string)user.Id);
                                <div class="form-check user-check-item mb-1" data-name="@user.FullName" data-email="@user.Email" data-section="@user.Section">
                                    <input class="form-check-input user-checkbox" type="checkbox" name="UserIds" value="@user.Id" id="user_@user.Id" @(isChecked ? "checked" : "") />
                                    <label class="form-check-label" for="user_@user.Id">
                                        <strong>@user.FullName</strong> <span class="text-muted">(@user.Email) — @user.Section</span>
                                    </label>
                                </div>
                            }
                        }
                    </div>

                    <!-- Peserta Terpilih (live) -->
                    <div class="border rounded p-3 mt-3" id="selected-participants-panel-wrapper">
                        <div class="d-flex align-items-center mb-2">
                            <strong><i class="bi bi-people-fill me-1 text-primary"></i>Peserta Terpilih</strong>
                            <span class="badge bg-primary ms-2" id="selected-participants-count">0 peserta</span>
                        </div>
                        <div id="selected-participants-panel" role="status" aria-live="polite" aria-atomic="false">
                            <span class="text-muted fst-italic">Belum ada pekerja dipilih</span>
                        </div>
                    </div>

                    <div id="step2Error" class="alert alert-danger d-none mt-3">Pilih minimal 1 pekerja untuk melanjutkan.</div>

                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn btn-outline-secondary btn-prev" id="btnPrev2">
                            <i class="bi bi-arrow-left me-1"></i>Sebelumnya
                        </button>
                        <button type="button" class="btn btn-primary btn-next" id="btnNext2">
                            Selanjutnya <i class="bi bi-arrow-right ms-1"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===================== STEP 3: AUTHORING SOAL ===================== -->
        <div id="step-3" class="step-panel d-none">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4"><i class="bi bi-card-list text-primary me-2"></i>Langkah 3: Authoring Soal</h5>

                    <div class="row g-4">
                        <!-- Left: Daftar Soal -->
                        <div class="col-lg-7">
                            <div class="card shadow-sm">
                                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                                    <span class="fw-semibold">Daftar Soal</span>
                                    <span class="small text-muted">Total <span id="injTotalPoin">0</span> poin</span>
                                </div>
                                <div class="card-body p-0" id="injQuestionList"></div>
                            </div>
                            <div id="step3Error" class="alert alert-danger d-none mt-3">Tambahkan minimal 1 soal sebelum melanjutkan.</div>
                        </div>
                        <!-- Right: Form soal (partial, reuse ManagePackageQuestions semantics) -->
                        <div class="col-lg-5">
                            @await Html.PartialAsync("~/Views/Admin/_InjectQuestionForm.cshtml")
                        </div>
                    </div>

                    <input type="hidden" asp-for="QuestionsJson" id="QuestionsJson" />
                    @* Phase 395 — hidden per-worker answers payload, serialized di submit-listener yang SAMA dgn #QuestionsJson *@
                    <input type="hidden" asp-for="AnswersJson" id="AnswersJson" />

                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn btn-outline-secondary btn-prev" id="btnPrev3">
                            <i class="bi bi-arrow-left me-1"></i>Sebelumnya
                        </button>
                        <button type="button" class="btn btn-primary btn-next" id="btnNext3">
                            Selanjutnya <i class="bi bi-arrow-right ms-1"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===================== STEP 4: SERTIFIKAT ===================== -->
        <div id="step-4" class="step-panel d-none">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4"><i class="bi bi-award text-primary me-2"></i>Langkah 4: Sertifikat</h5>

                    <div class="card mb-4">
                        <div class="card-header bg-light">
                            <h6 class="mb-0"><i class="bi bi-award me-2"></i>Sertifikat</h6>
                        </div>
                        <div class="card-body">
                            <!-- 3-mode radio -->
                            <div class="mb-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" asp-for="CertMode" id="certModeNone" value="None" />
                                    <label class="form-check-label" for="certModeNone">Tanpa Sertifikat</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" asp-for="CertMode" id="certModeAuto" value="Auto" />
                                    <label class="form-check-label" for="certModeAuto">Generate Otomatis (Nomor Resmi)</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" asp-for="CertMode" id="certModeManual" value="Manual" />
                                    <label class="form-check-label" for="certModeManual">Input Nomor Manual</label>
                                </div>
                            </div>

                            <!-- Auto: format preview (display-only; real allocation = service 393) -->
                            <div id="certAutoBlock" class="mb-3 d-none">
                                <div class="alert alert-secondary py-2 mb-0">
                                    <span>Format nomor: </span><code>KPB/xxx/{ROMAN}/{year}</code><span> (tahun mengikuti tanggal ujian).</span>
                                </div>
                            </div>

                            <!-- Manual: nomor sertifikat -->
                            <div id="certManualBlock" class="mb-3 d-none">
                                <label asp-for="ManualCertNumber" class="form-label fw-bold">Nomor Sertifikat</label>
                                <input asp-for="ManualCertNumber" class="form-control" id="NomorSertifikat" placeholder="mis. KPB/001/VI/2026" />
                                <div class="form-text text-muted">Nomor wajib unik (divalidasi sistem saat commit).</div>
                            </div>

                            <!-- Validity (Auto + Manual) -->
                            <div id="certValidityBlock" class="row g-3 d-none">
                                <div class="col-md-6">
                                    <label asp-for="CertValidUntil" class="form-label fw-bold">Masa Berlaku Sertifikat</label>
                                    <input asp-for="CertValidUntil" type="date" class="form-control" id="CertValidUntil" />
                                </div>
                                <div class="col-md-6 d-flex align-items-end">
                                    <div class="form-check">
                                        <input asp-for="CertPermanent" class="form-check-input" type="checkbox" id="CertPermanent" />
                                        <label class="form-check-label" for="CertPermanent">Berlaku selamanya (permanen)</label>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="form-text text-muted">Kosongkan atau centang permanen jika sertifikat tanpa batas waktu.</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn btn-outline-secondary btn-prev" id="btnPrev4">
                            <i class="bi bi-arrow-left me-1"></i>Sebelumnya
                        </button>
                        <button type="button" class="btn btn-primary btn-next" id="btnNext4">
                            Selanjutnya <i class="bi bi-arrow-right ms-1"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===================== STEP 5: JAWABAN (placeholder — Phase 395) ===================== -->
        <div id="step-5" class="step-panel d-none">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4"><i class="bi bi-pencil-square text-primary me-2"></i>Langkah 5: Jawaban</h5>
                    @* Seam Phase 395: sub-komponen jawaban per-pekerja (1-pekerja-per-layar) menggantikan #step5Placeholder tanpa menyentuh pills/nav (btnPrev5/btnNext5) *@
                    <div id="step5Root">

                        @* Empty state — tak ada pekerja / tak ada soal (di-toggle JS) *@
                        <div id="step5EmptyNoWorkers" class="alert alert-info d-none">
                            <i class="bi bi-people me-2"></i><strong>Belum ada pekerja dipilih</strong>
                            <div class="small mt-1">Kembali ke Langkah 2 untuk memilih pekerja sebelum mengisi jawaban.</div>
                        </div>
                        <div id="step5EmptyNoQuestions" class="alert alert-info d-none">
                            <i class="bi bi-card-list me-2"></i>Belum ada soal. Tambahkan soal di Langkah 3 terlebih dahulu.
                        </div>

                        @* Konten utama (di-toggle JS bila ada pekerja + soal) *@
                        <div id="step5Body" class="d-none">

                            @* Toggle mode default room (K2) *@
                            <div class="mb-3">
                                <label class="form-label fw-bold mb-1">Mode default room</label>
                                <div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="step5DefaultMode" id="step5DefaultManual" value="manual" checked />
                                        <label class="form-check-label" for="step5DefaultManual">Input jawaban asli</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="step5DefaultMode" id="step5DefaultAuto" value="auto" />
                                        <label class="form-check-label" for="step5DefaultAuto">Auto-generate dari skor target</label>
                                    </div>
                                </div>
                                <div class="form-text text-muted">Mode awal tiap pekerja; dapat ditimpa per-pekerja di bawah.</div>
                            </div>

                            <div class="row g-4">
                                @* Roster ringkas (K1) *@
                                <div class="col-lg-5">
                                    <div class="card">
                                        <div class="card-header bg-light">
                                            <h6 class="mb-0 fw-semibold">Ringkasan Pekerja</h6>
                                        </div>
                                        <div class="card-body p-0" style="max-height:280px;overflow-y:auto;">
                                            <table class="table table-hover table-sm mb-0 align-middle" role="status" aria-live="polite">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th style="width:40px">#</th>
                                                        <th>NIP / Nama</th>
                                                        <th style="width:90px">Mode</th>
                                                        <th style="width:110px">Skor Pratinjau</th>
                                                        <th style="width:60px">Status</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="step5RosterBody"></tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>

                                @* Form pekerja aktif (K2/K3/K4/K5/K6) *@
                                <div class="col-lg-7">
                                    @* Indikator pekerja aktif *@
                                    <div class="h6 fw-bold mb-2" id="step5WorkerHeading"></div>

                                    @* Kontrol antar-pekerja *@
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <button type="button" class="btn btn-outline-secondary btn-sm" id="step5PrevWorker">
                                            <i class="bi bi-chevron-left me-1"></i>« Pekerja Sebelumnya
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary btn-sm" id="step5NextWorker">
                                            Pekerja Berikutnya »<i class="bi bi-chevron-right ms-1"></i>
                                        </button>
                                    </div>

                                    @* Toggle mode per-pekerja (K2) *@
                                    <div class="mb-3">
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="radio" name="step5WorkerMode" id="step5ModeManual" value="manual" />
                                            <label class="form-check-label" for="step5ModeManual">Input jawaban asli</label>
                                        </div>
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="radio" name="step5WorkerMode" id="step5ModeAuto" value="auto" />
                                            <label class="form-check-label" for="step5ModeAuto">Auto-generate dari skor target</label>
                                        </div>
                                    </div>

                                    @* Body auto-gen (K4) — target + banner HYBRID (di-toggle JS) *@
                                    <div id="step5AutoBody" class="d-none">
                                        <div class="mb-3" style="max-width:220px;">
                                            <label class="form-label fw-bold" for="step5TargetScore">Skor target (%)</label>
                                            <input type="number" class="form-control" id="step5TargetScore" min="0" max="100" />
                                            <div class="form-text text-muted">Sistem memilih pola jawaban benar/salah agar capaian ≥ target.</div>
                                        </div>
                                        <div id="step5HybridBanner" class="alert alert-info py-2 d-none">
                                            <i class="bi bi-info-circle me-1"></i>Room ini memuat soal essay — skor essay diisi manual (auto-generate hanya menyentuh soal pilihan).
                                        </div>
                                    </div>

                                    @* Body form jawaban (input-asli K3 + essay HYBRID auto K4) — di-render JS *@
                                    <div id="step5AnswerForm"></div>

                                    @* Permukaan Pratinjau (K5) *@
                                    <div class="mt-3">
                                        <button type="button" class="btn btn-outline-primary" id="step5PreviewBtn"
                                                data-preview-url="@Url.Action("PreviewInjectScore", "InjectAssessment")">
                                            <i class="bi bi-eye me-1"></i>Pratinjau Skor
                                        </button>
                                        <div id="step5PreviewResult" class="mt-3" style="display:none;"></div>
                                    </div>

                                    @* State BLOCKING (K6) — di-toggle JS *@
                                    <div id="step5Blocking" class="alert alert-warning mt-3 d-none">
                                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                        <span id="step5BlockingMsg"></span>
                                        <div class="mt-2">
                                            <button type="button" class="btn btn-sm btn-outline-primary" id="step5SwitchToManual">Beralih ke input asli</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn btn-outline-secondary btn-prev" id="btnPrev5">
                            <i class="bi bi-arrow-left me-1"></i>Sebelumnya
                        </button>
                        <button type="button" class="btn btn-primary btn-next" id="btnNext5">
                            Selanjutnya <i class="bi bi-arrow-right ms-1"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===================== STEP 6: KONFIRMASI ===================== -->
        <div id="step-6" class="step-panel d-none">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4"><i class="bi bi-check2-circle text-primary me-2"></i>Langkah 6: Konfirmasi</h5>
                    <p class="text-muted mb-4">Periksa kembali data sebelum meng-inject.</p>

                    <!-- Setup Room -->
                    <div class="card mb-3">
                        <div class="card-header d-flex align-items-center">
                            <strong>Setup Room</strong>
                            <button type="button" class="btn btn-sm btn-outline-secondary ms-auto edit-from-confirm" data-step="1"><i class="bi bi-pencil me-1"></i>Edit</button>
                        </div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-sm-4">Judul</dt><dd class="col-sm-8" id="sum-title"></dd>
                                <dt class="col-sm-4">Kategori</dt><dd class="col-sm-8" id="sum-category"></dd>
                                <dt class="col-sm-4">Tipe</dt><dd class="col-sm-8" id="sum-type"></dd>
                                <dt class="col-sm-4">Tanggal Ujian</dt><dd class="col-sm-8" id="sum-date"></dd>
                                <dt class="col-sm-4">Durasi</dt><dd class="col-sm-8" id="sum-duration"></dd>
                                <dt class="col-sm-4">Pass Percentage</dt><dd class="col-sm-8" id="sum-pass"></dd>
                            </dl>
                        </div>
                    </div>

                    <!-- Pekerja -->
                    <div class="card mb-3">
                        <div class="card-header d-flex align-items-center">
                            <strong>Pekerja</strong>
                            <span class="badge bg-secondary ms-2" id="sum-worker-count"></span>
                            <button type="button" class="btn btn-sm btn-outline-secondary ms-auto edit-from-confirm" data-step="2"><i class="bi bi-pencil me-1"></i>Edit</button>
                        </div>
                        <div class="card-body" id="sum-worker-list"></div>
                    </div>

                    <!-- Soal -->
                    <div class="card mb-3">
                        <div class="card-header d-flex align-items-center">
                            <strong>Soal</strong>
                            <button type="button" class="btn btn-sm btn-outline-secondary ms-auto edit-from-confirm" data-step="3"><i class="bi bi-pencil me-1"></i>Edit</button>
                        </div>
                        <div class="card-body">
                            <span id="sum-soal-count">0</span> soal · Total <span id="sum-soal-poin">0</span> poin
                        </div>
                    </div>

                    <!-- Sertifikat -->
                    <div class="card mb-3">
                        <div class="card-header d-flex align-items-center">
                            <strong>Sertifikat</strong>
                            <button type="button" class="btn btn-sm btn-outline-secondary ms-auto edit-from-confirm" data-step="4"><i class="bi bi-pencil me-1"></i>Edit</button>
                        </div>
                        <div class="card-body"><span id="sum-cert"></span></div>
                    </div>

                    <div class="d-flex justify-content-between mt-4 mb-3">
                        <button type="button" class="btn btn-outline-secondary btn-prev" id="btnPrev6">
                            <i class="bi bi-arrow-left me-1"></i>Sebelumnya
                        </button>
                    </div>
                    <button type="submit" class="btn btn-success btn-lg w-100" id="btnInject">
                        <i class="bi bi-cloud-arrow-up-fill me-2"></i>Inject Assessment
                    </button>
                </div>
            </div>
        </div>

    </form>
</div>

@section Scripts {
<script>
// ===== Wizard Controller (port CreateAssessment.cshtml:877-937 → 6 steps) =====
(function WizardController() {
    var currentStep = 1;
    var visitedSteps = new Set([1]);
    var returnToConfirm = false;
    var TOTAL_STEPS = 6;
    var INJ_TODAY = '@DateTime.Today.ToString("yyyy-MM-dd")';
    var injQuestions = [];            // authored soal held in client state (D-07, no DB write)
    var injNextQTempId = 1;
    var injNextOptTempId = 1;

    // ---- goToStep ----
    function goToStep(n) {
        if (n < 1 || n > TOTAL_STEPS) return;
        currentStep = n;
        visitedSteps.add(n);

        document.querySelectorAll('.step-panel').forEach(function (panel) {
            panel.classList.add('d-none');
        });
        var target = document.getElementById('step-' + n);
        if (target) target.classList.remove('d-none');

        updatePills();

        if (n === 5) step5Rebuild();
        if (n === TOTAL_STEPS) populateSummary();

        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // ---- updatePills ----
    function updatePills() {
        for (var i = 1; i <= 6; i++) {
            var pill = document.getElementById('pill-' + i);
            if (!pill) continue;

            pill.className = 'nav-link';
            pill.disabled = true;
            var icon = pill.querySelector('i');

            if (i === currentStep) {
                pill.classList.add('bg-primary', 'text-white', 'active');
                pill.disabled = false;
                if (icon) { icon.className = 'bi bi-circle-fill me-1'; }
            } else if (visitedSteps.has(i) && i < currentStep) {
                pill.classList.add('bg-success', 'text-white');
                pill.disabled = false;
                if (icon) { icon.className = 'bi bi-check-circle-fill me-1'; }
            } else if (visitedSteps.has(i)) {
                pill.classList.add('text-primary', 'border', 'border-primary');
                pill.disabled = false;
                if (icon) { icon.className = 'bi bi-circle me-1'; }
            } else {
                pill.classList.add('text-muted', 'border');
                pill.disabled = true;
                if (icon) { icon.className = 'bi bi-circle me-1'; }
            }
        }
    }

    // ---- validateStep (Plan 02: step 1 setup, step 2 picker; Plan 03 adds step 3) ----
    function validateStep(n) {
        var panel = document.getElementById('step-' + n);
        if (panel) {
            panel.querySelectorAll('.is-invalid').forEach(function (el) { el.classList.remove('is-invalid'); });
        }
        var step2err = document.getElementById('step2Error');
        if (step2err) step2err.classList.add('d-none');
        var step3err = document.getElementById('step3Error');
        if (step3err) step3err.classList.add('d-none');
        var valid = true;

        if (n === 1) {
            var cat = document.getElementById('Category');
            var title = document.getElementById('Title');
            var cd = document.getElementById('CompletedAt');
            if (!cat || !cat.value) { if (cat) cat.classList.add('is-invalid'); valid = false; }
            if (!title || !title.value.trim()) { if (title) title.classList.add('is-invalid'); valid = false; }
            if (!cd || !cd.value) {
                if (cd) cd.classList.add('is-invalid'); valid = false;
            } else if (cd.value > INJ_TODAY) {
                cd.classList.add('is-invalid'); valid = false;
            }
        }

        if (n === 2) {
            var anyChecked = document.querySelectorAll('#userCheckboxContainer .user-checkbox:checked').length > 0;
            if (!anyChecked) {
                if (step2err) step2err.classList.remove('d-none');
                valid = false;
            }
        }

        if (n === 3) {
            if (injQuestions.length < 1) {
                if (step3err) step3err.classList.remove('d-none');
                valid = false;
            }
        }

        return valid;
    }

    // ---- populateSummary (Plan 04: confirm summary via .textContent — XSS-safe) ----
    function populateSummary() {
        function setText(id, v) { var el = document.getElementById(id); if (el) el.textContent = v; }
        function selText(id) { var el = document.getElementById(id); return (el && el.options[el.selectedIndex]) ? el.options[el.selectedIndex].text : ''; }
        function val(id) { var el = document.getElementById(id); return el ? el.value : ''; }
        setText('sum-title', val('Title'));
        setText('sum-category', selText('Category'));
        setText('sum-type', selText('assessmentTypeInput'));
        setText('sum-date', val('CompletedAt'));
        setText('sum-duration', val('DurationMinutes') + ' menit');
        setText('sum-pass', val('PassPercentage') + '%');
        var checked = Array.from(document.querySelectorAll('#userCheckboxContainer .user-checkbox:checked'));
        setText('sum-worker-count', checked.length + ' peserta');
        injRenderSelectedNames(document.getElementById('sum-worker-list'), checked);
        setText('sum-soal-count', injQuestions.length);
        setText('sum-soal-poin', injQuestions.reduce(function (s, q) { return s + (q.ScoreValue || 0); }, 0));
        var certChecked = document.querySelector('input[name="CertMode"]:checked');
        var certLabel = 'Tanpa Sertifikat';
        if (certChecked) {
            var lbl = document.querySelector('label[for="' + certChecked.id + '"]');
            if (lbl) certLabel = lbl.textContent.trim();
        }
        setText('sum-cert', certLabel);
    }

    // ---- wiring ----
    document.querySelectorAll('.btn-next').forEach(function (btn) {
        btn.addEventListener('click', function () {
            if (validateStep(currentStep)) {
                if (returnToConfirm) { returnToConfirm = false; goToStep(6); }
                else goToStep(currentStep + 1);
            }
        });
    });
    document.querySelectorAll('.edit-from-confirm').forEach(function (btn) {
        btn.addEventListener('click', function () {
            returnToConfirm = true;
            var step = parseInt(btn.getAttribute('data-step'), 10);
            if (!isNaN(step)) goToStep(step);
        });
    });
    document.querySelectorAll('.btn-prev').forEach(function (btn) {
        btn.addEventListener('click', function () {
            returnToConfirm = false;   // MED-01: abandon edit-from-confirm intent on non-forward nav
            goToStep(currentStep - 1);
        });
    });
    for (var i = 1; i <= TOTAL_STEPS; i++) {
        (function (n) {
            var pill = document.getElementById('pill-' + n);
            if (pill) pill.addEventListener('click', function () {
                if (visitedSteps.has(n)) { returnToConfirm = false; goToStep(n); }
            });
        })(i);
    }

    // ---- Worker picker (port CreateAssessment:1439-1665, Proton stripped) ----
    function injRenderSelectedNames(targetEl, checkboxes) {
        var names = (checkboxes || []).map(function (cb) {
            var label = document.querySelector('label[for="' + cb.id + '"]');
            if (label) { var s = label.querySelector('strong'); return s ? s.textContent : label.textContent.trim(); }
            return cb.value;
        });
        if (!targetEl) return;
        var node;
        if (names.length === 0) {
            node = document.createElement('span');
            node.className = 'text-muted fst-italic';
            node.textContent = 'Belum ada pekerja dipilih';
        } else {
            node = document.createElement('span');
            node.textContent = names.join(', ');   // XSS-safe textContent
        }
        if (typeof targetEl.replaceChildren === 'function') targetEl.replaceChildren(node);
        else { targetEl.innerHTML = ''; targetEl.appendChild(node); }
    }
    function injUpdateSelectedCount() {
        var checkboxes = Array.from(document.querySelectorAll('#userCheckboxContainer .user-checkbox:checked'));
        var badge = document.getElementById('selectedCountBadge');
        if (badge) badge.textContent = checkboxes.length + ' terpilih';
        var panelCount = document.getElementById('selected-participants-count');
        if (panelCount) panelCount.textContent = checkboxes.length + ' peserta';
        injRenderSelectedNames(document.getElementById('selected-participants-panel'), checkboxes);
    }
    function injApplyFilters() {
        var searchInput = document.getElementById('userSearchInput');
        var sectionFilter = document.getElementById('sectionFilter');
        if (!searchInput || !sectionFilter) return;
        var query = searchInput.value.toLowerCase();
        var selectedSection = sectionFilter.value;
        document.querySelectorAll('#userCheckboxContainer .user-check-item').forEach(function (item) {
            var name = (item.dataset.name || '').toLowerCase();
            var email = (item.dataset.email || '').toLowerCase();
            var section = item.dataset.section || '';
            var sectionMatch = true;
            if (selectedSection === '__none__') sectionMatch = (section === '');
            else if (selectedSection !== '') sectionMatch = (section === selectedSection);
            var textMatch = (query === '') || name.includes(query) || email.includes(query);
            item.style.display = (sectionMatch && textMatch) ? '' : 'none';
        });
    }
    (function wirePicker() {
        var searchInput = document.getElementById('userSearchInput');
        var sectionFilter = document.getElementById('sectionFilter');
        if (searchInput) searchInput.addEventListener('input', injApplyFilters);
        if (sectionFilter) sectionFilter.addEventListener('change', injApplyFilters);
        var clearBtn = document.getElementById('clearSearchBtn');
        if (clearBtn) clearBtn.addEventListener('click', function () { if (searchInput) searchInput.value = ''; injApplyFilters(); });
        var selectAllBtn = document.getElementById('selectAllBtn');
        if (selectAllBtn) selectAllBtn.addEventListener('click', function () {
            document.querySelectorAll('#userCheckboxContainer .user-check-item').forEach(function (item) {
                if (item.style.display !== 'none') item.querySelector('.user-checkbox').checked = true;
            });
            injUpdateSelectedCount();
        });
        var deselectAllBtn = document.getElementById('deselectAllBtn');
        if (deselectAllBtn) deselectAllBtn.addEventListener('click', function () {
            document.querySelectorAll('#userCheckboxContainer .user-check-item').forEach(function (item) {
                if (item.style.display !== 'none') item.querySelector('.user-checkbox').checked = false;
            });
            injUpdateSelectedCount();
        });
        var userContainer = document.getElementById('userCheckboxContainer');
        if (userContainer) userContainer.addEventListener('change', injUpdateSelectedCount);
        injUpdateSelectedCount();
    })();

    // ---- Authoring soal (REWIRE → client-state injQuestions[]; NEVER posts to per-question endpoint — Pitfall 1) ----
    function applyQTypeSwitch(qtype) {
        var optionsSection = document.getElementById('optionsSection');
        var rubrikSection = document.getElementById('rubrikSection');
        var maLabel = document.getElementById('maLabel');
        if (optionsSection) optionsSection.style.display = (qtype === 'Essay') ? 'none' : '';
        if (rubrikSection) rubrikSection.style.display = (qtype === 'Essay') ? '' : 'none';
        if (maLabel) maLabel.style.display = (qtype === 'MultipleAnswer') ? '' : 'none';
        document.querySelectorAll('.correct-input').forEach(function (inp) {
            inp.type = (qtype === 'MultipleAnswer') ? 'checkbox' : 'radio';
            if (qtype !== 'MultipleAnswer') inp.checked = false;
        });
    }

    function injTypeLabel(t) {
        if (t === 'MultipleChoice') return 'Single Answer';
        if (t === 'MultipleAnswer') return 'Multiple Answer';
        if (t === 'Essay') return 'Essay';
        return t;
    }

    function injRenderQuestionList() {
        var listEl = document.getElementById('injQuestionList');
        var totalEl = document.getElementById('injTotalPoin');
        if (!listEl) return;
        if (injQuestions.length === 0) {
            listEl.innerHTML = '<div class="p-4 text-center text-muted"><i class="bi bi-inbox fs-2 d-block mb-2"></i>Belum ada soal. Tambahkan soal menggunakan form di samping.</div>';
        } else {
            var wrap = document.createElement('div');
            wrap.className = 'table-responsive';
            var table = document.createElement('table');
            table.className = 'table table-hover table-sm mb-0 align-middle';
            var thead = document.createElement('thead');
            thead.className = 'table-light';
            thead.innerHTML = '<tr><th style="width:40px">#</th><th>Teks Soal</th><th style="width:120px">Tipe</th><th style="width:60px">Skor</th><th style="width:70px">Aksi</th></tr>';
            table.appendChild(thead);
            var tbody = document.createElement('tbody');
            injQuestions.forEach(function (q, idx) {
                var tr = document.createElement('tr');
                var tdNum = document.createElement('td'); tdNum.className = 'text-muted'; tdNum.textContent = (idx + 1);
                var tdText = document.createElement('td');
                var span = document.createElement('span'); span.className = 'd-inline-block text-truncate'; span.style.maxWidth = '220px';
                span.title = q.QuestionText; span.textContent = q.QuestionText;   // XSS-safe
                tdText.appendChild(span);
                var tdType = document.createElement('td');
                var badge = document.createElement('span'); badge.className = 'badge bg-secondary small'; badge.textContent = injTypeLabel(q.QuestionType);
                tdType.appendChild(badge);
                var tdScore = document.createElement('td'); tdScore.className = 'text-center'; tdScore.textContent = q.ScoreValue;
                var tdAksi = document.createElement('td');
                var btn = document.createElement('button'); btn.type = 'button'; btn.className = 'btn btn-outline-danger btn-sm py-0 px-1'; btn.title = 'Hapus';
                btn.innerHTML = '<i class="bi bi-trash"></i>';
                btn.addEventListener('click', function () { injRemoveQuestion(q.TempId); });
                tdAksi.appendChild(btn);
                tr.appendChild(tdNum); tr.appendChild(tdText); tr.appendChild(tdType); tr.appendChild(tdScore); tr.appendChild(tdAksi);
                tbody.appendChild(tr);
            });
            table.appendChild(tbody);
            wrap.appendChild(table);
            listEl.innerHTML = '';
            listEl.appendChild(wrap);
        }
        if (totalEl) totalEl.textContent = injQuestions.reduce(function (s, q) { return s + (q.ScoreValue || 0); }, 0);
    }

    function injRemoveQuestion(tempId) {
        if (!confirm('Hapus soal ini?')) return;
        injQuestions = injQuestions.filter(function (q) { return q.TempId !== tempId; });
        injQuestions.forEach(function (q, i) { q.Order = i; });
        injRenderQuestionList();
    }

    function injResetAuthoringForm() {
        var qt = document.getElementById('questionText'); if (qt) { qt.value = ''; qt.classList.remove('is-invalid'); }
        var sv = document.getElementById('scoreValue'); if (sv) { sv.value = '10'; sv.classList.remove('is-invalid'); }
        var el = document.getElementById('elemenTeknis'); if (el) el.value = '';
        var rb = document.getElementById('rubrik'); if (rb) { rb.value = ''; rb.classList.remove('is-invalid'); }
        ['A', 'B', 'C', 'D'].forEach(function (L) {
            var o = document.getElementById('option_' + L); if (o) { o.value = ''; o.classList.remove('is-invalid'); }
            var c = document.getElementById('correct_' + L); if (c) c.checked = false;
        });
        var qtype = document.getElementById('QuestionType'); if (qtype) qtype.value = 'MultipleChoice';
        applyQTypeSwitch('MultipleChoice');
    }

    var injAddBtn = document.getElementById('injAddQuestionBtn');
    if (injAddBtn) {
        injAddBtn.addEventListener('click', function () {
            var qType = document.getElementById('QuestionType').value;
            var qTextEl = document.getElementById('questionText');
            var svEl = document.getElementById('scoreValue');
            var rbEl = document.getElementById('rubrik');
            var qText = (qTextEl.value || '').trim();
            var score = parseInt(svEl.value, 10);
            var elemen = (document.getElementById('elemenTeknis').value || '').trim();
            var rubrik = (rbEl.value || '').trim();
            var errEl = document.getElementById('injAuthError');
            var problems = [];

            qTextEl.classList.remove('is-invalid'); svEl.classList.remove('is-invalid'); rbEl.classList.remove('is-invalid');
            if (!qText) { qTextEl.classList.add('is-invalid'); problems.push('Teks soal wajib diisi.'); }
            if (isNaN(score) || score < 1 || score > 100) { svEl.classList.add('is-invalid'); problems.push('Nilai soal harus 1–100.'); }

            var options = [];
            if (qType === 'MultipleChoice' || qType === 'MultipleAnswer') {
                var correctCount = 0;
                ['A', 'B', 'C', 'D'].forEach(function (L) {
                    var txt = (document.getElementById('option_' + L).value || '').trim();
                    var isC = document.getElementById('correct_' + L).checked;
                    if (txt) { options.push({ text: txt, isCorrect: isC }); if (isC) correctCount++; }
                });
                if (options.length < 2) problems.push('Minimal 2 opsi ber-teks.');
                if (qType === 'MultipleChoice' && correctCount !== 1) problems.push('Single Answer harus tepat 1 jawaban benar.');
                if (qType === 'MultipleAnswer' && correctCount < 2) problems.push('Multiple Answer butuh minimal 2 jawaban benar.');
            } else if (qType === 'Essay') {
                if (!rubrik) { rbEl.classList.add('is-invalid'); problems.push('Rubrik wajib diisi untuk Essay.'); }
            }

            if (problems.length > 0) {
                if (errEl) { errEl.textContent = problems.join(' '); errEl.classList.remove('d-none'); }
                return;
            }
            if (errEl) errEl.classList.add('d-none');

            injQuestions.push({
                TempId: injNextQTempId++,
                QuestionText: qText,
                QuestionType: qType,
                ScoreValue: score,
                Order: injQuestions.length,
                ElemenTeknis: elemen || null,
                Rubrik: (qType === 'Essay') ? rubrik : null,
                Options: (qType === 'Essay') ? [] : options.map(function (o) {
                    return { TempId: injNextOptTempId++, OptionText: o.text, IsCorrect: o.isCorrect };
                })
            });
            injRenderQuestionList();
            injResetAuthoringForm();
        });
    }

    var qTypeSel = document.getElementById('QuestionType');
    if (qTypeSel) {
        qTypeSel.addEventListener('change', function () { applyQTypeSwitch(this.value); });
        applyQTypeSwitch(qTypeSel.value);
    }
    injRenderQuestionList();

    // Serialize injQuestions → hidden #QuestionsJson before POST (Plan 04 controller deserializes)
    var injForm = document.getElementById('injectAssessmentForm');
    if (injForm) {
        injForm.addEventListener('submit', function () {
            var hidden = document.getElementById('QuestionsJson');
            if (hidden) hidden.value = JSON.stringify(injQuestions);
            // Phase 395 (Pitfall 4 — KRITIS): serialize answers di listener yang SAMA dgn #QuestionsJson.
            // Lupa = POST answers kosong → semua worker grade 0 (silent).
            var answersHidden = document.getElementById('AnswersJson');
            if (answersHidden) answersHidden.value = JSON.stringify(buildWorkerAnswersPayload());
        });
    }
    window.injGetQuestions = function () { return injQuestions; };

    // ---- Sertifikat radio 3-mode toggle (INJ-07) ----
    (function wireCert() {
        function applyCertMode() {
            var checked = document.querySelector('input[name="CertMode"]:checked');
            var mode = checked ? checked.value : 'None';
            var auto = document.getElementById('certAutoBlock');
            var manual = document.getElementById('certManualBlock');
            var validity = document.getElementById('certValidityBlock');
            if (auto) auto.classList.toggle('d-none', mode !== 'Auto');
            if (manual) manual.classList.toggle('d-none', mode !== 'Manual');
            if (validity) validity.classList.toggle('d-none', mode === 'None');
        }
        function applyPermanent() {
            var perm = document.getElementById('CertPermanent');
            var vu = document.getElementById('CertValidUntil');
            if (perm && vu) {
                if (perm.checked) { vu.value = ''; vu.disabled = true; }
                else { vu.disabled = false; }
            }
        }
        document.querySelectorAll('input[name="CertMode"]').forEach(function (r) {
            r.addEventListener('change', applyCertMode);
        });
        var perm = document.getElementById('CertPermanent');
        if (perm) perm.addEventListener('change', applyPermanent);
        applyCertMode();
        applyPermanent();
    })();

    // ---- Cek Judul (reuse GET /Admin/CheckTitleAvailability — port CreateAssessment:1250-1283) ----
    var btnCheckTitle = document.getElementById('btnCheckTitle');
    if (btnCheckTitle) {
        btnCheckTitle.addEventListener('click', function () {
            var title = (document.getElementById('Title').value || '').trim();
            var box = document.getElementById('titleCheckResult');
            box.style.display = 'block';
            if (!title) {
                box.innerHTML = '<div class="alert alert-secondary py-2 mb-0">Isi judul dulu sebelum cek.</div>';
                return;
            }
            btnCheckTitle.disabled = true;
            box.innerHTML = '<div class="text-muted small"><span class="spinner-border spinner-border-sm me-1"></span>Mengecek...</div>';
            var url = btnCheckTitle.getAttribute('data-check-url') + '?title=' + encodeURIComponent(title);
            fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (!data.exists) {
                        box.innerHTML = '<div class="alert alert-success py-2 mb-0"><i class="bi bi-check-circle me-1"></i>Judul tersedia.</div>';
                    } else {
                        // XSS-safe: matched server strings rendered via textContent
                        var wrap = document.createElement('div');
                        wrap.className = 'alert alert-warning py-2 mb-0';
                        var head = document.createElement('div');
                        head.innerHTML = '<i class="bi bi-exclamation-triangle me-1"></i>';
                        var headText = document.createElement('span');
                        headText.textContent = 'Judul mirip sudah ada — periksa agar tidak duplikat/double sertifikat.';
                        head.appendChild(headText);
                        wrap.appendChild(head);
                        var ul = document.createElement('ul');
                        ul.className = 'mb-0 mt-1';
                        (data.matches || []).forEach(function (m) {
                            var d = m.tanggal ? new Date(m.tanggal).toLocaleDateString('id-ID') : '-';
                            var li = document.createElement('li');
                            li.textContent = (m.category || '') + ' · ' + d + ' · ' + m.peserta + ' peserta';
                            ul.appendChild(li);
                        });
                        wrap.appendChild(ul);
                        box.innerHTML = '';
                        box.appendChild(wrap);
                    }
                })
                .catch(function () {
                    box.innerHTML = '<div class="alert alert-danger py-2 mb-0">Gagal cek judul. Coba lagi.</div>';
                })
                .finally(function () { btnCheckTitle.disabled = false; });
        });
    }

    // ============================================================================
    // Phase 395 — Step-5 sub-komponen ber-state (1-pekerja-per-layar, D-03)
    // IIFE-scoped state independen goToStep luar; render via .textContent (XSS-safe).
    // ============================================================================
    // workerState: { [userId]: { mode:'manual'|'auto', targetScore:int,
    //                            answers:{ [qTempId]:{ selected:[], text, score, skipped } },
    //                            preview:{ percentage, isPassed, blocked, overshoot } | null } }
    var step5State = {};
    var step5Idx = 0;

    function step5SelectedWorkers() {
        return Array.from(document.querySelectorAll('#userCheckboxContainer .user-checkbox:checked'));
    }
    function step5WorkerName(cb) {
        var l = document.querySelector('label[for="' + cb.id + '"]');
        var s = l && l.querySelector('strong');
        return s ? s.textContent : (l ? l.textContent.trim() : cb.value);
    }
    // NIP tak tersedia di client (picker pakai user.Id); tampilkan nama saja. Server resolve NIP.
    function step5DefaultMode() {
        var r = document.querySelector('input[name="step5DefaultMode"]:checked');
        return r ? r.value : 'manual';
    }
    function step5HasEssay() {
        return injQuestions.some(function (q) { return q.QuestionType === 'Essay'; });
    }

    // Rebuild state saat masuk Step-5: prune worker unchecked + prune answer ber-qTempId dangling.
    function step5Rebuild() {
        var workers = step5SelectedWorkers();
        var noWorkers = document.getElementById('step5EmptyNoWorkers');
        var noQuestions = document.getElementById('step5EmptyNoQuestions');
        var body = document.getElementById('step5Body');
        if (!body) return;

        var hasWorkers = workers.length > 0;
        var hasQuestions = injQuestions.length > 0;
        // Empty no-workers diutamakan; no-questions hanya tampil bila ada pekerja tapi belum ada soal.
        if (noWorkers) noWorkers.classList.toggle('d-none', hasWorkers);
        if (noQuestions) noQuestions.classList.toggle('d-none', !(hasWorkers && !hasQuestions));
        if (body) body.classList.toggle('d-none', !(hasWorkers && hasQuestions));
        if (!hasWorkers || !hasQuestions) { return; }

        var validQTempIds = {};
        injQuestions.forEach(function (q) { validQTempIds[q.TempId] = true; });
        var defMode = step5DefaultMode();

        // Bangun ulang state per worker tercentang (pertahankan jawaban existing yang valid).
        var nextState = {};
        workers.forEach(function (cb) {
            var prev = step5State[cb.value];
            var ws = prev || { mode: defMode, targetScore: 80, answers: {}, preview: null };
            // prune answers dgn qTempId yang tak ada lagi
            var prunedAnswers = {};
            Object.keys(ws.answers || {}).forEach(function (k) {
                if (validQTempIds[k]) prunedAnswers[k] = ws.answers[k];
            });
            ws.answers = prunedAnswers;
            if (!ws.mode) ws.mode = defMode;
            nextState[cb.value] = ws;
        });
        step5State = nextState;

        if (step5Idx >= workers.length) step5Idx = 0;
        step5RenderWorker();
        step5RenderRoster();
    }

    function step5CurrentWorker() {
        var workers = step5SelectedWorkers();
        if (workers.length === 0) return null;
        if (step5Idx >= workers.length) step5Idx = workers.length - 1;
        if (step5Idx < 0) step5Idx = 0;
        return workers[step5Idx];
    }

    // Render indikator + toggle mode + form jawaban untuk pekerja aktif.
    function step5RenderWorker() {
        var workers = step5SelectedWorkers();
        var cb = step5CurrentWorker();
        if (!cb) return;
        var ws = step5State[cb.value];

        // Indikator pekerja (textContent XSS-safe)
        var headingEl = document.getElementById('step5WorkerHeading');
        if (headingEl) headingEl.textContent = 'Pekerja ' + (step5Idx + 1) + ' dari ' + workers.length + ' — ' + step5WorkerName(cb);

        // Disable kontrol di ujung
        var prevBtn = document.getElementById('step5PrevWorker');
        var nextBtn = document.getElementById('step5NextWorker');
        if (prevBtn) prevBtn.disabled = (step5Idx <= 0);
        if (nextBtn) nextBtn.disabled = (step5Idx >= workers.length - 1);

        // Toggle mode per-pekerja
        var modeManual = document.getElementById('step5ModeManual');
        var modeAuto = document.getElementById('step5ModeAuto');
        if (modeManual) modeManual.checked = (ws.mode !== 'auto');
        if (modeAuto) modeAuto.checked = (ws.mode === 'auto');

        // Body auto-gen (target + HYBRID banner)
        var autoBody = document.getElementById('step5AutoBody');
        if (autoBody) autoBody.classList.toggle('d-none', ws.mode !== 'auto');
        var targetInput = document.getElementById('step5TargetScore');
        if (targetInput) targetInput.value = (ws.targetScore != null ? ws.targetScore : 80);
        var hybridBanner = document.getElementById('step5HybridBanner');
        if (hybridBanner) hybridBanner.classList.toggle('d-none', !(ws.mode === 'auto' && step5HasEssay()));

        // Form jawaban
        step5RenderAnswerForm(cb);

        // Reset permukaan pratinjau + blocking saat pindah/ubah mode
        step5RenderPreviewSurface(ws.preview);
        step5RenderBlocking(ws.preview);
    }

    // Render soal: input-asli (MC/MA/Essay) penuh; auto-gen hanya essay (HYBRID D-08.1).
    function step5RenderAnswerForm(cb) {
        var container = document.getElementById('step5AnswerForm');
        if (!container) return;
        container.innerHTML = '';
        var ws = step5State[cb.value];
        var auto = (ws.mode === 'auto');

        injQuestions.forEach(function (q, qi) {
            var isEssay = (q.QuestionType === 'Essay');
            // Auto-gen: MC/MA tidak dirender (server hitung); hanya essay (HYBRID).
            if (auto && !isEssay) return;

            var ans = ws.answers[q.TempId] || (ws.answers[q.TempId] = { selected: [], text: '', score: null, skipped: false });

            var block = document.createElement('div');
            block.className = 'mb-3 pb-3 border-bottom';

            var head = document.createElement('div');
            head.className = 'd-flex justify-content-between align-items-start mb-2';
            var qLabel = document.createElement('div');
            var num = document.createElement('span'); num.className = 'fw-bold me-1'; num.textContent = (qi + 1) + '.';
            var qText = document.createElement('span'); qText.textContent = q.QuestionText;   // XSS-safe
            qLabel.appendChild(num); qLabel.appendChild(qText);
            var badge = document.createElement('span'); badge.className = 'badge bg-secondary small ms-2'; badge.textContent = injTypeLabel(q.QuestionType);
            head.appendChild(qLabel); head.appendChild(badge);
            block.appendChild(head);

            // Skip checkbox (input-asli saja; auto essay tetap wajib)
            if (!auto) {
                var skipWrap = document.createElement('div');
                skipWrap.className = 'form-check form-check-inline mb-2';
                var skipInput = document.createElement('input');
                skipInput.className = 'form-check-input'; skipInput.type = 'checkbox';
                skipInput.id = 'step5Skip_' + q.TempId; skipInput.checked = !!ans.skipped;
                var skipLabel = document.createElement('label');
                skipLabel.className = 'form-check-label small text-muted'; skipLabel.setAttribute('for', skipInput.id);
                skipLabel.textContent = 'Lewati soal ini (dihitung 0)';
                skipInput.addEventListener('change', function () {
                    ans.skipped = skipInput.checked;
                    step5RenderAnswerForm(cb);
                });
                skipWrap.appendChild(skipInput); skipWrap.appendChild(skipLabel);
                block.appendChild(skipWrap);
            }

            var letters = ['A', 'B', 'C', 'D', 'E', 'F'];
            if ((q.QuestionType === 'MultipleChoice' || q.QuestionType === 'MultipleAnswer') && !auto) {
                (q.Options || []).forEach(function (opt, oi) {
                    var row = document.createElement('div'); row.className = 'form-check';
                    var input = document.createElement('input');
                    input.className = 'form-check-input';
                    input.type = (q.QuestionType === 'MultipleAnswer') ? 'checkbox' : 'radio';
                    input.name = 'step5q_' + q.TempId;
                    input.value = opt.TempId;
                    input.disabled = !!ans.skipped;
                    input.setAttribute('aria-label', 'opsi ' + (letters[oi] || (oi + 1)));
                    input.checked = ans.selected.indexOf(opt.TempId) !== -1;
                    input.addEventListener('change', function () {
                        if (q.QuestionType === 'MultipleAnswer') {
                            if (input.checked) { if (ans.selected.indexOf(opt.TempId) === -1) ans.selected.push(opt.TempId); }
                            else { ans.selected = ans.selected.filter(function (x) { return x !== opt.TempId; }); }
                        } else {
                            ans.selected = input.checked ? [opt.TempId] : [];
                        }
                    });
                    var lbl = document.createElement('label'); lbl.className = 'form-check-label';
                    var ltr = document.createElement('span'); ltr.className = 'fw-bold me-1'; ltr.textContent = (letters[oi] || (oi + 1)) + '.';
                    var otxt = document.createElement('span'); otxt.textContent = opt.OptionText;   // XSS-safe
                    lbl.appendChild(ltr); lbl.appendChild(otxt);
                    row.appendChild(input); row.appendChild(lbl);
                    block.appendChild(row);
                });
                if (q.QuestionType === 'MultipleAnswer') {
                    var hint = document.createElement('div');
                    hint.className = 'alert alert-info py-1 px-2 small mb-0 mt-1';
                    hint.textContent = 'Centang semua opsi yang dipilih pekerja.';
                    block.appendChild(hint);
                }
            } else if (isEssay) {
                // Essay: textarea teks + input skor (input-asli & auto HYBRID).
                var ta = document.createElement('textarea');
                ta.className = 'form-control mb-1'; ta.rows = 3; ta.value = ans.text || '';
                ta.id = 'step5EssayText_' + q.TempId;
                ta.placeholder = 'Teks jawaban essay';
                ta.disabled = !!ans.skipped;
                ta.addEventListener('input', function () {
                    ans.text = ta.value;
                    ta.classList.remove('is-invalid');
                    var fb = document.getElementById('step5EssayErr_' + q.TempId);
                    if (fb) fb.style.display = 'none';
                });
                block.appendChild(ta);

                // D-04 inline error slot (UI-SPEC K3) — teks essay wajib bila skor diisi.
                var essayErr = document.createElement('div');
                essayErr.id = 'step5EssayErr_' + q.TempId;
                essayErr.className = 'text-danger small mb-2';
                essayErr.style.display = 'none';
                essayErr.textContent = 'Teks jawaban essay wajib diisi karena skornya diisi.';
                block.appendChild(essayErr);

                var scoreWrap = document.createElement('div'); scoreWrap.style.maxWidth = '220px';
                var scoreLbl = document.createElement('label'); scoreLbl.className = 'form-label fw-bold';
                scoreLbl.textContent = 'Skor Essay (0–' + q.ScoreValue + ')';
                var scoreInput = document.createElement('input');
                scoreInput.className = 'form-control'; scoreInput.type = 'number'; scoreInput.min = 0; scoreInput.max = q.ScoreValue;
                scoreInput.value = (ans.score != null ? ans.score : '');
                scoreInput.disabled = !!ans.skipped;
                scoreInput.addEventListener('input', function () {
                    var v = parseInt(scoreInput.value, 10);
                    ans.score = isNaN(v) ? null : v;
                });
                scoreWrap.appendChild(scoreLbl); scoreWrap.appendChild(scoreInput);
                block.appendChild(scoreWrap);
            }

            container.appendChild(block);
        });
    }

    // Roster ringkas (K1) — render via .textContent.
    function step5RenderRoster() {
        var body = document.getElementById('step5RosterBody');
        if (!body) return;
        body.innerHTML = '';
        var workers = step5SelectedWorkers();
        workers.forEach(function (cb, i) {
            var ws = step5State[cb.value] || {};
            var tr = document.createElement('tr');
            if (i === step5Idx) tr.className = 'table-active';
            tr.style.cursor = 'pointer';
            tr.addEventListener('click', function () { step5Idx = i; step5RenderWorker(); step5RenderRoster(); });

            var tdNum = document.createElement('td'); tdNum.className = 'text-muted'; tdNum.textContent = (i + 1);
            var tdName = document.createElement('td'); tdName.textContent = step5WorkerName(cb);   // XSS-safe
            var tdMode = document.createElement('td');
            var modeBadge = document.createElement('span');
            modeBadge.className = 'badge ' + (ws.mode === 'auto' ? 'bg-primary' : 'bg-secondary');
            modeBadge.textContent = (ws.mode === 'auto' ? 'Auto' : 'Input asli');
            tdMode.appendChild(modeBadge);

            var tdScore = document.createElement('td');
            if (ws.preview && !ws.preview.blocked) {
                var sBadge = document.createElement('span');
                sBadge.className = 'badge ' + (ws.preview.isPassed ? 'bg-success' : 'bg-danger');
                sBadge.textContent = ws.preview.percentage + '% ' + (ws.preview.isPassed ? 'Lulus' : 'Tidak Lulus');
                tdScore.appendChild(sBadge);
            } else {
                tdScore.textContent = '—';
            }

            var tdStatus = document.createElement('td'); tdStatus.className = 'text-center';
            var icon = document.createElement('i');
            if (ws.preview && ws.preview.blocked) icon.className = 'bi bi-x-circle-fill text-danger';
            else if (ws.preview) icon.className = 'bi bi-check-circle-fill text-success';
            else icon.className = 'bi bi-exclamation-triangle-fill text-warning';
            tdStatus.appendChild(icon);

            tr.appendChild(tdNum); tr.appendChild(tdName); tr.appendChild(tdMode); tr.appendChild(tdScore); tr.appendChild(tdStatus);
            body.appendChild(tr);
        });
    }

    // Bangun answers array 1 worker (non-skipped → spec; auto MC/MA TIDAK dikirim, server hitung).
    function step5WorkerAnswers(ws) {
        var auto = (ws.mode === 'auto');
        var out = [];
        injQuestions.forEach(function (q) {
            var ans = ws.answers[q.TempId];
            if (!ans) return;
            var isEssay = (q.QuestionType === 'Essay');
            // Auto: hanya essay manual (HYBRID); MC/MA dihitung server.
            if (auto && !isEssay) return;
            if (!auto && ans.skipped) return;   // skip=OMIT (D-05) — JANGAN push answer
            if (isEssay) {
                out.push({ questionTempId: q.TempId, selectedOptionTempIds: [], textAnswer: (ans.text || null), essayScore: (ans.score != null ? ans.score : null) });
            } else {
                out.push({ questionTempId: q.TempId, selectedOptionTempIds: (ans.selected || []).slice(), textAnswer: null, essayScore: null });
            }
        });
        return out;
    }

    // Payload #AnswersJson (semua worker terpilih) — bentuk InjectWorkerAnswersVM.
    function buildWorkerAnswersPayload() {
        return step5SelectedWorkers().map(function (cb) {
            var ws = step5State[cb.value] || { mode: step5DefaultMode(), targetScore: 80, answers: {} };
            return {
                userId: cb.value,
                mode: ws.mode || 'manual',
                targetScore: (ws.targetScore != null ? ws.targetScore : 0),
                answers: step5WorkerAnswers(ws)
            };
        });
    }
    window.injBuildWorkerAnswers = buildWorkerAnswersPayload;

    // Bentuk soal yang dikirim ke endpoint preview (InjectQuestionSpec subset).
    function step5QuestionSpecs() {
        return injQuestions.map(function (q, i) {
            return {
                questionText: q.QuestionText, questionType: q.QuestionType, scoreValue: q.ScoreValue,
                order: i, tempId: q.TempId,
                options: (q.Options || []).map(function (o) { return { optionText: o.OptionText, isCorrect: o.IsCorrect, tempId: o.TempId }; })
            };
        });
    }

    function step5PassPercentage() {
        var el = document.getElementById('PassPercentage');
        var v = el ? parseInt(el.value, 10) : 70;
        return isNaN(v) ? 70 : v;
    }
    function step5CompletedAt() {
        var el = document.getElementById('CompletedAt');
        return el && el.value ? el.value : INJ_TODAY;
    }

    function step5RenderPreviewSurface(preview) {
        var box = document.getElementById('step5PreviewResult');
        if (!box) return;
        if (!preview || preview.blocked) { box.style.display = 'none'; box.innerHTML = ''; return; }
        box.style.display = 'block';
        box.innerHTML = '';
        var alert = document.createElement('div');
        alert.className = 'alert ' + (preview.isPassed ? 'alert-success' : 'alert-warning') + ' mb-0';
        var scoreSpan = document.createElement('span');
        scoreSpan.className = 'fs-4 fw-bold me-2'; scoreSpan.textContent = preview.percentage + '%';
        var badge = document.createElement('span');
        badge.className = 'badge ' + (preview.isPassed ? 'bg-success' : 'bg-danger');
        badge.textContent = preview.isPassed ? 'Lulus' : 'Tidak Lulus';
        alert.appendChild(scoreSpan); alert.appendChild(badge);
        box.appendChild(alert);
        if (preview.overshoot && preview.overshoot > 0 && preview.targetScore != null) {
            var note = document.createElement('div');
            note.className = 'form-text text-muted';
            note.textContent = 'Target ' + preview.targetScore + '% → capaian aktual ' + preview.percentage + '% (+' + preview.overshoot + ') karena pembulatan.';
            box.appendChild(note);
        }
    }

    function step5RenderBlocking(preview) {
        var blockEl = document.getElementById('step5Blocking');
        if (!blockEl) return;
        if (preview && preview.blocked) {
            blockEl.classList.remove('d-none');
            var msgEl = document.getElementById('step5BlockingMsg');
            if (msgEl) msgEl.textContent = preview.blockingMessage || 'Target tidak tercapai. Beralih ke input asli.';
        } else {
            blockEl.classList.add('d-none');
        }
    }

    // D-04 (UI-SPEC K3): validasi inline teks-essay WAJIB bila skor diisi — saat Pratinjau.
    // Hanya worker saat ini (form yang ter-render di DOM). Essay di-skip (input-asli, D-05) = omit → tak divalidasi.
    // Auto-gen HYBRID: essay selalu engaged (manual). Selaras guard server PreflightValidateAsync (commit) → preview == commit.
    function step5ValidateCurrentEssays(ws) {
        var invalidCount = 0;
        injQuestions.forEach(function (q) {
            if (q.QuestionType !== 'Essay') return;
            var taEl = document.getElementById('step5EssayText_' + q.TempId);
            var errEl = document.getElementById('step5EssayErr_' + q.TempId);
            if (taEl) taEl.classList.remove('is-invalid');
            if (errEl) errEl.style.display = 'none';
            var ans = ws.answers[q.TempId];
            if (!ans) return;
            var engaged = (ws.mode === 'auto') ? true : !ans.skipped;
            if (!engaged) return;
            if (ans.score != null && (!ans.text || !ans.text.trim())) {
                if (taEl) taEl.classList.add('is-invalid');
                if (errEl) errEl.style.display = 'block';
                invalidCount++;
            }
        });
        return invalidCount;
    }

    // ---- Wiring Step-5 ----
    (function wireStep5() {
        var prevBtn = document.getElementById('step5PrevWorker');
        var nextBtn = document.getElementById('step5NextWorker');
        if (prevBtn) prevBtn.addEventListener('click', function () { if (step5Idx > 0) { step5Idx--; step5RenderWorker(); step5RenderRoster(); } });
        if (nextBtn) nextBtn.addEventListener('click', function () {
            if (step5Idx < step5SelectedWorkers().length - 1) { step5Idx++; step5RenderWorker(); step5RenderRoster(); }
        });

        // Toggle mode per-pekerja
        document.querySelectorAll('input[name="step5WorkerMode"]').forEach(function (r) {
            r.addEventListener('change', function () {
                var cb = step5CurrentWorker(); if (!cb) return;
                step5State[cb.value].mode = r.value;
                step5State[cb.value].preview = null;   // mode berubah → pratinjau lama tak valid
                step5RenderWorker(); step5RenderRoster();
            });
        });

        // Target score input
        var targetInput = document.getElementById('step5TargetScore');
        if (targetInput) targetInput.addEventListener('input', function () {
            var cb = step5CurrentWorker(); if (!cb) return;
            var v = parseInt(targetInput.value, 10);
            step5State[cb.value].targetScore = isNaN(v) ? 0 : v;
            step5State[cb.value].preview = null;
        });

        // Switch BLOCKING → input asli (D-10): set mode manual, pre-fill grid (pola auto-gen terakhir tak tersedia di klien → biarkan HC isi)
        var switchBtn = document.getElementById('step5SwitchToManual');
        if (switchBtn) switchBtn.addEventListener('click', function () {
            var cb = step5CurrentWorker(); if (!cb) return;
            step5State[cb.value].mode = 'manual';
            step5State[cb.value].preview = null;
            step5RenderWorker(); step5RenderRoster();
        });

        // Pratinjau Skor (K5) — POST PreviewInjectScore (D-09 server-otoritas).
        var previewBtn = document.getElementById('step5PreviewBtn');
        if (previewBtn) previewBtn.addEventListener('click', function () {
            var cb = step5CurrentWorker(); if (!cb) return;
            var ws = step5State[cb.value];
            // D-04 inline (UI-SPEC K3): teks essay wajib bila skor diisi — cegah preview menyesatkan (preview == commit).
            if (step5ValidateCurrentEssays(ws) > 0) return;
            var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
            var token = tokenEl ? tokenEl.value : '';
            var url = previewBtn.getAttribute('data-preview-url');

            var reqBody = {
                passPercentage: step5PassPercentage(),
                title: (document.getElementById('Title').value || ''),
                category: (function () { var c = document.getElementById('Category'); return c ? c.value : ''; })(),
                completedAt: step5CompletedAt(),
                nip: cb.value,   // server resolve sebenarnya pakai NIP; di preview seed pakai field ini (advisory)
                mode: ws.mode || 'manual',
                targetScore: (ws.targetScore != null ? ws.targetScore : 0),
                questions: step5QuestionSpecs(),
                answers: step5WorkerAnswers(ws)
            };

            var origHtml = previewBtn.innerHTML;
            previewBtn.disabled = true;
            previewBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Menghitung skor…';

            fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify(reqBody)
            })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    ws.preview = {
                        percentage: data.percentage,
                        isPassed: data.isPassed,
                        blocked: data.blocked,
                        overshoot: data.overshoot,
                        blockingMessage: data.blockingMessage,
                        targetScore: (ws.mode === 'auto' ? ws.targetScore : null)
                    };
                    step5RenderPreviewSurface(ws.preview);
                    step5RenderBlocking(ws.preview);
                    step5RenderRoster();
                })
                .catch(function () {
                    var box = document.getElementById('step5PreviewResult');
                    if (box) { box.style.display = 'block'; box.innerHTML = '<div class="alert alert-danger mb-0">Gagal menghitung pratinjau. Coba lagi.</div>'; }
                })
                .finally(function () { previewBtn.disabled = false; previewBtn.innerHTML = origHtml; });
        });
    })();

    // expose for later-plan hooks
    window.injWizard = { goToStep: goToStep, validateStep: validateStep };

    updatePills();
})();
</script>
}
