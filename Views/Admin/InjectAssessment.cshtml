    // ============================================================================
    // Phase 395 — Step-5 sub-komponen ber-state (1-pekerja-per-layar, D-03)
    // IIFE-scoped state independen goToStep luar; render via .textContent (XSS-safe).
    // ============================================================================
    // workerState: { [userId]: { mode:'manual'|'auto', targetScore:int,
    //                            answers:{ [qTempId]:{ selected:[], text, score, skipped } },
    //                            preview:{ percentage, isPassed, blocked, overshoot } | null } }
    var step5State = {};
    var step5Idx = 0;

    function step5SelectedWorkers() {
        return Array.from(document.querySelectorAll('#userCheckboxContainer .user-checkbox:checked'));
    }
    function step5WorkerName(cb) {
        var l = document.querySelector('label[for="' + cb.id + '"]');
        var s = l && l.querySelector('strong');
        return s ? s.textContent : (l ? l.textContent.trim() : cb.value);
    }
    // NIP tak tersedia di client (picker pakai user.Id); tampilkan nama saja. Server resolve NIP.
    function step5DefaultMode() {
        var r = document.querySelector('input[name="step5DefaultMode"]:checked');
        return r ? r.value : 'manual';
    }
    function step5HasEssay() {
        return injQuestions.some(function (q) { return q.QuestionType === 'Essay'; });
    }

    // Rebuild state saat masuk Step-5: prune worker unchecked + prune answer ber-qTempId dangling.
    function step5Rebuild() {
        var workers = step5SelectedWorkers();
        var noWorkers = document.getElementById('step5EmptyNoWorkers');
        var noQuestions = document.getElementById('step5EmptyNoQuestions');
        var body = document.getElementById('step5Body');
        if (!body) return;

        var hasWorkers = workers.length > 0;
        var hasQuestions = injQuestions.length > 0;
        // Empty no-workers diutamakan; no-questions hanya tampil bila ada pekerja tapi belum ada soal.
        if (noWorkers) noWorkers.classList.toggle('d-none', hasWorkers);
        if (noQuestions) noQuestions.classList.toggle('d-none', !(hasWorkers && !hasQuestions));
        if (body) body.classList.toggle('d-none', !(hasWorkers && hasQuestions));
        if (!hasWorkers || !hasQuestions) { return; }

        var validQTempIds = {};
        injQuestions.forEach(function (q) { validQTempIds[q.TempId] = true; });
        var defMode = step5DefaultMode();

        // Bangun ulang state per worker tercentang (pertahankan jawaban existing yang valid).
        var nextState = {};
        workers.forEach(function (cb) {
            var prev = step5State[cb.value];
            var ws = prev || { mode: defMode, targetScore: 80, answers: {}, preview: null };
            // prune answers dgn qTempId yang tak ada lagi
            var prunedAnswers = {};
            Object.keys(ws.answers || {}).forEach(function (k) {
                if (validQTempIds[k]) prunedAnswers[k] = ws.answers[k];
            });
            ws.answers = prunedAnswers;
            if (!ws.mode) ws.mode = defMode;
            nextState[cb.value] = ws;
        });
        step5State = nextState;

        if (step5Idx >= workers.length) step5Idx = 0;
        step5RenderWorker();
        step5RenderRoster();
    }

    function step5CurrentWorker() {
        var workers = step5SelectedWorkers();
        if (workers.length === 0) return null;
        if (step5Idx >= workers.length) step5Idx = workers.length - 1;
        if (step5Idx < 0) step5Idx = 0;
        return workers[step5Idx];
    }

    // Render indikator + toggle mode + form jawaban untuk pekerja aktif.
    function step5RenderWorker() {
        var workers = step5SelectedWorkers();
        var cb = step5CurrentWorker();
        if (!cb) return;
        var ws = step5State[cb.value];

        // Indikator pekerja (textContent XSS-safe)
        var headingEl = document.getElementById('step5WorkerHeading');
        if (headingEl) headingEl.textContent = 'Pekerja ' + (step5Idx + 1) + ' dari ' + workers.length + ' — ' + step5WorkerName(cb);

        // Disable kontrol di ujung
        var prevBtn = document.getElementById('step5PrevWorker');
        var nextBtn = document.getElementById('step5NextWorker');
        if (prevBtn) prevBtn.disabled = (step5Idx <= 0);
        if (nextBtn) nextBtn.disabled = (step5Idx >= workers.length - 1);

        // Toggle mode per-pekerja
        var modeManual = document.getElementById('step5ModeManual');
        var modeAuto = document.getElementById('step5ModeAuto');
        if (modeManual) modeManual.checked = (ws.mode !== 'auto');
        if (modeAuto) modeAuto.checked = (ws.mode === 'auto');

        // Body auto-gen (target + HYBRID banner)
        var autoBody = document.getElementById('step5AutoBody');
        if (autoBody) autoBody.classList.toggle('d-none', ws.mode !== 'auto');
        var targetInput = document.getElementById('step5TargetScore');
        if (targetInput) targetInput.value = (ws.targetScore != null ? ws.targetScore : 80);
        var hybridBanner = document.getElementById('step5HybridBanner');
        if (hybridBanner) hybridBanner.classList.toggle('d-none', !(ws.mode === 'auto' && step5HasEssay()));

        // Form jawaban
        step5RenderAnswerForm(cb);

        // Reset permukaan pratinjau + blocking saat pindah/ubah mode
        step5RenderPreviewSurface(ws.preview);
        step5RenderBlocking(ws.preview);
    }

    // Render soal: input-asli (MC/MA/Essay) penuh; auto-gen hanya essay (HYBRID D-08.1).
    function step5RenderAnswerForm(cb) {
        var container = document.getElementById('step5AnswerForm');
        if (!container) return;
        container.innerHTML = '';
        var ws = step5State[cb.value];
        var auto = (ws.mode === 'auto');

        injQuestions.forEach(function (q, qi) {
            var isEssay = (q.QuestionType === 'Essay');
            // Auto-gen: MC/MA tidak dirender (server hitung); hanya essay (HYBRID).
            if (auto && !isEssay) return;

            var ans = ws.answers[q.TempId] || (ws.answers[q.TempId] = { selected: [], text: '', score: null, skipped: false });

            var block = document.createElement('div');
            block.className = 'mb-3 pb-3 border-bottom';

            var head = document.createElement('div');
            head.className = 'd-flex justify-content-between align-items-start mb-2';
            var qLabel = document.createElement('div');
            var num = document.createElement('span'); num.className = 'fw-bold me-1'; num.textContent = (qi + 1) + '.';
            var qText = document.createElement('span'); qText.textContent = q.QuestionText;   // XSS-safe
            qLabel.appendChild(num); qLabel.appendChild(qText);
            var badge = document.createElement('span'); badge.className = 'badge bg-secondary small ms-2'; badge.textContent = injTypeLabel(q.QuestionType);
            head.appendChild(qLabel); head.appendChild(badge);
            block.appendChild(head);

            // Skip checkbox (input-asli saja; auto essay tetap wajib)
            if (!auto) {
                var skipWrap = document.createElement('div');
                skipWrap.className = 'form-check form-check-inline mb-2';
                var skipInput = document.createElement('input');
                skipInput.className = 'form-check-input'; skipInput.type = 'checkbox';
                skipInput.id = 'step5Skip_' + q.TempId; skipInput.checked = !!ans.skipped;
                var skipLabel = document.createElement('label');
                skipLabel.className = 'form-check-label small text-muted'; skipLabel.setAttribute('for', skipInput.id);
                skipLabel.textContent = 'Lewati soal ini (dihitung 0)';
                skipInput.addEventListener('change', function () {
                    ans.skipped = skipInput.checked;
                    step5RenderAnswerForm(cb);
                });
                skipWrap.appendChild(skipInput); skipWrap.appendChild(skipLabel);
                block.appendChild(skipWrap);
            }

            var letters = ['A', 'B', 'C', 'D', 'E', 'F'];
            if ((q.QuestionType === 'MultipleChoice' || q.QuestionType === 'MultipleAnswer') && !auto) {
                (q.Options || []).forEach(function (opt, oi) {
                    var row = document.createElement('div'); row.className = 'form-check';
                    var input = document.createElement('input');
                    input.className = 'form-check-input';
                    input.type = (q.QuestionType === 'MultipleAnswer') ? 'checkbox' : 'radio';
                    input.name = 'step5q_' + q.TempId;
                    input.value = opt.TempId;
                    input.disabled = !!ans.skipped;
                    input.setAttribute('aria-label', 'opsi ' + (letters[oi] || (oi + 1)));
                    input.checked = ans.selected.indexOf(opt.TempId) !== -1;
                    input.addEventListener('change', function () {
                        if (q.QuestionType === 'MultipleAnswer') {
                            if (input.checked) { if (ans.selected.indexOf(opt.TempId) === -1) ans.selected.push(opt.TempId); }
                            else { ans.selected = ans.selected.filter(function (x) { return x !== opt.TempId; }); }
                        } else {
                            ans.selected = input.checked ? [opt.TempId] : [];
                        }
                    });
                    var lbl = document.createElement('label'); lbl.className = 'form-check-label';
                    var ltr = document.createElement('span'); ltr.className = 'fw-bold me-1'; ltr.textContent = (letters[oi] || (oi + 1)) + '.';
                    var otxt = document.createElement('span'); otxt.textContent = opt.OptionText;   // XSS-safe
                    lbl.appendChild(ltr); lbl.appendChild(otxt);
                    row.appendChild(input); row.appendChild(lbl);
                    block.appendChild(row);
                });
                if (q.QuestionType === 'MultipleAnswer') {
                    var hint = document.createElement('div');
                    hint.className = 'alert alert-info py-1 px-2 small mb-0 mt-1';
                    hint.textContent = 'Centang semua opsi yang dipilih pekerja.';
                    block.appendChild(hint);
                }
            } else if (isEssay) {
                // Essay: textarea teks + input skor (input-asli & auto HYBRID).
                var ta = document.createElement('textarea');
                ta.className = 'form-control mb-1'; ta.rows = 3; ta.value = ans.text || '';
                ta.id = 'step5EssayText_' + q.TempId;
                ta.placeholder = 'Teks jawaban essay';
                ta.disabled = !!ans.skipped;
                ta.addEventListener('input', function () {
                    ans.text = ta.value;
                    ta.classList.remove('is-invalid');
                    var fb = document.getElementById('step5EssayErr_' + q.TempId);
                    if (fb) fb.style.display = 'none';
                });
                block.appendChild(ta);

                // D-04 inline error slot (UI-SPEC K3) — teks essay wajib bila skor diisi.
                var essayErr = document.createElement('div');
                essayErr.id = 'step5EssayErr_' + q.TempId;
                essayErr.className = 'text-danger small mb-2';
                essayErr.style.display = 'none';
                essayErr.textContent = 'Teks jawaban essay wajib diisi karena skornya diisi.';
                block.appendChild(essayErr);

                var scoreWrap = document.createElement('div'); scoreWrap.style.maxWidth = '220px';
                var scoreLbl = document.createElement('label'); scoreLbl.className = 'form-label fw-bold';
                scoreLbl.textContent = 'Skor Essay (0–' + q.ScoreValue + ')';
                var scoreInput = document.createElement('input');
                scoreInput.className = 'form-control'; scoreInput.type = 'number'; scoreInput.min = 0; scoreInput.max = q.ScoreValue;
                scoreInput.value = (ans.score != null ? ans.score : '');
                scoreInput.disabled = !!ans.skipped;
                scoreInput.addEventListener('input', function () {
                    var v = parseInt(scoreInput.value, 10);
                    ans.score = isNaN(v) ? null : v;
                });
                scoreWrap.appendChild(scoreLbl); scoreWrap.appendChild(scoreInput);
                block.appendChild(scoreWrap);
            }

            container.appendChild(block);
        });
    }

    // Roster ringkas (K1) — render via .textContent.
    function step5RenderRoster() {
        var body = document.getElementById('step5RosterBody');
        if (!body) return;
        body.innerHTML = '';
        var workers = step5SelectedWorkers();
        workers.forEach(function (cb, i) {
            var ws = step5State[cb.value] || {};
            var tr = document.createElement('tr');
            if (i === step5Idx) tr.className = 'table-active';
            tr.style.cursor = 'pointer';
            tr.addEventListener('click', function () { step5Idx = i; step5RenderWorker(); step5RenderRoster(); });

            var tdNum = document.createElement('td'); tdNum.className = 'text-muted'; tdNum.textContent = (i + 1);
            var tdName = document.createElement('td'); tdName.textContent = step5WorkerName(cb);   // XSS-safe
            var tdMode = document.createElement('td');
            var modeBadge = document.createElement('span');
            modeBadge.className = 'badge ' + (ws.mode === 'auto' ? 'bg-primary' : 'bg-secondary');
            modeBadge.textContent = (ws.mode === 'auto' ? 'Auto' : 'Input asli');
            tdMode.appendChild(modeBadge);

            var tdScore = document.createElement('td');
            if (ws.preview && !ws.preview.blocked) {
                var sBadge = document.createElement('span');
                sBadge.className = 'badge ' + (ws.preview.isPassed ? 'bg-success' : 'bg-danger');
                sBadge.textContent = ws.preview.percentage + '% ' + (ws.preview.isPassed ? 'Lulus' : 'Tidak Lulus');
                tdScore.appendChild(sBadge);
            } else {
                tdScore.textContent = '—';
            }

            var tdStatus = document.createElement('td'); tdStatus.className = 'text-center';
            var icon = document.createElement('i');
            if (ws.preview && ws.preview.blocked) icon.className = 'bi bi-x-circle-fill text-danger';
            else if (ws.preview) icon.className = 'bi bi-check-circle-fill text-success';
            else icon.className = 'bi bi-exclamation-triangle-fill text-warning';
            tdStatus.appendChild(icon);

            tr.appendChild(tdNum); tr.appendChild(tdName); tr.appendChild(tdMode); tr.appendChild(tdScore); tr.appendChild(tdStatus);
            body.appendChild(tr);
        });
    }

    // Bangun answers array 1 worker (non-skipped → spec; auto MC/MA TIDAK dikirim, server hitung).
    function step5WorkerAnswers(ws) {
        var auto = (ws.mode === 'auto');
        var out = [];
        injQuestions.forEach(function (q) {
            var ans = ws.answers[q.TempId];
            if (!ans) return;
            var isEssay = (q.QuestionType === 'Essay');
            // Auto: hanya essay manual (HYBRID); MC/MA dihitung server.
            if (auto && !isEssay) return;
            if (!auto && ans.skipped) return;   // skip=OMIT (D-05) — JANGAN push answer
            if (isEssay) {
                out.push({ questionTempId: q.TempId, selectedOptionTempIds: [], textAnswer: (ans.text || null), essayScore: (ans.score != null ? ans.score : null) });
            } else {
                out.push({ questionTempId: q.TempId, selectedOptionTempIds: (ans.selected || []).slice(), textAnswer: null, essayScore: null });
            }
        });
        return out;
    }

    // Payload #AnswersJson (semua worker terpilih) — bentuk InjectWorkerAnswersVM.
    function buildWorkerAnswersPayload() {
        return step5SelectedWorkers().map(function (cb) {
            var ws = step5State[cb.value] || { mode: step5DefaultMode(), targetScore: 80, answers: {} };
            return {
                userId: cb.value,
                mode: ws.mode || 'manual',
                targetScore: (ws.targetScore != null ? ws.targetScore : 0),
                answers: step5WorkerAnswers(ws)
            };
        });
    }
    window.injBuildWorkerAnswers = buildWorkerAnswersPayload;

    // Bentuk soal yang dikirim ke endpoint preview (InjectQuestionSpec subset).
    function step5QuestionSpecs() {
        return injQuestions.map(function (q, i) {
            return {
                questionText: q.QuestionText, questionType: q.QuestionType, scoreValue: q.ScoreValue,
                order: i, tempId: q.TempId,
                options: (q.Options || []).map(function (o) { return { optionText: o.OptionText, isCorrect: o.IsCorrect, tempId: o.TempId }; })
            };
        });
    }

    function step5PassPercentage() {
        var el = document.getElementById('PassPercentage');
        var v = el ? parseInt(el.value, 10) : 70;
        return isNaN(v) ? 70 : v;
    }
    function step5CompletedAt() {
        var el = document.getElementById('CompletedAt');
        return el && el.value ? el.value : INJ_TODAY;
    }

    function step5RenderPreviewSurface(preview) {
        var box = document.getElementById('step5PreviewResult');
        if (!box) return;
        if (!preview || preview.blocked) { box.style.display = 'none'; box.innerHTML = ''; return; }
        box.style.display = 'block';
        box.innerHTML = '';
        var alert = document.createElement('div');
        alert.className = 'alert ' + (preview.isPassed ? 'alert-success' : 'alert-warning') + ' mb-0';
        var scoreSpan = document.createElement('span');
        scoreSpan.className = 'fs-4 fw-bold me-2'; scoreSpan.textContent = preview.percentage + '%';
        var badge = document.createElement('span');
        badge.className = 'badge ' + (preview.isPassed ? 'bg-success' : 'bg-danger');
        badge.textContent = preview.isPassed ? 'Lulus' : 'Tidak Lulus';
        alert.appendChild(scoreSpan); alert.appendChild(badge);
        box.appendChild(alert);
        if (preview.overshoot && preview.overshoot > 0 && preview.targetScore != null) {
            var note = document.createElement('div');
            note.className = 'form-text text-muted';
            note.textContent = 'Target ' + preview.targetScore + '% → capaian aktual ' + preview.percentage + '% (+' + preview.overshoot + ') karena pembulatan.';
            box.appendChild(note);
        }
    }

    function step5RenderBlocking(preview) {
        var blockEl = document.getElementById('step5Blocking');
        if (!blockEl) return;
        if (preview && preview.blocked) {
            blockEl.classList.remove('d-none');
            var msgEl = document.getElementById('step5BlockingMsg');
            if (msgEl) msgEl.textContent = preview.blockingMessage || 'Target tidak tercapai. Beralih ke input asli.';
        } else {
            blockEl.classList.add('d-none');
        }
    }

    // D-04 (UI-SPEC K3): validasi inline teks-essay WAJIB bila skor diisi — saat Pratinjau.
    // Hanya worker saat ini (form yang ter-render di DOM). Essay di-skip (input-asli, D-05) = omit → tak divalidasi.
    // Auto-gen HYBRID: essay selalu engaged (manual). Selaras guard server PreflightValidateAsync (commit) → preview == commit.
    function step5ValidateCurrentEssays(ws) {
        var invalidCount = 0;
        injQuestions.forEach(function (q) {
            if (q.QuestionType !== 'Essay') return;
            var taEl = document.getElementById('step5EssayText_' + q.TempId);
            var errEl = document.getElementById('step5EssayErr_' + q.TempId);
            if (taEl) taEl.classList.remove('is-invalid');
            if (errEl) errEl.style.display = 'none';
            var ans = ws.answers[q.TempId];
            if (!ans) return;
            var engaged = (ws.mode === 'auto') ? true : !ans.skipped;
            if (!engaged) return;
            if (ans.score != null && (!ans.text || !ans.text.trim())) {
                if (taEl) taEl.classList.add('is-invalid');
                if (errEl) errEl.style.display = 'block';
                invalidCount++;
            }
        });
        return invalidCount;
    }

    // ---- Wiring Step-5 ----
    (function wireStep5() {
        var prevBtn = document.getElementById('step5PrevWorker');
        var nextBtn = document.getElementById('step5NextWorker');
        if (prevBtn) prevBtn.addEventListener('click', function () { if (step5Idx > 0) { step5Idx--; step5RenderWorker(); step5RenderRoster(); } });
        if (nextBtn) nextBtn.addEventListener('click', function () {
            if (step5Idx < step5SelectedWorkers().length - 1) { step5Idx++; step5RenderWorker(); step5RenderRoster(); }
        });

        // Toggle mode per-pekerja
        document.querySelectorAll('input[name="step5WorkerMode"]').forEach(function (r) {
            r.addEventListener('change', function () {
                var cb = step5CurrentWorker(); if (!cb) return;
                step5State[cb.value].mode = r.value;
                step5State[cb.value].preview = null;   // mode berubah → pratinjau lama tak valid
                step5RenderWorker(); step5RenderRoster();
            });
        });

        // Target score input
        var targetInput = document.getElementById('step5TargetScore');
        if (targetInput) targetInput.addEventListener('input', function () {
            var cb = step5CurrentWorker(); if (!cb) return;
            var v = parseInt(targetInput.value, 10);
            step5State[cb.value].targetScore = isNaN(v) ? 0 : v;
            step5State[cb.value].preview = null;
        });

        // Switch BLOCKING → input asli (D-10): set mode manual, pre-fill grid (pola auto-gen terakhir tak tersedia di klien → biarkan HC isi)
        var switchBtn = document.getElementById('step5SwitchToManual');
        if (switchBtn) switchBtn.addEventListener('click', function () {
            var cb = step5CurrentWorker(); if (!cb) return;
            step5State[cb.value].mode = 'manual';
            step5State[cb.value].preview = null;
            step5RenderWorker(); step5RenderRoster();
        });

        // Pratinjau Skor (K5) — POST PreviewInjectScore (D-09 server-otoritas).
        var previewBtn = document.getElementById('step5PreviewBtn');
        if (previewBtn) previewBtn.addEventListener('click', function () {
            var cb = step5CurrentWorker(); if (!cb) return;
            var ws = step5State[cb.value];
            // D-04 inline (UI-SPEC K3): teks essay wajib bila skor diisi — cegah preview menyesatkan (preview == commit).
            if (step5ValidateCurrentEssays(ws) > 0) return;
            var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
            var token = tokenEl ? tokenEl.value : '';
            var url = previewBtn.getAttribute('data-preview-url');

            var reqBody = {
                passPercentage: step5PassPercentage(),
                title: (document.getElementById('Title').value || ''),
                category: (function () { var c = document.getElementById('Category'); return c ? c.value : ''; })(),
                completedAt: step5CompletedAt(),
                nip: cb.value,   // server resolve sebenarnya pakai NIP; di preview seed pakai field ini (advisory)
                mode: ws.mode || 'manual',
                targetScore: (ws.targetScore != null ? ws.targetScore : 0),
                questions: step5QuestionSpecs(),
                answers: step5WorkerAnswers(ws)
            };

            var origHtml = previewBtn.innerHTML;
            previewBtn.disabled = true;
            previewBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Menghitung skor…';

            fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify(reqBody)
            })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    ws.preview = {
                        percentage: data.percentage,
                        isPassed: data.isPassed,
                        blocked: data.blocked,
                        overshoot: data.overshoot,
                        blockingMessage: data.blockingMessage,
                        targetScore: (ws.mode === 'auto' ? ws.targetScore : null)
                    };
                    step5RenderPreviewSurface(ws.preview);
                    step5RenderBlocking(ws.preview);
                    step5RenderRoster();
                })
                .catch(function () {
                    var box = document.getElementById('step5PreviewResult');
                    if (box) { box.style.display = 'block'; box.innerHTML = '<div class="alert alert-danger mb-0">Gagal menghitung pratinjau. Coba lagi.</div>'; }
                })
                .finally(function () { previewBtn.disabled = false; previewBtn.innerHTML = origHtml; });
        });
    })();

    // expose for later-plan hooks
    window.injWizard = { goToStep: goToStep, validateStep: validateStep };

    updatePills();
})();

// ============================================================================
// Phase 396 — Jalur Import Excel (Langkah 5, N1-N4). IIFE terpisah; akses global
//   window.injGetQuestions (soal authored) + picker checkbox UserIds + antiforgery.
//   Render data via .textContent (XSS-safe, carry 395). preview == commit dijaga server.
// ============================================================================
(function InjectExcelPath() {
    function antiforgeryToken() {
        var el = document.querySelector('input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }
    function selectedUserIds() {
        return Array.from(document.querySelectorAll('#userCheckboxContainer .user-checkbox:checked'))
            .map(function (cb) { return cb.value; });
    }
    function passPercentage() {
        var el = document.getElementById('PassPercentage');
        var v = el ? parseInt(el.value, 10) : 70;
        return isNaN(v) ? 70 : v;
    }
    function serializeQuestionsHidden() {
        // Pastikan #QuestionsJson terisi soal terkini (server butuh soal untuk gen/parse).
        var hidden = document.getElementById('QuestionsJson');
        var qs = (typeof window.injGetQuestions === 'function') ? window.injGetQuestions() : [];
        if (hidden) hidden.value = JSON.stringify(qs);
        return qs;
    }

    // ── N1 toggle: form ↔ excel (mutually exclusive, IC-1) ──
    function applyMethod() {
        var checked = document.querySelector('input[name="step5Method"]:checked');
        var mode = checked ? checked.value : 'form';
        var formPath = document.getElementById('step5FormPath');
        var excelPanel = document.getElementById('step5ExcelPanel');
        var methodHidden = document.getElementById('Step5Method');
        var isExcel = (mode === 'excel');
        if (formPath) formPath.classList.toggle('d-none', isExcel);
        if (excelPanel) excelPanel.classList.toggle('d-none', !isExcel);
        if (methodHidden) methodHidden.value = isExcel ? 'excel' : 'form';
        // Tidak menghapus state form 395 (HC dapat kembali ke 'form').
    }
    document.querySelectorAll('input[name="step5Method"]').forEach(function (r) {
        r.addEventListener('change', applyMethod);
    });

    // ── N2c file input → enable/disable tombol Upload ──
    var fileEl = document.getElementById('step5ExcelFile');
    var uploadBtn = document.getElementById('btnUploadExcel');
    if (fileEl && uploadBtn) {
        fileEl.addEventListener('change', function () {
            uploadBtn.disabled = !(fileEl.files && fileEl.files.length > 0);
        });
    }

    // ── N2b Download Template → POST programatik (form sementara bawa QuestionsJson + UserIds + token) ──
    var downloadBtn = document.getElementById('btnDownloadTemplate');
    if (downloadBtn) {
        downloadBtn.addEventListener('click', function () {
            serializeQuestionsHidden();
            var url = downloadBtn.getAttribute('data-download-url');
            var tmp = document.createElement('form');
            tmp.method = 'post';
            tmp.action = url;
            tmp.style.display = 'none';
            function addField(name, value) {
                var inp = document.createElement('input');
                inp.type = 'hidden'; inp.name = name; inp.value = value;
                tmp.appendChild(inp);
            }
            addField('__RequestVerificationToken', antiforgeryToken());
            var qHidden = document.getElementById('QuestionsJson');
            addField('QuestionsJson', qHidden ? qHidden.value : '[]');
            selectedUserIds().forEach(function (id) { addField('UserIds', id); });
            document.body.appendChild(tmp);
            tmp.submit();
            document.body.removeChild(tmp);
        });
    }

    // ── N2d Upload & Pratinjau → fetch FormData → render N3 preview ATAU N4 errors ──
    function setLoading(on) {
        if (!uploadBtn) return;
        var spinner = document.getElementById('step5ExcelSpinner');
        var icon = document.getElementById('step5ExcelUploadIcon');
        var label = document.getElementById('step5ExcelUploadLabel');
        if (on) {
            uploadBtn.disabled = true;
            if (spinner) spinner.classList.remove('d-none');
            if (icon) icon.classList.add('d-none');
            if (label) label.textContent = 'Memproses…';
        } else {
            if (spinner) spinner.classList.add('d-none');
            if (icon) icon.classList.remove('d-none');
            if (label) label.textContent = 'Upload & Pratinjau';
            uploadBtn.disabled = !(fileEl && fileEl.files && fileEl.files.length > 0);
        }
    }
    function hidePreview() {
        var p = document.getElementById('step5ExcelPreview');
        if (p) p.style.display = 'none';
    }
    function showErrors(messages) {
        hidePreview();
        window.injExcelAnswersCache = '[]';   // T-396-10: invalid upload → commit hasilkan kosong
        var box = document.getElementById('step5ExcelErrors');
        var list = document.getElementById('step5ExcelErrorList');
        if (list) {
            list.innerHTML = '';
            messages.forEach(function (m) {
                var li = document.createElement('li');
                li.textContent = m;            // XSS-safe (carry 395)
                list.appendChild(li);
            });
        }
        if (box) box.classList.remove('d-none');
    }
    function renderPreview(result) {
        var errBox = document.getElementById('step5ExcelErrors');
        if (errBox) errBox.classList.add('d-none');

        var blankWarn = document.getElementById('step5ExcelBlankWarn');
        if (blankWarn) {
            if (result.skippedBlankCount && result.skippedBlankCount > 0) {
                blankWarn.textContent = result.skippedBlankCount +
                    ' jawaban kosong di Excel — soal terkait dihitung 0. Periksa pratinjau sebelum commit.';
                blankWarn.classList.remove('d-none');
            } else {
                blankWarn.classList.add('d-none');
            }
        }

        var body = document.getElementById('step5ExcelPreviewBody');
        if (body) {
            body.innerHTML = '';
            (result.previews || []).forEach(function (row, idx) {
                var tr = document.createElement('tr');
                var tdNum = document.createElement('td');
                tdNum.textContent = String(idx + 1);
                var tdNip = document.createElement('td');
                tdNip.textContent = (row.nip || '') + ' / ' + (row.name || '');
                var tdScore = document.createElement('td');
                tdScore.className = 'fw-bold';
                tdScore.textContent = (row.percentage != null ? row.percentage : 0) + '%';
                var tdPass = document.createElement('td');
                var badge = document.createElement('span');
                badge.className = 'badge ' + (row.isPassed ? 'bg-success' : 'bg-danger');
                badge.textContent = row.isPassed ? 'Lulus' : 'Tidak Lulus';
                tdPass.appendChild(badge);
                var tdAns = document.createElement('td');
                tdAns.textContent = (row.answered != null ? row.answered : 0) + ' / ' + (row.totalQuestions != null ? row.totalQuestions : 0);
                tr.appendChild(tdNum); tr.appendChild(tdNip); tr.appendChild(tdScore); tr.appendChild(tdPass); tr.appendChild(tdAns);
                body.appendChild(tr);
            });
        }

        var prev = document.getElementById('step5ExcelPreview');
        if (prev) prev.style.display = 'block';
        window.injExcelAnswersCache = result.answersJson || '[]';   // di-commit via #AnswersJson
    }

    if (uploadBtn) {
        uploadBtn.addEventListener('click', function () {
            if (!fileEl || !fileEl.files || fileEl.files.length === 0) return;
            serializeQuestionsHidden();
            setLoading(true);

            var fd = new FormData();
            fd.append('excel', fileEl.files[0]);
            var qHidden = document.getElementById('QuestionsJson');
            fd.append('QuestionsJson', qHidden ? qHidden.value : '[]');
            fd.append('PassPercentage', String(passPercentage()));
            selectedUserIds().forEach(function (id) { fd.append('UserIds', id); });
            fd.append('__RequestVerificationToken', antiforgeryToken());

            var url = uploadBtn.getAttribute('data-upload-url');
            fetch(url, { method: 'POST', body: fd, headers: { 'RequestVerificationToken': antiforgeryToken() } })
                .then(function (r) { return r.json(); })
                .then(function (result) {
                    if (!result || !result.ok) {
                        var msgs = (result && result.errors ? result.errors : []).map(function (e) { return e.message || ''; });
                        if (msgs.length === 0) msgs = ['Gagal membaca file Excel. Pastikan file .xlsx/.xls valid dan ≤ 10 MB, lalu coba lagi.'];
                        showErrors(msgs);
                    } else {
                        renderPreview(result);
                    }
                })
                .catch(function () {
                    showErrors(['Gagal membaca file Excel. Pastikan file .xlsx/.xls valid dan ≤ 10 MB, lalu coba lagi.']);
                })
                .finally(function () { setLoading(false); });
        });
    }

    // Init state.
    applyMethod();
})();

// ============================================================================
// Phase 397 — Penautan Pre/Post ke room existing (N1/N2/N3/N4/N5). IIFE terpisah.
//   - N1: tombol "Cari Room" kondisional tipe + chip removable + hidden #LinkedTargetRepId.
//   - N2: modal #roomPickerModal → SearchLinkTargets (debounced), filter tipe-lawan (server).
//   - N3/N4: ringkasan pairing di Step-6 (PreviewPairing) + daftar anti-dobel.
//   - N5: kontrol unlink pasca-commit → modal konfirmasi Bootstrap → UnlinkInjectGroup.
//   Render judul/kategori/NIP/Nama via .textContent (XSS-safe, T-397-14). POST kirim antiforgery (T-397-15).
// ============================================================================
(function InjectLinkPrePost() {
    function token() {
        var el = document.querySelector('input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }
    function fmtDate(v) {
        if (!v) return '-';
        var d = new Date(v);
        return isNaN(d.getTime()) ? '-' : d.toLocaleDateString('id-ID');
    }
    function typeLabel(t) { return t === 'PreTest' ? 'Pre-Test' : (t === 'PostTest' ? 'Post-Test' : (t || '')); }
    function oppositeType(injectType) {
        return injectType === 'PreTest' ? 'PostTest' : (injectType === 'PostTest' ? 'PreTest' : '');
    }
    function isPrePost(t) { return t === 'PreTest' || t === 'PostTest'; }

    var typeSel = document.getElementById('assessmentTypeInput');
    var linkBlock = document.getElementById('prePostLinkBlock');
    var btnCariRoom = document.getElementById('btnCariRoom');
    var btnCariRoomLabel = document.getElementById('btnCariRoomLabel');
    var oppositeHint = document.getElementById('prePostLinkOppositeHint');
    var hiddenRepId = document.getElementById('LinkedTargetRepId');
    var chip = document.getElementById('selectedRoomChip');
    var chipText = document.getElementById('selectedRoomChipText');
    var chipType = document.getElementById('selectedRoomChipType');
    var chipGroup = document.getElementById('selectedRoomChipGroup');
    var chipClose = document.getElementById('selectedRoomChipClose');

    // ── N1: show/hide tombol + hint dinamis sesuai tipe ──
    function applyTypeVisibility() {
        var t = typeSel ? typeSel.value : 'Standard';
        var show = isPrePost(t);
        if (linkBlock) linkBlock.classList.toggle('d-none', !show);
        if (oppositeHint) {
            oppositeHint.textContent = (t === 'PreTest')
                ? 'Cari room Post-Test pasangannya.'
                : (t === 'PostTest' ? 'Cari room Pre-Test pasangannya.' : '');
        }
        if (!show) clearChip();   // Standard → tautan tak valid (D-06): kosongkan chip + hidden field
    }
    if (typeSel) typeSel.addEventListener('change', applyTypeVisibility);

    // ── N1b: chip set/clear ──
    function setChip(row) {
        if (hiddenRepId) hiddenRepId.value = row.representativeId != null ? row.representativeId : '';
        if (chipText) chipText.textContent = (row.title || '') + ' (' + fmtDate(row.completedAt || row.schedule) + ')';
        if (chipType) chipType.textContent = typeLabel(row.assessmentType);
        if (chipGroup) {
            var kasusA = (row.linkedGroupId != null);
            chipGroup.textContent = kasusA ? 'Sudah ber-grup' : 'Standalone';
            chipGroup.className = 'badge ' + (kasusA ? 'bg-success' : 'bg-warning text-dark');
        }
        if (chip) chip.classList.remove('d-none');
        if (btnCariRoomLabel) btnCariRoomLabel.textContent = 'Ganti Room';
    }
    function clearChip() {
        if (hiddenRepId) hiddenRepId.value = '';
        if (chip) chip.classList.add('d-none');
        if (btnCariRoomLabel) btnCariRoomLabel.textContent = 'Cari Room Pasangan';
    }
    if (chipClose) chipClose.addEventListener('click', function () { clearChip(); });

    // ── N2: modal picker → SearchLinkTargets (debounced) ──
    var roomPickerModalEl = document.getElementById('roomPickerModal');
    var roomSearchInput = document.getElementById('roomSearchInput');
    var roomPickerResults = document.getElementById('roomPickerResults');
    var roomPickerOppositeLabel = document.getElementById('roomPickerOppositeLabel');
    var bsRoomModal = (roomPickerModalEl && window.bootstrap) ? new bootstrap.Modal(roomPickerModalEl) : null;
    var searchDebounce = null;

    function searchUrl() {
        var t = typeSel ? typeSel.value : 'Standard';
        var term = roomSearchInput ? (roomSearchInput.value || '') : '';
        return '@Url.Action("SearchLinkTargets", "InjectAssessment")'
            + '?term=' + encodeURIComponent(term) + '&injectType=' + encodeURIComponent(t);
    }
    function renderResultsLoading() {
        if (roomPickerResults) {
            roomPickerResults.innerHTML = '<div class="text-center py-3"><span class="spinner-border spinner-border-sm me-1"></span>Mencari&hellip;</div>';
        }
    }
    function renderResultsEmpty() {
        if (roomPickerResults) {
            var opp = oppositeType(typeSel ? typeSel.value : '');
            roomPickerResults.innerHTML = '';
            var d = document.createElement('div');
            d.className = 'text-center text-muted py-4';
            d.innerHTML = '<i class="bi bi-inbox d-block fs-3 mb-2"></i>';
            var span = document.createElement('span');
            span.textContent = 'Tidak ada room ' + typeLabel(opp) + ' yang cocok. Coba kata kunci lain.';
            d.appendChild(span);
            roomPickerResults.appendChild(d);
        }
    }
    function renderResultsError() {
        if (roomPickerResults) {
            roomPickerResults.innerHTML = '<div class="alert alert-danger small mb-0">Gagal memuat daftar room. Coba lagi.</div>';
        }
    }
    function renderResults(rows) {
        if (!roomPickerResults) return;
        roomPickerResults.innerHTML = '';
        if (!rows || rows.length === 0) { renderResultsEmpty(); return; }
        rows.forEach(function (row) {
            var btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'list-group-item list-group-item-action d-flex justify-content-between align-items-center';
            btn.setAttribute('role', 'option');

            // Kiri: judul + meta
            var left = document.createElement('div');
            var title = document.createElement('div');
            title.className = 'fw-bold';
            title.textContent = row.title || '';        // XSS-safe
            var meta = document.createElement('div');
            meta.className = 'small text-muted';
            meta.textContent = (row.category || '') + ' · ' + fmtDate(row.completedAt || row.schedule)
                + ' · ' + (row.userCount != null ? row.userCount : 0) + ' peserta';
            left.appendChild(title); left.appendChild(meta);

            // Kanan: badge tipe + grup + (Inject)
            var right = document.createElement('div');
            right.className = 'text-end';
            var bType = document.createElement('span');
            bType.className = 'badge bg-secondary me-1';
            bType.textContent = typeLabel(row.assessmentType);
            right.appendChild(bType);
            var bGroup = document.createElement('span');
            var kasusA = (row.linkedGroupId != null);
            bGroup.className = 'badge ' + (kasusA ? 'bg-success' : 'bg-warning text-dark');
            bGroup.textContent = kasusA ? 'Sudah ber-grup' : 'Standalone';
            right.appendChild(bGroup);
            if (row.isManualEntry) {
                var bInj = document.createElement('span');
                bInj.className = 'badge bg-info text-dark ms-1';
                bInj.textContent = 'Inject';
                right.appendChild(bInj);
            }

            btn.appendChild(left); btn.appendChild(right);
            btn.addEventListener('click', function () {
                setChip(row);
                if (bsRoomModal) bsRoomModal.hide();
            });
            roomPickerResults.appendChild(btn);
        });
    }
    function doSearch() {
        renderResultsLoading();
        fetch(searchUrl(), { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function (r) { return r.json(); })
            .then(function (rows) { renderResults(rows); })
            .catch(function () { renderResultsError(); });
    }
    if (btnCariRoom) {
        btnCariRoom.addEventListener('click', function () {
            if (roomPickerOppositeLabel) roomPickerOppositeLabel.textContent = typeLabel(oppositeType(typeSel ? typeSel.value : ''));
            if (bsRoomModal) bsRoomModal.show();
        });
    }
    if (roomPickerModalEl) {
        roomPickerModalEl.addEventListener('shown.bs.modal', function () {
            if (roomSearchInput) roomSearchInput.focus();
            doSearch();   // muat daftar awal (term kosong → terbaru)
        });
    }
    if (roomSearchInput) {
        roomSearchInput.addEventListener('input', function () {
            if (searchDebounce) clearTimeout(searchDebounce);
            searchDebounce = setTimeout(doSearch, 300);
        });
    }

    // ── N3/N4: ringkasan pairing di Step-6 (PreviewPairing) ──
    var pairingSummary = document.getElementById('previewPairingSummary');
    function selectedUserIdsForPairing() {
        return Array.from(document.querySelectorAll('#userCheckboxContainer .user-checkbox:checked'))
            .map(function (cb) { return cb.value; });
    }
    function completedAtIso() {
        var el = document.getElementById('CompletedAt');
        return el && el.value ? el.value : null;
    }
    function hidePairing() { if (pairingSummary) pairingSummary.classList.add('d-none'); }
    function renderPairing(p) {
        if (!pairingSummary) return;
        if (!p || !p.hasLink) { hidePairing(); return; }
        pairingSummary.classList.remove('d-none');

        var pairedBadge = document.getElementById('pairingPairedBadge');
        var unpairedBadge = document.getElementById('pairingUnpairedBadge');
        if (pairedBadge) pairedBadge.textContent = (p.paired != null ? p.paired : 0) + ' ter-pair';
        if (unpairedBadge) unpairedBadge.textContent = (p.unpaired != null ? p.unpaired : 0) + ' tanpa pasangan';

        var touchBanner = document.getElementById('pairingTouchOnlineBanner');
        var touchText = document.getElementById('pairingTouchOnlineText');
        var safeBanner = document.getElementById('pairingSafeBanner');
        if (p.willTouchOnline) {
            if (touchBanner) touchBanner.classList.remove('d-none');
            if (safeBanner) safeBanner.classList.add('d-none');
            if (touchText) touchText.textContent =
                'Room pasangan ini belum ber-grup. Saat commit, penanda grup ditulis ke sesi online tersebut '
                + '(skor, jawaban, dan status TIDAK diubah). Tindakan tercatat di audit.';
        } else {
            if (touchBanner) touchBanner.classList.add('d-none');
            if (safeBanner) safeBanner.classList.remove('d-none');
        }

        var dateWarn = document.getElementById('pairingDateWarn');
        if (dateWarn) dateWarn.classList.toggle('d-none', !p.dateWarn);

        // N4 — daftar anti-dobel (D-08)
        var dlPanel = document.getElementById('pairingDoubleLinkPanel');
        var dlList = document.getElementById('pairingDoubleLinkList');
        var errs = p.doubleLinkErrors || [];
        if (dlList) {
            dlList.innerHTML = '';
            errs.forEach(function (e) {
                var li = document.createElement('li');
                li.textContent = e.message || '';     // XSS-safe (Message berisi NIP+Nama)
                dlList.appendChild(li);
            });
        }
        if (dlPanel) dlPanel.classList.toggle('d-none', errs.length === 0);
    }
    function refreshPairing() {
        var repId = hiddenRepId ? hiddenRepId.value : '';
        var t = typeSel ? typeSel.value : 'Standard';
        if (!repId || !isPrePost(t)) { hidePairing(); return; }
        var body = {
            linkTargetRepId: parseInt(repId, 10),
            assessmentType: t,
            userIds: selectedUserIdsForPairing(),
            completedAt: completedAtIso()
        };
        fetch('@Url.Action("PreviewPairing", "InjectAssessment")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token() },
            body: JSON.stringify(body)
        })
            .then(function (r) { return r.json(); })
            .then(function (p) { renderPairing(p); })
            .catch(function () { hidePairing(); });
    }
    // Refresh ringkasan saat masuk Step-6 (tombol next ke step 6 / edit-from-confirm).
    document.querySelectorAll('.btn-next, .edit-from-confirm').forEach(function (b) {
        b.addEventListener('click', function () { setTimeout(refreshPairing, 50); });
    });

    // ── N5: unlink pasca-commit → modal konfirmasi → UnlinkInjectGroup ──
    var postCommitSurface = document.getElementById('postCommitLinkSurface');
    var btnConfirmUnlink = document.getElementById('btnConfirmUnlink');
    var unlinkSpinner = document.getElementById('unlinkSpinner');
    if (btnConfirmUnlink) {
        btnConfirmUnlink.addEventListener('click', function () {
            if (!postCommitSurface) return;
            var groupId = postCommitSurface.getAttribute('data-inject-group-id');
            if (!groupId) return;
            if (unlinkSpinner) unlinkSpinner.classList.remove('d-none');
            btnConfirmUnlink.disabled = true;

            var fd = new URLSearchParams();
            fd.append('injectGroupId', groupId);
            fd.append('__RequestVerificationToken', token());
            fetch(btnConfirmUnlink.getAttribute('data-unlink-url'), {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': token() },
                body: fd.toString()
            })
                .then(function (r) { return r.json(); })
                .then(function (res) {
                    var modalEl = document.getElementById('unlinkConfirmModal');
                    if (modalEl && window.bootstrap) {
                        var inst = bootstrap.Modal.getInstance(modalEl); if (inst) inst.hide();
                    }
                    // Toast in-place: ganti surface dgn notice.
                    var notice = document.createElement('div');
                    notice.className = 'alert ' + (res && res.ok ? 'alert-success' : 'alert-danger');
                    notice.textContent = (res && res.message) ? res.message : (res && res.ok ? 'Tautan dilepas.' : 'Gagal melepas tautan.');
                    if (postCommitSurface && postCommitSurface.parentNode) {
                        postCommitSurface.parentNode.replaceChild(notice, postCommitSurface);
                    }
                })
                .catch(function () {
                    alert('Gagal melepas tautan. Coba lagi.');
                })
                .finally(function () {
                    if (unlinkSpinner) unlinkSpinner.classList.add('d-none');
                    btnConfirmUnlink.disabled = false;
                });
        });
    }

    // Init.
    applyTypeVisibility();
})();
</script>
}
