// --- CLIPBOARD PASTE (TSV from Excel) ---
document.getElementById('editTablesContainer').addEventListener('paste', function(e) {
    var targetTbl = e.target.closest('.kkj-edit-tbl');
    if (!targetTbl) return;
    e.preventDefault();
    var text = (e.clipboardData || window.clipboardData).getData('text');
    if (!text) return;
    var pastedRows = text.trim().split('\n');
    var tbody = targetTbl.querySelector('.bagian-tbody');
    // Use selectedCells[0] as anchor
    var anchorTd = (selectedCells && selectedCells.length > 0) ? selectedCells[0] : null;
    var anchorRow = anchorTd ? anchorTd.closest('tr') : null;
    var startIdx = (anchorRow && tbody.contains(anchorRow)) ? Array.from(tbody.rows).indexOf(anchorRow) : tbody.rows.length;
    if (startIdx < 0) startIdx = tbody.rows.length;

    // Fixed column names (before dynamic columns)
    var fixedColNames = ['No','SkillGroup','SubSkillGroup','Indeks','Kompetensi'];

    // Get bagian columns from kkjBagians
    var bagianName = tbody.dataset.bagianName || '';
    var bagianObj = kkjBagians.find(function(b) { return b.Name === bagianName; });
    var dynamicCols = bagianObj ? (bagianObj.Columns || []) : [];

    pastedRows.forEach(function(rowText, pasteRowIdx) {
        var cols = rowText.split('\t');
        var targetRowIdx = startIdx + pasteRowIdx;
        var tr;
        if (targetRowIdx < tbody.rows.length) {
            tr = tbody.rows[targetRowIdx];
        } else {
            tr = makeEmptyRow(dynamicCols);
            tr.querySelector('input[name="Bagian"]').value = bagianName;
            tbody.appendChild(tr);
        }
        cols.forEach(function(cellVal, colIdx) {
            if (colIdx < fixedColNames.length) {
                var input = tr.querySelector('[name="' + fixedColNames[colIdx] + '"]');
                if (input) input.value = cellVal.trim();
            } else {
                // Dynamic column
                var dynIdx = colIdx - fixedColNames.length;
                if (dynIdx < dynamicCols.length) {
                    var colId = dynamicCols[dynIdx].Id;
                    var dynInput = tr.querySelector('[data-column-id="' + colId + '"]');
                    if (dynInput) dynInput.value = cellVal.trim();
                }
            }
        });
    });
});

// --- TAB/ENTER KEYBOARD NAVIGATION ---
document.getElementById('editTablesContainer').addEventListener('keydown', function(e) {
    if (e.key !== 'Tab' && e.key !== 'Enter') return;
    var inputs = Array.from(document.querySelectorAll('#editTablesContainer .bagian-tbody input.edit-input'));
    var idx = inputs.indexOf(document.activeElement);
    if (idx < 0) return;
    e.preventDefault();
    var nextIdx = e.shiftKey ? idx - 1 : idx + 1;
    if (nextIdx >= 0 && nextIdx < inputs.length) {
        inputs[nextIdx].focus();
        inputs[nextIdx].select();
    }
});

// ========== MULTI-CELL SELECTION ==========
var selectedCells = [];
var isDragging = false;
var dragStartTd = null;

function getCellCoords(td) {
    // Returns { tbl, tbody, rowIdx, colIdx } for a given <td>
    var tr = td.parentElement;
    var tbody = tr.parentElement;
    var rowIdx = Array.from(tbody.rows).indexOf(tr);
    // colIdx: count only data-input tds (skip Aksi which has no input.edit-input)
    var allTds = Array.from(tr.cells);
    var colIdx = allTds.indexOf(td);
    return { tbody: tbody, rowIdx: rowIdx, colIdx: colIdx };
}

function getRangeCells(startTd, endTd) {
    // Returns all tds in the rectangular range between startTd and endTd
    // Both must be in the same .kkj-edit-tbl
    var tbl = startTd.closest('.kkj-edit-tbl');
    if (!tbl || startTd.closest('.kkj-edit-tbl') !== endTd.closest('.kkj-edit-tbl')) return [startTd];

    var startCoords = getCellCoords(startTd);
    var endCoords   = getCellCoords(endTd);

    var minRow = Math.min(startCoords.rowIdx, endCoords.rowIdx);
    var maxRow = Math.max(startCoords.rowIdx, endCoords.rowIdx);
    var minCol = Math.min(startCoords.colIdx, endCoords.colIdx);
    var maxCol = Math.max(startCoords.colIdx, endCoords.colIdx);

    var cells = [];
    var tbody = startCoords.tbody;
    for (var r = minRow; r <= maxRow; r++) {
        if (r >= tbody.rows.length) break;
        var tr = tbody.rows[r];
        var tds = Array.from(tr.cells);
        for (var c = minCol; c <= maxCol; c++) {
            if (c >= tds.length) break;
            var td = tds[c];
            // Only include cells that have an edit-input (skip Aksi column)
            if (td.querySelector('input.edit-input')) {
                cells.push(td);
            }
        }
    }
    return cells;
}

function applySelection(cells) {
    // Clear previous highlight
    document.querySelectorAll('.cell-selected').forEach(function(el) {
        el.classList.remove('cell-selected');
    });
    selectedCells = cells;
    cells.forEach(function(td) { td.classList.add('cell-selected'); });
}

// Mousedown: start selection on a data-input td
document.addEventListener('mousedown', function(e) {
    var td = e.target.closest('.kkj-edit-tbl td');
    if (!td || !td.querySelector('input.edit-input')) return;

    isDragging = true;
    dragStartTd = td;

    if (e.shiftKey && selectedCells.length > 0) {
        // Extend selection from existing anchor
        var anchorTd = selectedCells[0];
        applySelection(getRangeCells(anchorTd, td));
    } else {
        applySelection([td]);
    }
    e.preventDefault(); // Prevent text selection on drag
    // Focus anchor input so document.activeElement is a valid edit-input for paste routing
    var anchorInput = selectedCells[0] && selectedCells[0].querySelector('input.edit-input');
    if (anchorInput) anchorInput.focus();
});

// Mousemove: extend selection while dragging
document.addEventListener('mousemove', function(e) {
    if (!isDragging || !dragStartTd) return;
    var td = e.target.closest('.kkj-edit-tbl td');
    if (!td || !td.querySelector('input.edit-input')) return;
    applySelection(getRangeCells(dragStartTd, td));
});

// Mouseup: end drag
document.addEventListener('mouseup', function() {
    isDragging = false;
});

// Click on input inside a cell: select just that cell
document.addEventListener('click', function(e) {
    if (e.target.tagName !== 'INPUT' || !e.target.classList.contains('edit-input')) return;
    var td = e.target.closest('td');
    if (!td) return;
    if (e.shiftKey && selectedCells.length > 0) {
        applySelection(getRangeCells(selectedCells[0], td));
    } else if (!e.ctrlKey) {
        applySelection([td]);
    }
});

// Keydown: Delete clears selected cells; Ctrl+C copies; Tab/Enter navigation unchanged
document.addEventListener('keydown', function(e) {
    // Only act if we're in the edit context
    if (!document.getElementById('editTablesContainer') ||
        document.getElementById('editTablesContainer').classList.contains('d-none')) return;

    if (e.key === 'Delete' && selectedCells.length > 1) {
        // Multi-cell delete: clear all selected inputs
        e.preventDefault();
        selectedCells.forEach(function(td) {
            var inp = td.querySelector('input.edit-input');
            if (inp) inp.value = '';
        });
        return;
    }

    if ((e.ctrlKey || e.metaKey) && e.key === 'c' && selectedCells.length > 0) {
        // Ctrl+C: copy selected range as TSV
        e.preventDefault();
        var tbl = selectedCells[0].closest('.kkj-edit-tbl');
        var startCoords = getCellCoords(selectedCells[0]);
        var endCoords   = getCellCoords(selectedCells[selectedCells.length - 1]);
        var minRow = Math.min(startCoords.rowIdx, endCoords.rowIdx);
        var maxRow = Math.max(startCoords.rowIdx, endCoords.rowIdx);
        var minCol = Math.min(startCoords.colIdx, endCoords.colIdx);
        var maxCol = Math.max(startCoords.colIdx, endCoords.colIdx);

        var lines = [];
        var tbody = startCoords.tbody;
        for (var r = minRow; r <= maxRow; r++) {
            if (r >= tbody.rows.length) break;
            var tr = tbody.rows[r];
            var tds = Array.from(tr.cells);
            var cols = [];
            for (var c = minCol; c <= maxCol; c++) {
                if (c >= tds.length) break;
                var inp = tds[c].querySelector('input.edit-input');
                cols.push(inp ? inp.value : '');
            }
            lines.push(cols.join('\t'));
        }
        navigator.clipboard.writeText(lines.join('\n')).catch(function() {
            // Fallback for older browsers
            var ta = document.createElement('textarea');
            ta.value = lines.join('\n');
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            document.body.removeChild(ta);
        });
        return;
    }

    if ((e.ctrlKey || e.metaKey) && e.key === 'v' && selectedCells.length > 0) {
        // Ctrl+V: read clipboard directly — decoupled from focus/activeElement state
        e.preventDefault();
        navigator.clipboard.readText().then(function(text) {
            if (!text) return;
            var anchorTd = selectedCells[0];
            var targetTbl = anchorTd.closest('.kkj-edit-tbl');
            if (!targetTbl) return;
            var tbody = targetTbl.querySelector('.bagian-tbody');
            if (!tbody) return;
            var anchorRow = anchorTd.closest('tr');
            var startIdx = (anchorRow && tbody.contains(anchorRow)) ? Array.from(tbody.rows).indexOf(anchorRow) : 0;
            if (startIdx < 0) startIdx = 0;

            // Fixed column names
            var fixedColNames = ['No','SkillGroup','SubSkillGroup','Indeks','Kompetensi'];

            // Get bagian dynamic columns
            var bagianNameCtrlV = tbody.dataset.bagianName || '';
            var bagianObjCtrlV = kkjBagians.find(function(b) { return b.Name === bagianNameCtrlV; });
            var dynamicColsCtrlV = bagianObjCtrlV ? (bagianObjCtrlV.Columns || []) : [];

            // All inputs in anchor row (for column index mapping)
            var anchorAllTds = Array.from(anchorTd.parentElement.cells);
            var anchorColIdx = anchorAllTds.indexOf(anchorTd);

            var pastedRows = text.trim().split('\n');
            pastedRows.forEach(function(rowText, pasteRowIdx) {
                var cols = rowText.split('\t');
                var targetRowIdx = startIdx + pasteRowIdx;
                var tr;
                if (targetRowIdx < tbody.rows.length) {
                    tr = tbody.rows[targetRowIdx];
                } else {
                    tr = makeEmptyRow(dynamicColsCtrlV);
                    tr.querySelector('input[name="Bagian"]').value = bagianNameCtrlV;
                    tbody.appendChild(tr);
                }
                cols.forEach(function(cellVal, colOffset) {
                    var colIdx = anchorColIdx + colOffset;
                    if (colIdx < fixedColNames.length) {
                        var input = tr.querySelector('[name="' + fixedColNames[colIdx] + '"]');
                        if (input) input.value = cellVal.trim();
                    } else {
                        // Dynamic column — colIdx includes 1 hidden Bagian input before fixed cols
                        // Actual td index for fixed cols starts at 0 (No), so dynamic starts at fixedColNames.length
                        var dynIdx = colIdx - fixedColNames.length;
                        if (dynIdx >= 0 && dynIdx < dynamicColsCtrlV.length) {
                            var dynColId = dynamicColsCtrlV[dynIdx].Id;
                            var dynInput = tr.querySelector('[data-column-id="' + dynColId + '"]');
                            if (dynInput) dynInput.value = cellVal.trim();
                        }
                    }
                });
            });
        }).catch(function(err) {
            console.warn('Clipboard read failed:', err);
        });
        return;
    }
});

// ========== COLUMN MANAGEMENT PANEL ==========
function loadColumnPanel(bagianId) {
    var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

    $.getJSON('/Admin/GetKkjColumns?bagianId=' + bagianId, function(columns) {
        var html = '';
        if (columns.length === 0) {
            html = '<p class="text-muted small">Belum ada kolom. Klik "Tambah Kolom" untuk menambahkan.</p>';
        } else {
            html = '<table class="table table-sm table-bordered"><thead><tr><th>Urutan</th><th>Nama Kolom</th><th>Aksi</th></tr></thead><tbody>';
            columns.forEach(function(col) {
                html += '<tr data-col-id="' + col.Id + '">'
                    + '<td><input type="number" class="form-control form-control-sm col-order-input" value="' + col.DisplayOrder + '" style="width:60px;"></td>'
                    + '<td><input type="text" class="form-control form-control-sm col-name-panel-input" value="' + escHtml(col.Name) + '"></td>'
                    + '<td>'
                    + '<button class="btn btn-sm btn-outline-primary me-1 btn-save-col" title="Simpan"><i class="bi bi-check"></i></button>'
                    + '<button class="btn btn-sm btn-outline-danger btn-delete-col" title="Hapus"><i class="bi bi-trash"></i></button>'
                    + '</td></tr>';
            });
            html += '</tbody></table>';
        }
        document.getElementById('columnListContainer').innerHTML = html;

        // Wire save buttons
        document.querySelectorAll('.btn-save-col').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var tr = btn.closest('tr');
                var colId = parseInt(tr.dataset.colId);
                var name = tr.querySelector('.col-name-panel-input').value.trim();
                var order = parseInt(tr.querySelector('.col-order-input').value) || 0;
                $.ajax({
                    url: '/Admin/KkjColumnSave',
                    type: 'POST',
                    contentType: 'application/json',
                    headers: { 'RequestVerificationToken': token },
                    data: JSON.stringify({ Id: colId, Name: name, DisplayOrder: order }),
                    success: function(resp) {
                        if (resp.success) {
                            // Update kkjBagians cache
                            var bagian = kkjBagians.find(function(b) { return b.Id === bagianId; });
                            if (bagian) {
                                var col = bagian.Columns.find(function(c) { return c.Id === colId; });
                                if (col) { col.Name = name; col.DisplayOrder = order; }
                            }
                            loadColumnPanel(bagianId);
                            var filter = document.getElementById('bagianFilter');
                            if (filter) renderReadTable(filter.value);
                            var toastEl = document.getElementById('saveToast');
                            var toast = new bootstrap.Toast(toastEl, { delay: 1500 });
                            toast.show();
                        } else {
                            alert('Error: ' + resp.message);
                        }
                    }
                });
            });
        });

        // Wire delete buttons
        document.querySelectorAll('.btn-delete-col').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var tr = btn.closest('tr');
                var colId = parseInt(tr.dataset.colId);
                if (!confirm('Hapus kolom ini? Tidak dapat dihapus jika masih ada data nilai.')) return;
                $.ajax({
                    url: '/Admin/KkjColumnDelete',
                    type: 'POST',
                    data: { id: colId, __RequestVerificationToken: token },
                    success: function(resp) {
                        if (resp.success) {
                            var bagian = kkjBagians.find(function(b) { return b.Id === bagianId; });
                            if (bagian) bagian.Columns = bagian.Columns.filter(function(c) { return c.Id !== colId; });
                            loadColumnPanel(bagianId);
                            var filter = document.getElementById('bagianFilter');
                            if (filter) renderReadTable(filter.value);
                        } else {
                            alert(resp.message);
                        }
                    }
                });
            });
        });
    });
}

// Add column button
document.getElementById('btnAddColumn').addEventListener('click', function() {
    var filter = document.getElementById('bagianFilter');
    var bagianName = filter ? filter.value : '';
    var bagian = kkjBagians.find(function(b) { return b.Name === bagianName; });
    if (!bagian) { alert('Pilih bagian terlebih dahulu.'); return; }
    var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
    $.ajax({
        url: '/Admin/KkjColumnAdd',
        type: 'POST',
        data: { bagianId: bagian.Id, __RequestVerificationToken: token },
        success: function(resp) {
            if (resp.success) {
                bagian.Columns = bagian.Columns || [];
                bagian.Columns.push({ Id: resp.id, Name: resp.name, DisplayOrder: resp.displayOrder });
                loadColumnPanel(bagian.Id);
                renderReadTable(bagianName);
            } else {
                alert('Error: ' + resp.message);
            }
        }
    });
});

// ========== POSITION MAPPING PANEL ==========
function loadMappingPanel(bagianId) {
    var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

    // Populate column select
    var bagian = kkjBagians.find(function(b) { return b.Id === bagianId; });
    var colSelect = document.getElementById('newPositionColumn');
    colSelect.innerHTML = '';
    if (bagian) {
        (bagian.Columns || []).forEach(function(col) {
            var opt = document.createElement('option');
            opt.value = col.Id;
            opt.textContent = col.Name;
            colSelect.appendChild(opt);
        });
    }

    $.getJSON('/Admin/GetPositionMappings?bagianId=' + bagianId, function(mappings) {
        var html = '';
        if (mappings.length === 0) {
            html = '<p class="text-muted small">Belum ada pemetaan jabatan.</p>';
        } else {
            html = '<table class="table table-sm table-bordered"><thead><tr><th>Jabatan</th><th>Kolom KKJ</th><th>Aksi</th></tr></thead><tbody>';
            mappings.forEach(function(m) {
                html += '<tr>'
                    + '<td>' + escHtml(m.Position) + '</td>'
                    + '<td>' + escHtml(m.ColumnName) + '</td>'
                    + '<td><button class="btn btn-sm btn-outline-danger btn-delete-mapping" data-mapping-id="' + m.Id + '">'
                    + '<i class="bi bi-trash"></i></button></td></tr>';
            });
            html += '</tbody></table>';
        }
        document.getElementById('mappingListContainer').innerHTML = html;

        document.querySelectorAll('.btn-delete-mapping').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var id = parseInt(btn.dataset.mappingId);
                if (!confirm('Hapus pemetaan jabatan ini?')) return;
                $.ajax({
                    url: '/Admin/PositionMappingDelete',
                    type: 'POST',
                    data: { id: id, __RequestVerificationToken: token },
                    success: function(resp) {
                        if (resp.success) loadMappingPanel(bagianId);
                        else alert(resp.message);
                    }
                });
            });
        });
    });
}

document.getElementById('btnAddMapping').addEventListener('click', function() {
    var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
    var filter = document.getElementById('bagianFilter');
    var bagianName = filter ? filter.value : '';
    var bagian = kkjBagians.find(function(b) { return b.Name === bagianName; });
    var position = document.getElementById('newPositionName').value.trim();
    var colId = parseInt(document.getElementById('newPositionColumn').value) || 0;
    if (!position) { alert('Masukkan nama jabatan.'); return; }
    if (!colId) { alert('Pilih kolom KKJ.'); return; }
    $.ajax({
        url: '/Admin/PositionMappingSave',
        type: 'POST',
        contentType: 'application/json',
        headers: { 'RequestVerificationToken': token },
        data: JSON.stringify({ Id: 0, Position: position, KkjColumnId: colId }),
        success: function(resp) {
            if (resp.success) {
                document.getElementById('newPositionName').value = '';
                if (bagian) loadMappingPanel(bagian.Id);
            } else {
                alert('Error: ' + resp.message);
            }
        }
    });
});
</script>
}
