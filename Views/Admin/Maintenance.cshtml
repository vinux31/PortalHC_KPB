@model HcPortal.Models.MaintenanceMode
@{
    ViewData["Title"] = "Mode Pemeliharaan";
    ViewData["ContainerClass"] = "container";
    var scopeGroups = HcPortal.Helpers.MaintenanceScopeCatalog.GetGroups();
    var activeKeys = HcPortal.Helpers.MaintenanceScopeCatalog.GetSelectedKeySet(Model.Scope);
    var selectedCount = activeKeys.Count;
}

<style>
    .maintenance-scope-toolbar {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1rem;
    }

    .maintenance-scope-groups {
        display: grid;
        gap: 1rem;
    }

    .maintenance-scope-group.hidden-by-filter,
    .maintenance-scope-item.hidden-by-filter {
        display: none !important;
    }
</style>

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Admin")">Kelola Data</a></li>
        <li class="breadcrumb-item active">Mode Pemeliharaan</li>
    </ol>
</nav>

<div class="d-flex align-items-center mb-4">
    <h2 class="fw-bold text-dark mb-0">
        <i class="bi bi-cone-striped me-2 text-warning"></i>Mode Pemeliharaan
    </h2>
    @if (Model.IsEnabled)
    {
        <span class="badge bg-success ms-3">Aktif</span>
    }
    else
    {
        <span class="badge bg-secondary ms-3">Nonaktif</span>
    }
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        @Html.ValidationSummary(false, "", new { @class = "mb-0" })
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body">
        <form method="post" asp-action="Maintenance" asp-controller="Admin" id="maintenanceForm">
            @Html.AntiForgeryToken()

            <div class="mb-4">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" name="isEnabled" id="isEnabled" value="true" @(Model.IsEnabled ? "checked" : "")>
                    <label class="form-check-label fw-bold" for="isEnabled">Mode Pemeliharaan</label>
                </div>
                <small class="text-muted">Aktifkan untuk memblokir akses pengguna ke halaman yang dipilih.</small>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Cakupan</label>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="scope" id="scopeAll" value="All" @(Model.Scope == "All" ? "checked" : "")>
                    <label class="form-check-label" for="scopeAll">Seluruh Website</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="scope" id="scopeSpecific" value="Specific" @(Model.Scope != "All" ? "checked" : "")>
                    <label class="form-check-label" for="scopeSpecific">Halaman Tertentu</label>
                </div>
            </div>

            <div class="mb-4 ms-4" id="moduleChecklist" style="@(Model.Scope != "All" ? "" : "display:none;")">
                <label class="form-label fw-bold">Pilih Halaman</label>
                <p class="text-muted small mb-3">Pilih halaman utama yang ingin ditutup. Semua halaman turunan di area yang sama akan ikut terdampak.</p>

                <div class="border rounded-4 bg-light p-3">
                    <div class="maintenance-scope-toolbar">
                        <div class="flex-grow-1" style="min-width:240px;">
                            <input type="search" class="form-control" id="scopeSearch" placeholder="Cari halaman..." aria-label="Cari halaman maintenance">
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <button type="button" class="btn btn-outline-primary btn-sm" id="selectAllScopes">Pilih semua</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="clearAllScopes">Kosongkan</button>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted small">Admin dan HC tetap bisa mengakses halaman yang di-maintenance.</span>
                        <span class="badge text-bg-light" id="selectedScopeSummary">@selectedCount halaman dipilih</span>
                    </div>

                    <div class="maintenance-scope-groups" id="scopeGroups">
                        @foreach (var group in scopeGroups)
                        {
                            <div class="border rounded-4 bg-white p-3" data-group-label="@group.Label.ToLowerInvariant()">
                                <div class="form-check mb-3">
                                    <input class="form-check-input scope-group-toggle" type="checkbox" id="group_@group.Key" data-group-key="@group.Key">
                                    <label class="form-check-label fw-semibold" for="group_@group.Key">@group.Label</label>
                                </div>
                                <div class="ps-3">
                                    @foreach (var option in group.Options)
                                    {
                                        <div class="form-check maintenance-scope-item mb-2" data-label="@option.Label.ToLowerInvariant()" data-group-key="@group.Key">
                                            <input class="form-check-input scope-item-check" type="checkbox" value="@option.Key" id="scope_@option.Key" @(activeKeys.Contains(option.Key) ? "checked" : "")>
                                            <label class="form-check-label" for="scope_@option.Key">@option.Label</label>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <input type="hidden" name="selectedModules" id="selectedModules" value="">

            <div class="mb-4">
                <label for="message" class="form-label fw-bold">Pesan Pemeliharaan</label>
                <textarea class="form-control" name="message" id="message" rows="3" placeholder="Masukkan pesan untuk ditampilkan kepada pengguna saat maintenance...">@Model.Message</textarea>
            </div>

            <div class="row">
                <div class="col-md-6 mb-4">
                    <label for="scheduledStartTime" class="form-label fw-bold">Tanggal Dimulai</label>
                    <input type="datetime-local" class="form-control" name="scheduledStartTime" id="scheduledStartTime"
                           value="@(Model.ScheduledStartTime.HasValue ? Model.ScheduledStartTime.Value.ToString("yyyy-MM-ddTHH:mm") : "")">
                    <small class="text-muted">Kosongkan jika ingin mengaktifkan secara manual.</small>
                </div>
                <div class="col-md-6 mb-4">
                    <label for="scheduledEndTime" class="form-label fw-bold">Tanggal Selesai</label>
                    <input type="datetime-local" class="form-control" name="scheduledEndTime" id="scheduledEndTime"
                           value="@(Model.ScheduledEndTime.HasValue ? Model.ScheduledEndTime.Value.ToString("yyyy-MM-ddTHH:mm") : "")">
                    <small class="text-muted">Kosongkan jika ingin menonaktifkan secara manual.</small>
                </div>
            </div>

            <button type="submit" class="btn btn-primary" id="btnSaveMaintenance"><i class="bi bi-save me-1"></i>Simpan Pengaturan</button>
        </form>
    </div>
</div>

@if (Model.IsEnabled && Model.ActivatedByName != null)
{
    <div class="mt-3 text-muted small">
        <i class="bi bi-info-circle me-1"></i>
        Diaktifkan oleh <strong>@Model.ActivatedByName</strong> pada @(Model.ActivatedAt.HasValue ? Model.ActivatedAt.Value.ToString("dd MMM yyyy HH:mm") : "-")
    </div>
}

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var scopeAll = document.getElementById('scopeAll');
        var scopeSpecific = document.getElementById('scopeSpecific');
        var checklist = document.getElementById('moduleChecklist');
        var searchInput = document.getElementById('scopeSearch');
        var selectedModules = document.getElementById('selectedModules');
        var summary = document.getElementById('selectedScopeSummary');
        var itemChecks = Array.from(document.querySelectorAll('.scope-item-check'));
        var groupChecks = Array.from(document.querySelectorAll('.scope-group-toggle'));
        var groups = Array.from(document.querySelectorAll('.maintenance-scope-group'));

        function toggleChecklist() {
            checklist.style.display = scopeSpecific.checked ? '' : 'none';
        }

        function getCheckedItems() {
            return itemChecks.filter(function (cb) { return cb.checked; });
        }

        function syncHiddenInput() {
            selectedModules.value = getCheckedItems().map(function (cb) { return cb.value; }).join(',');
        }

        function updateSummary() {
            summary.textContent = getCheckedItems().length + ' halaman dipilih';
        }

        function updateGroupState(groupKey) {
            var groupItems = itemChecks.filter(function (cb) {
                return cb.closest('.maintenance-scope-item').dataset.groupKey === groupKey;
            });
            var checkedCount = groupItems.filter(function (cb) { return cb.checked; }).length;
            var groupCheck = document.querySelector('.scope-group-toggle[data-group-key="' + groupKey + '"]');
            if (!groupCheck) return;

            groupCheck.checked = checkedCount > 0 && checkedCount === groupItems.length;
            groupCheck.indeterminate = checkedCount > 0 && checkedCount < groupItems.length;
        }

        function updateAllGroups() {
            groupChecks.forEach(function (groupCheck) {
                updateGroupState(groupCheck.dataset.groupKey);
            });
            syncHiddenInput();
            updateSummary();
        }

        function applyFilter() {
            var query = (searchInput.value || '').toLowerCase().trim();
            groups.forEach(function (group) {
                var groupLabel = group.dataset.groupLabel || '';
                var visibleChildren = 0;
                group.querySelectorAll('.maintenance-scope-item').forEach(function (item) {
                    var label = item.dataset.label || '';
                    var matched = !query || label.indexOf(query) !== -1 || groupLabel.indexOf(query) !== -1;
                    item.classList.toggle('hidden-by-filter', !matched);
                    if (matched) visibleChildren += 1;
                });
                group.classList.toggle('hidden-by-filter', visibleChildren === 0);
            });
        }

        scopeAll.addEventListener('change', toggleChecklist);
        scopeSpecific.addEventListener('change', toggleChecklist);

        itemChecks.forEach(function (checkbox) {
            checkbox.addEventListener('change', function () {
                updateGroupState(checkbox.closest('.maintenance-scope-item').dataset.groupKey);
                syncHiddenInput();
                updateSummary();
            });
        });

        groupChecks.forEach(function (groupCheck) {
            groupCheck.addEventListener('change', function () {
                var groupKey = groupCheck.dataset.groupKey;
                itemChecks.forEach(function (itemCheck) {
                    if (itemCheck.closest('.maintenance-scope-item').dataset.groupKey === groupKey) {
                        itemCheck.checked = groupCheck.checked;
                    }
                });
                updateAllGroups();
            });
        });

        document.getElementById('selectAllScopes').addEventListener('click', function () {
            itemChecks.forEach(function (checkbox) { checkbox.checked = true; });
            updateAllGroups();
        });

        document.getElementById('clearAllScopes').addEventListener('click', function () {
            itemChecks.forEach(function (checkbox) { checkbox.checked = false; });
            updateAllGroups();
        });

        searchInput.addEventListener('input', applyFilter);

        document.getElementById('maintenanceForm').addEventListener('submit', function (event) {
            syncHiddenInput();

            var startVal = document.getElementById('scheduledStartTime').value;
            var endVal = document.getElementById('scheduledEndTime').value;
            if (startVal && endVal && startVal >= endVal) {
                event.preventDefault();
                alert('Tanggal selesai harus setelah tanggal dimulai.');
                return;
            }

            if (scopeSpecific.checked && getCheckedItems().length === 0) {
                event.preventDefault();
                alert('Pilih minimal satu halaman jika menggunakan cakupan halaman tertentu.');
                return;
            }

            if (!scopeSpecific.checked) {
                selectedModules.value = '';
            }

            var btn = document.getElementById('btnSaveMaintenance');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Menyimpan...';
        });

        updateAllGroups();
        applyFilter();
        toggleChecklist();
    });
</script>
}
