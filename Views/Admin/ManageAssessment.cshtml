@{
    ViewData["Title"] = "Manage Assessment & Training";
    ViewData["ContainerClass"] = "container-fluid";

    var activeTab = ViewBag.ActiveTab as string ?? "assessment";
    var searchTerm = ViewBag.SearchTerm as string;
    var assessmentCategories = ViewBag.Categories as List<string> ?? new List<string>();
    var selectedCategory = ViewBag.SelectedCategory as string ?? "";
    var selectedStatus = ViewBag.SelectedStatus as string ?? "";

    // Phase 311 Plan 02: HTMX endpoint URLs (PathBase auto-resolved via @Url.Action).
    var urlAssessment = Url.Action("ManageAssessmentTab_Assessment", "AssessmentAdmin");
    var urlTraining = Url.Action("ManageAssessmentTab_Training", "AssessmentAdmin");
    var urlHistory = Url.Action("ManageAssessmentTab_History", "AssessmentAdmin");
}

@Html.AntiForgeryToken()

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Admin")">Kelola Data</a></li>
        <li class="breadcrumb-item active" aria-current="page">Manage Assessment & Training</li>
    </ol>
</nav>

<!-- Flash Messages -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="fw-bold text-dark mb-0">
        <i class="bi bi-sliders me-2 text-primary"></i>Manage Assessment & Training
    </h2>
    <div class="d-flex gap-2" id="header-assessment-btns"
         style="@(activeTab != "assessment" ? "display:none" : "")">
        <a href="@Url.Action("CreateAssessment", "AssessmentAdmin")" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Buat Assessment
        </a>
        <a href="@Url.Action("AssessmentMonitoring", "AssessmentAdmin")" class="btn btn-outline-success">
            <i class="bi bi-binoculars me-1"></i> Monitoring
        </a>
        <a href="@Url.Action("AuditLog", "AssessmentAdmin")" class="btn btn-outline-secondary">
            <i class="bi bi-clock-history me-1"></i> Audit Log
        </a>
    </div>
</div>

<!-- Tab Navigation -->
<ul class="nav nav-tabs mb-0" id="manageAssessmentTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="tab-assessment" data-bs-toggle="tab" data-bs-target="#pane-assessment"
                type="button" role="tab" aria-controls="pane-assessment" aria-selected="false">
            <i class="bi bi-sliders me-1"></i> Assessment Groups
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="tab-training" data-bs-toggle="tab" data-bs-target="#pane-training"
                type="button" role="tab" aria-controls="pane-training" aria-selected="false">
            <i class="bi bi-people me-1"></i> Input Records
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="tab-history" data-bs-toggle="tab" data-bs-target="#pane-history"
                type="button" role="tab" aria-controls="pane-history" aria-selected="false">
            <i class="bi bi-clock-history me-1"></i> History
        </button>
    </li>
</ul>

<!-- ============================================================ -->
<!-- Phase 311 Plan 02: Shared filter form di shell level         -->
<!-- (HTMX hx-include="#filter-form" target tab pane aktif).      -->
<!-- ============================================================ -->
<form id="filter-form" method="get" action="@Url.Action("ManageAssessment", "AssessmentAdmin")"
      class="row g-2 align-items-end my-3"
      onsubmit="return false;">

    <input type="hidden" name="tab" value="@activeTab" id="filter-tab" />
    <input type="hidden" name="page" value="1" id="filter-page" />
    <input type="hidden" name="pageSize" value="20" />

    <!-- Search input (D-03 debounce 500ms input) -->
    <div class="col-md-4">
        <div class="input-group">
            <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" class="form-control border-start-0 ps-0" name="search"
                   id="filter-search"
                   placeholder="Cari berdasarkan judul, kategori, nama, atau NIP..."
                   value="@searchTerm"
                   hx-get="@urlAssessment"
                   hx-trigger="input changed delay:500ms, keyup[key=='Enter']"
                   hx-target="#pane-@activeTab > div.htmx-tab-wrapper"
                   hx-swap="innerHTML"
                   hx-include="#filter-form"
                   hx-sync="this:replace" />
            <button class="btn btn-primary" type="button"
                    hx-get="@urlAssessment"
                    hx-target="#pane-@activeTab > div.htmx-tab-wrapper"
                    hx-swap="innerHTML"
                    hx-include="#filter-form"
                    hx-sync="closest form:replace">Cari</button>
            @if (!string.IsNullOrEmpty(searchTerm))
            {
                <button type="button" class="btn btn-outline-secondary" title="Hapus pencarian"
                        onclick="document.getElementById('filter-search').value=''; htmx.trigger('#filter-search','input')">
                    <i class="bi bi-x-lg"></i>
                </button>
            }
        </div>
    </div>

    <!-- Category dropdown (D-03 instant change) -->
    <div class="col-md-3">
        <select id="filter-category" name="category" class="form-select form-select-sm"
                hx-get="@urlAssessment"
                hx-trigger="change"
                hx-target="#pane-@activeTab > div.htmx-tab-wrapper"
                hx-swap="innerHTML"
                hx-include="#filter-form"
                hx-sync="this:replace">
            <option value="">Semua Kategori</option>
            @foreach (var cat in assessmentCategories)
            {
                if (selectedCategory == cat)
                { <option value="@cat" selected="selected">@cat</option> }
                else
                { <option value="@cat">@cat</option> }
            }
        </select>
    </div>

    <!-- Status dropdown (D-03 instant change) -->
    <div class="col-md-3">
        <select id="filter-status" name="statusFilter" class="form-select form-select-sm"
                hx-get="@urlAssessment"
                hx-trigger="change"
                hx-target="#pane-@activeTab > div.htmx-tab-wrapper"
                hx-swap="innerHTML"
                hx-include="#filter-form"
                hx-sync="this:replace">
            @if (string.IsNullOrEmpty(selectedStatus))
            { <option value="" selected="selected">Aktif (Open/Upcoming)</option> }
            else
            { <option value="">Aktif (Open/Upcoming)</option> }
            @if (selectedStatus == "Open")
            { <option value="Open" selected="selected">Open</option> }
            else
            { <option value="Open">Open</option> }
            @if (selectedStatus == "Upcoming")
            { <option value="Upcoming" selected="selected">Upcoming</option> }
            else
            { <option value="Upcoming">Upcoming</option> }
            @if (selectedStatus == "Closed")
            { <option value="Closed" selected="selected">Closed</option> }
            else
            { <option value="Closed">Closed</option> }
            @if (selectedStatus == "All")
            { <option value="All" selected="selected">Semua Status</option> }
            else
            { <option value="All">Semua Status</option> }
        </select>
    </div>

    <!-- Reset filter -->
    @if (!string.IsNullOrEmpty(selectedCategory) || !string.IsNullOrEmpty(selectedStatus) || !string.IsNullOrEmpty(searchTerm))
    {
        <div class="col-md-2">
            <a href="@Url.Action("ManageAssessment", "AssessmentAdmin", new { tab = activeTab })"
               class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-x-lg me-1"></i>Reset Filter
            </a>
        </div>
    }
</form>

<!-- Tab content -->
<div class="tab-content pt-2" id="manageAssessmentTabsContent">

    <!-- ===== TAB 1: ASSESSMENT GROUPS (active tab — hx-trigger=load) ===== -->
    <div class="tab-pane fade @(activeTab == "assessment" ? "show active" : "")"
         id="pane-assessment" role="tabpanel" aria-labelledby="tab-assessment">
        <div class="htmx-tab-wrapper"
             hx-get="@urlAssessment"
             hx-trigger="@(activeTab == "assessment" ? "load" : "shown.bs.tab from:#tab-assessment once")"
             hx-target="this"
             hx-swap="innerHTML"
             hx-include="#filter-form"
             hx-sync="this:replace"
             data-tab-name="assessment">
            <!-- Skeleton Assessment (UI-SPEC §1a) -->
            <div aria-busy="true" aria-label="Memuat data assessment" class="placeholder-glow">
                <div class="mb-3"><span class="placeholder col-2" style="height:24px"></span></div>
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        @for (int i = 0; i < 5; i++)
                        {
                            <div class="d-flex gap-2 mb-2 align-items-center" style="height:48px">
                                <span class="placeholder col-1"></span>
                                <span class="placeholder col-3"></span>
                                <span class="placeholder col-2"></span>
                                <span class="placeholder col-2"></span>
                                <span class="placeholder col-1"></span>
                                <span class="placeholder col-1"></span>
                                <span class="placeholder col-2"></span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== TAB 2: TRAINING RECORDS ===== -->
    <div class="tab-pane fade @(activeTab == "training" ? "show active" : "")"
         id="pane-training" role="tabpanel" aria-labelledby="tab-training">
        <div class="htmx-tab-wrapper"
             hx-get="@urlTraining"
             hx-trigger="@(activeTab == "training" ? "load" : "shown.bs.tab from:#tab-training once")"
             hx-target="this"
             hx-swap="innerHTML"
             hx-include="#filter-form"
             hx-sync="this:replace"
             data-tab-name="training">
            <!-- Skeleton Training (UI-SPEC §1b) -->
            <div aria-busy="true" aria-label="Memuat data training" class="placeholder-glow">
                <div class="d-flex justify-content-between mb-4">
                    <span class="placeholder col-2" style="height:24px"></span>
                    <div class="d-flex gap-2">
                        <span class="placeholder" style="width:140px;height:38px"></span>
                        <span class="placeholder" style="width:140px;height:38px"></span>
                    </div>
                </div>
                <div class="card bg-light border-0 mb-4">
                    <div class="card-body">
                        <div class="row g-3">
                            @for (int i = 0; i < 4; i++)
                            {
                                <div class="col-md-2"><span class="placeholder col-12" style="height:31px"></span></div>
                            }
                        </div>
                    </div>
                </div>
                @for (int i = 0; i < 5; i++)
                {
                    <div class="d-flex gap-2 mb-2" style="height:48px">
                        <span class="placeholder col-3"></span>
                        <span class="placeholder col-2"></span>
                        <span class="placeholder col-2"></span>
                        <span class="placeholder col-2"></span>
                        <span class="placeholder col-1"></span>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ===== TAB 3: HISTORY ===== -->
    <div class="tab-pane fade @(activeTab == "history" ? "show active" : "")"
         id="pane-history" role="tabpanel" aria-labelledby="tab-history">
        <div class="htmx-tab-wrapper"
             hx-get="@urlHistory"
             hx-trigger="@(activeTab == "history" ? "load" : "shown.bs.tab from:#tab-history once")"
             hx-target="this"
             hx-swap="innerHTML"
             hx-include="#filter-form"
             hx-sync="this:replace"
             data-tab-name="history">
            <!-- Skeleton History (UI-SPEC §1c) -->
            <div aria-busy="true" aria-label="Memuat riwayat" class="placeholder-glow">
                <div class="d-flex gap-3 mb-3 border-bottom pb-2">
                    <span class="placeholder col-2" style="height:32px"></span>
                    <span class="placeholder col-2" style="height:32px"></span>
                </div>
                <div class="row g-2 mb-3">
                    <div class="col-md-4"><span class="placeholder col-12" style="height:31px"></span></div>
                    <div class="col-md-4"><span class="placeholder col-12" style="height:31px"></span></div>
                </div>
                @for (int i = 0; i < 4; i++)
                {
                    <div class="d-flex gap-2 mb-2" style="height:40px">
                        <span class="placeholder col-3"></span>
                        <span class="placeholder col-3"></span>
                        <span class="placeholder col-2"></span>
                        <span class="placeholder col-2"></span>
                    </div>
                }
            </div>
        </div>
    </div>

</div>

<!-- Phase 311 Plan 02: HTMX 2.0.x vendored locally (D-02) -->
<script src="~/lib/htmx/htmx.min.js" defer></script>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Activate the correct tab based on ViewBag.ActiveTab
    var activeTab = '@activeTab';
    var tabId = activeTab === 'training' ? 'tab-training'
              : activeTab === 'history' ? 'tab-history'
              : 'tab-assessment';
    var tabEl = document.getElementById(tabId);
    if (tabEl) {
        new bootstrap.Tab(tabEl).show();
    }

    // Show/hide header action buttons based on active tab
    var headerAssessmentBtns = document.getElementById('header-assessment-btns');
    var manageAssessmentTabs = document.getElementById('manageAssessmentTabs');

    if (manageAssessmentTabs && headerAssessmentBtns) {
        manageAssessmentTabs.querySelectorAll('button[data-bs-toggle="tab"]').forEach(function(btn) {
            btn.addEventListener('shown.bs.tab', function(e) {
                var target = e.target.getAttribute('data-bs-target');
                if (target === '#pane-assessment') {
                    headerAssessmentBtns.style.display = '';
                } else {
                    headerAssessmentBtns.style.display = 'none';
                }
                // Phase 311 Plan 02: update hidden tab name di filter form supaya
                // filter trigger fetch tab yang aktif sekarang.
                var newTab = target.replace('#pane-','');
                var hiddenTab = document.getElementById('filter-tab');
                if (hiddenTab) hiddenTab.value = newTab;

                // Update hx-get filter input + dropdowns ke endpoint tab aktif (D-05 mendukung
                // filter affects active tab, cross-tab invalidation di-handle di bawah).
                var endpointMap = {
                    'assessment': '@urlAssessment',
                    'training': '@urlTraining',
                    'history': '@urlHistory'
                };
                var endpoint = endpointMap[newTab];
                if (endpoint) {
                    document.querySelectorAll('#filter-form [hx-get]').forEach(function(el){
                        el.setAttribute('hx-get', endpoint);
                        el.setAttribute('hx-target', '#pane-' + newTab + ' > div.htmx-tab-wrapper');
                    });
                    // Re-process attributes karena htmx tidak observe atribut runtime change
                    if (window.htmx) htmx.process(document.getElementById('filter-form'));
                }
            });
        });
    }
});

// Phase 311 Plan 04 gap closure (BUG-2A): Cross-tab cache invalidation (D-05).
// Listener fire HANYA saat swap berasal dari filter form change/input —
// BUKAN saat normal lazy-load tab activation swap. Dipakai elt provenance
// check via htmx:afterSwap event detail.requestConfig.elt: kalau elt
// closest ke #filter-form, swap = filter-driven; selain itu skip.
// BUG-2B fix: restored hx-trigger DROP `once` modifier — wrapper akan
// re-fire setiap shown.bs.tab event sampai content swap (saat user filter
// ulang, invalidation fire lagi). Sederhana, no htmx.cleanup needed.
document.body.addEventListener('htmx:afterSwap', function(evt) {
    var target = evt.detail.target;
    if (!target || !target.classList || !target.classList.contains('htmx-tab-wrapper')) return;

    // Provenance check: hanya invalidate saat trigger elt berada di dalam #filter-form.
    // evt.detail.requestConfig.elt = element yang trigger HTMX request.
    // Tab activation swap (hx-trigger="load" atau "shown.bs.tab") punya elt = wrapper itu sendiri,
    // BUKAN element di dalam #filter-form. Filter-driven swap punya elt = input/select di filter-form.
    var triggerElt = evt.detail.requestConfig && evt.detail.requestConfig.elt;
    if (!triggerElt || !triggerElt.closest || !triggerElt.closest('#filter-form')) {
        return; // Skip: bukan filter-driven swap (normal tab activation atau retry)
    }

    var activeTabName = target.getAttribute('data-tab-name');
    document.querySelectorAll('.htmx-tab-wrapper').forEach(function(wrapper){
        var tabName = wrapper.getAttribute('data-tab-name');
        if (tabName === activeTabName) return;
        // Reset ke skeleton placeholder + restore hx-trigger TANPA `once` (BUG-2B fix Option 2).
        // Tanpa `once`, wrapper akan re-fire setiap shown.bs.tab event — acceptable karena
        // selama wrapper sudah swap content sekali, fire kedua akan re-fetch dengan filter terbaru
        // (idempotent + intentional behavior post-invalidation).
        wrapper.innerHTML = '<div aria-busy="true" aria-label="Memuat data" class="placeholder-glow"><div class="row g-2 mb-2"><span class="placeholder col-12" style="height:48px"></span></div><div class="row g-2 mb-2"><span class="placeholder col-12" style="height:48px"></span></div></div>';
        wrapper.setAttribute('hx-trigger', 'shown.bs.tab from:#tab-' + tabName);
        if (window.htmx) htmx.process(wrapper);
    });
});

// Phase 311 Plan 02: Error template (UI-SPEC §2).
// Saat partial endpoint return 4xx/5xx atau network fail, swap target dengan error template + retry button.
function renderHtmxError(targetEl) {
    targetEl.innerHTML = '<div role="alert" class="alert alert-danger d-flex align-items-start gap-2 my-3">' +
        '<i class="bi bi-exclamation-triangle-fill flex-shrink-0" style="font-size:1.25rem"></i>' +
        '<div class="flex-grow-1">' +
        '<div class="fw-semibold mb-1">Gagal memuat data</div>' +
        '<div class="small mb-2">Periksa koneksi jaringan Anda lalu coba lagi. Jika masalah berlanjut, hubungi administrator.</div>' +
        '<button type="button" class="btn btn-sm btn-outline-danger" data-htmx-retry>' +
        '<i class="bi bi-arrow-clockwise me-1"></i>Coba Lagi' +
        '</button>' +
        '</div>' +
        '</div>';
}
document.body.addEventListener('htmx:responseError', function(evt) {
    var target = evt.detail.target || evt.target;
    if (target && target.classList && target.classList.contains('htmx-tab-wrapper')) {
        renderHtmxError(target);
    }
});
document.body.addEventListener('htmx:sendError', function(evt) {
    var target = evt.detail.target || evt.target;
    if (target && target.classList && target.classList.contains('htmx-tab-wrapper')) {
        renderHtmxError(target);
    }
});
// Phase 311 Plan 04 gap closure (BUG-5A): Retry button delegation.
// Pakai htmx.ajax('GET', url, {target, swap}) direct supaya bypass trigger
// dispatcher (handler lama trigger 'load' tidak match wrapper hx-trigger
// 'shown.bs.tab' → no-op). Direct ajax call paling robust dan preserve
// filter values via hx-include semantics (htmx.ajax otomatis include form
// data sesuai hx-include attribute pada wrapper).
document.body.addEventListener('click', function(evt) {
    var btn = evt.target.closest('[data-htmx-retry]');
    if (!btn) return;
    var wrapper = btn.closest('.htmx-tab-wrapper');
    if (!wrapper || !window.htmx) return;
    var url = wrapper.getAttribute('hx-get');
    if (!url) return;
    // Show skeleton selama refetch in-flight (UX feedback).
    wrapper.innerHTML = '<div aria-busy="true" aria-label="Memuat ulang data" class="placeholder-glow"><div class="row g-2 mb-2"><span class="placeholder col-12" style="height:48px"></span></div><div class="row g-2 mb-2"><span class="placeholder col-12" style="height:48px"></span></div></div>';
    // Direct AJAX call: bypass trigger dispatcher, target = wrapper, innerHTML swap.
    // hx-include="#filter-form" pada wrapper sudah declarative — htmx.ajax
    // honor hx-include attribute saat element argument disediakan (3rd arg).
    htmx.ajax('GET', url, { target: wrapper, swap: 'innerHTML', source: wrapper });
});

// Regenerate Token handler — preserved dari versi lama
document.body.addEventListener('click', function(evt) {
    var btn = evt.target.closest('.btn-regenerate-token');
    if (!btn) return;
    (async function() {
        var id = btn.dataset.id;
        var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value
            || document.querySelector('[name="__RequestVerificationToken"]')?.value;
        try {
            var res = await fetch(appUrl('/Admin/RegenerateToken/' + id), {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: '__RequestVerificationToken=' + encodeURIComponent(token)
            });
            var data = await res.json();
            if (data.success) {
                alert('Token baru: ' + data.token);
            } else {
                alert('Error: ' + data.message);
            }
        } catch (e) {
            alert('Gagal regenerate token.');
        }
    })();
});

// History tab: Riwayat Assessment client-side filter (preserved dari versi lama)
function filterAssessmentRows() {
    var workerFilter = document.getElementById('assessmentWorkerFilter')?.value.toLowerCase() || '';
    var titleFilter = document.getElementById('assessmentTitleFilter')?.value.toLowerCase() || '';
    var rows = document.querySelectorAll('#assessmentHistoryTable .assessment-history-row');
    rows.forEach(function(row) {
        var worker = row.getAttribute('data-worker') || '';
        var title = row.getAttribute('data-title') || '';
        var workerMatch = !workerFilter || worker.includes(workerFilter);
        var titleMatch = !titleFilter || title.toLowerCase().includes(titleFilter);
        row.style.display = (workerMatch && titleMatch) ? '' : 'none';
    });
}
</script>
}
