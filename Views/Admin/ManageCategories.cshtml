@model IEnumerable<HcPortal.Models.AssessmentCategory>

@{
    ViewData["Title"] = "Kategori Assessment";
    var editCategory = ViewBag.EditCategory as HcPortal.Models.AssessmentCategory;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select@2/dist/css/tom-select.css">

<div class="container-fluid px-4 py-4">

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Admin")">Kelola Data</a></li>
            <li class="breadcrumb-item active" aria-current="page">Kategori Assessment</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-tags me-2 text-primary"></i>Kategori Assessment
            </h2>
            <p class="text-muted mb-0">Kelola kategori assessment, hierarki, dan penandatangan sertifikat</p>
        </div>
        <div class="d-flex gap-2">
            <div class="btn-group">
                <button type="button" class="btn btn-outline-success dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-download me-1"></i>Export
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="@Url.Action("ExportCategoriesExcel", "Admin")"><i class="bi bi-file-earmark-excel me-2"></i>Excel</a></li>
                    <li><a class="dropdown-item" href="@Url.Action("ExportCategoriesPdf", "Admin")"><i class="bi bi-file-earmark-pdf me-2"></i>PDF</a></li>
                </ul>
            </div>
            <button type="button" class="btn btn-primary" data-bs-toggle="collapse" data-bs-target="#addCategoryForm">
                <i class="bi bi-plus-circle me-2"></i>Tambah Kategori
            </button>
        </div>
    </div>

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Add Form -->
    <div class="collapse @(TempData["ShowAddForm"] != null ? "show" : "") mb-4" id="addCategoryForm">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-primary text-white fw-bold">
                <i class="bi bi-plus-circle me-2"></i>Tambah Kategori Baru
            </div>
            <div class="card-body">
                <form method="post" action="@Url.Action("AddCategory", "Admin")">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label fw-bold">Nama Kategori <span class="text-danger">*</span></label>
                            <input type="text" name="name" class="form-control" placeholder="e.g. OJT" required maxlength="100" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Nilai Lulus Default (%)</label>
                            <input type="number" name="defaultPassPercentage" class="form-control" value="70" min="0" max="100" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-bold">Urutan</label>
                            <input type="number" name="sortOrder" class="form-control" value="0" min="0" />
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-plus-circle me-1"></i>Tambah
                            </button>
                        </div>
                    </div>
                    <div class="row g-3 mt-1">
                        <div class="col-md-5">
                            <label class="form-label fw-bold">Kategori Induk</label>
                            <select class="form-select" name="parentId">
                                <option value="">— Tidak ada (Kategori Utama) —</option>
                                @if (ViewBag.PotentialParents != null)
                                {
                                    foreach (var pp in (IEnumerable<HcPortal.Models.AssessmentCategory>)ViewBag.PotentialParents)
                                    {
                                        <option value="@pp.Id">@(pp.Parent != null ? "↳ " : "")@pp.Name</option>
                                    }
                                }
                            </select>
                            <div class="form-text">Kosongkan untuk membuat kategori utama.</div>
                        </div>
                        <div class="col-md-7">
                            <label class="form-label fw-bold">Penandatangan</label>
                            <select class="form-select" id="signatorySelect" name="signatoryUserId">
                                <option value="">— Tidak ada —</option>
                                @if (ViewBag.AllUsers != null)
                                {
                                    foreach (var u in (IEnumerable<dynamic>)ViewBag.AllUsers)
                                    {
                                        <option value="@u.Id"
                                                data-position="@u.Position"
                                                data-fullname="@u.FullName">@u.FullName (@u.NIP)</option>
                                    }
                                }
                            </select>
                            <div id="psignPreview" class="mt-3 d-none">
                                <div class="text-muted small mb-1">Preview P-Sign pada sertifikat:</div>
                                <div class="psign-badge-cert" style="display:inline-block; text-align:center; background:transparent;">
                                    <img src="~/images/psign-pertamina.png" style="height:48px; margin-bottom:8px;" />
                                    <div id="psignPreviewPosition" style="font-size:0.85rem; color:#333; line-height:1.3;"></div>
                                    <div id="psignPreviewName" style="font-size:0.9rem; font-weight:700; color:#000; line-height:1.3; margin-top:4px;"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Edit Form (shown when edit is triggered) -->
    @if (editCategory != null)
    {
        <div class="card border-0 shadow-sm mb-4 border-warning">
            <div class="card-header bg-warning text-dark fw-bold">
                <i class="bi bi-pencil-square me-2"></i>Edit Kategori: @editCategory.Name
            </div>
            <div class="card-body">
                <form method="post" action="@Url.Action("EditCategory", "Admin", new { id = editCategory.Id })">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label fw-bold">Nama Kategori <span class="text-danger">*</span></label>
                            <input type="text" name="name" class="form-control" value="@editCategory.Name" required maxlength="100" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Nilai Lulus Default (%)</label>
                            <input type="number" name="defaultPassPercentage" class="form-control" value="@editCategory.DefaultPassPercentage" min="0" max="100" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-bold">Urutan</label>
                            <input type="number" name="sortOrder" class="form-control" value="@editCategory.SortOrder" min="0" />
                        </div>
                        <div class="col-md-2 d-flex align-items-end gap-2">
                            <button type="submit" class="btn btn-warning w-100">
                                <i class="bi bi-save me-1"></i>Simpan
                            </button>
                            <a href="@Url.Action("ManageCategories", "Admin")" class="btn btn-outline-secondary">
                                <i class="bi bi-x"></i>
                            </a>
                        </div>
                    </div>
                    <div class="row g-3 mt-1">
                        <div class="col-md-5">
                            <label class="form-label fw-bold">Kategori Induk</label>
                            <select class="form-select" name="parentId">
                                <option value="">— Tidak ada (Kategori Utama) —</option>
                                @if (ViewBag.PotentialParents != null)
                                {
                                    foreach (var pp in (IEnumerable<HcPortal.Models.AssessmentCategory>)ViewBag.PotentialParents)
                                    {
                                        if (editCategory.ParentId.HasValue && editCategory.ParentId.Value == pp.Id)
                                        {
                                            <option value="@pp.Id" selected>@(pp.Parent != null ? "↳ " : "")@pp.Name</option>
                                        }
                                        else
                                        {
                                            <option value="@pp.Id">@(pp.Parent != null ? "↳ " : "")@pp.Name</option>
                                        }
                                    }
                                }
                            </select>
                            <div class="form-text">Kosongkan untuk membuat kategori utama.</div>
                        </div>
                        <div class="col-md-7">
                            <label class="form-label fw-bold">Penandatangan</label>
                            <select class="form-select" id="editSignatorySelect" name="signatoryUserId">
                                <option value="">— Tidak ada —</option>
                                @if (ViewBag.AllUsers != null)
                                {
                                    foreach (var u in (IEnumerable<dynamic>)ViewBag.AllUsers)
                                    {
                                        if (editCategory.SignatoryUserId == (string)u.Id)
                                        {
                                            <option value="@u.Id"
                                                    data-position="@u.Position"
                                                    data-fullname="@u.FullName"
                                                    selected>@u.FullName (@u.NIP)</option>
                                        }
                                        else
                                        {
                                            <option value="@u.Id"
                                                    data-position="@u.Position"
                                                    data-fullname="@u.FullName">@u.FullName (@u.NIP)</option>
                                        }
                                    }
                                }
                            </select>
                            <div id="editPsignPreview" class="mt-3 @(editCategory.SignatoryUserId != null ? "" : "d-none")">
                                <div class="text-muted small mb-1">Preview P-Sign pada sertifikat:</div>
                                <div class="psign-badge-cert" style="display:inline-block; text-align:center; background:transparent;">
                                    <img src="~/images/psign-pertamina.png" style="height:48px; margin-bottom:8px;" />
                                    <div id="editPsignPreviewPosition" style="font-size:0.85rem; color:#333; line-height:1.3;"></div>
                                    <div id="editPsignPreviewName" style="font-size:0.9rem; font-weight:700; color:#000; line-height:1.3; margin-top:4px;"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    }

    <!-- Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-tags fs-1 d-block mb-3"></i>
                    <h5>Belum ada kategori</h5>
                    <p class="small">Tambahkan kategori assessment menggunakan tombol 'Tambah Kategori' di atas.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-bordered align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="p-3" style="width:50px;">#</th>
                                <th class="p-3">Nama Kategori</th>
                                <th class="p-3 text-center" style="width:180px;">Nilai Lulus Default (%)</th>
                                <th class="p-3 text-center" style="width:100px;">Urutan</th>
                                <th class="p-3" style="width:160px;">Penandatangan</th>
                                <th class="p-3 text-center" style="width:110px;">Status</th>
                                <th class="p-3 text-center" style="width:160px;">Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var rowNum = 0; }
                            @foreach (var parent in Model)
                            {
                                rowNum++;
                                var hasChildren = parent.Children.Any();
                                <tr>
                                    <td class="p-3 text-muted small">@rowNum</td>
                                    <td class="p-3 fw-bold">
                                        @parent.Name
                                        @if (hasChildren)
                                        {
                                            <span class="badge bg-light text-secondary border ms-2 small">Parent</span>
                                        }
                                    </td>
                                    <td class="p-3 text-center">@parent.DefaultPassPercentage%</td>
                                    <td class="p-3 text-center">@parent.SortOrder</td>
                                    <td class="p-3">@(parent.Signatory != null ? parent.Signatory.FullName : "—")</td>
                                    <td class="p-3 text-center">
                                        @if (parent.IsActive)
                                        {
                                            <span class="badge bg-success">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Nonaktif</span>
                                        }
                                    </td>
                                    <td class="p-3 text-center">
                                        <div class="btn-group btn-group-sm">
                                            <a href="@Url.Action("EditCategory", "Admin", new { id = parent.Id })"
                                               class="btn btn-outline-primary"
                                               aria-label="Edit kategori"
                                               title="Edit">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                            <form method="post" action="@Url.Action("ToggleCategoryActive", "Admin")" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@parent.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-warning" title="@(parent.IsActive ? "Nonaktifkan" : "Aktifkan")">
                                                    <i class="bi @(parent.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                                </button>
                                            </form>
                                            @if (hasChildren)
                                            {
                                                <button type="button" class="btn btn-sm btn-danger" disabled
                                                        aria-label="Hapus kategori"
                                                        title="Hapus sub-kategori terlebih dahulu sebelum menghapus kategori ini.">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn btn-sm btn-danger"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#deleteModal"
                                                        data-id="@parent.Id"
                                                        data-name="@parent.Name"
                                                        aria-label="Hapus kategori"
                                                        title="Hapus">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                                @foreach (var child in parent.Children)
                                {
                                    rowNum++;
                                    var childHasChildren = child.Children.Any();
                                    <tr>
                                        <td class="p-3 text-muted small">@rowNum</td>
                                        <td class="p-3 ps-4">
                                            <i class="bi bi-arrow-return-right text-muted me-2 small"></i>@child.Name
                                            @if (childHasChildren)
                                            {
                                                <span class="badge bg-light text-secondary border ms-2 small">Parent</span>
                                            }
                                        </td>
                                        <td class="p-3 text-center">@child.DefaultPassPercentage%</td>
                                        <td class="p-3 text-center">@child.SortOrder</td>
                                        <td class="p-3">@(child.Signatory != null ? child.Signatory.FullName : "—")</td>
                                        <td class="p-3 text-center">
                                            @if (child.IsActive)
                                            {
                                                <span class="badge bg-success">Aktif</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Nonaktif</span>
                                            }
                                        </td>
                                        <td class="p-3 text-center">
                                            <div class="btn-group btn-group-sm">
                                                <a href="@Url.Action("EditCategory", "Admin", new { id = child.Id })"
                                                   class="btn btn-outline-primary"
                                                   aria-label="Edit kategori"
                                                   title="Edit">
                                                    <i class="bi bi-pencil-square"></i>
                                                </a>
                                                <form method="post" action="@Url.Action("ToggleCategoryActive", "Admin")" style="display:inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@child.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-warning" title="@(child.IsActive ? "Nonaktifkan" : "Aktifkan")">
                                                        <i class="bi @(child.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                                    </button>
                                                </form>
                                                @if (childHasChildren)
                                                {
                                                    <button type="button" class="btn btn-sm btn-danger" disabled
                                                            aria-label="Hapus kategori"
                                                            title="Hapus sub-kategori terlebih dahulu sebelum menghapus kategori ini.">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button type="button" class="btn btn-sm btn-danger"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#deleteModal"
                                                            data-id="@child.Id"
                                                            data-name="@child.Name"
                                                            aria-label="Hapus kategori"
                                                            title="Hapus">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                    @foreach (var gc in child.Children)
                                    {
                                        rowNum++;
                                        <tr>
                                            <td class="p-3 text-muted small">@rowNum</td>
                                            <td class="p-3 ps-5">
                                                <i class="bi bi-arrow-return-right text-muted me-2 small"></i>@gc.Name
                                            </td>
                                            <td class="p-3 text-center">@gc.DefaultPassPercentage%</td>
                                            <td class="p-3 text-center">@gc.SortOrder</td>
                                            <td class="p-3">@(gc.Signatory != null ? gc.Signatory.FullName : "—")</td>
                                            <td class="p-3 text-center">
                                                @if (gc.IsActive)
                                                {
                                                    <span class="badge bg-success">Aktif</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Nonaktif</span>
                                                }
                                            </td>
                                            <td class="p-3 text-center">
                                                <div class="btn-group btn-group-sm">
                                                    <a href="@Url.Action("EditCategory", "Admin", new { id = gc.Id })"
                                                       class="btn btn-outline-primary"
                                                       aria-label="Edit kategori"
                                                       title="Edit">
                                                        <i class="bi bi-pencil-square"></i>
                                                    </a>
                                                    <form method="post" action="@Url.Action("ToggleCategoryActive", "Admin")" style="display:inline;">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@gc.Id" />
                                                        <button type="submit" class="btn btn-sm btn-outline-warning" title="@(gc.IsActive ? "Nonaktifkan" : "Aktifkan")">
                                                            <i class="bi @(gc.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                                        </button>
                                                    </form>
                                                    <button type="button" class="btn btn-sm btn-danger"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#deleteModal"
                                                            data-id="@gc.Id"
                                                            data-name="@gc.Name"
                                                            aria-label="Hapus kategori"
                                                            title="Hapus">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Konfirmasi Hapus</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Apakah Anda yakin ingin menghapus kategori "<strong id="deleteModalName"></strong>"?
                <br><small class="text-muted">Tindakan ini tidak dapat dibatalkan. Assessment yang sudah menggunakan kategori ini tidak akan terpengaruh.</small>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteModalId" />
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Hapus
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/tom-select@2/dist/js/tom-select.complete.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Delete modal
        var deleteModal = document.getElementById('deleteModal');
        if (deleteModal) {
            deleteModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                var id = button.getAttribute('data-id');
                var name = button.getAttribute('data-name');
                document.getElementById('deleteModalName').textContent = name;
                document.getElementById('deleteModalId').value = id;
                document.getElementById('deleteForm').action = '@Url.Action("DeleteCategory", "Admin")';
            });
        }

        // tom-select for add form signatory
        var addSig = document.getElementById('signatorySelect');
        if (addSig) new TomSelect(addSig, { allowEmptyOption: true });

        // tom-select for edit form signatory
        var editSig = document.getElementById('editSignatorySelect');
        if (editSig) new TomSelect(editSig, { allowEmptyOption: true });

        // P-Sign preview logic — add form
        function bindSignatoryPreview(selectId, previewId, positionId, nameId) {
            var sel = document.getElementById(selectId);
            var preview = document.getElementById(previewId);
            if (!sel || !preview) return;

            function updatePreview() {
                var opt = sel.options[sel.selectedIndex];
                if (!opt || !opt.value) {
                    preview.classList.add('d-none');
                    return;
                }
                preview.classList.remove('d-none');
                document.getElementById(positionId).textContent = opt.dataset.position || '';
                document.getElementById(nameId).textContent = opt.dataset.fullname || '';
            }

            sel.addEventListener('change', updatePreview);
            // Initialize on load (for edit form with pre-selected value)
            updatePreview();
        }

        bindSignatoryPreview('signatorySelect', 'psignPreview', 'psignPreviewPosition', 'psignPreviewName');
        bindSignatoryPreview('editSignatorySelect', 'editPsignPreview', 'editPsignPreviewPosition', 'editPsignPreviewName');
    });
</script>
