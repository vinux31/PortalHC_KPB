@using HcPortal.Models
@{
    ViewData["Title"] = "Manage Questions";
    int packageId = (int)ViewBag.PackageId;
    int assessmentId = (int)ViewBag.AssessmentId;
    var questions = ViewBag.Questions as List<PackageQuestion> ?? new List<PackageQuestion>();
    // Phase 415 SEC-01/02/05: Section list per-paket (sudah OrderBy SectionNumber dari controller).
    var sections = ViewBag.Sections as List<AssessmentPackageSection> ?? new List<AssessmentPackageSection>();
    // Label tampilan Section: "@SectionNumber. @Name" atau "Section @SectionNumber" bila Nama kosong.
    Func<AssessmentPackageSection, string> sectionLabel = s =>
        string.IsNullOrWhiteSpace(s.Name) ? $"Section {s.SectionNumber}" : $"{s.SectionNumber}. {s.Name}";
}

@* Phase 415 SEC-05: template baris soal (reuse markup existing) untuk daftar dikelompokkan per Section. *@
@{
    Func<PackageQuestion, Microsoft.AspNetCore.Mvc.Razor.HelperResult> questionRow = @<text>
        @{ var qtype = item.QuestionType ?? "MultipleChoice"; }
        <tr>
            <td class="text-muted">@item.Order</td>
            <td>
                <span class="d-inline-block text-truncate" style="max-width:260px" title="@item.QuestionText">
                    @item.QuestionText
                </span>
            </td>
            <td>
                <span class="badge @QuestionTypeLabels.BadgeClass(qtype) small">@QuestionTypeLabels.Short(qtype)</span>
            </td>
            <td class="text-center">@item.ScoreValue</td>
            <td>
                <div class="d-flex gap-1">
                    <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-1" onclick="loadPreview(@item.Id)" title="Preview">
                        <i class="bi bi-eye"></i>
                    </button>
                    <button type="button" class="btn btn-outline-primary btn-sm py-0 px-1" onclick="loadEditForm(@item.Id)" title="Edit">
                        <i class="bi bi-pencil"></i>
                    </button>
                    <form asp-action="DeleteQuestion" asp-controller="AssessmentAdmin" method="post" class="d-inline"
                          onsubmit="return confirm('Hapus soal ini?')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="questionId" value="@item.Id" />
                        <input type="hidden" name="packageId" value="@ViewBag.PackageId" />
                        <button type="submit" class="btn btn-outline-danger btn-sm py-0 px-1" title="Hapus">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                </div>
            </td>
        </tr>
    </text>;
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0">Manage Questions</h1>
            <p class="text-muted mb-0">Package: <strong>@ViewBag.PackageName</strong> &mdash; @ViewBag.AssessmentTitle</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="ImportPackageQuestions" asp-controller="AssessmentAdmin" asp-route-packageId="@packageId"
               class="btn btn-outline-success btn-sm">
                <i class="bi bi-upload me-1"></i>Import Excel
            </a>
            <a asp-action="ManagePackages" asp-controller="AssessmentAdmin" asp-route-assessmentId="@assessmentId"
               class="btn btn-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Kembali ke Packages
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <!-- Phase 415 SEC-01/02: Panel Kelola Section (inline, full-width — D-415-01) -->
    <div class="card shadow-sm mb-4" id="sectionPanelCard">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Kelola Section</span>
            @if (sections.Any())
            {
                <form asp-action="SetAllSectionsNewPage" asp-controller="AssessmentAdmin" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="packageId" value="@packageId" />
                    <button type="submit" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-file-earmark-break me-1"></i>Semua Section mulai halaman baru
                    </button>
                </form>
            }
        </div>
        <div class="card-body">
            <p class="text-muted small mb-3">Section mengelompokkan soal per area/equipment. Opsional — paket tanpa Section berperilaku seperti sebelumnya.</p>
            <div class="row g-3">
                <!-- Daftar Section -->
                <div class="col-lg-7">
                    @if (!sections.Any())
                    {
                        <div class="p-4 text-center text-muted">
                            <i class="bi bi-collection fs-2 d-block mb-2"></i>
                            <div class="fw-semibold">Belum ada Section.</div>
                            <div class="small">Tambahkan Section memakai form di samping, atau biarkan kosong — paket akan berperilaku seperti sebelumnya (semua soal tanpa Section).</div>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover table-sm mb-0 align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:90px">No. Section</th>
                                        <th>Nama</th>
                                        <th class="text-center" style="width:120px">Mulai Halaman Baru</th>
                                        <th class="text-center" style="width:80px">Acak</th>
                                        <th style="width:120px">Aksi</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in sections)
                                    {
                                        var qCount = questions.Count(q => q.SectionId == s.Id);
                                        <tr>
                                            <td class="text-center text-muted">@s.SectionNumber</td>
                                            <td>@(string.IsNullOrWhiteSpace(s.Name) ? "—" : s.Name)</td>
                                            <td class="text-center">
                                                @if (s.StartNewPage)
                                                {
                                                    <span class="badge bg-secondary small">Ya</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">Tidak</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                @if (s.ShuffleEnabled)
                                                {
                                                    <span class="badge bg-secondary small">Ya</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">Tidak</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="d-flex gap-1">
                                                    <button type="button"
                                                            class="btn btn-outline-primary btn-sm py-0 px-1"
                                                            title="Ubah Section"
                                                            data-section-id="@s.Id"
                                                            data-section-number="@s.SectionNumber"
                                                            data-section-name="@s.Name"
                                                            data-section-startnewpage="@(s.StartNewPage ? "true" : "false")"
                                                            data-section-shuffleenabled="@(s.ShuffleEnabled ? "true" : "false")"
                                                            onclick="loadSectionEdit(this)">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    <form asp-action="DeleteSection" asp-controller="AssessmentAdmin" method="post" class="d-inline"
                                                          onsubmit="return confirm('Hapus Section ini? Soal di dalamnya menjadi &quot;Tanpa Section&quot; (Lainnya), tidak terhapus.')">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="sectionId" value="@s.Id" />
                                                        <input type="hidden" name="packageId" value="@packageId" />
                                                        <button type="submit" class="btn btn-outline-danger btn-sm py-0 px-1" title="Hapus Section">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                                @if (qCount > 0)
                                                {
                                                    <div class="form-text mt-0">@qCount soal</div>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                <!-- Form buat/edit Section -->
                <div class="col-lg-5">
                    <form id="sectionForm" asp-action="CreateSection" asp-controller="AssessmentAdmin" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="packageId" value="@packageId" />
                        <input type="hidden" id="sectionEditId" name="sectionId" value="" />

                        <div class="fw-semibold mb-2" id="sectionFormTitle">Tambah Section</div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold small">No. Section <span class="text-danger">*</span></label>
                            <input type="number" class="form-control form-control-sm" name="sectionNumber" id="sectionNumber"
                                   min="1" step="1" required style="max-width:120px" />
                            <div class="form-text">Angka urut tampilan (1, 2, 3 …). Harus unik dalam paket ini.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold small">Nama Section</label>
                            <input type="text" class="form-control form-control-sm" name="name" id="sectionName"
                                   placeholder="mis. Pompa &amp; Kompresor" />
                            <div class="form-text">Opsional — label tampilan, mis. "Pompa &amp; Kompresor".</div>
                        </div>

                        <div class="form-check form-switch mb-1">
                            <input class="form-check-input" type="checkbox" name="startNewPage" value="true" id="sectionStartNewPage" />
                            <label class="form-check-label small" for="sectionStartNewPage">Mulai Halaman Baru</label>
                        </div>
                        <div class="form-text text-muted mb-3">Saat aktif, Section ini mulai di halaman baru saat ujian. (Berlaku penuh di fitur pagination — Fase 417.)</div>

                        <div class="form-check form-switch mb-1">
                            <input class="form-check-input" type="checkbox" name="shuffleEnabled" value="true" id="sectionShuffleEnabled" checked />
                            <label class="form-check-label small" for="sectionShuffleEnabled">Acak Soal di Section ini</label>
                        </div>
                        <div class="form-text text-muted mb-3">Saat aktif, urutan soal &amp; pilihan diacak hanya di dalam Section ini. (Berlaku penuh di fitur acak per-Section — Fase 416.)</div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-sm">
                                <i class="bi bi-save me-1"></i>Simpan Section
                            </button>
                            <button type="button" class="btn btn-secondary btn-sm" id="sectionCancelBtn"
                                    style="display:none" onclick="resetSectionForm()">
                                Batal
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Left: Daftar soal -->
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <span class="fw-semibold">Daftar Soal (@questions.Count soal • Total @questions.Sum(q => q.ScoreValue) poin)</span>
                </div>
                <div class="card-body p-0">
                    @if (!questions.Any())
                    {
                        <div class="p-4 text-center text-muted">
                            <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                            Belum ada soal. Tambahkan soal menggunakan form di samping atau import dari Excel.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover table-sm mb-0 align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:40px">#</th>
                                        <th>Teks Soal</th>
                                        <th style="width:110px">Tipe</th>
                                        <th style="width:60px">Skor</th>
                                        <th style="width:110px">Aksi</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @* Phase 415 SEC-05: kelompokkan soal per Section (header neutral bg-light), grup "Lainnya" terakhir. *@
                                    @foreach (var s in sections)
                                    {
                                        var sectionQuestions = questions.Where(q => q.SectionId == s.Id).ToList();
                                        <tr class="bg-light">
                                            <td colspan="5" class="fw-semibold">
                                                @(string.IsNullOrWhiteSpace(s.Name) ? $"Section {s.SectionNumber}" : $"Section {s.SectionNumber} — {s.Name}") <span class="text-muted fw-normal">(@sectionQuestions.Count soal)</span>
                                            </td>
                                        </tr>
                                        @foreach (var q in sectionQuestions)
                                        {
                                            @questionRow(q)
                                        }
                                    }
                                    @{
                                        var ungrouped = questions.Where(q => q.SectionId == null).ToList();
                                    }
                                    @if (ungrouped.Any())
                                    {
                                        <tr class="bg-light">
                                            <td colspan="5" class="fw-semibold">
                                                Lainnya (tanpa Section) <span class="text-muted fw-normal">(@ungrouped.Count soal)</span>
                                            </td>
                                        </tr>
                                        @foreach (var q in ungrouped)
                                        {
                                            @questionRow(q)
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Right: Form create/edit soal -->
        <div class="col-lg-5">
            <div class="card shadow-sm" id="questionFormCard">
                <div class="card-header bg-light">
                    <span class="fw-semibold" id="formTitle">Tambah Soal Baru</span>
                </div>
                <div class="card-body">
                    <form id="questionForm" asp-action="CreateQuestion" asp-controller="AssessmentAdmin" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="packageId" value="@packageId" />
                        <input type="hidden" id="editQuestionId" name="questionId" value="" />

                        <!-- QuestionType dropdown -->
                        <div class="mb-3">
                            <label class="form-label fw-medium small">Tipe Soal</label>
                            <select class="form-select form-select-sm" id="QuestionType" name="questionType">
                                <option value="MultipleChoice">@QuestionTypeLabels.Long("MultipleChoice")</option>
                                <option value="MultipleAnswer">@QuestionTypeLabels.Long("MultipleAnswer")</option>
                                <option value="Essay">@QuestionTypeLabels.Long("Essay")</option>
                            </select>
                        </div>

                        <!-- Phase 415 SEC-03: dropdown assign soal → Section -->
                        <div class="mb-3">
                            <label class="form-label fw-medium small">Section</label>
                            <select class="form-select form-select-sm" id="sectionIdSelect" name="sectionId">
                                <option value="">— Tanpa Section (Lainnya) —</option>
                                @foreach (var s in sections)
                                {
                                    <option value="@s.Id">@sectionLabel(s)</option>
                                }
                            </select>
                            <div class="form-text">Soal tanpa Section masuk grup "Lainnya" di urutan terakhir.</div>
                        </div>

                        <!-- Teks soal -->
                        <div class="mb-3">
                            <label class="form-label fw-medium small">Teks Soal <span class="text-danger">*</span></label>
                            <textarea class="form-control form-control-sm" id="questionText" name="questionText"
                                      rows="3" required placeholder="Tuliskan pertanyaan..."></textarea>
                        </div>

                        <!-- Gambar soal inline (D-01) -->
                        <div class="mb-3 img-drop" id="questionImgWrap">
                            <label class="form-label small fw-semibold">Gambar Soal (opsional)</label>
                            <div class="d-flex align-items-center gap-2">
                                <span class="img-thumb d-inline-flex align-items-center justify-content-center border rounded bg-light"
                                      style="width:46px;height:46px;overflow:hidden;flex:0 0 46px">
                                    <img id="questionImgThumb" src="" alt="" class="d-none" style="width:46px;height:46px;object-fit:cover" />
                                    <i id="questionImgIcon" class="bi bi-image text-muted"></i>
                                </span>
                                <span id="questionImgMeta" class="text-muted flex-grow-1" style="font-size:.72rem">Belum ada gambar</span>
                                <label class="btn btn-outline-primary btn-sm mb-0" id="questionImgPickBtn">
                                    Pilih<input type="file" name="questionImage" id="questionImgField" accept="image/png,image/jpeg" hidden />
                                </label>
                                <button type="button" class="btn btn-outline-danger btn-sm d-none" id="questionImgClear" aria-label="Hapus gambar ini">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                            <div class="form-check mt-2 d-none" id="questionRemoveWrap">
                                <input class="form-check-input" type="checkbox" name="removeQuestionImage" value="true" id="removeQuestionImage" />
                                <label class="form-check-label small" for="removeQuestionImage">Hapus gambar</label>
                            </div>
                            <input type="text" name="questionImageAlt" id="questionImageAlt" class="form-control form-control-sm mt-2"
                                   placeholder="Teks alternatif (opsional)" />
                            <div class="form-text">Deskripsi singkat gambar untuk pembaca layar.</div>
                            <div class="form-text">JPG atau PNG, maksimal 5 MB.</div>
                        </div>

                        <!-- Opsi A-D (MC/MA) -->
                        <div id="optionsSection" class="mb-3">
                            <label class="form-label fw-medium small">Opsi Jawaban</label>
                            <div id="maLabel" class="alert alert-info py-1 px-2 small mb-2" style="display:none">
                                <i class="bi bi-info-circle me-1"></i>Centang semua opsi yang benar (minimal 2).
                            </div>
                            @foreach (var (letter, name) in new[] { ("A","optionA"), ("B","optionB"), ("C","optionC"), ("D","optionD") })
                            {
                                var correctName = "correct" + char.ToUpper(name[^1]);
                                <div class="input-group input-group-sm mb-2">
                                    <div class="input-group-text" style="width:36px">
                                        <input class="form-check-input mt-0 correct-input" type="radio"
                                               name="@correctName" id="correct_@letter" value="true"
                                               aria-label="Opsi @letter benar" />
                                    </div>
                                    <span class="input-group-text fw-bold">@letter</span>
                                    <input type="text" class="form-control" name="@name"
                                           id="option_@letter" placeholder="Opsi @letter" />
                                </div>
                                <!-- Gambar opsi @letter inline (D-01) -->
                                <div class="img-drop mb-2 ms-4 d-flex align-items-center gap-2" id="opt@(letter)ImgWrap">
                                    <span class="img-thumb d-inline-flex align-items-center justify-content-center border rounded bg-light"
                                          style="width:46px;height:46px;overflow:hidden;flex:0 0 46px">
                                        <img id="opt@(letter)ImgThumb" src="" alt="" class="d-none" style="width:46px;height:46px;object-fit:cover" />
                                        <i id="opt@(letter)ImgIcon" class="bi bi-image text-muted"></i>
                                    </span>
                                    <span id="opt@(letter)ImgMeta" class="text-muted flex-grow-1" style="font-size:.72rem">Belum ada gambar</span>
                                    <input type="text" name="@($"option{letter}ImageAlt")" id="opt@(letter)ImageAlt"
                                           class="form-control form-control-sm" style="max-width:140px" placeholder="Teks alternatif (opsional)" />
                                    <label class="btn btn-outline-primary btn-sm mb-0" id="opt@(letter)ImgPickBtn">
                                        Pilih<input type="file" name="@($"option{letter}Image")" id="opt@(letter)ImgField" accept="image/png,image/jpeg" hidden />
                                    </label>
                                    <button type="button" class="btn btn-outline-danger btn-sm d-none" id="opt@(letter)ImgClear" aria-label="Hapus gambar opsi @letter">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                    <span class="form-check mb-0 d-none" id="opt@(letter)RemoveWrap">
                                        <input class="form-check-input" type="checkbox" name="@($"removeOption{letter}Image")" value="true" id="removeOption@(letter)Image" />
                                        <label class="form-check-label small" for="removeOption@(letter)Image">Hapus</label>
                                    </span>
                                </div>
                            }
                            <div class="form-text">Klik radio/checkbox di kiri untuk tandai jawaban benar.</div>
                        </div>

                        <!-- Rubrik / Essay section -->
                        <div id="rubrikSection" style="display:none" class="mb-3">
                            <label class="form-label fw-medium small">Rubrik / Kunci Jawaban <span class="text-danger">*</span></label>
                            <textarea class="form-control form-control-sm" name="rubrik" id="rubrik"
                                      rows="3" placeholder="Tulis rubrik penilaian atau kunci jawaban essay..."></textarea>
                            <div class="mt-2">
                                <label class="form-label fw-medium small">Batas Karakter Jawaban</label>
                                <input type="number" name="maxCharacters" id="maxCharacters"
                                       class="form-control form-control-sm" value="2000"
                                       min="100" max="10000" style="max-width:120px" />
                                <div class="form-text">Default: 2000 karakter</div>
                            </div>
                        </div>

                        <!-- ScoreValue -->
                        <div class="mb-3">
                            <label class="form-label fw-medium small">Nilai Soal (ScoreValue)</label>
                            <input type="number" name="scoreValue" id="scoreValue"
                                   class="form-control form-control-sm" value="10"
                                   min="1" max="100" step="1" required style="max-width:80px"
                                   data-original-score="10" data-affected-sessions="0" />
                            <div class="form-text" id="scoreHelp">Range 1–100</div>
                        </div>

                        <!-- Elemen Teknis (opsional) -->
                        <div class="mb-3">
                            <label class="form-label fw-medium small">Elemen Teknis <span class="text-muted">(opsional)</span></label>
                            <input type="text" name="elemenTeknis" id="elemenTeknis"
                                   class="form-control form-control-sm" placeholder="e.g. Pengetahuan Proses" />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-sm" id="submitBtn">
                                <i class="bi bi-plus-circle me-1"></i>Tambah Soal
                            </button>
                            <button type="button" class="btn btn-secondary btn-sm" id="cancelEditBtn"
                                    style="display:none" onclick="resetForm()">
                                Batal Edit
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Preview Modal -->
<div class="modal fade" id="previewModal" tabindex="-1" aria-labelledby="previewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-light">
                <h5 class="modal-title" id="previewModalLabel">
                    <i class="bi bi-eye me-2"></i>Preview Soal
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="previewModalBody">
                <div class="text-center py-3">
                    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                    <span class="ms-2">Memuat preview...</span>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Tutup</button>
            </div>
        </div>
    </div>
</div>

@* Lightbox host: _PreviewQuestion di-inject via AJAX ke #previewModalBody, jadi modal lightbox + JS harus hadir di host page ini (Phase 354 RND-04) *@
@await Html.PartialAsync("_ImageLightboxModal")

<!-- Edit Warning Modal -->
<div class="modal fade" id="editTypeWarningModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Peringatan Ubah Tipe Soal</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Mengubah tipe soal akan menghapus jawaban peserta yang ada untuk soal ini. Lanjutkan?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-warning btn-sm" id="confirmTypeChange">Ya, Lanjutkan</button>
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Batal</button>
            </div>
        </div>
    </div>
</div>

<!-- Score Change Warning Modal (Phase 306, D-06 D-07 D-08 / CD-02) -->
<div class="modal fade" id="editScoreWarningModal" tabindex="-1"
     aria-labelledby="editScoreWarningModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title" id="editScoreWarningModalLabel">
                    <i class="bi bi-exclamation-triangle me-2"></i>Peringatan Ubah Skor
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
            </div>
            <div class="modal-body" id="editScoreWarningModalBody">
                <!-- populated by JS: populateScoreWarningModal() -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-warning btn-sm" id="confirmScoreChange">Ya, Lanjutkan</button>
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Batal</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var originalType = null;
    var pendingType = null;
    var editTypeWarningModal = null;
    var editScoreWarningModal = null;
    var scoreChangeBypassed = false;

    // Initialize Bootstrap modals
    document.addEventListener('DOMContentLoaded', function () {
        editTypeWarningModal = new bootstrap.Modal(document.getElementById('editTypeWarningModal'));
        editScoreWarningModal = new bootstrap.Modal(document.getElementById('editScoreWarningModal'));

        document.getElementById('confirmTypeChange').addEventListener('click', function () {
            document.getElementById('QuestionType').value = pendingType;
            applyQTypeSwitch(pendingType);
            editTypeWarningModal.hide();
        });

        // Phase 306 (D-06/D-09): Score change confirmation flow
        document.getElementById('questionForm').addEventListener('submit', function (event) {
            if (scoreChangeBypassed) { scoreChangeBypassed = false; return; }

            var editIdEl = document.getElementById('editQuestionId');
            var isEditMode = editIdEl && editIdEl.value !== '';
            if (!isEditMode) return;

            var scoreInput = document.getElementById('scoreValue');
            var form = document.getElementById('questionForm');
            var originalScore = parseInt(scoreInput.dataset.originalScore, 10);
            var newScore = parseInt(scoreInput.value, 10);
            var affectedN = parseInt(form.dataset.affectedSessions, 10) || 0;
            var qOrder = form.dataset.questionOrder || '';

            if (!isNaN(originalScore) && newScore !== originalScore && affectedN > 0) {
                event.preventDefault();
                populateScoreWarningModal(qOrder, originalScore, newScore, affectedN);
                editScoreWarningModal.show();
            }
        });

        document.getElementById('confirmScoreChange').addEventListener('click', function () {
            editScoreWarningModal.hide();
            scoreChangeBypassed = true;
            document.getElementById('questionForm').submit();
        });
    });

    // Phase 306 (D-07): populate modal body copy with order/old/new/affectedN tokens
    function populateScoreWarningModal(order, oldScore, newScore, affectedN) {
        document.getElementById('editScoreWarningModalBody').innerHTML =
            'Skor soal #' + order + ' akan diubah dari <strong>' + oldScore + '</strong> menjadi <strong>' +
            newScore + '</strong>. <strong>' + affectedN + ' peserta</strong> sudah menjawab — ' +
            'persentase mereka akan dihitung ulang otomatis. Lanjutkan?';
    }

    // QuestionType change handler
    document.getElementById('QuestionType').addEventListener('change', function () {
        var newType = this.value;
        var isEditMode = document.getElementById('editQuestionId').value !== '';

        // Warn if editing an existing question and type changes
        if (isEditMode && originalType && originalType !== newType) {
            pendingType = newType;
            this.value = originalType; // revert visually until confirmed
            editTypeWarningModal.show();
            return;
        }

        applyQTypeSwitch(newType);
    });

    function applyQTypeSwitch(qtype) {
        var optionsSection = document.getElementById('optionsSection');
        var rubrikSection = document.getElementById('rubrikSection');
        var maLabel = document.getElementById('maLabel');

        optionsSection.style.display = (qtype === 'Essay') ? 'none' : '';
        rubrikSection.style.display = (qtype === 'Essay') ? '' : 'none';
        // scoreInput.disabled & scoreInput.value=10 lines removed (Phase 306, D-02/D-03/D-04) — input selalu enabled, value user-entered di-preserve
        maLabel.style.display = (qtype === 'MultipleAnswer') ? '' : 'none';

        // Switch radio <-> checkbox for correct answer inputs
        document.querySelectorAll('.correct-input').forEach(function (inp) {
            inp.type = (qtype === 'MultipleAnswer') ? 'checkbox' : 'radio';
            if (qtype !== 'MultipleAnswer') inp.checked = false;
        });
        // scoreHelp.textContent dynamic update removed (Phase 306, D-05) — static "Range 1–100" dari Razor
    }

    // Load preview via AJAX
    window.loadPreview = function (questionId) {
        var modal = new bootstrap.Modal(document.getElementById('previewModal'));
        document.getElementById('previewModalBody').innerHTML =
            '<div class="text-center py-3"><div class="spinner-border spinner-border-sm text-primary" role="status"></div><span class="ms-2">Memuat preview...</span></div>';
        modal.show();

        fetch((window.basePath || '') + '/Admin/PreviewQuestion?questionId=' + questionId, {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(function (r) { return r.text(); })
        .then(function (html) { document.getElementById('previewModalBody').innerHTML = html; })
        .catch(function () { document.getElementById('previewModalBody').innerHTML = '<div class="alert alert-danger">Gagal memuat preview.</div>'; });
    };

    // Load edit form
    window.loadEditForm = function (questionId) {
        fetch((window.basePath || '') + '/Admin/EditQuestion?questionId=' + questionId, {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            populateEditForm(data);
        })
        .catch(function () {
            // Fallback: redirect to edit page
            window.location.href = (window.basePath || '') + '/Admin/EditQuestion?questionId=' + questionId;
        });
    };

    function populateEditForm(data) {
        var form = document.getElementById('questionForm');
        form.action = (window.basePath || '') + '/Admin/EditQuestion';

        document.getElementById('formTitle').textContent = 'Edit Soal #' + data.order;
        document.getElementById('editQuestionId').value = data.id;
        document.getElementById('questionText').value = data.questionText || '';
        document.getElementById('elemenTeknis').value = data.elemenTeknis || '';
        document.getElementById('rubrik').value = data.rubrik || '';
        document.getElementById('maxCharacters').value = data.maxCharacters || 2000;
        document.getElementById('scoreValue').value = data.scoreValue || 10;
        // Phase 306 (D-09): inject data attributes for score-change modal trigger
        document.getElementById('scoreValue').dataset.originalScore = data.scoreValue || 10;
        document.getElementById('questionForm').dataset.affectedSessions = data.affectedSessions || 0;
        document.getElementById('questionForm').dataset.questionOrder = data.order || '';

        var qtype = data.questionType || 'MultipleChoice';
        document.getElementById('QuestionType').value = qtype;
        originalType = qtype;
        applyQTypeSwitch(qtype);

        // Phase 415 SEC-03: prefill dropdown Section (null → "Lainnya" / value kosong).
        var secSel = document.getElementById('sectionIdSelect');
        if (secSel) secSel.value = (data.sectionId != null) ? String(data.sectionId) : '';

        // Populate options
        var optLetters = ['A', 'B', 'C', 'D'];
        var optFields = ['optionA', 'optionB', 'optionC', 'optionD'];
        var correctFields = ['correctA', 'correctB', 'correctC', 'correctD'];

        if (data.options && data.options.length) {
            data.options.forEach(function (opt, i) {
                if (i < 4) {
                    var textEl = document.getElementById('option_' + optLetters[i]);
                    var correctEl = document.getElementById('correct_' + optLetters[i]);
                    if (textEl) textEl.value = opt.optionText || '';
                    if (correctEl) correctEl.checked = opt.isCorrect === true;
                    // Prefill thumbnail gambar opsi (D-06/IMG-07)
                    prefillImage(IMAGE_FIELDS[i + 1], opt.imagePath, opt.imageAlt);
                }
            });
        }
        // Opsi tak terisi (mis. <4) → reset image field-nya ke create-state
        for (var k = (data.options ? data.options.length : 0); k < 4; k++) {
            resetImageField(IMAGE_FIELDS[k + 1]);
        }
        // Prefill thumbnail gambar soal (D-06/IMG-07)
        prefillImage(IMAGE_FIELDS[0], data.imagePath, data.imageAlt);

        document.getElementById('submitBtn').innerHTML = '<i class="bi bi-save me-1"></i>Simpan Perubahan';
        document.getElementById('cancelEditBtn').style.display = '';

        // Scroll to form
        document.getElementById('questionFormCard').scrollIntoView({ behavior: 'smooth' });
    }

    // ---- Gambar: FileReader thumbnail instan + prefill edit (D-07a/D-03/IMG-07) ----
    // prefix: 'question' | 'optA'..'optD'. Field id konvensi: {prefix}ImgThumb/Icon/Meta/Field/Clear, {removeId}.
    var IMAGE_FIELDS = [
        { prefix: 'question', removeId: 'removeQuestionImage', removeWrap: 'questionRemoveWrap', pickBtn: 'questionImgPickBtn' },
        { prefix: 'optA', removeId: 'removeOptionAImage', removeWrap: 'optARemoveWrap', pickBtn: 'optAImgPickBtn' },
        { prefix: 'optB', removeId: 'removeOptionBImage', removeWrap: 'optBRemoveWrap', pickBtn: 'optBImgPickBtn' },
        { prefix: 'optC', removeId: 'removeOptionCImage', removeWrap: 'optCRemoveWrap', pickBtn: 'optCImgPickBtn' },
        { prefix: 'optD', removeId: 'removeOptionDImage', removeWrap: 'optDRemoveWrap', pickBtn: 'optDImgPickBtn' }
    ];

    function fmtSize(bytes) {
        var kb = bytes / 1024;
        return kb >= 1024 ? (kb / 1024).toFixed(1) + ' MB' : kb.toFixed(0) + ' KB';
    }

    function imgEl(prefix, suffix) { return document.getElementById(prefix + suffix); }

    function showThumb(prefix, src, metaText) {
        var thumb = imgEl(prefix, 'ImgThumb'), icon = imgEl(prefix, 'ImgIcon'),
            meta = imgEl(prefix, 'ImgMeta'), clear = imgEl(prefix, 'ImgClear');
        if (thumb) { thumb.src = src; thumb.classList.remove('d-none'); }
        if (icon) icon.classList.add('d-none');
        if (meta) meta.textContent = metaText;
        if (clear) clear.classList.remove('d-none');
    }

    function emptyThumb(prefix) {
        var thumb = imgEl(prefix, 'ImgThumb'), icon = imgEl(prefix, 'ImgIcon'),
            meta = imgEl(prefix, 'ImgMeta'), clear = imgEl(prefix, 'ImgClear'),
            field = imgEl(prefix, 'ImgField');
        if (thumb) { thumb.src = ''; thumb.classList.add('d-none'); }
        if (icon) icon.classList.remove('d-none');
        if (meta) meta.textContent = 'Belum ada gambar';
        if (clear) clear.classList.add('d-none');
        if (field) field.value = '';
    }

    function wireImageField(cfg) {
        var field = imgEl(cfg.prefix, 'ImgField');
        var clear = imgEl(cfg.prefix, 'ImgClear');
        var removeCb = document.getElementById(cfg.removeId);
        if (field) {
            field.addEventListener('change', function () {
                if (!field.files || !field.files.length) { emptyThumb(cfg.prefix); return; }
                var file = field.files[0];
                var reader = new FileReader();
                reader.onload = function (e) { showThumb(cfg.prefix, e.target.result, file.name + ' · ' + fmtSize(file.size)); };
                reader.readAsDataURL(file);
                // Konflik D-05 nicety: file baru → uncheck + disable checkbox hapus (backend tetap otoritatif).
                if (removeCb) { removeCb.checked = false; removeCb.disabled = true; }
            });
        }
        if (clear) {
            clear.addEventListener('click', function () {
                emptyThumb(cfg.prefix);
                if (removeCb) removeCb.disabled = false;
            });
        }
    }

    function wireAllImageFields() { IMAGE_FIELDS.forEach(wireImageField); }
    document.addEventListener('DOMContentLoaded', wireAllImageFields);

    // Prefill thumbnail lama saat edit (file input tetap kosong — D-03).
    function prefillImage(cfg, imagePath, imageAlt) {
        var altInput = document.getElementById(cfg.prefix === 'question' ? 'questionImageAlt' : cfg.prefix + 'ImageAlt');
        if (altInput) altInput.value = imageAlt || '';
        var removeWrap = document.getElementById(cfg.removeWrap);
        var removeCb = document.getElementById(cfg.removeId);
        if (removeCb) { removeCb.checked = false; removeCb.disabled = false; }
        var pickBtn = document.getElementById(cfg.pickBtn);
        if (imagePath) {
            showThumb(cfg.prefix, imagePath, 'Gambar tersimpan');
            if (removeWrap) removeWrap.classList.remove('d-none'); // EDIT-only checkbox tampil
            if (pickBtn) pickBtn.childNodes[0].nodeValue = 'Ganti';
        } else {
            emptyThumb(cfg.prefix);
            if (removeWrap) removeWrap.classList.add('d-none');
            if (pickBtn) pickBtn.childNodes[0].nodeValue = 'Pilih';
        }
    }

    function resetImageField(cfg) {
        emptyThumb(cfg.prefix);
        var altInput = document.getElementById(cfg.prefix === 'question' ? 'questionImageAlt' : cfg.prefix + 'ImageAlt');
        if (altInput) altInput.value = '';
        var removeWrap = document.getElementById(cfg.removeWrap);
        var removeCb = document.getElementById(cfg.removeId);
        if (removeCb) { removeCb.checked = false; removeCb.disabled = false; }
        if (removeWrap) removeWrap.classList.add('d-none'); // sembunyikan checkbox saat create
        var pickBtn = document.getElementById(cfg.pickBtn);
        if (pickBtn) pickBtn.childNodes[0].nodeValue = 'Pilih';
    }

    window.resetForm = function () {
        var form = document.getElementById('questionForm');
        form.action = (window.basePath || '') + '/Admin/CreateQuestion';
        form.reset();

        document.getElementById('formTitle').textContent = 'Tambah Soal Baru';
        document.getElementById('editQuestionId').value = '';
        originalType = null;

        applyQTypeSwitch('MultipleChoice');
        document.getElementById('QuestionType').value = 'MultipleChoice';
        document.getElementById('scoreValue').value = 10;

        // Phase 415 SEC-03: reset dropdown Section ke "Lainnya".
        var secSel = document.getElementById('sectionIdSelect');
        if (secSel) secSel.value = '';

        IMAGE_FIELDS.forEach(resetImageField);

        document.getElementById('submitBtn').innerHTML = '<i class="bi bi-plus-circle me-1"></i>Tambah Soal';
        document.getElementById('cancelEditBtn').style.display = 'none';
    };

    // ---- Phase 415 SEC-01/02: panel Kelola Section (JS minim, D-415-02) ----
    // Prefill form Section dari data-attribute baris (XSS-safe: pakai .value, bukan innerHTML).
    window.loadSectionEdit = function (btn) {
        var form = document.getElementById('sectionForm');
        form.action = (window.basePath || '') + '/Admin/EditSection';

        document.getElementById('sectionEditId').value = btn.getAttribute('data-section-id') || '';
        document.getElementById('sectionNumber').value = btn.getAttribute('data-section-number') || '';
        document.getElementById('sectionName').value = btn.getAttribute('data-section-name') || '';
        document.getElementById('sectionStartNewPage').checked = (btn.getAttribute('data-section-startnewpage') === 'true');
        document.getElementById('sectionShuffleEnabled').checked = (btn.getAttribute('data-section-shuffleenabled') === 'true');

        document.getElementById('sectionFormTitle').textContent = 'Ubah Section';
        document.getElementById('sectionCancelBtn').style.display = '';
        document.getElementById('sectionPanelCard').scrollIntoView({ behavior: 'smooth' });
    };

    window.resetSectionForm = function () {
        var form = document.getElementById('sectionForm');
        form.action = (window.basePath || '') + '/Admin/CreateSection';
        form.reset();
        document.getElementById('sectionEditId').value = '';
        document.getElementById('sectionShuffleEnabled').checked = true;   // default ON
        document.getElementById('sectionFormTitle').textContent = 'Tambah Section';
        document.getElementById('sectionCancelBtn').style.display = 'none';
    };
}());
</script>
}
