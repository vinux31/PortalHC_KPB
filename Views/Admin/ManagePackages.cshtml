@{
    ViewData["Title"] = "Manage Packages";
    var packages = ViewBag.Packages as List<HcPortal.Models.AssessmentPackage> ?? new List<HcPortal.Models.AssessmentPackage>();
    int assessmentId = (int)ViewBag.AssessmentId;
    var assignmentCounts = ViewBag.AssignmentCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
}
<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0">Manage Packages</h1>
            <p class="text-muted">Assessment: <strong>@ViewBag.AssessmentTitle</strong></p>
        </div>
        <a asp-action="ManageAssessment" asp-controller="AssessmentAdmin" asp-route-tab="assessment" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-2"></i>Back to Manage
        </a>
    </div>

    <!-- TempData alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    @if (ViewBag.IsSamePackageLocked == true)
    {
        <div class="alert alert-info d-flex align-items-center mb-3" role="alert">
            <i class="bi bi-lock-fill me-2 fs-5"></i>
            <div>
                <strong>Paket soal disinkronkan dari Pre-Test.</strong>
                Perubahan soal hanya bisa dilakukan di sesi Pre-Test. Paket di halaman ini otomatis terupdate.
                @if (ViewBag.PreSessionId != null)
                {
                    <a asp-action="ManagePackages" asp-route-assessmentId="@ViewBag.PreSessionId" class="alert-link ms-2">
                        <i class="bi bi-arrow-right me-1"></i>Buka Pre-Test
                    </a>
                }
            </div>
        </div>
    }

    @if (ViewBag.IsPostSession == true && ViewBag.IsSamePackageLocked != true)
    {
        <div class="mb-3">
            <div id="copyPreConfirm" class="d-none">
                <div class="alert alert-warning d-flex align-items-center gap-2">
                    <span>Ini akan menimpa semua paket soal Post-Test yang ada. Lanjutkan?</span>
                    <form method="post" asp-action="CopyPackagesFromPre" asp-controller="AssessmentAdmin" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="postSessionId" value="@ViewBag.AssessmentId" />
                        <button type="submit" class="btn btn-sm btn-warning">Konfirmasi</button>
                    </form>
                    <button type="button" class="btn btn-sm btn-secondary"
                            onclick="document.getElementById('copyPreConfirm').classList.add('d-none'); document.getElementById('copyPreBtn').classList.remove('d-none');">
                        Batal
                    </button>
                </div>
            </div>
            <button type="button" id="copyPreBtn" class="btn btn-outline-info"
                    onclick="this.classList.add('d-none'); document.getElementById('copyPreConfirm').classList.remove('d-none');">
                <i class="bi bi-clipboard"></i> Copy dari Pre-Test
            </button>
        </div>
    }

    @{
        // Compute summary data for the panel
        bool hasMismatch = false;
        int? referenceCount = null;
        if (packages.Any(p => p.Questions.Any()))
        {
            referenceCount = packages.Where(p => p.Questions.Any()).Select(p => p.Questions.Count).First();
            hasMismatch = packages.Where(p => p.Questions.Any()).Any(p => p.Questions.Count != referenceCount);
        }
        bool isMultiPackage = packages.Count > 1;
        string modeLabel = isMultiPackage ? $"Multi-Package ({packages.Count} paket)" : "Single Package";
    }

    @* Phase 374: Card Pengacakan Soal & Jawaban (SHUF-10/11/12/13/14). Render dari ViewBag (Plan 02). *@
    @if (ViewBag.HideShuffleToggle != true)
    {
        bool isShuffleLocked = ViewBag.IsShuffleLocked == true;
        bool sqChecked = ViewBag.ShuffleQuestions == true;
        bool soChecked = ViewBag.ShuffleOptions == true;
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="bi bi-shuffle text-primary me-1"></i>Pengacakan Soal &amp; Jawaban</h5>
            </div>
            <div class="card-body">
                @if (isShuffleLocked)
                {
                    <div class="alert alert-info d-flex align-items-center mb-3" role="alert">
                        <i class="bi bi-lock-fill me-2 fs-5"></i>
                        <div>
                            <strong>Pengaturan pengacakan terkunci.</strong>
                            Sudah ada peserta yang memulai ujian, sehingga pengaturan Acak Soal dan Acak Pilihan Jawaban tidak dapat diubah lagi untuk menjaga keadilan ujian.
                        </div>
                    </div>
                }
                <form method="post" asp-action="UpdateShuffleSettings" asp-controller="AssessmentAdmin">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="assessmentId" value="@ViewBag.AssessmentId" />
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" name="shuffleQuestions" id="shuffleQuestions" value="true" @(sqChecked ? "checked" : "") @(isShuffleLocked ? "disabled" : "") />
                        <label class="form-check-label" for="shuffleQuestions">Acak Soal</label>
                    </div>
                    <div class="form-text text-muted mb-3">Saat aktif, urutan dan pemilihan soal diacak berbeda untuk setiap peserta — sehingga peserta yang duduk berdekatan kecil kemungkinan mendapat soal yang sama urutannya. Saat nonaktif, semua peserta mendapat soal yang sama dengan urutan yang sama persis (urutan asli sesuai paket soal).</div>
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" name="shuffleOptions" id="shuffleOptions" value="true" @(soChecked ? "checked" : "") @(isShuffleLocked ? "disabled" : "") />
                        <label class="form-check-label" for="shuffleOptions">Acak Pilihan Jawaban</label>
                    </div>
                    <div class="form-text text-muted mb-3">Saat aktif, urutan pilihan jawaban (A, B, C, D) diacak berbeda di setiap soal untuk tiap peserta — jawaban benar tetap dinilai dengan benar, hanya posisinya yang berpindah. Saat nonaktif, urutan pilihan jawaban tampil sama untuk semua peserta sesuai urutan yang tersimpan di sistem.</div>
                    @if (ViewBag.IsPostSession == true && ViewBag.PreShuffleQuestions == false && sqChecked)
                    {
                        <div class="alert alert-warning d-flex align-items-center mb-3" role="alert">
                            <i class="bi bi-question-circle me-2"></i>
                            <div>Pre diatur OFF, Post masih ON — sengaja?</div>
                        </div>
                    }
                    <div id="shuffleSizeWarning" class="alert alert-warning d-flex align-items-center mb-3 @(ViewBag.ShowSizeMismatchWarning == true ? "" : "d-none")" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <div>Jumlah soal antar paket berbeda — nilai maksimal &amp; pass% bisa tak setara antar peserta.</div>
                    </div>
                    <button type="submit" class="btn btn-primary" @(isShuffleLocked ? "disabled" : "")><i class="bi bi-save me-1"></i>Simpan Pengaturan</button>
                </form>
            </div>
        </div>
    }

    @* v32.4 RTK-05: Card Ujian Ulang (mirror card shuffle, MINUS lock D-03, PLUS progressive disclosure D-04). Render dari ViewBag (405-04, controller :5752-5760). *@
    @if (ViewBag.HideRetakeToggle != true)
    {
        bool arChecked = ViewBag.AllowRetake == true;
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="bi bi-arrow-repeat text-primary me-1"></i>Ujian Ulang</h5>
            </div>
            <div class="card-body">
                <form method="post" asp-action="UpdateRetakeSettings" asp-controller="AssessmentAdmin" id="retakeSettingsForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="assessmentId" value="@ViewBag.AssessmentId" />
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" name="allowRetake" id="allowRetake" value="true" @(arChecked ? "checked" : "") />
                        <label class="form-check-label" for="allowRetake">Izinkan Ujian Ulang</label>
                    </div>
                    <div class="form-text text-muted mb-3">Saat aktif, peserta yang gagal boleh mengulang ujian ini secara mandiri (di bawah batas percobaan dan setelah masa jeda).</div>

                    <div id="retakeFields" class="@(arChecked ? "" : "d-none")">
                        <div class="mb-3" style="max-width: 320px;">
                            <label for="maxAttempts" class="form-label fw-bold">Maksimal Percobaan</label>
                            <input type="number" class="form-control" name="maxAttempts" id="maxAttempts" min="1" max="5" value="@(ViewBag.MaxAttempts ?? 2)" />
                            <div class="form-text text-muted">Berapa kali peserta boleh mencoba (termasuk percobaan pertama). Rentang 1–5.</div>
                            @if ((int)(ViewBag.MaxAttempts ?? 2) < (int)(ViewBag.RetakeMaxAttemptsUsedInGroup ?? 0))
                            {
                                <div class="alert alert-warning d-flex align-items-start mt-2 mb-0" role="alert">
                                    <i class="bi bi-exclamation-triangle me-2 mt-1"></i>
                                    <div>Maksimal percobaan yang Anda set lebih kecil dari jumlah percobaan yang sudah dipakai sebagian peserta. Peserta tersebut tidak akan kehilangan percobaan yang sudah berjalan, tetapi tidak bisa menambah percobaan baru. Pengaturan tetap bisa disimpan.</div>
                                </div>
                            }
                        </div>
                        <div class="mb-3" style="max-width: 320px;">
                            <label for="retakeCooldownHours" class="form-label fw-bold">Jeda Ujian Ulang (jam)</label>
                            <input type="number" class="form-control" name="retakeCooldownHours" id="retakeCooldownHours" min="0" max="168" value="@(ViewBag.RetakeCooldownHours ?? 24)" />
                            <div class="form-text text-muted">Jeda minimal sebelum boleh mencoba lagi. 0 = tanpa jeda. Satuan: jam (maksimal 168 = 7 hari).</div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Simpan Pengaturan</button>
                </form>
            </div>
        </div>

        @* v32.7 RTH-05/D-07: modal pra-simpan NON-BLOCKING saat MaxAttempts dipilih < jumlah terpakai (angka dari GET via MaxInGroupAsync). *@
        <div class="modal fade" id="retakeMaxConfirmModal" tabindex="-1" aria-labelledby="retakeMaxConfirmLabel" aria-hidden="true">
          <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title" id="retakeMaxConfirmLabel"><i class="bi bi-exclamation-triangle text-warning me-2"></i>Konfirmasi Batas Percobaan</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
              </div>
              <div class="modal-body">
                Sebagian peserta sudah memakai lebih dari batas percobaan baru. Mereka tidak akan kehilangan percobaan yang sudah berjalan, tetapi tidak bisa menambah percobaan baru. Lanjutkan menyimpan?
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                <button type="button" class="btn btn-primary" id="retakeMaxConfirmYes"><i class="bi bi-save me-1"></i>Ya, Lanjutkan</button>
              </div>
            </div>
          </div>
        </div>
        <script>
            // v32.7 RTH-05/D-07: WAJIB DOMContentLoaded — script ini ter-render inline di tengah body,
            // sedangkan bootstrap.bundle dimuat di akhir layout. Tanpa defer → `bootstrap is not defined`
            // (ReferenceError) → interceptor submit tak ke-attach → modal tak muncul (lesson Phase 390.1).
            document.addEventListener('DOMContentLoaded', function () {
                var form = document.getElementById('retakeSettingsForm');
                if (!form) return;
                var usedInGroup = @(ViewBag.RetakeMaxAttemptsUsedInGroup ?? 0);   // angka terpakai dari GET (MaxInGroupAsync, D-05)
                var confirmed = false;
                var modalEl = document.getElementById('retakeMaxConfirmModal');
                var modal = (modalEl && typeof bootstrap !== 'undefined') ? new bootstrap.Modal(modalEl) : null;
                form.addEventListener('submit', function (e) {
                    if (confirmed || !modal) return;   // sudah dikonfirmasi (atau modal tak tersedia) → biarkan submit
                    var input = document.getElementById('maxAttempts');
                    var val = input ? parseInt(input.value, 10) : NaN;
                    if (!isNaN(val) && val < usedInGroup) {   // non-blocking: hanya konfirmasi, server tetap simpan
                        e.preventDefault();
                        modal.show();
                    }
                });
                var yesBtn = document.getElementById('retakeMaxConfirmYes');
                if (yesBtn) yesBtn.addEventListener('click', function () {
                    confirmed = true;
                    if (modal) modal.hide();
                    form.submit();
                });
            });
        </script>
    }

    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex align-items-center gap-3 flex-wrap">
                <div>
                    <span class="text-muted small">Mode:</span>
                    <strong class="ms-1">@modeLabel</strong>
                </div>
                @if (packages.Any())
                {
                    <div class="vr d-none d-md-block"></div>
                    @foreach (var pkg in packages)
                    {
                        bool pkgHasQuestions = pkg.Questions.Any();
                        bool pkgOk = pkgHasQuestions && (!hasMismatch || pkg.Questions.Count == referenceCount);
                        bool pkgWarning = pkgHasQuestions && hasMismatch && pkg.Questions.Count != referenceCount;
                        <div class="d-flex align-items-center gap-1">
                            <span class="badge @(pkgOk ? "text-bg-success" : pkgWarning ? "text-bg-warning" : "text-bg-secondary")">
                                @(pkgOk ? "OK" : pkgWarning ? "Warning" : "Kosong")
                            </span>
                            <span class="small">@pkg.PackageName: @pkg.Questions.Count soal</span>
                        </div>
                    }
                }
                @if (hasMismatch)
                {
                    <div class="text-warning small ms-auto">
                        <i class="bi bi-exclamation-triangle me-1"></i>Jumlah soal tidak sama antar paket
                    </div>
                }
            </div>
        </div>
    </div>

    @{
        var etCoverage = ViewBag.EtCoverage as Dictionary<string, Dictionary<int, int>>;
        var etGroups = ViewBag.EtGroups as List<string>;
    }
    @if (etGroups != null && etGroups.Any() && packages.Any(p => p.Questions.Any()))
    {
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h6 class="mb-0 fw-bold"><i class="bi bi-grid-3x3 me-2 text-primary"></i>Distribusi Elemen Teknis</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Elemen Teknis</th>
                                @foreach (var pkg in packages)
                                {
                                    <th class="text-center">@pkg.PackageName</th>
                                }
                                <th class="text-center fw-bold">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var et in etGroups)
                            {
                                var row = etCoverage![et];
                                var total = row.Values.Sum();
                                <tr>
                                    <td>@et</td>
                                    @foreach (var pkg in packages)
                                    {
                                        var count = row.ContainsKey(pkg.Id) ? row[pkg.Id] : 0;
                                        var cellClass = (count == 0 && et != "(Tanpa ET)") ? "text-danger fw-bold" : "";
                                        <td class="text-center @cellClass">
                                            @if (count == 0 && et != "(Tanpa ET)")
                                            {
                                                <i class="bi bi-exclamation-triangle text-warning me-1"></i>
                                            }
                                            @count
                                        </td>
                                    }
                                    <td class="text-center fw-bold">@total</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <div class="row">
        <!-- Create Package Form -->
        @if (ViewBag.IsSamePackageLocked != true)
        {
            <div class="col-md-4">
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 fw-bold text-primary">Add New Package</h6>
                    </div>
                    <div class="card-body">
                        <form asp-action="CreatePackage" method="post">
                            <input type="hidden" name="assessmentId" value="@assessmentId" />
                            <div class="mb-3">
                                <label class="form-label">Package Name</label>
                                <input type="text" name="packageName" class="form-control" placeholder="e.g., Paket A" required />
                                <div class="form-text">Use "Paket A", "Paket B", "Paket C"</div>
                            </div>
                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-plus-circle me-2"></i>Create Package
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }

        <!-- Package List -->
        <div class="col-md-8">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 fw-bold text-primary">Packages (@packages.Count)</h6>
                </div>
                <div class="card-body">
                    @if (!packages.Any())
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-collection display-4"></i>
                            <p class="mt-2">No packages yet. Create your first package.</p>
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var pkg in packages)
                            {
                                <div class="list-group-item px-0">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-0 fw-bold">@pkg.PackageName</h6>
                                            <small class="text-muted">@pkg.Questions.Count questions</small>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <a asp-action="ManagePackageQuestions" asp-route-packageId="@pkg.Id"
                                               class="btn btn-sm btn-outline-success">
                                                <i class="bi bi-list-check me-1"></i>Kelola Soal
                                            </a>
                                            <a asp-action="ImportPackageQuestions" asp-route-packageId="@pkg.Id"
                                               class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-upload me-1"></i>Import Questions
                                            </a>
                                            <a asp-action="PreviewPackage" asp-route-packageId="@pkg.Id"
                                               class="btn btn-sm btn-outline-secondary">
                                                <i class="bi bi-eye me-1"></i>Preview
                                            </a>
                                            @{
                                                var aCount = assignmentCounts.ContainsKey(pkg.Id) ? assignmentCounts[pkg.Id] : 0;
                                            }
                                            @if (ViewBag.IsSamePackageLocked != true)
                                            {
                                                <form asp-action="DeletePackage" method="post"
                                                      data-pkg-name="@pkg.PackageName"
                                                      data-assign-count="@aCount"
                                                      onsubmit="return confirmDeletePackage(this);">
                                                    <input type="hidden" name="packageId" value="@pkg.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDeletePackage(form) {
            var pkgName = form.getAttribute('data-pkg-name');
            var aCount = parseInt(form.getAttribute('data-assign-count'), 10);
            var msg = aCount > 0
                ? 'PERINGATAN: ' + aCount + ' peserta sudah ditugaskan ke ' + pkgName + '. Menghapus paket ini akan menghapus semua data jawaban dan penugasan mereka.\n\nLanjutkan hapus?'
                : 'Hapus ' + pkgName + ' dan semua pertanyaannya?';
            return confirm(msg);
        }
    </script>
    <script>
        // Phase 374 SHUF-12: warning §9 live recompute saat flip Acak Soal (precondition dari ViewBag, Pitfall 4 opsi b).
        (function () {
            var sq = document.getElementById('shuffleQuestions');
            var warn = document.getElementById('shuffleSizeWarning');
            if (!sq || !warn) return;
            var hasMismatch = @((ViewBag.HasSizeMismatch == true) ? "true" : "false");
            var multiPkg = @(((int)(ViewBag.PackagesWithQuestions ?? 0)) >= 2 ? "true" : "false");
            function recompute() {
                // Muncul bila: >=2 paket-ber-soal AND Acak Soal OFF (state saat ini) AND ukuran beda.
                var show = multiPkg && hasMismatch && !sq.checked;
                warn.classList.toggle('d-none', !show);
            }
            sq.addEventListener('change', recompute);
            recompute(); // page load
        })();
    </script>
    <script>
        // v32.4 RTK-05: progressive disclosure — reveal #retakeFields saat #allowRetake ON.
        // Input tetap di DOM (selalu ter-submit; server Math.Clamp jadi guard, bukan min/max client).
        document.getElementById('allowRetake')?.addEventListener('change', function () {
            document.getElementById('retakeFields')?.classList.toggle('d-none', !this.checked);
        });
    </script>
}
