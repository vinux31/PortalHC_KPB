@model HcPortal.Models.AssessmentSession

@{
    ViewData["Title"] = "Manage Questions";
    Layout = "_Layout";
}

<div class="d-flex align-items-start mb-4">
    <div class="flex-grow-1">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Admin")">Kelola Data</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("ManageAssessment", "Admin")">Manage Assessment</a></li>
                <li class="breadcrumb-item active">Kelola Soal</li>
            </ol>
        </nav>
        <h2 class="fw-bold text-dark mb-1"><i class="bi bi-list-check me-2 text-primary"></i>Manage Questions</h2>
        <p class="text-muted mb-0">Assessment: <strong>@Model.Title</strong></p>
    </div>
    <a href="@Url.Action("ManageAssessment", "Admin")" class="btn btn-outline-secondary ms-3">
        <i class="bi bi-arrow-left me-2"></i>Back
    </a>
</div>

<div class="row g-4">
    <!-- Add Question Form -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-header py-3 border-0 bg-light">
                <h6 class="m-0 fw-bold text-primary">Tambah Soal Baru</h6>
            </div>
            <div class="card-body">
                <form asp-action="AddQuestion" asp-controller="Admin" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="has_id" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Pertanyaan</label>
                        <textarea name="question_text" class="form-control" rows="3" required placeholder="Tulis pertanyaan di sini..."></textarea>
                    </div>

                    <label class="form-label fw-semibold">Pilihan Jawaban</label>
                    <div class="mb-2 input-group">
                        <span class="input-group-text bg-light fw-bold">A</span>
                        <input type="text" name="options" class="form-control" required placeholder="Pilihan A" />
                        <div class="input-group-text">
                            <input class="form-check-input mt-0" type="radio" name="correct_option_index" value="0" checked aria-label="Jawaban benar" />
                        </div>
                    </div>
                    <div class="mb-2 input-group">
                        <span class="input-group-text bg-light fw-bold">B</span>
                        <input type="text" name="options" class="form-control" required placeholder="Pilihan B" />
                        <div class="input-group-text">
                            <input class="form-check-input mt-0" type="radio" name="correct_option_index" value="1" aria-label="Jawaban benar" />
                        </div>
                    </div>
                    <div class="mb-2 input-group">
                        <span class="input-group-text bg-light fw-bold">C</span>
                        <input type="text" name="options" class="form-control" required placeholder="Pilihan C" />
                        <div class="input-group-text">
                            <input class="form-check-input mt-0" type="radio" name="correct_option_index" value="2" aria-label="Jawaban benar" />
                        </div>
                    </div>
                    <div class="mb-3 input-group">
                        <span class="input-group-text bg-light fw-bold">D</span>
                        <input type="text" name="options" class="form-control" required placeholder="Pilihan D" />
                        <div class="input-group-text">
                            <input class="form-check-input mt-0" type="radio" name="correct_option_index" value="3" aria-label="Jawaban benar" />
                        </div>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-plus-circle me-2"></i>Tambah Soal
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Question List -->
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header py-3 border-0 bg-light d-flex justify-content-between align-items-center">
                <h6 class="m-0 fw-bold text-primary">Daftar Soal (@Model.Questions.Count)</h6>
                <span class="badge bg-info">Total Skor: @Model.Questions.Sum(q => q.ScoreValue)</span>
            </div>
            <div class="card-body">
                @if (!Model.Questions.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-clipboard-x display-4"></i>
                        <p class="mt-3">Belum ada soal. Tambahkan soal pertama di panel kiri.</p>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var question in Model.Questions.OrderBy(q => q.Order))
                        {
                            <div class="list-group-item px-0">
                                <div class="d-flex justify-content-between align-items-start">
                                    <h6 class="mb-1 fw-bold">@question.Order. @question.QuestionText</h6>
                                    <form asp-action="DeleteQuestion" asp-controller="Admin" method="post"
                                          onsubmit="return confirm('Hapus soal ini?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@question.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger border-0">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                                <ul class="list-unstyled ms-3 mt-2 mb-1">
                                    @foreach (var opt in question.Options)
                                    {
                                        <li class="@(opt.IsCorrect ? "text-success fw-bold" : "text-muted")">
                                            <i class="bi @(opt.IsCorrect ? "bi-check-circle-fill" : "bi-circle") me-2"></i>
                                            @opt.OptionText
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
