@{
    var managementData = ViewBag.ManagementData as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var totalCount = (int)(ViewBag.TotalCount ?? 0);
    var searchTerm = ViewBag.SearchTerm as string;
    var assessmentCategories = ViewBag.Categories as List<string> ?? new List<string>();
    var selectedAssessmentCategory = ViewBag.SelectedCategory as string ?? "";
    var selectedAssessmentStatus = ViewBag.SelectedStatus as string ?? "";
    // MAP-21: baca paging.Take dari ViewBag (drop magic-number 20)
    var pageSize = (int)(ViewBag.PageSize ?? 20);
}

<!-- Filter Form (Phase 322 — HTMX inline triggers, scoped to Assessment Groups tab only) -->
<form id="filterFormAssessment" onsubmit="return false;" class="mb-3">
    <input type="hidden" name="tab" value="assessment" />
    <input type="hidden" name="page" value="1" id="filterPageAssessment" />
    <input type="hidden" name="pageSize" value="@pageSize" />

    <!-- Search Row -->
    <div class="row mb-3">
        <div class="col-md-6">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" class="form-control border-start-0 ps-0" name="search"
                       id="searchAssessment"
                       placeholder="Cari berdasarkan judul, kategori, nama, atau NIP..."
                       value="@searchTerm"
                       hx-get="@Url.Action("ManageAssessmentTab_Assessment", "AssessmentAdmin")"
                       hx-trigger="input changed delay:500ms, keyup[key=='Enter']"
                       hx-target="closest .htmx-tab-wrapper"
                       hx-swap="innerHTML"
                       hx-include="closest form" />
                <button class="btn btn-primary" type="button"
                        hx-get="@Url.Action("ManageAssessmentTab_Assessment", "AssessmentAdmin")"
                        hx-target="closest .htmx-tab-wrapper"
                        hx-swap="innerHTML"
                        hx-include="closest form">Cari</button>
                @if (!string.IsNullOrEmpty(searchTerm))
                {
                    <button type="button" class="btn btn-outline-secondary" title="Hapus pencarian"
                            onclick="document.getElementById('searchAssessment').value=''; htmx.trigger('#searchAssessment','input')">
                        <i class="bi bi-x-lg"></i>
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- Filter Row: Kategori + Status -->
    <div class="row mb-3">
        <div class="col-md-3">
            <select id="categoryFilter" name="category" class="form-select form-select-sm"
                    hx-get="@Url.Action("ManageAssessmentTab_Assessment", "AssessmentAdmin")"
                    hx-trigger="change"
                    hx-target="closest .htmx-tab-wrapper"
                    hx-swap="innerHTML"
                    hx-include="closest form">
                <option value="">Semua Kategori</option>
                @foreach (var cat in assessmentCategories)
                {
                    if (selectedAssessmentCategory == cat)
                    { <option value="@cat" selected="selected">@cat</option> }
                    else
                    { <option value="@cat">@cat</option> }
                }
            </select>
        </div>
        <div class="col-md-3">
            <select id="statusFilter" name="statusFilter" class="form-select form-select-sm"
                    hx-get="@Url.Action("ManageAssessmentTab_Assessment", "AssessmentAdmin")"
                    hx-trigger="change"
                    hx-target="closest .htmx-tab-wrapper"
                    hx-swap="innerHTML"
                    hx-include="closest form">
                @if (string.IsNullOrEmpty(selectedAssessmentStatus))
                { <option value="" selected="selected">Aktif (Open/Upcoming)</option> }
                else
                { <option value="">Aktif (Open/Upcoming)</option> }
                @if (selectedAssessmentStatus == "Open")
                { <option value="Open" selected="selected">Open</option> }
                else
                { <option value="Open">Open</option> }
                @if (selectedAssessmentStatus == "Upcoming")
                { <option value="Upcoming" selected="selected">Upcoming</option> }
                else
                { <option value="Upcoming">Upcoming</option> }
                @if (selectedAssessmentStatus == "Closed")
                { <option value="Closed" selected="selected">Closed</option> }
                else
                { <option value="Closed">Closed</option> }
                @if (selectedAssessmentStatus == "All")
                { <option value="All" selected="selected">Semua Status</option> }
                else
                { <option value="All">Semua Status</option> }
            </select>
        </div>
        @if (!string.IsNullOrEmpty(selectedAssessmentCategory) || !string.IsNullOrEmpty(selectedAssessmentStatus) || !string.IsNullOrEmpty(searchTerm))
        {
            <div class="col-md-2">
                <button type="button" class="btn btn-sm btn-outline-secondary"
                        hx-get="@Url.Action("ManageAssessmentTab_Assessment", "AssessmentAdmin")"
                        hx-target="closest .htmx-tab-wrapper"
                        hx-swap="innerHTML"
                        onclick="document.getElementById('searchAssessment').value=''; document.getElementById('categoryFilter').value=''; document.getElementById('statusFilter').value=''; document.getElementById('filterPageAssessment').value='1';">
                    <i class="bi bi-x-lg me-1"></i>Reset Filter
                </button>
            </div>
        }
    </div>
</form>

<!-- Stats Badge -->
<div class="mb-3 d-flex align-items-center flex-wrap gap-2">
    <span class="badge bg-secondary fs-6">@totalCount grup assessment</span>
    @* Phase 338 CIL-01: counter per-status (preserve default Open filter, badge cue Closed exist) *@
    <span class="badge bg-success" title="Assessment dengan status Open">@(ViewBag.OpenCount ?? 0) Open</span>
    <span class="badge bg-warning text-dark" title="Assessment dengan status Upcoming">@(ViewBag.UpcomingCount ?? 0) Upcoming</span>
    <span class="badge bg-secondary cil01-pulse"
          data-cil01-animate="true"
          title="Closed assessment (hidden by default — pilih filter 'Closed' atau 'Semua Status' untuk lihat, atau search judul spesifik)">
        @(ViewBag.ClosedCount ?? 0) Closed
    </span>
</div>
<style>
    .cil01-pulse { animation: cil01-fade 1.5s ease-in-out 1; }
    @@keyframes cil01-fade {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.6; transform: scale(1.08); }
    }
    /* MAP-03: chevron rotate via CSS [aria-expanded] (Bootstrap auto-set) */
    .toggle-chevron .chevron-icon { transition: transform 0.2s; }
    .toggle-chevron[aria-expanded="true"] .chevron-icon { transform: rotate(180deg); }
</style>

@if (!managementData.Any())
{
    var hasActiveFilter = !string.IsNullOrEmpty(selectedAssessmentCategory) || !string.IsNullOrEmpty(selectedAssessmentStatus);
    <!-- Empty State -->
    <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5">
            <i class="bi bi-inbox text-muted mb-3" style="font-size: 4rem;"></i>
            @if (!string.IsNullOrEmpty(searchTerm))
            {
                <h5 class="text-muted">Tidak ada assessment ditemukan untuk "@searchTerm"</h5>
                <p class="text-muted small">Coba sesuaikan kata kunci pencarian atau lihat semua assessment.</p>
                <a asp-action="ManageAssessment" asp-controller="AssessmentAdmin" asp-route-tab="assessment"
                   class="btn btn-sm btn-outline-primary mt-2">
                    <i class="bi bi-arrow-counterclockwise me-1"></i> Reset Semua Filter
                </a>
            }
            else if (hasActiveFilter)
            {
                @* MAP-05: empty-state filter-aware — kategori/status aktif + search kosong (D-02) *@
                <h5 class="text-muted">Tidak ada assessment untuk filter ini</h5>
                <p class="text-muted small">Coba ubah atau reset filter untuk melihat assessment lain.</p>
                <a asp-action="ManageAssessment" asp-controller="AssessmentAdmin" asp-route-tab="assessment"
                   class="btn btn-sm btn-outline-primary mt-2">
                    <i class="bi bi-arrow-counterclockwise me-1"></i> Reset Semua Filter
                </a>
            }
            else
            {
                <h5 class="text-muted">Tidak ada assessment ditemukan</h5>
                <p class="text-muted small">Buat assessment pertama untuk memulai.</p>
                <a href="@Url.Action("CreateAssessment", "AssessmentAdmin")" class="btn btn-primary mt-3">
                    <i class="bi bi-plus-circle me-1"></i> Buat Assessment
                </a>
            }
        </div>
    </div>
}
else
{
    <!-- Assessment Table -->
    <div class="card shadow-sm border-0">
        <div class="table-responsive" style="min-height: calc(100vh - 420px); overflow-y: auto;">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr class="text-center">
                        <th style="width:50px">No</th>
                        <th>Judul</th>
                        <th>Kategori</th>
                        <th>Jadwal</th>
                        <th>Durasi</th>
                        <th>Status</th>
                        <th>Token</th>
                        <th>Peserta</th>
                        <th style="width:100px">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var rowNum = (currentPage - 1) * pageSize + 1;
                    }
                    @foreach (var group in managementData)
                    {
                        var categoryBadge = (string)group.Category switch
                        {
                            "OJT"                     => "bg-primary",
                            "IHT"                     => "bg-success",
                            "Training Licencor"       => "bg-danger",
                            "OTS"                     => "bg-warning text-dark",
                            "Mandatory HSSE Training" => "bg-info",
                            "Proton"                  => "bg-purple",
                            "Assessment Proton"       => "bg-purple",
                            _                         => "bg-secondary"
                        };
                        // MAM-10: bind GroupStatus (derived Open/Upcoming/Closed), bukan rep single-session Status.
                        var statusBadge = (string)group.GroupStatus switch
                        {
                            "Open"     => "bg-success",
                            "Upcoming" => "bg-info",
                            "Closed"   => "bg-secondary",
                            _          => "bg-secondary"
                        };

                        var collapseId = "users-" + (int)group.RepresentativeId;
                        var userList = (IEnumerable<dynamic>)group.Users;
                        var userCount = (int)group.UserCount;

                        <tr>
                            <td>@(rowNum++)</td>
                            <td class="fw-semibold">
                                @group.Title
                                @if ((bool)group.IsPrePostGroup)
                                {
                                    <span class="badge bg-primary rounded-pill ms-2"><i class="bi bi-arrow-left-right"></i> Pre-Post Test</span>
                                }
                            </td>
                            <td><span class="badge @categoryBadge">@group.Category</span></td>
                            <td>@(((DateTime)group.Schedule).ToString("dd MMM yyyy HH:mm"))</td>
                            <td>@group.DurationMinutes menit</td>
                            <td><span class="badge @statusBadge">@group.GroupStatus</span></td>
                            <td>
                                @if ((bool)group.IsTokenRequired)
                                {
                                    <span class="badge bg-success">Ya</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Tidak</span>
                                }
                            </td>
                            <td>
                                <button class="btn btn-sm btn-link text-decoration-none p-0 toggle-chevron" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#@collapseId"
                                        aria-expanded="false" aria-controls="@collapseId"
                                        aria-label="Tampilkan/sembunyikan @userCount peserta">
                                    <i class="bi bi-people me-1"></i>@userCount peserta
                                    <i class="bi bi-chevron-down chevron-icon ms-1"></i>
                                </button>
                                <div class="collapse mt-1" id="@collapseId">
                                    <ul class="list-unstyled small text-muted mb-0">
                                        @foreach (var u in userList)
                                        {
                                            <li class="d-flex justify-content-between align-items-center">
                                                <span><i class="bi bi-person me-1"></i>@u.UserFullName (@u.UserEmail)</span>
                                                <a href="@Url.Action("UserAssessmentHistory", "AssessmentAdmin", new { userId = u.UserId })"
                                                   class="btn btn-link btn-sm p-0 text-muted" title="Riwayat Assessment">
                                                    <i class="bi bi-clock-history"></i>
                                                </a>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </td>
                            <td>
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                            data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        @* MAM-02: Pre-Post → list view (renders both-half Pre+Post), hindari single-date filter yang miss PostTest beda tanggal. *@
                                        @if ((bool)group.IsPrePostGroup)
                                        {
                                            <li>
                                                <a class="dropdown-item" href="@Url.Action("AssessmentMonitoring", "AssessmentAdmin", new { search = (string)group.Title })">
                                                    <i class="bi bi-binoculars me-2"></i>Monitoring (Pre &amp; Post)
                                                </a>
                                            </li>
                                        }
                                        else
                                        {
                                            <li>
                                                <a class="dropdown-item" href="@Url.Action("AssessmentMonitoringDetail", "AssessmentAdmin", new { title = (string)group.Title, category = (string)group.Category, scheduleDate = ((DateTime)group.Schedule).Date.ToString("yyyy-MM-dd") })">
                                                    <i class="bi bi-binoculars me-2"></i>Monitoring
                                                </a>
                                            </li>
                                        }
                                        <li>
                                            <a class="dropdown-item" asp-action="EditAssessment" asp-controller="AssessmentAdmin"
                                               asp-route-id="@group.RepresentativeId">
                                                <i class="bi bi-pencil me-2"></i>Edit
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-action="ManagePackages" asp-controller="AssessmentAdmin"
                                               asp-route-assessmentId="@group.RepresentativeId">
                                                <i class="bi bi-collection me-2"></i>Manage Packages
                                            </a>
                                        </li>
                                        @* MAM-02: row Pre-Post kirim linkedGroupId → endpoint query both-half (Pre+Post); standard tetap scheduleDate. *@
                                        <li>
                                            <a class="dropdown-item" href="@Url.Action("ExportAssessmentResults", "AssessmentAdmin", new { title = (string)group.Title, category = (string)group.Category, scheduleDate = ((DateTime)group.Schedule).Date.ToString("yyyy-MM-dd"), linkedGroupId = (bool)group.IsPrePostGroup ? (int?)group.LinkedGroupId : null })">
                                                <i class="bi bi-file-earmark-excel me-2"></i>Export Excel@((bool)group.IsPrePostGroup ? " (Pre & Post)" : "")
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" href="@Url.Action("BulkExportPdf", "AssessmentAdmin", new { title = (string)group.Title, category = (string)group.Category, scheduleDate = ((DateTime)group.Schedule).Date.ToString("yyyy-MM-dd"), linkedGroupId = (bool)group.IsPrePostGroup ? (int?)group.LinkedGroupId : null })">
                                                <i class="bi bi-file-zip me-2"></i>Bulk Export PDF (ZIP)@((bool)group.IsPrePostGroup ? " (Pre & Post)" : "")
                                            </a>
                                        </li>
                                        @if ((bool)group.IsTokenRequired)
                                        {
                                        <li>
                                            <button type="button" class="dropdown-item text-warning btn-regenerate-token"
                                                    data-id="@group.RepresentativeId">
                                                <i class="bi bi-arrow-repeat me-2"></i>Regenerate Token
                                            </button>
                                        </li>
                                        }
                                        @{
                                            // PHASE 312 D-01 + Q1 opsi B: UI hide pakai Status only.
                                            // ResponseCount cek di backend (defense-in-depth via EnsureCanDeleteAsync).
                                            bool isAdmin = User.IsInRole("Admin");
                                            string groupStatus = (string)group.Status;
                                            bool canHcDelete = groupStatus != "Completed";
                                        }
                                        @if (isAdmin || canHcDelete)
                                        {
                                            <li><hr class="dropdown-divider"></li>
                                            if ((bool)group.IsPrePostGroup)
                                            {
                                                <!-- D-19: delete hanya per-grup untuk Pre-Post; Phase 312: modal trigger -->
                                                <li>
                                                    <button type="button" class="dropdown-item text-danger"
                                                            data-bs-toggle="modal" data-bs-target="#deleteAssessmentModal"
                                                            data-delete-type="prepost"
                                                            data-delete-id="@group.LinkedGroupId"
                                                            data-delete-title="@group.Title">
                                                        <i class="bi bi-trash3 me-2"></i>Hapus Grup Pre-Post
                                                    </button>
                                                </li>
                                            }
                                            else
                                            {
                                                <li>
                                                    <button type="button" class="dropdown-item text-danger"
                                                            data-bs-toggle="modal" data-bs-target="#deleteAssessmentModal"
                                                            data-delete-type="group"
                                                            data-delete-id="@group.RepresentativeId"
                                                            data-delete-title="@group.Title">
                                                        <i class="bi bi-trash me-2"></i>Hapus Grup
                                                    </button>
                                                </li>
                                            }
                                        }
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination (Phase 322 — HTMX with hx-include filter form for state preservation) -->
    @if (totalPages > 1)
    {
        <nav aria-label="Assessment pagination" class="mt-4">
            <div class="d-flex justify-content-between align-items-center">
                <div class="text-muted small">
                    Menampilkan @((currentPage - 1) * pageSize + 1) - @(Math.Min(currentPage * pageSize, totalCount)) dari @totalCount grup
                </div>
                <ul class="pagination pagination-sm mb-0">
                    @{
                        var paginateAction = Url.Action("ManageAssessmentTab_Assessment", "AssessmentAdmin");
                    }
                    @* First Page *@
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" type="button"
                                hx-get="@paginateAction"
                                hx-vals='{"page":"1"}'
                                hx-include="#filterFormAssessment"
                                hx-target="closest .htmx-tab-wrapper"
                                hx-swap="innerHTML"
                                @(currentPage == 1 ? "disabled" : "")>
                            <i class="bi bi-chevron-double-left"></i>
                        </button>
                    </li>
                    @* Previous Page *@
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" type="button"
                                hx-get="@paginateAction"
                                hx-vals='{"page":"@(currentPage - 1)"}'
                                hx-include="#filterFormAssessment"
                                hx-target="closest .htmx-tab-wrapper"
                                hx-swap="innerHTML"
                                @(currentPage == 1 ? "disabled" : "")>
                            <i class="bi bi-chevron-left"></i>
                        </button>
                    </li>
                    @* Page Numbers *@
                    @{
                        var startPage = Math.Max(1, currentPage - 2);
                        var endPage = Math.Min(totalPages, currentPage + 2);
                        for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <button class="page-link" type="button"
                                        hx-get="@paginateAction"
                                        hx-vals='{"page":"@i"}'
                                        hx-include="#filterFormAssessment"
                                        hx-target="closest .htmx-tab-wrapper"
                                        hx-swap="innerHTML">@i</button>
                            </li>
                        }
                    }
                    @* Next Page *@
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <button class="page-link" type="button"
                                hx-get="@paginateAction"
                                hx-vals='{"page":"@(currentPage + 1)"}'
                                hx-include="#filterFormAssessment"
                                hx-target="closest .htmx-tab-wrapper"
                                hx-swap="innerHTML"
                                @(currentPage == totalPages ? "disabled" : "")>
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </li>
                    @* Last Page *@
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <button class="page-link" type="button"
                                hx-get="@paginateAction"
                                hx-vals='{"page":"@totalPages"}'
                                hx-include="#filterFormAssessment"
                                hx-target="closest .htmx-tab-wrapper"
                                hx-swap="innerHTML"
                                @(currentPage == totalPages ? "disabled" : "")>
                            <i class="bi bi-chevron-double-right"></i>
                        </button>
                    </li>
                </ul>
            </div>
        </nav>
    }
}

<!-- PHASE 312: Shared delete modal — 2-step impact preview + final confirm (D-02, UI-SPEC) -->
<!-- PHASE 312 WR-02: URL di-render server-side via @@Url.Action agar path-prefix Dev (/KPB-PortalHC) ter-resolve correctly -->
<div class="modal fade" id="deleteAssessmentModal" tabindex="-1"
     aria-labelledby="deleteAssessmentModalLabel" aria-hidden="true" role="alertdialog"
     data-action-single="@Url.Action("DeleteAssessment", "AssessmentAdmin")"
     data-action-group="@Url.Action("DeleteAssessmentGroup", "AssessmentAdmin")"
     data-action-prepost="@Url.Action("DeletePrePostGroup", "AssessmentAdmin")"
     data-impact-url="@Url.Action("GetDeleteImpact", "AssessmentAdmin")">
    <div class="modal-dialog modal-dialog-scrollable" id="dam-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title fw-semibold" id="deleteAssessmentModalLabel">
                    <i class="bi bi-trash3 me-2"></i><span id="dam-title">Hapus Assessment</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Tutup"></button>
            </div>

            <div class="modal-body">
                <!-- Step 1: Impact preview panel -->
                <div id="dam-step-1">
                    <div id="dam-loading" class="text-center py-3" role="status" aria-live="polite">
                        <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                        Memuat dampak penghapusan...
                    </div>
                    <div id="dam-content" style="display:none;" aria-live="polite">
                        <p class="fw-semibold mb-2">Dampak penghapusan:</p>
                        <ul class="mb-2">
                            <li>Status saat ini: <strong id="dam-status">-</strong></li>
                            <li><strong id="dam-response-count">0</strong> peserta dengan jawaban tersimpan</li>
                            <li><strong id="dam-cert-count">0</strong> sertifikat akan terhapus</li>
                            <li><strong id="dam-package-count">0</strong> paket soal (beserta soal &amp; opsi)</li>
                            <li><strong id="dam-attempt-count">0</strong> riwayat percobaan ujian</li>
                        </ul>
                        <div id="dam-prepost-breakdown" style="display:none;" class="mt-3">
                            <p class="fw-semibold mt-3 mb-2">Rincian per sesi:</p>
                            <ul class="mb-0">
                                <li>Pre-Test — Status: <span id="dam-pre-status">-</span>, <span id="dam-pre-resp">0</span> jawaban</li>
                                <li>Post-Test — Status: <span id="dam-post-status">-</span>, <span id="dam-post-resp">0</span> jawaban</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Step 2: Final confirm panel -->
                <div id="dam-step-2" style="display:none;">
                    <div class="alert alert-danger" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-1"></i>
                        <strong>Tindakan ini tidak dapat dibatalkan.</strong>
                    </div>
                    <p class="mb-2">Anda akan menghapus permanen:</p>
                    <ul class="mb-2">
                        <li id="dam-cascade-1">Sesi assessment beserta semua paket soal, soal, dan opsi</li>
                        <li>Semua jawaban peserta yang sudah tersimpan</li>
                        <li>Riwayat percobaan ujian peserta</li>
                        <li>Penugasan paket soal ke peserta</li>
                    </ul>
                    <p class="text-muted small mb-0">Lanjutkan?</p>
                </div>
            </div>

            <div class="modal-footer">
                <!-- Footer 1: Batal + Lanjutkan -->
                <div id="dam-footer-1" class="d-flex justify-content-end gap-2 w-100">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                    <button type="button" class="btn btn-danger" id="dam-next-btn" disabled>
                        Lanjutkan<i class="bi bi-arrow-right ms-1"></i>
                    </button>
                </div>
                <!-- Footer 2: Kembali + Hapus Permanen (form submit) -->
                <div id="dam-footer-2" class="d-flex justify-content-end gap-2 w-100" style="display:none;">
                    <button type="button" class="btn btn-secondary" id="dam-back-btn">
                        <i class="bi bi-arrow-left me-1"></i>Kembali
                    </button>
                    <form id="dam-submit-form" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" id="dam-form-id" disabled />
                        <input type="hidden" name="linkedGroupId" id="dam-form-linkedid" disabled />
                        <button type="submit" class="btn btn-danger" id="dam-submit-btn">
                            <i class="bi bi-trash3 me-1"></i>Hapus Permanen
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    // PHASE 312 Q2 RESOLVED: handler attached via event delegation di document.body (stable across DOM mutations).
    // Idempotent flag mencegah double-bind. htmx:afterSwap listener defensive check (handler di document.body
    // tidak perlu re-bind — survive partial swap natural).
    if (window.__dam312Attached) {
        return;
    }
    window.__dam312Attached = true;

    // PHASE 312 WR-02: URL di-inject via data-* attribute pada modal element
    // (di-render server-side dengan @@Url.Action) — path-prefix-aware untuk Dev (/KPB-PortalHC).
    // Tidak perlu base href atau JS path concatenation.

    // Reset modal state ke Step 1 + loading
    function resetModal() {
        document.getElementById('dam-step-1').style.display = '';
        document.getElementById('dam-step-2').style.display = 'none';
        document.getElementById('dam-footer-1').style.display = '';
        document.getElementById('dam-footer-2').style.display = 'none';
        document.getElementById('dam-loading').style.display = '';
        document.getElementById('dam-loading').innerHTML = '<span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>Memuat dampak penghapusan...';
        document.getElementById('dam-content').style.display = 'none';
        document.getElementById('dam-prepost-breakdown').style.display = 'none';
        document.getElementById('dam-next-btn').disabled = true;
        document.getElementById('dam-dialog').classList.remove('modal-lg');
    }

    // show.bs.modal: read data-* attributes, fetch impact, populate Step 1
    document.body.addEventListener('show.bs.modal', function (event) {
        var modalEl = event.target;
        if (!modalEl || modalEl.id !== 'deleteAssessmentModal') return;

        var trigger = event.relatedTarget;
        if (!trigger) return;

        var type = trigger.dataset.deleteType;       // "single" | "group" | "prepost"
        var id   = trigger.dataset.deleteId;
        var title = trigger.dataset.deleteTitle || '';

        resetModal();

        // Set title per type (per UI-SPEC line 106-110)
        var titleMap = {
            'single':  'Hapus Assessment: ' + title,
            'group':   'Hapus Grup Assessment: ' + title,
            'prepost': 'Hapus Grup Pre-Post Test: ' + title
        };
        document.getElementById('dam-title').textContent = titleMap[type] || ('Hapus: ' + title);

        // Cascade item 1 per type (per UI-SPEC line 134-136)
        var cascadeMap = {
            'single':  'Sesi assessment beserta semua paket soal, soal, dan opsi',
            'group':   'Semua sesi assessment dalam grup beserta paket soal, soal, dan opsi',
            'prepost': 'Kedua sesi (Pre-Test dan Post-Test) beserta paket soal, soal, dan opsi'
        };
        document.getElementById('dam-cascade-1').textContent = cascadeMap[type] || cascadeMap['single'];

        // Form action + hidden field setup
        var form = document.getElementById('dam-submit-form');
        var formId = document.getElementById('dam-form-id');
        var formLinkedId = document.getElementById('dam-form-linkedid');
        formId.disabled = true;
        formLinkedId.disabled = true;

        // PHASE 312 WR-02: read pre-rendered URLs dari data-* attribute pada modal element
        var actionSingle  = modalEl.dataset.actionSingle;
        var actionGroup   = modalEl.dataset.actionGroup;
        var actionPrepost = modalEl.dataset.actionPrepost;
        var impactUrl     = modalEl.dataset.impactUrl;

        if (type === 'single') {
            form.action = actionSingle;
            formId.value = id;
            formId.disabled = false;
        } else if (type === 'group') {
            form.action = actionGroup;
            formId.value = id;
            formId.disabled = false;
        } else if (type === 'prepost') {
            form.action = actionPrepost;
            formLinkedId.value = id;
            formLinkedId.disabled = false;
            document.getElementById('dam-dialog').classList.add('modal-lg');
        }

        // Fetch impact (URL pre-rendered server-side via @@Url.Action)
        var url = impactUrl
            + '?type=' + encodeURIComponent(type)
            + '&id=' + encodeURIComponent(id);

        fetch(url, { credentials: 'same-origin' })
            .then(function (r) {
                if (!r.ok) throw new Error('HTTP ' + r.status);
                return r.json();
            })
            .then(function (data) {
                document.getElementById('dam-status').textContent = data.status || '-';
                document.getElementById('dam-response-count').textContent = data.responseCount || 0;
                document.getElementById('dam-cert-count').textContent = data.certCount || 0;
                document.getElementById('dam-package-count').textContent = data.packageCount || 0;
                document.getElementById('dam-attempt-count').textContent = data.attemptCount || 0;

                if (type === 'prepost' && data.prePostBreakdown) {
                    document.getElementById('dam-pre-status').textContent = data.prePostBreakdown.pre.status || '-';
                    document.getElementById('dam-pre-resp').textContent = data.prePostBreakdown.pre.responseCount || 0;
                    document.getElementById('dam-post-status').textContent = data.prePostBreakdown.post.status || '-';
                    document.getElementById('dam-post-resp').textContent = data.prePostBreakdown.post.responseCount || 0;
                    document.getElementById('dam-prepost-breakdown').style.display = '';
                }

                document.getElementById('dam-loading').style.display = 'none';
                document.getElementById('dam-content').style.display = '';
                document.getElementById('dam-next-btn').disabled = false;
            })
            .catch(function (err) {
                document.getElementById('dam-loading').innerHTML =
                    '<span class="text-danger"><i class="bi bi-exclamation-circle me-1"></i>Gagal memuat data dampak. Tutup dan coba lagi.</span>';
                // Lanjutkan tetap disabled
            });
    });

    // Step navigation: Lanjutkan → Step 2, Kembali → Step 1
    document.body.addEventListener('click', function (event) {
        var t = event.target.closest('#dam-next-btn');
        if (t && !t.disabled) {
            document.getElementById('dam-step-1').style.display = 'none';
            document.getElementById('dam-step-2').style.display = '';
            document.getElementById('dam-footer-1').style.display = 'none';
            document.getElementById('dam-footer-2').style.display = '';
            document.getElementById('dam-back-btn').focus();
            return;
        }
        var b = event.target.closest('#dam-back-btn');
        if (b) {
            document.getElementById('dam-step-1').style.display = '';
            document.getElementById('dam-step-2').style.display = 'none';
            document.getElementById('dam-footer-1').style.display = '';
            document.getElementById('dam-footer-2').style.display = 'none';
            document.getElementById('dam-next-btn').focus();
            return;
        }
    });

    // PHASE 312 Q2 RESOLVED: htmx:afterSwap defensive check.
    // Handler di document.body adalah event-delegated (stable). Listener ini hanya warn kalau
    // modal element hilang setelah swap (modal markup di partial bottom — should persist).
    document.body.addEventListener('htmx:afterSwap', function (event) {
        if (!document.getElementById('deleteAssessmentModal')) {
            console.warn('[Phase 312] deleteAssessmentModal hilang setelah htmx:afterSwap — verifikasi partial render');
        }
        // No re-bind needed: handlers di document.body (event delegation) survive DOM mutations.
    });
})();
</script>
