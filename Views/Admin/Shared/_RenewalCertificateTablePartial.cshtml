@model HcPortal.Models.CertificationManagementViewModel

<span id="partial-expired-count" class="d-none">@Model.ExpiredCount</span>
<span id="partial-akan-expired-count" class="d-none">@Model.AkanExpiredCount</span>

<div class="card-body p-0">
    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-3" style="width:40px">
                        <input type="checkbox" class="form-check-input" id="cb-select-all" aria-label="Pilih semua" />
                    </th>
                    <th style="width:48px">No</th>
                    <th>Nama</th>
                    <th>Judul Sertifikat</th>
                    <th class="d-none d-md-table-cell">Kategori</th>
                    <th class="d-none d-md-table-cell">Sub Kategori</th>
                    <th style="width:110px">Valid Until</th>
                    <th style="width:120px">Status</th>
                    <th style="width:90px">Aksi</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Rows.Count == 0)
                {
                    <tr>
                        <td colspan="9" class="text-center py-5">
                            <i class="bi bi-patch-check-fill fs-1 text-success d-block mb-3"></i>
                            <strong>Tidak ada sertifikat yang perlu di-renew</strong>
                            <p class="text-muted mt-1 mb-3">Semua sertifikat aktif atau sudah di-renew.</p>
                            <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Kembali ke Kelola Data
                            </a>
                        </td>
                    </tr>
                }
                else
                {
                    @for (int i = 0; i < Model.Rows.Count; i++)
                    {
                        var row = Model.Rows[i];
                        var nomor = (Model.CurrentPage - 1) * Model.PageSize + i + 1;
                        <tr>
                            <td class="ps-3">
                                <input type="checkbox"
                                       class="form-check-input cb-select"
                                       data-kategori="@(row.Kategori ?? "")"
                                       data-sourceid="@row.SourceId"
                                       data-recordtype="@row.RecordType"
                                       aria-label="Pilih @row.NamaWorker - @row.Judul" />
                            </td>
                            <td>@nomor</td>
                            <td>@row.NamaWorker</td>
                            <td>@row.Judul</td>
                            <td class="d-none d-md-table-cell">@(row.Kategori ?? "-")</td>
                            <td class="d-none d-md-table-cell">@(row.SubKategori ?? "-")</td>
                            <td>@(row.ValidUntil?.ToString("dd MMM yyyy") ?? "-")</td>
                            <td>
                                @if (row.Status == CertificateStatus.Expired)
                                {
                                    <span class="badge bg-danger">Expired</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Akan Expired</span>
                                }
                            </td>
                            <td>
                                <button type="button"
                                        class="btn btn-sm btn-outline-secondary btn-history me-1"
                                        data-worker-id="@row.WorkerId"
                                        data-worker-name="@row.NamaWorker"
                                        data-mode="renewal"
                                        title="Lihat riwayat sertifikat @row.NamaWorker"
                                        aria-label="Lihat riwayat sertifikat @row.NamaWorker">
                                    <i class="bi bi-clock-history"></i>
                                </button>
                                @if (row.RecordType == RecordType.Assessment)
                                {
                                    <a href="/Admin/CreateAssessment?renewSessionId=@row.SourceId"
                                       class="btn btn-sm btn-warning"
                                       aria-label="Renew sertifikat @row.Judul untuk @row.NamaWorker">
                                        <i class="bi bi-arrow-repeat me-1"></i>Renew
                                    </a>
                                }
                                else
                                {
                                    <a href="/Admin/CreateAssessment?renewTrainingId=@row.SourceId"
                                       class="btn btn-sm btn-warning"
                                       aria-label="Renew sertifikat @row.Judul untuk @row.NamaWorker">
                                        <i class="bi bi-arrow-repeat me-1"></i>Renew
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-4 px-3" aria-label="Pagination">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a href="#" class="page-link" data-page="@(Model.CurrentPage - 1)">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a href="#" class="page-link" data-page="@i">@i</a>
                </li>
            }
            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a href="#" class="page-link" data-page="@(Model.CurrentPage + 1)">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
}

@if (Model.TotalCount > 0)
{
    var from = (Model.CurrentPage - 1) * Model.PageSize + 1;
    var to = Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount);
    <p class="text-center text-muted small mt-2 pb-3">
        Menampilkan @from - @to dari @Model.TotalCount sertifikat
    </p>
}
