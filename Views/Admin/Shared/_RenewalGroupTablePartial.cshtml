@model HcPortal.Models.RenewalGroup

<div class="table-responsive">
    <table class="table table-striped table-hover mb-0">
        <caption class="visually-hidden">Daftar pekerja untuk @Model.Judul</caption>
        <thead class="table-light">
            <tr>
                <th class="ps-3" style="width:40px">
                    <input type="checkbox" class="form-check-input cb-group-select-all"
                           data-group-key="@Model.GroupKey"
                           aria-label="Pilih semua di group @Model.Judul" />
                </th>
                <th>Nama</th>
                <th class="d-none d-md-table-cell">Kategori</th>
                <th class="d-none d-md-table-cell">Sub Kategori</th>
                <th style="width:110px">Valid Until</th>
                <th style="width:120px">Status</th>
                <th style="width:90px">Aksi</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.Rows)
            {
                <tr>
                    <td class="ps-3">
                        <input type="checkbox"
                               class="form-check-input cb-select"
                               data-kategori="@(row.Kategori ?? "")"
                               data-sourceid="@row.SourceId"
                               data-recordtype="@row.RecordType"
                               data-group-key="@Model.GroupKey"
                               aria-label="Pilih @row.NamaWorker - @row.Judul" />
                    </td>
                    <td>@row.NamaWorker</td>
                    <td class="d-none d-md-table-cell">@(row.Kategori ?? "-")</td>
                    <td class="d-none d-md-table-cell">@(row.SubKategori ?? "-")</td>
                    <td>@(row.ValidUntil?.ToString("dd MMM yyyy") ?? "-")</td>
                    <td>
                        @if (row.Status == CertificateStatus.Expired)
                        {
                            <span class="badge bg-danger">Expired</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Akan Expired</span>
                        }
                    </td>
                    <td>
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary btn-history me-1"
                                data-worker-id="@row.WorkerId"
                                data-worker-name="@row.NamaWorker"
                                data-mode="renewal"
                                title="Lihat riwayat sertifikat @row.NamaWorker"
                                aria-label="Lihat riwayat sertifikat @row.NamaWorker">
                            <i class="bi bi-clock-history"></i>
                        </button>
                        @if (row.RecordType == RecordType.Assessment)
                        {
                            <a href="/Admin/CreateAssessment?renewSessionId=@row.SourceId"
                               class="btn btn-sm btn-warning"
                               aria-label="Renew sertifikat @row.Judul untuk @row.NamaWorker">
                                <i class="bi bi-arrow-repeat me-1"></i>Renew
                            </a>
                        }
                        else
                        {
                            <a href="/Admin/CreateAssessment?renewTrainingId=@row.SourceId"
                               class="btn btn-sm btn-warning"
                               aria-label="Renew sertifikat @row.Judul untuk @row.NamaWorker">
                                <i class="bi bi-arrow-repeat me-1"></i>Renew
                            </a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3 px-3" aria-label="Pagination group @Model.Judul">
        <ul class="pagination pagination-sm justify-content-center">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a href="#" class="page-link" data-page="@(Model.CurrentPage - 1)"
                   data-group-key="@Model.GroupKey" data-group-judul="@Model.Judul">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a href="#" class="page-link" data-page="@i"
                       data-group-key="@Model.GroupKey" data-group-judul="@Model.Judul">@i</a>
                </li>
            }
            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a href="#" class="page-link" data-page="@(Model.CurrentPage + 1)"
                   data-group-key="@Model.GroupKey" data-group-judul="@Model.Judul">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
    <p class="text-center text-muted small mt-1 pb-3">
        Menampilkan @((Model.CurrentPage - 1) * Model.PageSize + 1) - @(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount)) dari @Model.TotalCount pekerja
    </p>
}
