@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    // MAM-08: antiforgery token untuk hx-post delete (dikirim di body __RequestVerificationToken).
    var antiToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
    var workers = ViewBag.Workers as List<HcPortal.Models.WorkerTrainingStatus> ?? new();
    var selectedSection = ViewBag.SelectedSection as string ?? "";
    var selectedCategory = ViewBag.SelectedCategory as string ?? "";
    var selectedUnit = ViewBag.SelectedUnit as string ?? "";
    var selectedStatus = ViewBag.SelectedStatus as string ?? "";
    var searchTerm2 = ViewBag.SearchTerm as string ?? "";
    bool isInitialState = (bool)(ViewBag.IsInitialState ?? true);
    // MAM-07: pagination state (set di ManageAssessmentTab_Training caller).
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var totalCount = (int)(ViewBag.TotalCount ?? 0);
    var pageSize = (int)(ViewBag.PageSize ?? 20);
}

<style>
    /* MAP-03: chevron rotate via CSS [aria-expanded] (Bootstrap auto-set) */
    .toggle-chevron .chevron-icon { transition: transform 0.2s; }
    .toggle-chevron[aria-expanded="true"] .chevron-icon { transform: rotate(180deg); }
</style>

<!-- Tab Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">Input Records</h5>
    <div class="d-flex gap-2">
        <a href="@Url.Action("ImportTraining", "TrainingAdmin")" class="btn btn-outline-primary">
            <i class="bi bi-file-earmark-arrow-up me-2"></i>Import Excel
        </a>
        <a href="@Url.Action("AddTraining", "TrainingAdmin")" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>Tambah Training
        </a>
        <a href="@Url.Action("AddManualAssessment", "TrainingAdmin")" class="btn btn-info text-white">
            <i class="bi bi-plus-lg me-2"></i>Tambah Assessment Manual
        </a>
    </div>
</div>

<!-- Filter Section (Phase 322 — HTMX inline triggers, scoped to Input Records tab only) -->
<div class="card bg-light border-0 mb-4">
    <div class="card-body">
        <form id="filterFormTraining" onsubmit="return false;">
            <input type="hidden" name="tab" value="training" />
            <input type="hidden" name="isFiltered" value="true" />

            <div class="row g-3 align-items-end">
                <!-- Dropdown: Bagian -->
                <div class="col-12 col-md-2">
                    <label class="form-label fw-bold small">@OrgLabels.GetLabel(0)</label>
                    <select class="form-select form-select-sm" name="section" id="filterSection"
                            hx-get="@Url.Action("ManageAssessmentTab_Training", "AssessmentAdmin")"
                            hx-trigger="change"
                            hx-target="closest .htmx-tab-wrapper"
                            hx-swap="innerHTML"
                            hx-include="closest form"
                            onchange="document.getElementById('filterUnit').value='';">
                        <option value="">Semua @OrgLabels.GetLabel(0)</option>
                        @{ var sects = ViewBag.TrainingSections as List<string> ?? new List<string>(); }
                        @foreach (var s in sects)
                        {
                            if (selectedSection == s)
                            { <option value="@s" selected="selected">@s</option> }
                            else
                            { <option value="@s">@s</option> }
                        }
                    </select>
                </div>

                <!-- Dropdown: Kategori Training -->
                <div class="col-12 col-md-2">
                    <label class="form-label fw-bold small">Kategori Training</label>
                    <select class="form-select form-select-sm" name="category" id="filterCategory"
                            hx-get="@Url.Action("ManageAssessmentTab_Training", "AssessmentAdmin")"
                            hx-trigger="change"
                            hx-target="closest .htmx-tab-wrapper"
                            hx-swap="innerHTML"
                            hx-include="closest form">
                        <option value="">-- Pilih Kategori --</option>
                        @{
                            var cats = new[] {
                                ("OJT", "OJT"), ("IHT", "IHT"),
                                ("Training Licencor", "Training Licencor"), ("OTS", "OTS"),
                                ("MANDATORY", "Mandatory HSSE Training"), ("Proton", "Proton"),
                                ("ISS", "ISS"), ("OSS", "OSS")
                            };
                        }
                        @foreach (var (val, label) in cats)
                        {
                            if (selectedCategory == val)
                            { <option value="@val" selected="selected">@label</option> }
                            else
                            { <option value="@val">@label</option> }
                        }
                    </select>
                </div>

                <!-- Dropdown: Unit -->
                <div class="col-12 col-md-2">
                    <label class="form-label fw-bold small">@OrgLabels.GetLabel(1)</label>
                    <select class="form-select form-select-sm" name="unit" id="filterUnit"
                            hx-get="@Url.Action("ManageAssessmentTab_Training", "AssessmentAdmin")"
                            hx-trigger="change"
                            hx-target="closest .htmx-tab-wrapper"
                            hx-swap="innerHTML"
                            hx-include="closest form">
                        <option value="">Semua @OrgLabels.GetLabel(1)</option>
                        @{ var trainingUnits = ViewBag.TrainingUnits as List<string> ?? new List<string>(); }
                        @foreach (var unitVal in trainingUnits)
                        {
                            if (selectedUnit == unitVal)
                            { <option value="@unitVal" selected="selected">@unitVal</option> }
                            else
                            { <option value="@unitVal">@unitVal</option> }
                        }
                    </select>
                </div>

                <!-- Dropdown: Status -->
                <div class="col-12 col-md-2">
                    <label class="form-label fw-bold small">Status Training</label>
                    <select class="form-select form-select-sm" name="statusFilter" id="filterStatus"
                            hx-get="@Url.Action("ManageAssessmentTab_Training", "AssessmentAdmin")"
                            hx-trigger="change"
                            hx-target="closest .htmx-tab-wrapper"
                            hx-swap="innerHTML"
                            hx-include="closest form">
                        <option value="">Semua</option>
                        @if (selectedStatus == "Sudah")
                        { <option value="Sudah" selected="selected">Sudah</option> }
                        else
                        { <option value="Sudah">Sudah</option> }
                        @if (selectedStatus == "Belum")
                        { <option value="Belum" selected="selected">Belum</option> }
                        else
                        { <option value="Belum">Belum</option> }
                    </select>
                </div>

                <!-- Search Nama/Nopeg -->
                <div class="col-12 col-md-3">
                    <label class="form-label fw-bold small">Cari Nama/Nopeg</label>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" name="search"
                               id="searchTraining"
                               placeholder="Cari nama atau nopeg..."
                               value="@searchTerm2"
                               hx-get="@Url.Action("ManageAssessmentTab_Training", "AssessmentAdmin")"
                               hx-trigger="input changed delay:500ms, keyup[key=='Enter']"
                               hx-target="closest .htmx-tab-wrapper"
                               hx-swap="innerHTML"
                               hx-include="closest form" />
                        <button class="btn btn-primary" type="button" title="Cari"
                                hx-get="@Url.Action("ManageAssessmentTab_Training", "AssessmentAdmin")"
                                hx-target="closest .htmx-tab-wrapper"
                                hx-swap="innerHTML"
                                hx-include="closest form">
                            <i class="bi bi-search"></i>
                        </button>
                        <button type="button" class="btn btn-secondary" title="Reset Filter"
                                hx-get="@Url.Action("ManageAssessmentTab_Training", "AssessmentAdmin")"
                                hx-target="closest .htmx-tab-wrapper"
                                hx-swap="innerHTML"
                                onclick="document.getElementById('filterSection').value=''; document.getElementById('filterCategory').value=''; document.getElementById('filterUnit').value=''; document.getElementById('filterStatus').value=''; document.getElementById('searchTraining').value='';">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </button>
                    </div>
                </div>
            </div>
        </form>

    </div>
</div>

@* MAM-08: re-fetch Tab2 saat record dihapus (HX-Trigger recordDeleted dari handler delete).
   hx-include filterFormTraining bawa filter + isFiltered=true → isInitialState tetap false (tidak balik empty-state). *@
<div hx-get="@Url.Action("ManageAssessmentTab_Training", "AssessmentAdmin")"
     hx-trigger="recordDeleted from:body"
     hx-include="#filterFormTraining"
     hx-target="closest .htmx-tab-wrapper"
     hx-swap="innerHTML"
     style="display:none;"></div>

<!-- Workers List -->
@if (isInitialState)
{
    <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-funnel fs-1 d-block mb-3"></i>
            <h5>Pilih filter untuk menampilkan data pekerja</h5>
            <p class="small">Silakan pilih opsi pada filter di atas untuk menampilkan daftar pekerja</p>
        </div>
    </div>
}
else if (workers.Count == 0)
{
    <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-search fs-1 d-block mb-3"></i>
            <h5>Tidak ada pekerja ditemukan untuk filter ini.</h5>
            <p class="small">Coba ubah filter pencarian Anda</p>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width:50px">No</th>
                        <th>Nama</th>
                        <th>Nopeg</th>
                        <th>Jabatan</th>
                        <th>@OrgLabels.GetLabel(1)</th>
                        <th>Status Training</th>
                        <th style="width:80px">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int workerRowNum = 1;
                    }
                    @foreach (var worker in workers)
                    {
                        var workerCollapseId = "worker-records-" + worker.WorkerId.Replace("-", "");
                        var initial = string.IsNullOrEmpty(worker.WorkerName) ? "?" : worker.WorkerName.Substring(0, 1).ToUpper();
                        <tr>
                            <td>@(workerRowNum++)</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle bg-primary text-white me-3 d-flex align-items-center justify-content-center fw-bold"
                                         style="width:36px;height:36px;font-size:0.9rem;flex-shrink:0;">
                                        @initial
                                    </div>
                                    <span class="fw-semibold">@worker.WorkerName</span>
                                </div>
                            </td>
                            <td class="text-muted">@worker.NIP</td>
                            <td><span class="badge bg-light text-dark border">@worker.Position</span></td>
                            <td class="text-muted small">@worker.Unit</td>
                            <td>
                                @* MAP-19: selalu render CompletionDisplayText (konsisten, bukan gated "Belum ada") *@
                                <span class="badge bg-info text-dark">@worker.CompletionDisplayText</span>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary toggle-chevron" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#@workerCollapseId"
                                        aria-expanded="false" aria-controls="@workerCollapseId"
                                        title="Lihat Records"
                                        aria-label="Tampilkan/sembunyikan rekam jejak @worker.WorkerName">
                                    <i class="bi bi-chevron-down chevron-icon"></i>
                                </button>
                            </td>
                        </tr>
                        <!-- Expanded row: training records for this worker -->
                        <tr class="collapse" id="@workerCollapseId">
                            <td colspan="7" class="p-0">
                                <div class="p-3 bg-light border-top border-bottom">
                                    @{
                                        // Phase 371 (URG-03): derivasi status online 6-way meniru DeriveUserStatus
                                        // (AssessmentAdminController:2799) + lapis IsPassed->Lulus/Tidak + warna (D-03).
                                        // URUTAN CEK KRITIS: PendingGrading PERTAMA (essay punya CompletedAt terisi bersamaan).
                                        string OnlineLabel(HcPortal.Models.AssessmentSession a)
                                        {
                                            if (a.Status == AssessmentConstants.AssessmentStatus.PendingGrading) return "Menunggu Penilaian";
                                            if (a.CompletedAt != null) return a.IsPassed == true ? "Lulus" : "Tidak Lulus";
                                            if (a.Status == "Cancelled") return "Dibatalkan";
                                            if (a.Status == "Abandoned") return "Abandoned";
                                            if (a.StartedAt != null) return "Sedang Dikerjakan";
                                            return "Belum Mulai"; // Open + Upcoming jatuh ke sini (Pitfall 3)
                                        }
                                        string OnlineClass(string label) => label switch
                                        {
                                            "Lulus" => "bg-success",
                                            "Tidak Lulus" => "bg-danger",
                                            "Menunggu Penilaian" => "bg-warning text-dark",
                                            "Sedang Dikerjakan" => "bg-primary",
                                            "Dibatalkan" => "bg-dark",
                                            "Abandoned" => "bg-dark",
                                            _ => "bg-secondary" // Belum Mulai
                                        };
                                        string ManualStatusClass(string s) => s switch
                                        {
                                            "Passed" => "bg-success",
                                            "Valid" => "bg-primary",
                                            "Failed" => "bg-danger",
                                            "Expired" => "bg-warning text-dark",
                                            AssessmentConstants.AssessmentStatus.PendingGrading => "bg-warning text-dark",
                                            _ => "bg-secondary"
                                        };

                                        var trainingRows = (worker.TrainingRecords ?? new List<HcPortal.Models.TrainingRecord>())
                                            .Select(r => new { Type = "Training", Date = r.Tanggal, Title = r.Judul, Detail = r.Penyelenggara ?? "\u2014", Status = r.Status ?? "", StatusClass = ManualStatusClass(r.Status ?? ""), ValidUntil = r.ValidUntil, Id = r.Id, IsOnline = false, CanViewResult = false });
                                        var assessmentRows = (worker.AssessmentSessions ?? new List<HcPortal.Models.AssessmentSession>())
                                            .Where(a => a.IsManualEntry)
                                            .Select(a => new { Type = "Assessment", Date = a.CompletedAt ?? a.Schedule, Title = a.Title, Detail = a.Score.HasValue ? $"{a.Score} - {(a.IsPassed == true ? "Lulus" : a.IsPassed == false ? "Tidak Lulus" : AssessmentConstants.AssessmentStatus.PendingGrading)}" : "\u2014", Status = a.IsPassed == true ? "Passed" : a.IsPassed == false ? "Failed" : AssessmentConstants.AssessmentStatus.PendingGrading, StatusClass = ManualStatusClass(a.IsPassed == true ? "Passed" : a.IsPassed == false ? "Failed" : AssessmentConstants.AssessmentStatus.PendingGrading), ValidUntil = a.ValidUntil, Id = a.Id, IsOnline = false, CanViewResult = false });
                                        var onlineRows = (worker.AssessmentSessions ?? new List<HcPortal.Models.AssessmentSession>())
                                            .Where(a => !a.IsManualEntry)
                                            .Select(a => new { Type = "AssessmentOnline", Date = a.CompletedAt ?? a.Schedule, Title = a.Title, Detail = (a.CompletedAt != null && a.Score.HasValue) ? $"{a.Score}" : "\u2014", Status = OnlineLabel(a), StatusClass = OnlineClass(OnlineLabel(a)), ValidUntil = a.ValidUntil, Id = a.Id, IsOnline = true, CanViewResult = (a.Status == AssessmentConstants.AssessmentStatus.PendingGrading || a.CompletedAt != null) });
                                        var allRows = trainingRows.Concat(assessmentRows).Concat(onlineRows).OrderByDescending(r => r.Date).ToList();
                                    }
                                    @if (allRows.Count == 0)
                                    {
                                        <div class="text-center py-3 text-muted">
                                            <i class="bi bi-inbox me-2"></i>Belum ada record untuk pekerja ini.
                                            <a href="@Url.Action("AddTraining", "TrainingAdmin")" class="btn btn-sm btn-primary ms-3">
                                                <i class="bi bi-plus-lg me-1"></i>Tambah Training
                                            </a>
                                            <a href="@Url.Action("AddManualAssessment", "TrainingAdmin")" class="btn btn-sm btn-info text-white ms-1">
                                                <i class="bi bi-plus-lg me-1"></i>Tambah Assessment
                                            </a>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <small class="fw-bold text-muted">Input Records — @worker.WorkerName</small>
                                            <a href="@Url.Action("WorkerDetail", "Worker", new { id = worker.WorkerId })"
                                               class="btn btn-sm btn-outline-secondary">
                                                <i class="bi bi-person-lines-fill me-1"></i>Lihat Detail
                                            </a>
                                        </div>
                                        <div class="table-responsive">
                                            <table class="table table-sm table-bordered align-middle mb-0 bg-white">
                                                <thead class="table-secondary">
                                                    <tr>
                                                        <th>Tanggal</th>
                                                        <th>Tipe</th>
                                                        <th>Judul</th>
                                                        <th>Detail</th>
                                                        <th>Status</th>
                                                        <th>Berlaku Sampai</th>
                                                        <th>Aksi</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var row in allRows)
                                                    {
                                                        <tr>
                                                            <td class="small">@row.Date.ToString("dd MMM yyyy")</td>
                                                            <td>
                                                                @if (row.Type == "Training")
                                                                {
                                                                    <span class="badge bg-success">Training Manual</span>
                                                                }
                                                                else if (row.Type == "AssessmentOnline")
                                                                {
                                                                    <span class="badge bg-secondary">Assessment Online</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="badge bg-info text-white">Assessment Manual</span>
                                                                }
                                                            </td>
                                                            <td class="fw-semibold small">@row.Title</td>
                                                            <td class="small text-muted">@row.Detail</td>
                                                            <td>
                                                                <span class="badge @row.StatusClass">@(string.IsNullOrEmpty(row.Status) ? "\u2014" : row.Status)</span>
                                                            </td>
                                                            <td class="small">
                                                                @(row.ValidUntil.HasValue ? row.ValidUntil.Value.ToString("dd MMM yyyy") : "\u2014")
                                                            </td>
                                                            <td>
                                                                <div class="d-flex gap-1">
                                                                    @if (row.IsOnline)
                                                                    {
                                                                        @* Phase 371 (D-02): online read-only. Lihat hasil HANYA Completed/Menunggu Penilaian.
                                                                           NO Edit, NO Hapus (placeholder Phase 367 — extension point cascade delete). *@
                                                                        @if (row.CanViewResult)
                                                                        {
                                                                            <a href="@Url.Action("Results", "CMP", new { id = row.Id })"
                                                                               class="btn btn-sm btn-outline-info" title="Lihat hasil" target="_blank">
                                                                                <i class="bi bi-eye"></i>
                                                                            </a>
                                                                        }
                                                                    }
                                                                    else if (row.Type == "Training")
                                                                    {
                                                                        <a href="@Url.Action("EditTraining", "TrainingAdmin", new { id = row.Id })"
                                                                           class="btn btn-sm btn-outline-primary" title="Edit">
                                                                            <i class="bi bi-pencil"></i>
                                                                        </a>
                                                                        @* MAM-08: hx-post delete (re-swap Tab2 preserve filter); token di body. *@
                                                                        <button type="button" class="btn btn-sm btn-outline-danger" title="Hapus"
                                                                                hx-post="@Url.Action("DeleteTraining", "TrainingAdmin")"
                                                                                hx-vals='@Html.Raw($"{{\"id\": {row.Id}, \"__RequestVerificationToken\": \"{antiToken}\"}}")'
                                                                                hx-confirm="Hapus training record ini?"
                                                                                hx-swap="none">
                                                                            <i class="bi bi-trash"></i>
                                                                        </button>
                                                                    }
                                                                    else
                                                                    {
                                                                        <a href="@Url.Action("EditManualAssessment", "TrainingAdmin", new { id = row.Id })"
                                                                           class="btn btn-sm btn-outline-primary" title="Edit">
                                                                            <i class="bi bi-pencil"></i>
                                                                        </a>
                                                                        @* MAM-08: hx-post delete (re-swap Tab2 preserve filter); token di body. *@
                                                                        <button type="button" class="btn btn-sm btn-outline-danger" title="Hapus"
                                                                                hx-post="@Url.Action("DeleteManualAssessment", "TrainingAdmin")"
                                                                                hx-vals='@Html.Raw($"{{\"id\": {row.Id}, \"__RequestVerificationToken\": \"{antiToken}\"}}")'
                                                                                hx-confirm="Hapus assessment record ini?"
                                                                                hx-swap="none">
                                                                            <i class="bi bi-trash"></i>
                                                                        </button>
                                                                    }
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- MAM-07: Pagination (HTMX, hx-include filterFormTraining untuk preserve filter state) -->
    @if (totalPages > 1)
    {
        <nav aria-label="Training records pagination" class="mt-4">
            <div class="d-flex justify-content-between align-items-center">
                <div class="text-muted small">
                    Menampilkan @((currentPage - 1) * pageSize + 1) - @(Math.Min(currentPage * pageSize, totalCount)) dari @totalCount pekerja
                </div>
                <ul class="pagination pagination-sm mb-0">
                    @{
                        var paginateAction = Url.Action("ManageAssessmentTab_Training", "AssessmentAdmin");
                    }
                    @* First Page *@
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" type="button"
                                hx-get="@paginateAction"
                                hx-vals='{"page":"1"}'
                                hx-include="#filterFormTraining"
                                hx-target="closest .htmx-tab-wrapper"
                                hx-swap="innerHTML"
                                @(currentPage == 1 ? "disabled" : "")>
                            <i class="bi bi-chevron-double-left"></i>
                        </button>
                    </li>
                    @* Previous Page *@
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" type="button"
                                hx-get="@paginateAction"
                                hx-vals='{"page":"@(currentPage - 1)"}'
                                hx-include="#filterFormTraining"
                                hx-target="closest .htmx-tab-wrapper"
                                hx-swap="innerHTML"
                                @(currentPage == 1 ? "disabled" : "")>
                            <i class="bi bi-chevron-left"></i>
                        </button>
                    </li>
                    @* Page Numbers *@
                    @{
                        var startPage = Math.Max(1, currentPage - 2);
                        var endPage = Math.Min(totalPages, currentPage + 2);
                        for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <button class="page-link" type="button"
                                        hx-get="@paginateAction"
                                        hx-vals='{"page":"@i"}'
                                        hx-include="#filterFormTraining"
                                        hx-target="closest .htmx-tab-wrapper"
                                        hx-swap="innerHTML">@i</button>
                            </li>
                        }
                    }
                    @* Next Page *@
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <button class="page-link" type="button"
                                hx-get="@paginateAction"
                                hx-vals='{"page":"@(currentPage + 1)"}'
                                hx-include="#filterFormTraining"
                                hx-target="closest .htmx-tab-wrapper"
                                hx-swap="innerHTML"
                                @(currentPage == totalPages ? "disabled" : "")>
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </li>
                    @* Last Page *@
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <button class="page-link" type="button"
                                hx-get="@paginateAction"
                                hx-vals='{"page":"@totalPages"}'
                                hx-include="#filterFormTraining"
                                hx-target="closest .htmx-tab-wrapper"
                                hx-swap="innerHTML"
                                @(currentPage == totalPages ? "disabled" : "")>
                            <i class="bi bi-chevron-double-right"></i>
                        </button>
                    </li>
                </ul>
            </div>
        </nav>
    }
}
