@using HcPortal.Models
@model PackageQuestion

@{
    var qtype = Model.QuestionType ?? "MultipleChoice";
    var badgeClass = qtype == "MultipleAnswer" ? "bg-primary" : (qtype == "Essay" ? "bg-info text-dark" : "bg-secondary");
    var badgeLabel = qtype == "MultipleAnswer" ? "Multi Jawaban" : (qtype == "Essay" ? "Essay" : "Pilihan Ganda");
}

<div class="card border-0">
    <div class="card-body p-0">
        <!-- Badge tipe soal -->
        <div class="mb-3">
            <span class="badge @badgeClass me-2">@badgeLabel</span>
            <span class="text-muted small">Preview tampilan pekerja</span>
        </div>

        <!-- Teks soal -->
        <p class="fw-medium mb-3">@Model.QuestionText</p>

        @if (qtype == "Essay")
        {
            <!-- Essay: textarea disabled -->
            <div class="mb-2">
                <label class="form-label small text-muted">Tulis jawaban Anda</label>
                <textarea class="form-control" rows="4"
                          placeholder="Tulis jawaban Anda..."
                          maxlength="@Model.MaxCharacters"
                          disabled></textarea>
                <div class="form-text">Batas: @Model.MaxCharacters karakter</div>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Rubrik))
            {
                <div class="alert alert-light border mt-3 py-2">
                    <span class="fw-medium small text-muted">Rubrik (hanya terlihat HC):</span>
                    <p class="mb-0 small mt-1">@Model.Rubrik</p>
                </div>
            }
        }
        else
        {
            <!-- MC / MA: radio or checkbox list -->
            @if (qtype == "MultipleAnswer")
            {
                <p class="small text-info mb-2"><i class="bi bi-info-circle me-1"></i>Pilih semua yang benar</p>
            }
            <div class="list-group">
                @{
                    var letters = new[] { "A", "B", "C", "D" };
                    var options = Model.Options.OrderBy(o => o.Id).ToList();
                }
                @for (int i = 0; i < options.Count; i++)
                {
                    var opt = options[i];
                    var letter = i < letters.Length ? letters[i] : (i + 1).ToString();
                    <label class="list-group-item list-group-item-action d-flex align-items-center gap-3">
                        <input class="form-check-input mt-0"
                               type="@(qtype == "MultipleAnswer" ? "checkbox" : "radio")"
                               disabled
                               style="transform:scale(1.2)" />
                        <span class="fw-medium">@letter.</span>
                        <span>@opt.OptionText</span>
                    </label>
                }
            </div>
        }

        <div class="mt-3 pt-2 border-top d-flex gap-3 text-muted small">
            <span><i class="bi bi-award me-1"></i>Nilai: <strong>@Model.ScoreValue</strong></span>
            @if (!string.IsNullOrWhiteSpace(Model.ElemenTeknis))
            {
                <span><i class="bi bi-tag me-1"></i>@Model.ElemenTeknis</span>
            }
        </div>
    </div>
</div>
