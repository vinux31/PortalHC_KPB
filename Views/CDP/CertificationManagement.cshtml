@model HcPortal.Models.CertificationManagementViewModel
@{
    ViewData["Title"] = "Certification Management";
}

<div class="container-fluid py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-1">
                <i class="bi bi-patch-check me-2 text-success"></i>Certification Management
            </h4>
            <p class="text-muted mb-0">Daftar semua sertifikat pelatihan dan asesmen pekerja</p>
        </div>
        <a asp-controller="CDP" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Kembali ke CDP
        </a>
    </div>

    <!-- Summary Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body">
                    <div class="fs-2 fw-bold text-primary">@Model.TotalCount</div>
                    <div class="small text-muted mt-1">
                        <i class="bi bi-award me-1"></i>Total Sertifikat
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body">
                    <div class="fs-2 fw-bold text-success">@Model.AktifCount</div>
                    <div class="small text-muted mt-1">
                        <i class="bi bi-check-circle me-1"></i>Aktif
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body">
                    <div class="fs-2 fw-bold text-warning">@Model.AkanExpiredCount</div>
                    <div class="small text-muted mt-1">
                        <i class="bi bi-exclamation-triangle me-1"></i>Akan Expired
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body">
                    <div class="fs-2 fw-bold text-danger">@Model.ExpiredCount</div>
                    <div class="small text-muted mt-1">
                        <i class="bi bi-x-circle me-1"></i>Expired
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">No</th>
                            <th>Nama</th>
                            <th class="d-none d-md-table-cell">Bagian</th>
                            <th class="d-none d-md-table-cell">Unit</th>
                            <th>Judul</th>
                            <th class="d-none d-md-table-cell">Kategori</th>
                            <th>Nomor Sertifikat</th>
                            <th>Tgl Terbit</th>
                            <th>Valid Until</th>
                            <th>Tipe</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Rows.Count == 0)
                        {
                            <tr>
                                <td colspan="11" class="text-center text-muted py-4">Belum ada data sertifikat</td>
                            </tr>
                        }
                        else
                        {
                            @for (int i = 0; i < Model.Rows.Count; i++)
                            {
                                var row = Model.Rows[i];
                                var nomor = (Model.CurrentPage - 1) * Model.PageSize + i + 1;
                                <tr>
                                    <td class="ps-3">@nomor</td>
                                    <td>@row.NamaWorker</td>
                                    <td class="d-none d-md-table-cell">@(row.Bagian ?? "-")</td>
                                    <td class="d-none d-md-table-cell">@(row.Unit ?? "-")</td>
                                    <td>@row.Judul</td>
                                    <td class="d-none d-md-table-cell">@(row.Kategori ?? "-")</td>
                                    <td>@(row.NomorSertifikat ?? "-")</td>
                                    <td>@(row.TanggalTerbit?.ToString("dd MMM yyyy") ?? "-")</td>
                                    <td>@(row.ValidUntil?.ToString("dd MMM yyyy") ?? "-")</td>
                                    <td>
                                        @if (row.RecordType == RecordType.Training)
                                        {
                                            <span class="badge bg-primary">Training</span>
                                        }
                                        else
                                        {
                                            <span class="badge" style="background-color: #6f42c1 !important;">Assessment</span>
                                        }
                                    </td>
                                    <td>
                                        @switch (row.Status)
                                        {
                                            case CertificateStatus.Aktif:
                                                <span class="badge bg-success">Aktif</span>
                                                break;
                                            case CertificateStatus.AkanExpired:
                                                <span class="badge bg-warning text-dark">Akan Expired</span>
                                                break;
                                            case CertificateStatus.Expired:
                                                <span class="badge bg-danger">Expired</span>
                                                break;
                                            case CertificateStatus.Permanent:
                                                <span class="badge bg-secondary">Permanent</span>
                                                break;
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4" aria-label="Pagination">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="CertificationManagement" asp-route-page="@(Model.CurrentPage - 1)">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="CertificationManagement" asp-route-page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="CertificationManagement" asp-route-page="@(Model.CurrentPage + 1)">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }

    <!-- Info text -->
    @if (Model.TotalCount > 0)
    {
        var from = (Model.CurrentPage - 1) * Model.PageSize + 1;
        var to = Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount);
        <p class="text-center text-muted small mt-2">
            Menampilkan @from - @to dari @Model.TotalCount sertifikat
        </p>
    }

</div>
