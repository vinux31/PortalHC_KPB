@model HcPortal.Models.CDPDashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .dashboard-loading { opacity: 0.5; pointer-events: none; position: relative; }
    .dashboard-loading::after {
        content: '';
        position: absolute; top: 50%; left: 50%;
        width: 2rem; height: 2rem;
        margin: -1rem 0 0 -1rem;
        border: 3px solid #dee2e6; border-top-color: #0d6efd;
        border-radius: 50%; animation: spin 0.6s linear infinite;
        z-index: 10;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }
    .dashboard-spinner {
        display: none; position: absolute; top: 50%; left: 50%;
        transform: translate(-50%, -50%); z-index: 11;
    }
    .dashboard-loading .dashboard-spinner { display: block; }
</style>

<div class="container-fluid px-4">

    <div class="mb-4">
        <h2><i class="bi bi-speedometer2 me-2"></i>Dashboard</h2>
        <p class="text-muted">@Model.ScopeLabel</p>
    </div>

    <ul class="nav nav-tabs mb-4" id="dashboardTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="proton-tab" data-bs-toggle="tab"
                    data-bs-target="#proton-pane" type="button" role="tab"
                    aria-controls="proton-pane" aria-selected="true">
                <i class="bi bi-graph-up me-1"></i>Coaching Proton
            </button>
        </li>
        @if (Model.AssessmentAnalyticsData != null)
        {
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="analytics-tab" data-bs-toggle="tab"
                        data-bs-target="#analytics-pane" type="button" role="tab"
                        aria-controls="analytics-pane" aria-selected="false">
                    <i class="bi bi-clipboard-data me-1"></i>Assessment Analytics
                </button>
            </li>
        }
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active" id="proton-pane" role="tabpanel" aria-labelledby="proton-tab">
            @if (Model.CoacheeData != null)
            {
                <partial name="Shared/_CoacheeDashboardPartial" model="Model.CoacheeData" />
            }
            else if (Model.ProtonProgressData != null)
            {
                <partial name="Shared/_CoachingProtonPartial" model="Model.ProtonProgressData" />
            }
        </div>
        @if (Model.AssessmentAnalyticsData != null)
        {
            <div class="tab-pane fade" id="analytics-pane" role="tabpanel" aria-labelledby="analytics-tab">
                <partial name="Shared/_AssessmentAnalyticsPartial" model="Model.AssessmentAnalyticsData" />
            </div>
        }
    </div>

</div>

<script>
    // ============================================================
    // Coaching Proton Cascade Filters (Phase 121)
    // ============================================================
    (function () {
        var sectionEl = document.getElementById('protonFilterSection');
        var unitEl = document.getElementById('protonFilterUnit');
        var categoryEl = document.getElementById('protonFilterCategory');
        var trackEl = document.getElementById('protonFilterTrack');
        var resetBtn = document.getElementById('protonFilterReset');
        if (!sectionEl) return; // proton filters not rendered (coachee view)

        var protonAbort = null;
        var allTracks = []; // cached full track list for client-side filtering

        // Cache initial tracks from server
        fetch('/CDP/GetCascadeOptions?section=')
            .then(function (r) { return r.json(); })
            .then(function (data) { allTracks = data.tracks || []; });

        sectionEl.addEventListener('change', function () {
            var section = this.value;
            unitEl.innerHTML = '<option value="">Semua Unit</option>';
            if (section) {
                fetch('/CDP/GetCascadeOptions?section=' + encodeURIComponent(section))
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        (data.units || []).forEach(function (u) {
                            var opt = document.createElement('option');
                            opt.value = u; opt.textContent = u;
                            unitEl.appendChild(opt);
                        });
                    });
            }
            categoryEl.value = '';
            trackEl.value = '';
            refreshProtonContent();
        });

        unitEl.addEventListener('change', function () { refreshProtonContent(); });

        categoryEl.addEventListener('change', function () {
            // Client-side track filtering by category prefix
            var cat = this.value;
            trackEl.innerHTML = '<option value="">Semua</option>';
            var filtered = cat ? allTracks.filter(function (t) { return t.indexOf(cat) === 0; }) : allTracks;
            filtered.forEach(function (t) {
                var opt = document.createElement('option');
                opt.value = t; opt.textContent = t;
                trackEl.appendChild(opt);
            });
            refreshProtonContent();
        });

        trackEl.addEventListener('change', function () { refreshProtonContent(); });

        resetBtn.addEventListener('click', function () {
            if (!sectionEl.disabled) sectionEl.value = '';
            if (!unitEl.disabled) {
                unitEl.innerHTML = '<option value="">Semua Unit</option>';
            }
            categoryEl.value = '';
            trackEl.innerHTML = '<option value="">Semua</option>';
            allTracks.forEach(function (t) {
                var opt = document.createElement('option');
                opt.value = t; opt.textContent = t;
                trackEl.appendChild(opt);
            });
            refreshProtonContent();
        });

        function refreshProtonContent() {
            var container = document.getElementById('proton-content');
            if (!container) return;
            container.classList.add('dashboard-loading');

            var params = new URLSearchParams();
            if (sectionEl.value) params.set('section', sectionEl.value);
            if (unitEl.value) params.set('unit', unitEl.value);
            if (categoryEl.value) params.set('category', categoryEl.value);
            if (trackEl.value) params.set('track', trackEl.value);

            if (protonAbort) protonAbort.abort();
            protonAbort = new AbortController();

            fetch('/CDP/FilterCoachingProton?' + params, { signal: protonAbort.signal })
                .then(function (resp) { return resp.text(); })
                .then(function (html) {
                    container.innerHTML = html;
                    container.querySelectorAll('script').forEach(function (old) {
                        var s = document.createElement('script');
                        s.textContent = old.textContent;
                        old.parentNode.replaceChild(s, old);
                    });
                    container.classList.remove('dashboard-loading');
                })
                .catch(function (e) {
                    if (e.name !== 'AbortError') {
                        console.error(e);
                        container.classList.remove('dashboard-loading');
                    }
                });
        }
    })();

    // ============================================================
    // Assessment Analytics AJAX Filters
    // ============================================================
    (function () {
        var sectionEl = document.getElementById('analyticsFilterSection');
        var unitEl = document.getElementById('analyticsFilterUnit');
        var categoryEl = document.getElementById('analyticsFilterCategory');
        var clearBtn = document.getElementById('analyticsClearBtn');
        var exportBtn = document.getElementById('analyticsExportBtn');
        if (!sectionEl) return; // analytics tab not rendered

        var analyticsAbort = null;

        // Section change: cascade units, reset category, refresh
        sectionEl.addEventListener('change', function () {
            var section = this.value;
            unitEl.innerHTML = '<option value="">Semua Unit</option>';
            if (section) {
                fetch('/CDP/GetCascadeOptions?section=' + encodeURIComponent(section))
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        (data.units || []).forEach(function (u) {
                            var opt = document.createElement('option');
                            opt.value = u;
                            opt.textContent = u;
                            unitEl.appendChild(opt);
                        });
                    });
            }
            refreshAnalyticsContent(1);
        });

        unitEl.addEventListener('change', function () { refreshAnalyticsContent(1); });
        categoryEl.addEventListener('change', function () { refreshAnalyticsContent(1); });

        clearBtn.addEventListener('click', function () {
            sectionEl.value = '';
            unitEl.innerHTML = '<option value="">Semua Unit</option>';
            categoryEl.value = '';
            refreshAnalyticsContent(1);
        });

        function buildParams(page) {
            var params = new URLSearchParams();
            var section = sectionEl.value;
            var unit = unitEl.value;
            var category = categoryEl.value;
            if (section) params.set('section', section);
            if (unit) params.set('unit', unit);
            if (category) params.set('category', category);
            params.set('page', page || 1);
            return params;
        }

        function updateExportLink() {
            if (!exportBtn) return;
            var params = new URLSearchParams();
            var section = sectionEl.value;
            var unit = unitEl.value;
            var category = categoryEl.value;
            if (section) params.set('section', section);
            if (unit) params.set('unit', unit);
            if (category) params.set('category', category);
            var qs = params.toString();
            exportBtn.href = '/CDP/ExportAnalyticsResults' + (qs ? '?' + qs : '');
        }

        function refreshAnalyticsContent(page) {
            page = page || 1;
            var container = document.getElementById('analytics-content');
            if (!container) return;
            container.classList.add('dashboard-loading');
            updateExportLink();

            if (analyticsAbort) analyticsAbort.abort();
            analyticsAbort = new AbortController();

            var params = buildParams(page);
            fetch('/CDP/FilterAssessmentAnalytics?' + params, { signal: analyticsAbort.signal })
                .then(function (resp) { return resp.text(); })
                .then(function (html) {
                    container.innerHTML = html;
                    // Re-execute scripts for charts
                    container.querySelectorAll('script').forEach(function (old) {
                        var s = document.createElement('script');
                        s.textContent = old.textContent;
                        old.parentNode.replaceChild(s, old);
                    });
                    bindAnalyticsPagination();
                    container.classList.remove('dashboard-loading');
                })
                .catch(function (e) {
                    if (e.name !== 'AbortError') {
                        console.error(e);
                        container.classList.remove('dashboard-loading');
                    }
                });
        }

        function bindAnalyticsPagination() {
            var container = document.getElementById('analytics-content');
            if (!container) return;
            container.querySelectorAll('.analytics-page-link').forEach(function (link) {
                link.addEventListener('click', function (e) {
                    e.preventDefault();
                    var page = this.getAttribute('data-page');
                    if (page) refreshAnalyticsContent(parseInt(page));
                });
            });
        }

        // Bind initial pagination
        bindAnalyticsPagination();
        // Set initial export link
        updateExportLink();
    })();

    // ============================================================
    // Tab activation from URL params (legacy support)
    // ============================================================
    (function () {
        var params = new URLSearchParams(window.location.search);
        if (params.get('activeTab') === 'analytics') {
            var analyticsTabEl = document.getElementById('analytics-tab');
            if (analyticsTabEl) {
                var tab = new bootstrap.Tab(analyticsTabEl);
                tab.show();
            }
        }
    })();
</script>
