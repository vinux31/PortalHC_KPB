@model HcPortal.Models.HistoriProtonViewModel
@{
    ViewData["Title"] = "Histori Proton - CDP";
    var lockedSection = ViewBag.LockedSection as string;
    var userLevel = (int)(ViewBag.UserLevel ?? 0);
    var isLocked = userLevel == 4 && !string.IsNullOrEmpty(lockedSection);
    var orgStructureJson = ViewBag.OrgStructureJson as string ?? "{}";
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="CDP">CDP</a></li>
            <li class="breadcrumb-item active">Histori Proton</li>
        </ol>
    </nav>

    <h4 class="mb-4"><i class="bi bi-clock-history me-2"></i>Histori Proton</h4>

    <!-- Search and Filter Bar -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-3">
                    <label class="form-label small text-muted">Cari</label>
                    <input type="text" id="searchInput" class="form-control" placeholder="Cari nama atau NIP...">
                </div>
                <div class="col-12 col-md-auto">
                    <label class="form-label small text-muted">Bagian</label>
                    @if (isLocked)
                    {
                        <select id="filterBagian" class="form-select" disabled>
                            <option value="">Semua Bagian</option>
                            @foreach (var s in Model.AvailableSections)
                            {
                                @if (s == lockedSection)
                                {
                                    <option value="@s" selected>@s</option>
                                }
                                else
                                {
                                    <option value="@s">@s</option>
                                }
                            }
                        </select>
                    }
                    else
                    {
                        <select id="filterBagian" class="form-select">
                            <option value="">Semua Bagian</option>
                            @foreach (var s in Model.AvailableSections)
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    }
                </div>
                <div class="col-12 col-md-auto">
                    <label class="form-label small text-muted">Unit</label>
                    <select id="filterUnit" class="form-select">
                        <option value="">Semua Unit</option>
                    </select>
                </div>
                <div class="col-12 col-md-auto">
                    <label class="form-label small text-muted">Jalur</label>
                    <select id="filterJalur" class="form-select">
                        <option value="">Semua Jalur</option>
                        <option value="Panelman">Panelman</option>
                        <option value="Operator">Operator</option>
                    </select>
                </div>
                <div class="col-12 col-md-auto">
                    <label class="form-label small text-muted">Status</label>
                    <select id="filterStatus" class="form-select">
                        <option value="">Semua Status</option>
                        <option value="Lulus">Lulus</option>
                        <option value="Dalam Proses">Dalam Proses</option>
                        <option value="Belum Mulai">Belum Mulai</option>
                    </select>
                </div>
                <div class="col-12 col-md-auto">
                    <button type="button" id="btnReset" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i>Reset
                    </button>
                </div>
                <div class="col-12 col-md-auto">
                    <label class="form-label small text-muted d-block">&nbsp;</label>
                    <a id="btnExportHistoriProton"
                       href="@Url.Action("ExportHistoriProton", "CDP")"
                       class="btn btn-success">
                        <i class="bi bi-file-earmark-excel me-1"></i>Export Excel
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0" id="workerTable">
                    <thead class="table-light">
                        <tr>
                            <th style="width:50px">No</th>
                            <th>Nama</th>
                            <th>NIP</th>
                            <th>Unit</th>
                            <th>Jalur</th>
                            <th>Progress Proton</th>
                            <th>Status</th>
                            <th style="width:140px">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Workers.Any())
                        {
                            var rowNum = 0;
                            @foreach (var w in Model.Workers)
                            {
                                rowNum++;
                                <tr data-nama="@w.Nama.ToLower()" data-nip="@w.NIP.ToLower()" data-section="@w.Section" data-unit="@w.Unit" data-jalur="@w.Jalur" data-status="@w.Status">
                                    <td class="row-number">@rowNum</td>
                                    <td>@w.Nama</td>
                                    <td>@w.NIP</td>
                                    <td>@w.Unit</td>
                                    <td>@w.Jalur</td>
                                    <td>
                                        <div class="step-indicator">
                                            @{
                                                var t1Class = w.Tahun1Done ? "done" : w.Tahun1InProgress ? "in-progress" : "empty";
                                                var t2Class = w.Tahun2Done ? "done" : w.Tahun2InProgress ? "in-progress" : "empty";
                                                var t3Class = w.Tahun3Done ? "done" : w.Tahun3InProgress ? "in-progress" : "empty";
                                            }
                                            <span class="step-dot @t1Class" title="Tahun 1"></span>
                                            <span class="step-line"></span>
                                            <span class="step-dot @t2Class" title="Tahun 2"></span>
                                            <span class="step-line"></span>
                                            <span class="step-dot @t3Class" title="Tahun 3"></span>
                                        </div>
                                    </td>
                                    <td>
                                        @if (w.Status == "Lulus")
                                        {
                                            <span class="badge bg-success">Lulus</span>
                                        }
                                        else if (w.Status == "Dalam Proses")
                                        {
                                            <span class="badge bg-warning text-dark">Dalam Proses</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Belum Mulai</span>
                                        }
                                    </td>
                                    <td>
                                        <a href="@Url.Action("HistoriProtonDetail", new { userId = w.UserId })" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye me-1"></i>Lihat Riwayat
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <!-- Empty state -->
            <div id="emptyState" class="text-center py-5 d-none">
                <i class="bi bi-funnel fs-1 text-muted"></i>
                <p class="text-muted mt-2">Tidak ada pekerja yang sesuai dengan filter.</p>
            </div>

            <!-- Pagination -->
            <div id="paginationContainer" class="d-flex justify-content-between align-items-center px-3 py-2 border-top">
                <small class="text-muted" id="paginationInfo"></small>
                <nav>
                    <ul class="pagination pagination-sm mb-0" id="paginationControls"></ul>
                </nav>
            </div>
        </div>
    </div>
</div>

<style>
    .step-indicator {
        display: inline-flex;
        align-items: center;
        gap: 0;
    }
    .step-indicator .step-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        display: inline-block;
    }
    .step-indicator .step-dot.done { background-color: var(--bs-success); }
    .step-indicator .step-dot.in-progress { background-color: var(--bs-warning); }
    .step-indicator .step-dot.empty { background-color: var(--bs-gray-300); }
    .step-indicator .step-line {
        width: 16px;
        height: 2px;
        background-color: var(--bs-gray-400);
        display: inline-block;
    }
</style>

@section Scripts {
<script>
(function() {
    // OrganizationStructure cascade data
    var sectionUnits = @Html.Raw(orgStructureJson);

    const ROWS_PER_PAGE = 15;
    const table = document.getElementById('workerTable');
    const tbody = table.querySelector('tbody');
    const allRows = Array.from(tbody.querySelectorAll('tr'));
    const searchInput = document.getElementById('searchInput');
    const filterBagian = document.getElementById('filterBagian');
    const filterUnit = document.getElementById('filterUnit');
    const filterJalur = document.getElementById('filterJalur');
    const filterStatus = document.getElementById('filterStatus');
    const btnReset = document.getElementById('btnReset');
    const emptyState = document.getElementById('emptyState');
    const paginationInfo = document.getElementById('paginationInfo');
    const paginationControls = document.getElementById('paginationControls');
    const paginationContainer = document.getElementById('paginationContainer');

    let currentPage = 1;
    let visibleRows = allRows.slice();

    function updateUnitOptions() {
        var bagianVal = filterBagian.value;
        filterUnit.innerHTML = '<option value="">Semua Unit</option>';

        if (bagianVal && sectionUnits[bagianVal]) {
            sectionUnits[bagianVal].forEach(function(u) {
                var opt = document.createElement('option');
                opt.value = u;
                opt.textContent = u;
                filterUnit.appendChild(opt);
            });
        }
    }

    function applyFilters() {
        const search = searchInput.value.toLowerCase().trim();
        const bagian = filterBagian.value;
        const unit = filterUnit.value;
        const jalur = filterJalur.value;
        const status = filterStatus.value;

        visibleRows = allRows.filter(function(row) {
            if (search && !row.dataset.nama.includes(search) && !row.dataset.nip.includes(search)) return false;
            if (bagian && row.dataset.section !== bagian) return false;
            if (unit && row.dataset.unit !== unit) return false;
            if (jalur && row.dataset.jalur !== jalur) return false;
            if (status && row.dataset.status !== status) return false;
            return true;
        });

        currentPage = 1;
        render();
    }

    function render() {
        // Hide all rows
        allRows.forEach(function(r) { r.style.display = 'none'; });

        var totalPages = Math.max(1, Math.ceil(visibleRows.length / ROWS_PER_PAGE));
        if (currentPage > totalPages) currentPage = totalPages;

        var start = (currentPage - 1) * ROWS_PER_PAGE;
        var end = start + ROWS_PER_PAGE;
        var pageRows = visibleRows.slice(start, end);

        // Show page rows and renumber
        pageRows.forEach(function(r, i) {
            r.style.display = '';
            r.querySelector('.row-number').textContent = start + i + 1;
        });

        // Empty state
        if (visibleRows.length === 0) {
            emptyState.classList.remove('d-none');
            paginationContainer.classList.add('d-none');
        } else {
            emptyState.classList.add('d-none');
            paginationContainer.classList.remove('d-none');
        }

        // Pagination info
        if (visibleRows.length > 0) {
            paginationInfo.textContent = 'Menampilkan ' + (start + 1) + '-' + Math.min(end, visibleRows.length) + ' dari ' + visibleRows.length + ' pekerja';
        }

        // Pagination controls
        paginationControls.innerHTML = '';
        if (totalPages > 1) {
            // Previous
            var prevLi = document.createElement('li');
            prevLi.className = 'page-item' + (currentPage === 1 ? ' disabled' : '');
            prevLi.innerHTML = '<a class="page-link" href="#">&laquo;</a>';
            prevLi.addEventListener('click', function(e) { e.preventDefault(); if (currentPage > 1) { currentPage--; render(); } });
            paginationControls.appendChild(prevLi);

            for (var p = 1; p <= totalPages; p++) {
                (function(page) {
                    var li = document.createElement('li');
                    li.className = 'page-item' + (page === currentPage ? ' active' : '');
                    li.innerHTML = '<a class="page-link" href="#">' + page + '</a>';
                    li.addEventListener('click', function(e) { e.preventDefault(); currentPage = page; render(); });
                    paginationControls.appendChild(li);
                })(p);
            }

            // Next
            var nextLi = document.createElement('li');
            nextLi.className = 'page-item' + (currentPage === totalPages ? ' disabled' : '');
            nextLi.innerHTML = '<a class="page-link" href="#">&raquo;</a>';
            nextLi.addEventListener('click', function(e) { e.preventDefault(); if (currentPage < totalPages) { currentPage++; render(); } });
            paginationControls.appendChild(nextLi);
        }
    }

    searchInput.addEventListener('keyup', applyFilters);
    filterBagian.addEventListener('change', function() { updateUnitOptions(); applyFilters(); });
    filterUnit.addEventListener('change', applyFilters);
    filterJalur.addEventListener('change', applyFilters);
    filterStatus.addEventListener('change', applyFilters);

    btnReset.addEventListener('click', function() {
        searchInput.value = '';
        if (!filterBagian.disabled) {
            filterBagian.value = '';
        }
        filterUnit.value = '';
        filterJalur.value = '';
        filterStatus.value = '';
        updateUnitOptions();
        if (filterBagian.disabled && filterBagian.value) {
            updateUnitOptions();
        }
        applyFilters();
    });

    // Initial setup: if L4 locked, populate units for locked section
    if (filterBagian.disabled && filterBagian.value) {
        updateUnitOptions();
    }

    // Initial render
    render();

    // Export href updater
    function updateExportHref() {
        const search = document.getElementById('searchInput')?.value ?? '';
        const section = document.getElementById('filterBagian')?.value ?? '';
        const unit = document.getElementById('filterUnit')?.value ?? '';
        const jalur = document.getElementById('filterJalur')?.value ?? '';
        const status = document.getElementById('filterStatus')?.value ?? '';
        const params = new URLSearchParams();
        if (search) params.set('search', search);
        if (section) params.set('section', section);
        if (unit) params.set('unit', unit);
        if (jalur) params.set('jalur', jalur);
        if (status) params.set('status', status);
        const base = '@Url.Action("ExportHistoriProton", "CDP")';
        const qs = params.toString();
        document.getElementById('btnExportHistoriProton').href = base + (qs ? '?' + qs : '');
    }

    ['searchInput','filterBagian','filterUnit','filterJalur','filterStatus'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.addEventListener('change', updateExportHref);
        if (el && el.tagName === 'INPUT') el.addEventListener('input', updateExportHref);
    });
})();
</script>
}
