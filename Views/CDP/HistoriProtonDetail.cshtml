@{
    ViewData["Title"] = "Detail Histori Proton - CDP";
}

<div class="container-fluid py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="CDP">CDP</a></li>
            <li class="breadcrumb-item"><a asp-action="HistoriProton" asp-controller="CDP">Histori Proton</a></li>
            <li class="breadcrumb-item active">Detail</li>
        </ol>
    </nav>

    <div class="card shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-clock-history text-muted" style="font-size: 3rem;"></i>
            <h5 class="mt-3 text-muted">Halaman Detail Histori Proton</h5>
            <p class="text-muted">Fitur ini sedang dalam pengembangan (Phase 108).</p>
            <a asp-action="HistoriProton" asp-controller="CDP" class="btn btn-outline-primary mt-2">
                <i class="bi bi-arrow-left"></i> Kembali
            </a>
        </div>
    </div>
</div>
