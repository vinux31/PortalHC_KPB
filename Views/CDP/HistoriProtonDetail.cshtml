@model HcPortal.Models.HistoriProtonDetailViewModel
@{
    ViewData["Title"] = "Detail Histori Proton - CDP";
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="CDP">CDP</a></li>
            <li class="breadcrumb-item"><a asp-action="HistoriProton" asp-controller="CDP">Histori Proton</a></li>
            <li class="breadcrumb-item active">Detail</li>
        </ol>
    </nav>

    <h2 class="mb-4"><i class="bi bi-clock-history me-2"></i>Detail Histori Proton</h2>

    <!-- Worker Header Card -->
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-6">
                            <dl class="mb-0">
                                <dt class="text-muted small">Nama</dt>
                                <dd class="fw-semibold">@Model.Nama</dd>
                                <dt class="text-muted small">NIP</dt>
                                <dd>@Model.NIP</dd>
                                <dt class="text-muted small">Jalur</dt>
                                <dd><span class="badge bg-primary">@Model.Jalur</span></dd>
                            </dl>
                        </div>
                        <div class="col-sm-6">
                            <dl class="mb-0">
                                <dt class="text-muted small">Unit</dt>
                                <dd>@Model.Unit</dd>
                                <dt class="text-muted small">Section</dt>
                                <dd>@Model.Section</dd>
                            </dl>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Timeline — Phase 236 D-12: section separator per tahun -->
            @if (Model.Nodes.Any())
            {
                var groupedByTahun = Model.Nodes.GroupBy(n => n.TahunKe).OrderBy(g => g.First().TahunUrutan);
                @foreach (var tahunGroup in groupedByTahun)
                {
                    <div class="card mb-4 shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="bi bi-calendar3 me-2"></i>@tahunGroup.Key</h5>
                        </div>
                        <div class="card-body p-3">
                            <div class="timeline">
                                @foreach (var node in tahunGroup)
                                {
                                    var statusClass = node.Status == "Lulus" ? "status-lulus" : "status-proses";
                                    var collapseId = $"collapse-{node.AssignmentId}";
                                    <div class="timeline-node @statusClass">
                                        <div class="card shadow-sm">
                                            <div class="card-header bg-white" role="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <span class="fw-semibold">@node.TahunKe</span>
                                                    <div class="d-flex align-items-center gap-2">
                                                        @if (node.Status == "Lulus")
                                                        {
                                                            <span class="badge bg-success">Lulus</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-warning text-dark">Dalam Proses</span>
                                                        }
                                                        <i class="bi bi-chevron-down small"></i>
                                                    </div>
                                                </div>
                                            </div>
                                            <div id="@collapseId" class="collapse">
                                                <div class="card-body">
                                                    <div class="row g-2">
                                                        <div class="col-sm-6">
                                                            <small class="text-muted d-block">Unit</small>
                                                            <span>@node.Unit</span>
                                                        </div>
                                                        <div class="col-sm-6">
                                                            <small class="text-muted d-block">Coach</small>
                                                            <span>@(string.IsNullOrEmpty(node.CoachName) ? "-" : node.CoachName)</span>
                                                        </div>
                                                        @if (node.CompetencyLevel.HasValue)
                                                        {
                                                            <div class="col-sm-6">
                                                                <small class="text-muted d-block">Level Kompetensi</small>
                                                                <span>@node.CompetencyLevel</span>
                                                            </div>
                                                        }
                                                        <div class="col-sm-6">
                                                            <small class="text-muted d-block">Tanggal Mulai</small>
                                                            <span>@node.StartDate.ToString("dd MMM yyyy")</span>
                                                        </div>
                                                        <div class="col-sm-6">
                                                            <small class="text-muted d-block">Tanggal Selesai</small>
                                                            <span>@(node.EndDate.HasValue ? node.EndDate.Value.ToString("dd MMM yyyy") : "-")</span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-muted fs-1"></i>
                    <p class="text-muted mt-2">Tidak ada riwayat Proton.</p>
                </div>
            }

            <!-- Back button -->
            <div class="mt-3">
                <a asp-action="HistoriProton" asp-controller="CDP" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Kembali ke Daftar
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .timeline {
        position: relative;
        padding-left: 40px;
    }
    .timeline-node {
        position: relative;
        margin-bottom: 1.5rem;
    }
    /* Circle indicator */
    .timeline-node::before {
        content: '';
        position: absolute;
        left: -33px;
        top: 18px;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        z-index: 2;
    }
    .timeline-node.status-lulus::before {
        background-color: var(--bs-success);
        border: 2px solid var(--bs-success);
    }
    .timeline-node.status-proses::before {
        background-color: var(--bs-warning);
        border: 2px solid var(--bs-warning);
    }
    /* Connector line segment below each node */
    .timeline-node::after {
        content: '';
        position: absolute;
        left: -27px;
        top: 34px;
        bottom: -1.5rem;
        width: 2px;
        z-index: 1;
    }
    .timeline-node.status-lulus::after {
        background-color: var(--bs-gray-400);
        border: none;
    }
    .timeline-node.status-proses::after {
        background: repeating-linear-gradient(
            to bottom,
            var(--bs-gray-400) 0px,
            var(--bs-gray-400) 4px,
            transparent 4px,
            transparent 8px
        );
    }
    .timeline-node:last-child::after {
        display: none;
    }
    /* Chevron rotation on expand */
    .timeline-node .card-header[aria-expanded="true"] .bi-chevron-down {
        transform: rotate(180deg);
    }
    .timeline-node .card-header .bi-chevron-down {
        transition: transform 0.2s;
    }
</style>
