@{
    ViewData["Title"] = "CDP - Career Development Portal";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h2 class="mb-1">
                <i class="bi bi-person-workspace me-2"></i>Career Development Portal
            </h2>
            <p class="text-muted">Kelola rencana pengembangan individu, coaching, dan pemantauan progres</p>
        </div>
    </div>

    <div class="row g-4">
        <!-- Plan IDP (Silabus) -->
        <div class="col-12 col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex align-items-center mb-3">
                        <div class="icon-box bg-primary bg-opacity-10 text-primary rounded-3 p-3 me-3">
                            <i class="bi bi-file-earmark-pdf fs-3"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">Individual Development Plan</h5>
                            <small class="text-muted">Dokumen Silabus</small>
                        </div>
                    </div>
                    <p class="text-muted mb-3">Lihat dokumen kurikulum dan rencana pengembangan individu Proton</p>
                    <a href="@Url.Action("PlanIdp", "CDP")" class="btn btn-primary w-100 mt-auto">
                        <i class="bi bi-arrow-right-circle me-2"></i>Lihat Dokumen
                    </a>
                </div>
            </div>
        </div>

        <!-- Progress & Tracking -->
        <div class="col-12 col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex align-items-center mb-3">
                        <div class="icon-box bg-warning bg-opacity-10 text-warning rounded-3 p-3 me-3">
                            <i class="bi bi-graph-up-arrow fs-3"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">Proton Coaching</h5>
                            <small class="text-muted">Status IDP</small>
                        </div>
                    </div>
                    <p class="text-muted mb-3">Pantau progres deliverable Proton dan status persetujuan</p>
                    <a href="@Url.Action("CoachingProton", "CDP")" class="btn btn-warning w-100 mt-auto">
                        <i class="bi bi-arrow-right-circle me-2"></i>Proton Coaching
                    </a>
                </div>
            </div>
        </div>

        <!-- Histori Proton -->
        <div class="col-12 col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex align-items-center mb-3">
                        <div class="icon-box bg-info bg-opacity-10 text-info rounded-3 p-3 me-3">
                            <i class="bi bi-clock-history fs-3"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">Proton History</h5>
                            <small class="text-muted">Riwayat Perjalanan</small>
                        </div>
                    </div>
                    <p class="text-muted mb-3">Lihat riwayat perjalanan Proton per pekerja</p>
                    <a href="@Url.Action("HistoriProton", "CDP")" class="btn btn-info w-100 mt-auto">
                        <i class="bi bi-arrow-right-circle me-2"></i>Lihat Riwayat
                    </a>
                </div>
            </div>
        </div>

    </div>

    <hr class="my-5">

    <div class="row g-4">
        <!-- Dashboard Monitoring -->
        <div class="col-12 col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex align-items-center mb-3">
                        <div class="icon-box bg-info bg-opacity-10 text-info rounded-3 p-3 me-3">
                            <i class="bi bi-speedometer2 fs-3"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">Proton Dashboard</h5>
                            <small class="text-muted">Monitoring & Progres</small>
                        </div>
                    </div>
                    <p class="text-muted mb-3">Pantau progres Proton Coaching, tingkat penyelesaian, dan status coachee</p>
                    <a href="@Url.Action("Dashboard", "CDP")" class="btn btn-info w-100 mt-auto">
                        <i class="bi bi-arrow-right-circle me-2"></i>Lihat Dashboard
                    </a>
                </div>
            </div>
        </div>

        <!-- Certification Management -->
        <div class="col-12 col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex align-items-center mb-3">
                        <div class="icon-box bg-success bg-opacity-10 text-success rounded-3 p-3 me-3">
                            <i class="bi bi-patch-check fs-3"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">Certification Management</h5>
                            <small class="text-muted">Kelola Sertifikat</small>
                        </div>
                    </div>
                    <p class="text-muted mb-3">Lihat dan kelola semua sertifikat pelatihan dan asesmen pekerja</p>
                    <a href="@Url.Action("CertificationManagement", "CDP")" class="btn btn-success w-100 mt-auto">
                        <i class="bi bi-arrow-right-circle me-2"></i>Kelola Sertifikat
                    </a>
                </div>
            </div>
        </div>
    </div>


</div>

<style>
    .icon-box {
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card {
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
</style>
