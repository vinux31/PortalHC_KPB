@using HcPortal.Models
@{
    ViewData["Title"] = "Plan IDP";
    var allTracks = ViewBag.AllTracks as List<HcPortal.Models.ProtonTrack> ?? new List<HcPortal.Models.ProtonTrack>();
    var selectedBagian = ViewBag.Bagian as string ?? "";
    var selectedUnit = ViewBag.Unit as string ?? "";
    var selectedTrackId = ViewBag.TrackId as int?;
    var hasFilter = (bool)(ViewBag.HasFilter ?? false);
    var isCoachee = (bool)(ViewBag.IsCoachee ?? false);
    var hasAssignment = (bool)(ViewBag.HasAssignment ?? true);
    var silabusRowsJson = ViewBag.SilabusRowsJson as string ?? "[]";
    var guidanceGroupedJson = ViewBag.GuidanceGroupedJson as string ?? "[]";
    var coacheeBagian = ViewBag.CoacheeBagian as string ?? "";
    var userLevel = (int)(ViewBag.UserLevel ?? 0);
    var lockedSection = ViewBag.LockedSection as string ?? "";
    var isL4Locked = userLevel == 4 && !string.IsNullOrEmpty(lockedSection);
}

<div class="d-flex align-items-start mb-4">
    <div>
        <h2 class="fw-bold text-dark mb-1">
            <i class="bi bi-list-check me-2 text-primary"></i>Plan IDP
        </h2>
        <p class="text-muted">Silabus dan dokumen coaching guidance Proton.</p>
    </div>
</div>

@if (isCoachee && !hasAssignment)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>
        Anda belum memiliki penugasan Proton. Hubungi coach Anda untuk penetapan track.
    </div>
    return;
}

@* Bootstrap 2-tab nav *@
<ul class="nav nav-tabs mb-4" id="planIdpTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="silabus-tab" data-bs-toggle="tab" data-bs-target="#silabusTab"
                type="button" role="tab" aria-controls="silabusTab" aria-selected="true">
            <i class="bi bi-list-ol me-1"></i>Silabus
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="guidance-tab" data-bs-toggle="tab" data-bs-target="#guidanceTab"
                type="button" role="tab" aria-controls="guidanceTab" aria-selected="false">
            <i class="bi bi-file-earmark-text me-1"></i>Coaching Guidance
        </button>
    </li>
</ul>

<div class="tab-content" id="planIdpTabContent">

    @* ====== SILABUS TAB ====== *@
    <div class="tab-pane fade show active" id="silabusTab" role="tabpanel" aria-labelledby="silabus-tab">

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h6 class="fw-bold text-muted mb-3"><i class="bi bi-funnel me-1"></i>Filter Silabus</h6>
                <form method="get" action="@Url.Action("PlanIdp","CDP")" id="silabusFilterForm">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Bagian</label>
                            @if (isCoachee && !string.IsNullOrEmpty(coacheeBagian))
                            {
                                <input type="hidden" name="bagian" value="@coacheeBagian" />
                                <input type="text" class="form-control bg-light" value="@coacheeBagian" disabled />
                            }
                            else if (isL4Locked)
                            {
                                <input type="hidden" name="bagian" value="@lockedSection" />
                                <input type="text" class="form-control bg-light" value="@lockedSection" disabled />
                            }
                            else
                            {
                                <select class="form-select" id="silabusBagian" name="bagian">
                                    <option value="">-- Pilih Bagian --</option>
                                </select>
                            }
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Unit</label>
                            <select class="form-select" id="silabusUnit" name="unit"
                                    disabled="@(string.IsNullOrEmpty(selectedBagian) ? "disabled" : null)">
                                <option value="">-- Pilih Unit --</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Track</label>
                            <select class="form-select" id="silabusTrack" name="trackId">
                                <option value="">-- Pilih Track --</option>
                                @foreach (var track in allTracks)
                                {
                                    <option value="@track.Id" selected="@(selectedTrackId == track.Id ? "selected" : null)">@track.DisplayName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-search me-1"></i>Muat Data
                            </button>
                        </div>
                    </div>
                </form>
                @* Coachee: locked to their Bagian, no reset needed *@
            </div>
        </div>

        <div id="silabusTableContainer"></div>
        <script type="application/json" id="silabusData">@Html.Raw(silabusRowsJson)</script>
        <script type="application/json" id="silabusFilter">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
            bagian = selectedBagian,
            unit = selectedUnit,
            trackId = selectedTrackId,
            hasFilter = hasFilter
        }))</script>

    </div>

    @* ====== COACHING GUIDANCE TAB ====== *@
    <div class="tab-pane fade" id="guidanceTab" role="tabpanel" aria-labelledby="guidance-tab">

        <div id="guidanceAccordionContainer">
            <div class="text-center py-5 text-muted">
                <i class="bi bi-file-earmark-text fs-1 mb-3 d-block opacity-50"></i>
                <p>Memuat data coaching guidance...</p>
            </div>
        </div>
        <script type="application/json" id="guidanceData">@Html.Raw(guidanceGroupedJson)</script>

    </div>

</div>

@section Scripts {
<script>
(function() {
    // ======================================================
    // Cascading bagian→unit dropdown for Silabus filter
    // ======================================================
    const orgStructure = @Html.Raw(ViewBag.SectionUnitsJson ?? "{}");
    const selectedBagianInit = '@Html.Raw(selectedBagian)';
    const selectedUnitInit = '@Html.Raw(selectedUnit)';

    const bagianSelect = document.getElementById('silabusBagian');
    if (bagianSelect) {
        // Populate Bagian dropdown from DB data
        Object.keys(orgStructure).forEach(function(section) {
            const opt = document.createElement('option');
            opt.value = section;
            opt.textContent = section;
            if (section === selectedBagianInit) opt.selected = true;
            bagianSelect.appendChild(opt);
        });

        // Populate Unit dropdown if bagian already selected
        if (selectedBagianInit && orgStructure[selectedBagianInit]) {
            const unitSelect = document.getElementById('silabusUnit');
            unitSelect.disabled = false;
            orgStructure[selectedBagianInit].forEach(function(u) {
                const opt = document.createElement('option');
                opt.value = u;
                opt.textContent = u;
                if (u === selectedUnitInit) opt.selected = true;
                unitSelect.appendChild(opt);
            });
        }

        bagianSelect.addEventListener('change', function() {
            const bagian = this.value;
            const unitSelect = document.getElementById('silabusUnit');
            unitSelect.innerHTML = '<option value="">-- Pilih Unit --</option>';
            if (bagian && orgStructure[bagian]) {
                orgStructure[bagian].forEach(function(u) {
                    const opt = document.createElement('option');
                    opt.value = u;
                    opt.textContent = u;
                    unitSelect.appendChild(opt);
                });
            }
            unitSelect.disabled = !bagian;
        });
    }

    // ======================================================
    // Silabus read-only table renderer
    // ======================================================
    (function() {
        const silabusRows = JSON.parse(document.getElementById('silabusData').textContent || '[]');
        const filterRaw = JSON.parse(document.getElementById('silabusFilter').textContent);
        const hasFilter = filterRaw.hasFilter;
        const currentUnit = filterRaw.unit || '';
        const container = document.getElementById('silabusTableContainer');

        function escHtml(str) {
            if (!str) return '';
            return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        }

        if (!hasFilter) {
            container.innerHTML = '<div class="text-center py-5 text-muted">' +
                '<i class="bi bi-funnel fs-1 mb-3 d-block opacity-50"></i>' +
                '<p>Pilih Bagian, Unit, dan Track kemudian klik <strong>Muat Data</strong> untuk menampilkan silabus.</p>' +
                '</div>';
            return;
        }

        if (silabusRows.length === 0) {
            container.innerHTML = '<div class="alert alert-info">Tidak ada data silabus untuk filter ini.</div>';
            return;
        }

        let html = '<div class="mb-2 text-muted small">Menampilkan silabus untuk: <strong>' + escHtml(currentUnit) + '</strong></div>';
        html += '<div class="table-responsive"><table class="table table-bordered table-sm">' +
            '<thead class="table-light">' +
            '<tr>' +
            '<th>Kompetensi</th>' +
            '<th>Sub Kompetensi</th>' +
            '<th>Target</th>' +
            '<th>Deliverable</th>' +
            '</tr>' +
            '</thead>' +
            '<tbody>';

        let i = 0;
        while (i < silabusRows.length) {
            const row = silabusRows[i];
            // Kompetensi rowspan
            let kompSpan = 1;
            while (i + kompSpan < silabusRows.length && silabusRows[i + kompSpan].Kompetensi === row.Kompetensi) kompSpan++;

            let j = i;
            while (j < i + kompSpan) {
                const subRow = silabusRows[j];
                // SubKompetensi rowspan within kompetensi group
                let subSpan = 1;
                while (j + subSpan < i + kompSpan && silabusRows[j + subSpan].SubKompetensi === subRow.SubKompetensi) subSpan++;

                for (let k = j; k < j + subSpan; k++) {
                    const dRow = silabusRows[k];
                    html += '<tr>';
                    if (k === i) {
                        html += '<td rowspan="' + kompSpan + '" class="align-middle fw-semibold">' + escHtml(dRow.Kompetensi) + '</td>';
                    }
                    if (k === j) {
                        html += '<td rowspan="' + subSpan + '" class="align-middle">' + escHtml(dRow.SubKompetensi) + '</td>';
                    }
                    html += '<td class="align-middle">' + escHtml(dRow.Target || '-') + '</td>';
                    html += '<td>' + escHtml(dRow.Deliverable) + '</td>';
                    html += '</tr>';
                }
                j += subSpan;
            }
            i += kompSpan;
        }

        html += '</tbody></table></div>';
        container.innerHTML = html;
    })();

    // ======================================================
    // Coaching Guidance accordion renderer
    // ======================================================
    (function() {
        const guidanceData = JSON.parse(document.getElementById('guidanceData').textContent || '[]');
        const container = document.getElementById('guidanceAccordionContainer');

        function escHtml(str) {
            if (!str) return '';
            return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        }
        function formatSize(bytes) {
            if (!bytes) return '';
            if (bytes < 1024) return bytes + ' B';
            if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
            return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
        }

        if (!guidanceData || guidanceData.length === 0) {
            container.innerHTML = '<div class="alert alert-info">Belum ada file coaching guidance.</div>';
            return;
        }

        // 4-level accordion: Bagian > Unit > TrackType > TahunKe
        let html = '<div class="accordion" id="guidanceAccordion">';
        guidanceData.forEach(function(bagianGroup, bi) {
            const bagianId = 'bagian_' + bi;
            html += '<div class="accordion-item">' +
                '<h2 class="accordion-header">' +
                '<button class="accordion-button collapsed fw-bold" type="button"' +
                ' data-bs-toggle="collapse" data-bs-target="#' + bagianId + '">' +
                '<i class="bi bi-diagram-3 me-2 text-primary"></i>' + escHtml(bagianGroup.Bagian) +
                '</button>' +
                '</h2>' +
                '<div id="' + bagianId + '" class="accordion-collapse collapse" data-bs-parent="#guidanceAccordion">' +
                '<div class="accordion-body p-0">' +
                '<div class="accordion" id="units_' + bi + '">';

            bagianGroup.Units.forEach(function(unitGroup, ui) {
                const unitId = 'unit_' + bi + '_' + ui;
                html += '<div class="accordion-item border-0 border-bottom">' +
                    '<h2 class="accordion-header">' +
                    '<button class="accordion-button collapsed ps-4" type="button"' +
                    ' data-bs-toggle="collapse" data-bs-target="#' + unitId + '">' +
                    '<i class="bi bi-building me-2 text-secondary"></i>' + escHtml(unitGroup.Unit) +
                    '</button>' +
                    '</h2>' +
                    '<div id="' + unitId + '" class="accordion-collapse collapse" data-bs-parent="#units_' + bi + '">' +
                    '<div class="accordion-body p-0">' +
                    '<div class="accordion" id="types_' + bi + '_' + ui + '">';

                unitGroup.TrackTypes.forEach(function(ttGroup, ti) {
                    const ttId = 'tt_' + bi + '_' + ui + '_' + ti;
                    html += '<div class="accordion-item border-0 border-bottom">' +
                        '<h2 class="accordion-header">' +
                        '<button class="accordion-button collapsed ps-5" type="button"' +
                        ' data-bs-toggle="collapse" data-bs-target="#' + ttId + '">' +
                        '<i class="bi bi-person-badge me-2 text-info"></i>' + escHtml(ttGroup.TrackType) +
                        '</button>' +
                        '</h2>' +
                        '<div id="' + ttId + '" class="accordion-collapse collapse" data-bs-parent="#types_' + bi + '_' + ui + '">' +
                        '<div class="accordion-body p-0">' +
                        '<div class="accordion" id="tahun_' + bi + '_' + ui + '_' + ti + '">';

                    ttGroup.TahunKeList.forEach(function(tkGroup, ki) {
                        const tkId = 'tk_' + bi + '_' + ui + '_' + ti + '_' + ki;
                        html += '<div class="accordion-item border-0 border-bottom">' +
                            '<h2 class="accordion-header">' +
                            '<button class="accordion-button collapsed ps-5 text-dark" type="button"' +
                            ' data-bs-toggle="collapse" data-bs-target="#' + tkId + '">' +
                            '<i class="bi bi-calendar3 me-2 text-muted"></i>' + escHtml(tkGroup.TahunKe) +
                            '<span class="badge bg-secondary ms-2">' + tkGroup.Files.length + ' file</span>' +
                            '</button>' +
                            '</h2>' +
                            '<div id="' + tkId + '" class="accordion-collapse collapse" data-bs-parent="#tahun_' + bi + '_' + ui + '_' + ti + '">' +
                            '<div class="accordion-body ps-5">';

                        if (tkGroup.Files.length === 0) {
                            html += '<p class="text-muted small">Belum ada file coaching guidance.</p>';
                        } else {
                            html += '<div class="list-group list-group-flush">';
                            tkGroup.Files.forEach(function(f) {
                                html += '<div class="list-group-item d-flex align-items-center justify-content-between px-0">' +
                                    '<div>' +
                                    '<i class="bi bi-file-earmark me-2 text-primary"></i>' +
                                    '<span>' + escHtml(f.FileName) + '</span>' +
                                    '<small class="text-muted ms-2">' + formatSize(f.FileSize) + ' &bull; ' + escHtml(f.UploadedAt) + '</small>' +
                                    '</div>' +
                                    '<a href="/CDP/GuidanceDownload?id=' + f.Id + '" class="btn btn-sm btn-outline-primary" title="Download">' +
                                    '<i class="bi bi-download me-1"></i>Download' +
                                    '</a>' +
                                    '</div>';
                            });
                            html += '</div>';
                        }

                        html += '</div></div></div>'; // accordion-body, collapse, accordion-item (tahun)
                    });

                    html += '</div></div></div></div>'; // accordion (tahun), accordion-body, collapse, accordion-item (tracktype)
                });

                html += '</div></div></div></div>'; // accordion (types), accordion-body, collapse, accordion-item (unit)
            });

            html += '</div></div></div></div>'; // accordion (units), accordion-body, collapse, accordion-item (bagian)
        });

        html += '</div>'; // outer accordion
        container.innerHTML = html;
    })();
})();
</script>
}
