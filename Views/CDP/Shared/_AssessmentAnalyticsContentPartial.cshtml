@model HcPortal.Models.AssessmentAnalyticsSubModel

<!-- KPI Summary Cards -->
<div class="row g-4 mb-4">
    <!-- Total Assigned -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm bg-primary text-white h-100 position-relative">
            <div class="card-body">
                <div class="position-absolute end-0 top-0 p-3 opacity-25">
                    <i class="bi bi-clipboard-check" style="font-size: 3rem;"></i>
                </div>
                <h6 class="text-uppercase small mb-2 fw-semibold opacity-75">Total Assigned</h6>
                <h2 class="fw-bold mb-0">@Model.TotalAssigned</h2>
                <small class="opacity-75">All assessment sessions</small>
            </div>
        </div>
    </div>

    <!-- Completed -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm bg-info text-white h-100 position-relative">
            <div class="card-body">
                <div class="position-absolute end-0 top-0 p-3 opacity-25">
                    <i class="bi bi-check-circle-fill" style="font-size: 3rem;"></i>
                </div>
                <h6 class="text-uppercase small mb-2 fw-semibold opacity-75">Completed</h6>
                <h2 class="fw-bold mb-0">@Model.TotalCompleted</h2>
                <small class="opacity-75">Completed assessments</small>
            </div>
        </div>
    </div>

    <!-- Pass Rate -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm bg-success text-white h-100 position-relative">
            <div class="card-body">
                <div class="position-absolute end-0 top-0 p-3 opacity-25">
                    <i class="bi bi-trophy-fill" style="font-size: 3rem;"></i>
                </div>
                <h6 class="text-uppercase small mb-2 fw-semibold opacity-75">Pass Rate</h6>
                <h2 class="fw-bold mb-0">@Model.PassRate.ToString("F1")%</h2>
                <small class="opacity-75">@Model.PassedCount passed</small>
            </div>
        </div>
    </div>

    <!-- Average Score -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm bg-warning text-dark h-100 position-relative">
            <div class="card-body">
                <div class="position-absolute end-0 top-0 p-3 opacity-25">
                    <i class="bi bi-star-fill" style="font-size: 3rem;"></i>
                </div>
                <h6 class="text-uppercase small mb-2 fw-semibold opacity-75">Average Score</h6>
                <h2 class="fw-bold mb-0">@Model.AverageScore.ToString("F1")</h2>
                <small class="opacity-75">Out of 100</small>
            </div>
        </div>
    </div>
</div>

<!-- Performance Analytics Charts -->
<div class="row g-4 mb-4">
    <!-- Pass Rate by Category Chart -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-bar-chart-fill me-2 text-primary"></i>Pass Rate by Category
                </h6>
            </div>
            <div class="card-body">
                <canvas id="analyticsCategoryChart" height="300"></canvas>
            </div>
        </div>
    </div>

    <!-- Score Distribution Chart -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-graph-up me-2 text-info"></i>Score Distribution
                </h6>
            </div>
            <div class="card-body">
                <canvas id="analyticsScoreChart" height="300"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Results Table -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-semibold">Assessment Results</h5>
        <span class="badge bg-primary">@Model.TotalCompleted Total</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="px-4">#</th>
                        <th>Assessment</th>
                        <th>User</th>
                        <th>NIP</th>
                        <th>Section</th>
                        <th>Category</th>
                        <th>Score</th>
                        <th>Pass %</th>
                        <th>Status</th>
                        <th>Completed</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Assessments.Count == 0)
                    {
                        <tr>
                            <td colspan="11" class="text-center py-5">
                                <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                                <p class="text-muted mt-2 mb-0">No results found</p>
                                <small class="text-muted">Try adjusting your filters</small>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @for (int i = 0; i < Model.Assessments.Count; i++)
                        {
                            var item = Model.Assessments[i];
                            var rowNum = (Model.CurrentPage - 1) * Model.PageSize + i + 1;
                            <tr>
                                <td class="px-4">@rowNum</td>
                                <td>
                                    <div class="fw-semibold">@item.Title</div>
                                </td>
                                <td>@item.UserName</td>
                                <td>@(item.UserNIP ?? "-")</td>
                                <td>@(item.UserSection ?? "-")</td>
                                <td>
                                    <span class="badge bg-secondary">@item.Category</span>
                                </td>
                                <td class="fw-bold">@item.Score</td>
                                <td>@item.PassPercentage%</td>
                                <td>
                                    @if (item.IsPassed)
                                    {
                                        <span class="badge bg-success">Pass</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Fail</span>
                                    }
                                </td>
                                <td>
                                    @if (item.CompletedAt.HasValue)
                                    {
                                        @item.CompletedAt.Value.ToString("dd MMM yyyy HH:mm")
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a href="@Url.Action("Results", "CMP", new { id = item.Id })"
                                           class="btn btn-sm btn-outline-info"
                                           title="View results">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="@Url.Action("UserAssessmentHistory", "Admin", new { userId = item.UserId })"
                                           class="btn btn-sm btn-outline-primary"
                                           title="View user history">
                                            <i class="bi bi-person-lines-fill"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination Footer -->
    @if (Model.TotalCompleted > 0)
    {
        <div class="card-footer bg-white border-0 py-3">
            <div class="d-flex justify-content-between align-items-center">
                <div class="text-muted small">
                    Showing @((Model.CurrentPage - 1) * Model.PageSize + 1) to @(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCompleted)) of @Model.TotalCompleted
                </div>

                @if (Model.TotalPages > 1)
                {
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link analytics-page-link" href="#" data-page="1">
                                    <i class="bi bi-chevron-bar-left"></i>
                                </a>
                            </li>
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link analytics-page-link" href="#" data-page="@(Model.CurrentPage - 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>

                            @{
                                var startPage = Math.Max(1, Model.CurrentPage - 2);
                                var endPage = Math.Min(Model.TotalPages, Model.CurrentPage + 2);
                            }
                            @for (int p = startPage; p <= endPage; p++)
                            {
                                <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link analytics-page-link" href="#" data-page="@p">@p</a>
                                </li>
                            }

                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link analytics-page-link" href="#" data-page="@(Model.CurrentPage + 1)">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link analytics-page-link" href="#" data-page="@Model.TotalPages">
                                    <i class="bi bi-chevron-bar-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                }
            </div>
        </div>
    }
</div>

<script>
    // Category Pass Rate Chart
    var analyticsCategoryStats = @Html.Raw(Json.Serialize(Model.CategoryStats));

    if (analyticsCategoryStats && analyticsCategoryStats.length > 0) {
        var ctxCategory = document.getElementById('analyticsCategoryChart').getContext('2d');
        new Chart(ctxCategory, {
            type: 'bar',
            data: {
                labels: analyticsCategoryStats.map(function(c) { return c.categoryName; }),
                datasets: [
                    {
                        label: 'Pass Rate (%)',
                        data: analyticsCategoryStats.map(function(c) { return c.passRate; }),
                        backgroundColor: 'rgba(13, 110, 253, 0.7)',
                        borderColor: 'rgba(13, 110, 253, 1)',
                        borderWidth: 1
                    },
                    {
                        label: 'Avg Score',
                        data: analyticsCategoryStats.map(function(c) { return c.averageScore; }),
                        backgroundColor: 'rgba(25, 135, 84, 0.7)',
                        borderColor: 'rgba(25, 135, 84, 1)',
                        borderWidth: 1
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        max: 100,
                        ticks: {
                            callback: function(value) { return value + '%'; }
                        }
                    }
                },
                plugins: {
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return context.dataset.label + ': ' + context.parsed.y + '%';
                            }
                        }
                    }
                }
            }
        });
    } else {
        var categoryChartEl = document.getElementById('analyticsCategoryChart');
        if (categoryChartEl) {
            categoryChartEl.parentElement.innerHTML =
                '<div class="text-center text-muted py-5"><i class="bi bi-bar-chart text-muted" style="font-size:3rem;"></i><p class="mt-2">No data available for chart</p></div>';
        }
    }

    // Score Distribution Chart
    var analyticsScoreDistribution = @Html.Raw(Json.Serialize(Model.ScoreDistribution));
    var analyticsScoreLabels = ['0-20', '21-40', '41-60', '61-80', '81-100'];
    var analyticsScoreColors = [
        'rgba(220, 53, 69, 0.7)',
        'rgba(255, 193, 7, 0.7)',
        'rgba(13, 202, 240, 0.7)',
        'rgba(13, 110, 253, 0.7)',
        'rgba(25, 135, 84, 0.7)'
    ];

    if (analyticsScoreDistribution && analyticsScoreDistribution.some(function(v) { return v > 0; })) {
        var ctxScore = document.getElementById('analyticsScoreChart').getContext('2d');
        new Chart(ctxScore, {
            type: 'bar',
            data: {
                labels: analyticsScoreLabels,
                datasets: [{
                    label: 'Number of Assessments',
                    data: analyticsScoreDistribution,
                    backgroundColor: analyticsScoreColors,
                    borderColor: analyticsScoreColors.map(function(c) { return c.replace('0.7', '1'); }),
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1, precision: 0 }
                    },
                    x: {
                        title: { display: true, text: 'Score Range' }
                    }
                },
                plugins: {
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return context.parsed.y + ' assessment(s)';
                            }
                        }
                    }
                }
            }
        });
    } else {
        var scoreChartEl = document.getElementById('analyticsScoreChart');
        if (scoreChartEl) {
            scoreChartEl.parentElement.innerHTML =
                '<div class="text-center text-muted py-5"><i class="bi bi-graph-up text-muted" style="font-size:3rem;"></i><p class="mt-2">No data available for chart</p></div>';
        }
    }
</script>
