@model HcPortal.Models.AssessmentAnalyticsSubModel

<!-- Filter Bar (stays outside AJAX content area) -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Section</label>
                <select id="analyticsFilterSection" class="form-select form-select-sm">
                    <option value="">Semua Section</option>
                    @foreach (var sec in Model.AvailableSections)
                    {
                        <option value="@sec" selected="@(Model.FilterSection == sec)">@sec</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Unit</label>
                <select id="analyticsFilterUnit" class="form-select form-select-sm">
                    <option value="">Semua Unit</option>
                    @foreach (var u in Model.AvailableUnits)
                    {
                        <option value="@u" selected="@(Model.FilterUnit == u)">@u</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Kategori</label>
                <select id="analyticsFilterCategory" class="form-select form-select-sm">
                    <option value="">Semua Kategori</option>
                    @foreach (var cat in Model.AvailableCategories)
                    {
                        <option value="@cat" selected="@(Model.FilterCategory == cat)">@cat</option>
                    }
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end gap-2">
                <button id="analyticsClearBtn" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>Clear
                </button>
                <a id="analyticsExportBtn" href="/CDP/ExportAnalyticsResults" class="btn btn-success btn-sm">
                    <i class="bi bi-file-earmark-excel me-1"></i>Export
                </a>
            </div>
        </div>
    </div>
</div>

<!-- AJAX Content Area (replaced on filter change) -->
<div id="analytics-content" class="position-relative">
    <partial name="Shared/_AssessmentAnalyticsContentPartial" model="Model" />
</div>
