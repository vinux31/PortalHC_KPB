@model HcPortal.Models.ProtonProgressSubModel

<!-- Phase 121: Filter Bar (stays static during AJAX refresh) -->
<div class="card border-0 shadow-sm mb-4" id="proton-filters">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-3 col-sm-6">
                <label class="form-label small fw-semibold">Section</label>
                @{
                    var sectionLocked = Model.RoleLevel >= 4;
                    var selectedSection = Model.LockedSection ?? Model.FilterSection;
                }
                <select id="protonFilterSection" class="form-select form-select-sm" @(sectionLocked ? "disabled" : "")>
                    <option value="">Semua Section</option>
                    @foreach (var s in Model.AvailableSections)
                    {
                        if (s == selectedSection)
                        {
                            <option value="@s" selected>@s</option>
                        }
                        else
                        {
                            <option value="@s">@s</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3 col-sm-6">
                <label class="form-label small fw-semibold">Unit</label>
                @{
                    var unitLocked = Model.RoleLevel >= 5;
                    var selectedUnit = Model.LockedUnit ?? Model.FilterUnit;
                }
                <select id="protonFilterUnit" class="form-select form-select-sm" @(unitLocked ? "disabled" : "")>
                    <option value="">Semua Unit</option>
                    @foreach (var u in Model.AvailableUnits)
                    {
                        if (u == selectedUnit)
                        {
                            <option value="@u" selected>@u</option>
                        }
                        else
                        {
                            <option value="@u">@u</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2 col-sm-6">
                <label class="form-label small fw-semibold">Kategori</label>
                <select id="protonFilterCategory" class="form-select form-select-sm">
                    <option value="">Semua</option>
                    @foreach (var c in Model.AvailableCategories)
                    {
                        if (c == Model.FilterCategory)
                        {
                            <option value="@c" selected>@c</option>
                        }
                        else
                        {
                            <option value="@c">@c</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2 col-sm-6">
                <label class="form-label small fw-semibold">Track</label>
                <select id="protonFilterTrack" class="form-select form-select-sm">
                    <option value="">Semua</option>
                    @foreach (var t in Model.AvailableTracks)
                    {
                        if (t == Model.FilterTrack)
                        {
                            <option value="@t" selected>@t</option>
                        }
                        else
                        {
                            <option value="@t">@t</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2 col-sm-6">
                <button type="button" id="protonFilterReset" class="btn btn-outline-secondary btn-sm w-100">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
                </button>
            </div>
        </div>
    </div>
</div>

<!-- AJAX-replaceable content container -->
<div id="proton-content" style="position: relative;">
    <div class="dashboard-spinner"><div class="spinner-border text-primary"></div></div>
    <partial name="Shared/_CoachingProtonContentPartial" model="Model" />
</div>
