@model HcPortal.Models.AnalyticsDashboardViewModel
@{
    ViewData["Title"] = "Analytics Dashboard";
}

<style>
    .dashboard-loading { opacity: 0.5; pointer-events: none; position: relative; }
    .dashboard-loading::after {
        content: '';
        position: absolute; top: 50%; left: 50%;
        width: 2rem; height: 2rem;
        margin: -1rem 0 0 -1rem;
        border: 3px solid #dee2e6; border-top-color: #0d6efd;
        border-radius: 50%; animation: spin 0.6s linear infinite;
        z-index: 10;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }
    .heatmap-high { background-color: rgba(40,167,69,0.35); }
    .heatmap-mid  { background-color: rgba(255,193,7,0.30); }
    .heatmap-low  { background-color: rgba(220,53,69,0.30); }
    canvas { min-height: 280px; }
    select:disabled { opacity: 0.6; cursor: not-allowed; }
    .summary-card { transition: transform 0.15s; }
    .summary-card:hover { transform: translateY(-2px); }
    .skeleton { background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: 4px; height: 1.5rem; }
    @@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
    .sort-header { cursor: pointer; user-select: none; }
    .sort-header:hover { background-color: rgba(0,0,0,0.05); }
    .sort-header::after { content: ' \2195'; opacity: 0.3; font-size: 0.8em; }
    .sort-header.asc::after { content: ' \2191'; opacity: 0.8; }
    .sort-header.desc::after { content: ' \2193'; opacity: 0.8; }
    .insight-card { border-left: 3px solid #0d6efd; background: #f8f9fa; }
    .legend-item { display: inline-flex; align-items: center; gap: 4px; margin-right: 12px; font-size: 0.8rem; }
    .legend-dot { width: 12px; height: 12px; border-radius: 2px; display: inline-block; }
</style>

<!-- Config element for JS URLs -->
<div id="analyticsConfig" class="d-none"
    data-summary-url="@Url.Action("GetAnalyticsSummary", "CMP")"
    data-fail-rate-url="@Url.Action("GetFailRateData", "CMP")"
    data-trend-url="@Url.Action("GetTrendData", "CMP")"
    data-et-breakdown-url="@Url.Action("GetEtBreakdownData", "CMP")"
    data-expiring-soon-url="@Url.Action("GetExpiringSoonData", "CMP")"
    data-drill-down-url="@Url.Action("GetFailRateDrillDown", "CMP")"
    data-export-fail-rate-url="@Url.Action("ExportFailRateExcel", "CMP")"
    data-export-trend-url="@Url.Action("ExportTrendExcel", "CMP")"
    data-export-et-breakdown-url="@Url.Action("ExportEtBreakdownExcel", "CMP")"
    data-cascade-units-url="@Url.Action("GetAnalyticsCascadeUnits", "CMP")"
    data-cascade-sub-kategori-url="@Url.Action("GetAnalyticsCascadeSubKategori", "CMP")"
    data-assessment-list-url="@Url.Action("GetPrePostAssessmentList", "CMP")"
    data-item-analysis-url="@Url.Action("GetItemAnalysisData", "CMP")"
    data-gain-score-url="@Url.Action("GetGainScoreData", "CMP")"
    data-export-item-analysis-url="@Url.Action("ExportItemAnalysisExcel", "CMP")"
    data-export-gain-score-url="@Url.Action("ExportGainScoreExcel", "CMP")">
</div>

<div class="container-fluid py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb small">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Beranda</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "CMP")">CMP</a></li>
            <li class="breadcrumb-item active">Analytics Dashboard</li>
        </ol>
    </nav>
    <div class="row mb-4">
        <div class="col">
            <h4 class="fw-semibold mb-1"><i class="bi bi-graph-up me-2"></i>Analytics Dashboard</h4>
            <p class="text-muted">Visualisasi data assessment dan sertifikat</p>
        </div>
    </div>

    <!-- Filter Bar -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <!-- Mobile filter toggle -->
            <div class="d-md-none mb-2">
                <button class="btn btn-outline-secondary btn-sm w-100" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapseBody">
                    <i class="bi bi-funnel me-1"></i>Filter
                </button>
            </div>
            <div class="collapse show d-md-block" id="filterCollapseBody">
                <div class="row g-3 align-items-end">
                    <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                        <label for="filterBagian" class="form-label form-label-sm mb-1">Bagian</label>
                        <select id="filterBagian" class="form-select form-select-sm">
                            <option value="">Semua Bagian</option>
                            @foreach (var s in Model.Sections)
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>
                    <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                        <label for="filterUnit" class="form-label form-label-sm mb-1">Unit</label>
                        <select id="filterUnit" class="form-select form-select-sm" disabled>
                            <option value="">Semua Unit</option>
                        </select>
                    </div>
                    <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                        <label for="filterKategori" class="form-label form-label-sm mb-1">Kategori</label>
                        <select id="filterKategori" class="form-select form-select-sm">
                            <option value="">Semua Kategori</option>
                            @foreach (var c in Model.Categories)
                            {
                                <option value="@c">@c</option>
                            }
                        </select>
                    </div>
                    <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                        <label for="filterSubKategori" class="form-label form-label-sm mb-1">SubKategori</label>
                        <select id="filterSubKategori" class="form-select form-select-sm" disabled>
                            <option value="">Semua SubKategori</option>
                        </select>
                    </div>
                    <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                        <label for="filterStart" class="form-label form-label-sm mb-1">Dari</label>
                        <input type="date" id="filterStart" class="form-control form-control-sm">
                    </div>
                    <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                        <label for="filterEnd" class="form-label form-label-sm mb-1">s/d</label>
                        <input type="date" id="filterEnd" class="form-control form-control-sm">
                    </div>
                    <div class="col-md-3" id="filterAssessmentGroup" style="display:none;">
                        <label class="form-label form-label-sm mb-1">Pilih Assessment</label>
                        <select class="form-select form-select-sm" id="filterAssessment">
                            <option value="">— Pilih assessment —</option>
                        </select>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col">
                        <button id="btnApply" class="btn btn-primary btn-sm me-2">
                            <i class="bi bi-funnel me-1"></i>Terapkan Filter
                        </button>
                        <button id="btnReset" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row g-3 mb-4" id="summaryCards">
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm summary-card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <div class="rounded-circle bg-primary bg-opacity-10 p-2 me-2">
                            <i class="bi bi-clipboard-data text-primary"></i>
                        </div>
                        <small class="text-muted">Total Sesi</small>
                    </div>
                    <h3 class="mb-0 fw-bold" id="summaryTotalSessions"><div class="skeleton" style="width:60px;">&nbsp;</div></h3>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm summary-card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <div class="rounded-circle bg-success bg-opacity-10 p-2 me-2">
                            <i class="bi bi-check-circle text-success"></i>
                        </div>
                        <small class="text-muted">Pass Rate</small>
                    </div>
                    <h3 class="mb-0 fw-bold" id="summaryPassRate"><div class="skeleton" style="width:60px;">&nbsp;</div></h3>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm summary-card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <div class="rounded-circle bg-danger bg-opacity-10 p-2 me-2">
                            <i class="bi bi-shield-exclamation text-danger"></i>
                        </div>
                        <small class="text-muted">Sertifikat Expired</small>
                    </div>
                    <h3 class="mb-0 fw-bold" id="summaryExpiring"><div class="skeleton" style="width:60px;">&nbsp;</div></h3>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm summary-card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <div class="rounded-circle bg-info bg-opacity-10 p-2 me-2">
                            <i class="bi bi-arrow-up-right text-info"></i>
                        </div>
                        <small class="text-muted">Avg Gain Score</small>
                    </div>
                    <h3 class="mb-0 fw-bold" id="summaryAvgGain"><div class="skeleton" style="width:60px;">&nbsp;</div></h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Nav Tabs -->
    <ul class="nav nav-tabs mb-3" id="analyticsTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <a class="nav-link active" id="tab-failrate" data-bs-toggle="tab" href="#tabFailRate" role="tab">Fail Rate</a>
        </li>
        <li class="nav-item" role="presentation">
            <a class="nav-link" id="tab-trend" data-bs-toggle="tab" href="#tabTrend" role="tab">Trend</a>
        </li>
        <li class="nav-item" role="presentation">
            <a class="nav-link" id="tab-et" data-bs-toggle="tab" href="#tabEtBreakdown" role="tab">Skor Elemen Teknis</a>
        </li>
        <li class="nav-item" role="presentation">
            <a class="nav-link" id="tab-expiring" data-bs-toggle="tab" href="#tabExpiring" role="tab">Sertifikat Expired</a>
        </li>
        <li class="nav-item" role="presentation">
            <a class="nav-link" id="tab-itemanalysis" data-bs-toggle="tab" href="#tabItemAnalysis" role="tab">Item Analysis</a>
        </li>
        <li class="nav-item" role="presentation">
            <a class="nav-link" id="tab-gainscore" data-bs-toggle="tab" href="#tabGainScore" role="tab">Gain Score Report</a>
        </li>
    </ul>

    <div class="tab-content" id="analyticsTabContent">

        <!-- Tab 1: Fail Rate Assessment -->
        <div class="tab-pane fade show active" id="tabFailRate" role="tabpanel">
            <div class="row g-4">
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-transparent border-bottom-0 pb-0">
                            <div class="d-flex align-items-center justify-content-between">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-bar-chart-fill text-danger fs-4 me-2"></i>
                                    <div>
                                        <h6 class="mb-0 fw-semibold">Fail Rate Assessment</h6>
                                        <small class="text-muted">Per section dan kategori — klik bar untuk detail</small>
                                    </div>
                                </div>
                                <button class="btn btn-outline-success btn-sm" onclick="exportFailRate()">
                                    <i class="bi bi-file-earmark-excel me-1"></i>Export Excel
                                </button>
                            </div>
                        </div>
                        <div class="card-body">
                            <canvas id="failRateChart" role="img" aria-label="Grafik fail rate assessment"></canvas>
                            <div id="failRateEmpty" class="text-center text-muted py-5" style="display:none;">
                                <i class="bi bi-bar-chart fs-1 d-block mb-2"></i>
                                Belum ada data<br>
                                <small>Tidak ada data assessment untuk filter yang dipilih. Coba ubah periode atau hapus filter.</small>
                            </div>
                            <!-- Color legend -->
                            <div id="failRateLegend" class="mt-2 text-center" style="display:none;">
                                <span class="legend-item"><span class="legend-dot" style="background:#28a745;"></span> &lt;30% (Baik)</span>
                                <span class="legend-item"><span class="legend-dot" style="background:#ffc107;"></span> 30-60% (Perlu Perhatian)</span>
                                <span class="legend-item"><span class="legend-dot" style="background:#dc3545;"></span> &gt;60% (Kritis)</span>
                            </div>
                            <!-- Insight panel -->
                            <div id="failRateInsight" class="mt-3" style="display:none;">
                                <div class="card insight-card border-0">
                                    <div class="card-body py-2 px-3">
                                        <small class="text-muted">Ringkasan</small>
                                        <div id="failRateInsightText" class="small fw-semibold"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab 2: Trend Assessment -->
        <div class="tab-pane fade" id="tabTrend" role="tabpanel">
            <div class="row g-4">
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-transparent border-bottom-0 pb-0">
                            <div class="d-flex align-items-center justify-content-between">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-graph-up-arrow text-primary fs-4 me-2"></i>
                                    <div>
                                        <h6 class="mb-0 fw-semibold">Trend Assessment</h6>
                                        <small class="text-muted">Pass / Fail per bulan</small>
                                    </div>
                                </div>
                                <button class="btn btn-outline-success btn-sm" onclick="exportTrend()">
                                    <i class="bi bi-file-earmark-excel me-1"></i>Export Excel
                                </button>
                            </div>
                        </div>
                        <div class="card-body">
                            <canvas id="trendChart" role="img" aria-label="Grafik trend assessment pass fail per bulan"></canvas>
                            <div id="trendEmpty" class="text-center text-muted py-5" style="display:none;">
                                <i class="bi bi-graph-up fs-1 d-block mb-2"></i>
                                Belum ada data<br>
                                <small>Tidak ada data trend untuk filter yang dipilih. Coba ubah periode atau hapus filter.</small>
                            </div>
                            <!-- Trend insight -->
                            <div id="trendInsight" class="row g-3 mt-3" style="display:none;">
                                <div class="col-md-4">
                                    <div class="card insight-card border-0">
                                        <div class="card-body py-2 px-3 text-center">
                                            <small class="text-muted">Bulan Terbaik</small>
                                            <div id="trendBestMonth" class="fw-bold text-success">-</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="card insight-card border-0" style="border-left-color:#dc3545!important;">
                                        <div class="card-body py-2 px-3 text-center">
                                            <small class="text-muted">Bulan Terburuk</small>
                                            <div id="trendWorstMonth" class="fw-bold text-danger">-</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="card insight-card border-0" style="border-left-color:#6f42c1!important;">
                                        <div class="card-body py-2 px-3 text-center">
                                            <small class="text-muted">Trend</small>
                                            <div id="trendDirection" class="fw-bold">-</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-4">
                                <h6 class="fw-semibold">Rata-rata Gain Score per Bulan</h6>
                                <div id="gainScoreSinglePoint" style="display:none;" class="text-center py-4">
                                    <small class="text-muted d-block">Gain Score</small>
                                    <span class="display-4 fw-bold text-primary" id="gainScoreSingleValue">-</span>
                                    <small class="text-muted d-block" id="gainScoreSingleLabel">-</small>
                                </div>
                                <canvas id="gainScoreTrendChart" height="200"></canvas>
                                <div class="text-center text-muted py-3" id="gainTrendEmpty" style="display:none;">
                                    <small>Belum ada data gain score untuk periode ini.</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab 3: Skor Elemen Teknis -->
        <div class="tab-pane fade" id="tabEtBreakdown" role="tabpanel">
            <div class="row g-4">
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-transparent border-bottom-0 pb-0">
                            <div class="d-flex align-items-center justify-content-between">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-grid-3x3-gap-fill text-warning fs-4 me-2"></i>
                                    <div>
                                        <h6 class="mb-0 fw-semibold">Skor Elemen Teknis</h6>
                                        <small class="text-muted">Rata-rata skor per kategori assessment</small>
                                    </div>
                                </div>
                                <button class="btn btn-outline-success btn-sm" onclick="exportEtBreakdown()">
                                    <i class="bi bi-file-earmark-excel me-1"></i>Export Excel
                                </button>
                            </div>
                        </div>
                        <div class="card-body">
                            <!-- ET Insight cards -->
                            <div id="etInsight" class="row g-3 mb-3" style="display:none;">
                                <div class="col-md-4">
                                    <div class="card insight-card border-0">
                                        <div class="card-body py-2 px-3 text-center">
                                            <small class="text-muted">Elemen Terkuat</small>
                                            <div id="etBestElement" class="fw-bold text-success small">-</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="card insight-card border-0" style="border-left-color:#dc3545!important;">
                                        <div class="card-body py-2 px-3 text-center">
                                            <small class="text-muted">Elemen Terlemah</small>
                                            <div id="etWorstElement" class="fw-bold text-danger small">-</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="card insight-card border-0" style="border-left-color:#ffc107!important;">
                                        <div class="card-body py-2 px-3 text-center">
                                            <small class="text-muted">Ringkasan</small>
                                            <div id="etSummaryText" class="fw-bold small">-</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div id="etTableContainer" class="table-responsive"></div>
                            <div id="etEmpty" class="text-center text-muted py-5" style="display:none;">
                                <i class="bi bi-grid-3x3-gap fs-1 d-block mb-2"></i>
                                Belum ada data<br>
                                <small>Tidak ada data skor elemen teknis untuk filter yang dipilih.</small>
                            </div>
                            <div id="etLegend" class="mt-2" style="display:none;">
                                <span class="legend-item"><span class="legend-dot" style="background:rgba(40,167,69,0.35);"></span> &ge;80% (Baik)</span>
                                <span class="legend-item"><span class="legend-dot" style="background:rgba(255,193,7,0.30);"></span> 60-79% (Cukup)</span>
                                <span class="legend-item"><span class="legend-dot" style="background:rgba(220,53,69,0.30);"></span> &lt;60% (Kurang)</span>
                            </div>
                            <small class="text-muted d-block mt-2">Data hanya tersedia untuk assessment dengan paket soal</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab 4: Sertifikat Akan Expired -->
        <div class="tab-pane fade" id="tabExpiring" role="tabpanel">
            <div class="row g-4">
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-transparent border-bottom-0 pb-0">
                            <div class="d-flex align-items-center justify-content-between">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-shield-exclamation text-danger fs-4 me-2"></i>
                                    <div>
                                        <h6 class="mb-0 fw-semibold">Sertifikat Akan Expired</h6>
                                        <small class="text-muted">Dalam beberapa hari ke depan</small>
                                    </div>
                                </div>
                                <select id="expiringThreshold" class="form-select form-select-sm" style="width:auto;">
                                    <option value="30">30 hari</option>
                                    <option value="60">60 hari</option>
                                    <option value="90">90 hari</option>
                                </select>
                            </div>
                        </div>
                        <div class="card-body">
                            <div id="expiringAlert" style="display:none;"></div>
                            <div id="expiringTableContainer" class="table-responsive"></div>
                            <div id="expiringEmpty" class="text-center text-muted py-5" style="display:none;">
                                <i class="bi bi-check-circle-fill text-success fs-1 d-block mb-2"></i>
                                <h6 class="text-success">Semua sertifikat masih berlaku</h6>
                                <small>Tidak ada sertifikat yang akan expired dalam periode yang dipilih.</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab 5: Item Analysis -->
        <div class="tab-pane fade" id="tabItemAnalysis" role="tabpanel">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h6 class="fw-semibold mb-0">Item Analysis</h6>
                    <button class="btn btn-outline-success btn-sm" onclick="exportItemAnalysis()">
                        <i class="bi bi-file-earmark-excel me-1"></i>Export Item Analysis
                    </button>
                </div>
                <div class="card-body" id="itemAnalysisContainer">
                    <div class="text-center text-muted py-5" id="itemAnalysisEmpty">
                        <i class="bi bi-hand-index fs-1 d-block mb-2 text-primary"></i>
                        <h6>Pilih assessment terlebih dahulu</h6>
                        <p><i class="bi bi-arrow-up"></i> Gunakan dropdown <strong>"Pilih Assessment"</strong> di atas, lalu klik <strong>Terapkan Filter</strong>.</p>
                    </div>
                    <!-- Insight summary -->
                    <div id="itemAnalysisInsight" class="alert alert-info py-2 small" style="display:none;"></div>
                    <div id="itemAnalysisContent" style="display:none;">
                        <div class="mb-2" id="itemAnalysisWarning" style="display:none;">
                            <span class="badge bg-warning text-dark">Data belum cukup (N&lt;30)</span>
                            <small class="text-muted ms-2">Nilai discrimination index mungkin tidak reliabel.</small>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-sm table-hover" id="itemAnalysisTable">
                                <thead class="table-light">
                                    <tr>
                                        <th>No</th>
                                        <th>Soal</th>
                                        <th>Tingkat Kesulitan (p-value)</th>
                                        <th>Kategori</th>
                                        <th>Indeks Diskriminasi</th>
                                        <th>N Responden</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                        <div id="distractorDetails"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab 6: Gain Score Report -->
        <div class="tab-pane fade" id="tabGainScore" role="tabpanel">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-3">
                        <h6 class="fw-semibold mb-0">Gain Score Report</h6>
                        <div class="btn-group btn-group-sm" role="group">
                            <input type="radio" class="btn-check" name="gainView" id="gainViewWorker" checked autocomplete="off">
                            <label class="btn btn-outline-primary" for="gainViewWorker" onclick="toggleGainView('worker')">Per Pekerja</label>
                            <input type="radio" class="btn-check" name="gainView" id="gainViewElemen" autocomplete="off">
                            <label class="btn btn-outline-primary" for="gainViewElemen" onclick="toggleGainView('elemen')">Per Elemen Kompetensi</label>
                        </div>
                    </div>
                    <button class="btn btn-outline-success btn-sm" onclick="exportGainScore()">
                        <i class="bi bi-file-earmark-excel me-1"></i>Export Gain Score
                    </button>
                </div>
                <div class="card-body" id="gainScoreContainer">
                    <div class="text-center text-muted py-5" id="gainScoreEmpty">
                        <i class="bi bi-hand-index fs-1 d-block mb-2 text-primary"></i>
                        <h6>Pilih assessment terlebih dahulu</h6>
                        <p><i class="bi bi-arrow-up"></i> Gunakan dropdown <strong>"Pilih Assessment"</strong> di atas, lalu klik <strong>Terapkan Filter</strong>.</p>
                    </div>
                    <!-- Insight summary -->
                    <div id="gainScoreInsight" class="alert alert-info py-2 small" style="display:none;"></div>
                    <div id="gainScoreContent" style="display:none;">
                        <div id="gainWorkerView">
                            <div class="table-responsive">
                                <table class="table table-sm table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Nama Pekerja</th>
                                            <th>NIP</th>
                                            <th>Pre Score</th>
                                            <th>Post Score</th>
                                            <th class="fw-semibold">Gain Score</th>
                                        </tr>
                                    </thead>
                                    <tbody id="gainWorkerBody"></tbody>
                                </table>
                            </div>
                        </div>
                        <div id="gainElemenView" style="display:none;">
                            <div class="table-responsive">
                                <table class="table table-sm table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Elemen Kompetensi</th>
                                            <th>Avg Pre</th>
                                            <th>Avg Post</th>
                                            <th class="fw-semibold">Avg Gain</th>
                                        </tr>
                                    </thead>
                                    <tbody id="gainElemenBody"></tbody>
                                </table>
                            </div>
                        </div>
                        <div class="mt-4">
                            <h6 class="fw-semibold">Perbandingan Antar Kelompok (Bagian)</h6>
                            <div class="table-responsive">
                                <table class="table table-sm table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Bagian</th>
                                            <th>Jumlah Pekerja</th>
                                            <th>Avg Pre Score</th>
                                            <th>Avg Post Score</th>
                                            <th class="fw-semibold">Avg Gain Score</th>
                                        </tr>
                                    </thead>
                                    <tbody id="groupComparisonBody"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div><!-- /.tab-content -->
</div><!-- /.container-fluid -->

<!-- Drill-down Modal -->
<div class="modal fade" id="drillDownModal" tabindex="-1" aria-labelledby="drillDownModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title fw-semibold" id="drillDownModalLabel">Detail Assessment</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
            </div>
            <div class="modal-body">
                <div id="drillDownBody">
                    <div class="text-center py-3"><div class="spinner-border spinner-border-sm text-primary"></div> Memuat...</div>
                </div>
            </div>
        </div>
    </div>
</div>

