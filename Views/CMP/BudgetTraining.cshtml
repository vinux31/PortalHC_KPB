@model HcPortal.Models.BudgetTrainingViewModel
@{
    ViewData["Title"] = "Budget Training & Assessment";
    // Helper for sort links
    string SortUrl(string field)
    {
        var newDir = (Model.SortBy == field && Model.SortDir == "asc") ? "desc" : "asc";
        return Url.Action("BudgetTraining", new { tahun = Model.FilterTahun, type = Model.FilterType, kategori = Model.FilterKategori, search = Model.Search, sortBy = field, sortDir = newDir, pageSize = Model.PageSize });
    }
    string SortIcon(string field)
    {
        if (Model.SortBy != field) return "bi-arrow-down-up text-muted opacity-50";
        return Model.SortDir == "asc" ? "bi-arrow-up" : "bi-arrow-down";
    }
    string PageUrl(int pg)
    {
        return Url.Action("BudgetTraining", new { tahun = Model.FilterTahun, type = Model.FilterType, kategori = Model.FilterKategori, search = Model.Search, sortBy = Model.SortBy, sortDir = Model.SortDir, page = pg, pageSize = Model.PageSize });
    }
}

<div class="container-fluid py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-3">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "CMP")">CMP</a></li>
            <li class="breadcrumb-item active">Budget Training</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="bi bi-wallet2 me-2"></i>Budget Training & Assessment</h2>
            <p class="text-muted mb-0">Kelola anggaran pelatihan dan asesmen</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-2"></i>@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <!-- Tabs -->
    <ul class="nav nav-tabs mb-4" id="budgetTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="data-tab" data-bs-toggle="tab" data-bs-target="#tab-data" type="button" role="tab" aria-controls="tab-data" aria-selected="true">
                <i class="bi bi-table me-1"></i>Data Budget
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="ringkasan-tab" data-bs-toggle="tab" data-bs-target="#tab-ringkasan" type="button" role="tab" aria-controls="tab-ringkasan" aria-selected="false">
                <i class="bi bi-bar-chart me-1"></i>Ringkasan
            </button>
        </li>
    </ul>

    <div class="tab-content" id="budgetTabContent">
        <!-- Tab Data Budget -->
        <div class="tab-pane fade show active" id="tab-data" role="tabpanel" aria-labelledby="data-tab">
            <!-- Filters + Action Buttons -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <form method="get" class="d-flex justify-content-between align-items-end flex-wrap gap-2">
                        <div class="d-flex gap-2 align-items-end flex-wrap">
                            <div>
                                <label class="form-label small mb-1">Tahun</label>
                                <select name="tahun" class="form-select form-select-sm">
                                    <option value="">Semua</option>
                                    @foreach (var t in Model.AvailableTahun)
                                    {
                                        <option value="@t" selected="@(Model.FilterTahun == t)">@t</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <label class="form-label small mb-1">Type</label>
                                <select name="type" class="form-select form-select-sm">
                                    <option value="">Semua</option>
                                    <option value="Training" selected="@(Model.FilterType == "Training")">Training</option>
                                    <option value="Assessment" selected="@(Model.FilterType == "Assessment")">Assessment</option>
                                </select>
                            </div>
                            <div>
                                <label class="form-label small mb-1">Kategori</label>
                                <select name="kategori" class="form-select form-select-sm">
                                    <option value="">Semua</option>
                                    @foreach (var k in Model.AvailableKategori)
                                    {
                                        <option value="@k" selected="@(Model.FilterKategori == k)">@k</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <label class="form-label small mb-1">Cari</label>
                                <input type="text" name="search" value="@Model.Search" class="form-control form-control-sm" placeholder="Judul / Vendor..." />
                            </div>
                            <div>
                                <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-funnel me-1"></i>Filter</button>
                                <a href="@Url.Action("BudgetTraining")" class="btn btn-sm btn-outline-secondary">Reset</a>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <a href="@Url.Action("BudgetTrainingExport", "CMP", new { tahun = Model.FilterTahun })" class="btn btn-sm btn-outline-success">
                                <i class="bi bi-download me-1"></i>Export
                            </a>
                            <a href="@Url.Action("BudgetTrainingImport", "CMP")" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-upload me-1"></i>Import
                            </a>
                            <a href="@Url.Action("BudgetTrainingCreate", "CMP")" class="btn btn-sm btn-primary">
                                <i class="bi bi-plus-lg me-1"></i>Tambah
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Bulk Action Bar (hidden by default) -->
            <div id="bulkBar" class="card border-0 shadow-sm mb-3 d-none">
                <div class="card-body py-2 d-flex align-items-center gap-3">
                    <span class="fw-semibold"><span id="bulkCount">0</span> item dipilih</span>
                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="bulkDeleteSelected()"><i class="bi bi-trash me-1"></i>Hapus Terpilih</button>
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="openBulkUpdateModal()"><i class="bi bi-pencil-square me-1"></i>Update Realisasi Terpilih</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="clearSelection()">Batal</button>
                </div>
            </div>

            <!-- Table -->
            <div class="card border-0 shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:36px"><input type="checkbox" class="form-check-input" id="selectAll" title="Pilih Semua" /></th>
                                <th>No</th>
                                <th>Type</th>
                                <th><a href="@SortUrl("judul")" class="text-decoration-none text-dark">Judul <i class="bi @SortIcon("judul") small"></i></a></th>
                                <th><a href="@SortUrl("kategori")" class="text-decoration-none text-dark">Kategori <i class="bi @SortIcon("kategori") small"></i></a></th>
                                <th class="text-end"><a href="@SortUrl("anggaran")" class="text-decoration-none text-dark">Anggaran <i class="bi @SortIcon("anggaran") small"></i></a></th>
                                <th class="text-end"><a href="@SortUrl("realisasi")" class="text-decoration-none text-dark">Realisasi <i class="bi @SortIcon("realisasi") small"></i></a></th>
                                <th class="text-center" style="min-width:120px"><a href="@SortUrl("serapan")" class="text-decoration-none text-dark">% Serapan <i class="bi @SortIcon("serapan") small"></i></a></th>
                                <th class="text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Items.Any())
                            {
                                <tr><td colspan="9" class="text-center text-muted py-4">Belum ada data budget.</td></tr>
                            }
                            @{ var no = (Model.CurrentPage - 1) * Model.PageSize; }
                            @foreach (var item in Model.Items)
                            {
                                no++;
                                var pct = item.EstimasiBiayaTotal > 0 ? (int)(item.RealisasiBiaya / item.EstimasiBiayaTotal * 100) : 0;
                                var pctColor = pct > 100 ? "bg-danger" : pct >= 80 ? "bg-success" : pct >= 50 ? "bg-warning" : "bg-info";
                                var rowClass = pct > 100 ? "table-danger" : "";
                                <tr class="@rowClass" data-anggaran="@item.EstimasiBiayaTotal.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                                    <td><input type="checkbox" class="form-check-input row-check" value="@item.Id" /></td>
                                    <td>@no</td>
                                    <td><span class="badge @(item.Type == "Training" ? "bg-info" : "bg-purple") bg-opacity-75">@item.Type</span></td>
                                    <td>@item.Judul</td>
                                    <td class="small">@(item.Kategori ?? "-")</td>
                                    <td class="text-end fw-semibold">@item.EstimasiBiayaTotal.ToString("#,0")</td>
                                    <td class="text-end realisasi-cell" data-id="@item.Id" data-value="@item.RealisasiBiaya.ToString(System.Globalization.CultureInfo.InvariantCulture)" role="button" title="Klik untuk edit">@item.RealisasiBiaya.ToString("#,0")</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height:6px">
                                                <div class="progress-bar @pctColor" style="width:@(Math.Min(pct, 100))%"></div>
                                            </div>
                                            <span class="small @(pct > 100 ? "text-danger fw-bold" : "text-muted")" style="min-width:36px">@pct%</span>
                                            @if (pct > 100)
                                            {
                                                <i class="bi bi-exclamation-triangle-fill text-danger small" title="Over Budget!"></i>
                                            }
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-primary me-1 btn-edit-item" title="Edit"
                                                data-id="@item.Id"
                                                data-type="@item.Type"
                                                data-judul="@Html.Encode(item.Judul)"
                                                data-kategori="@Html.Encode(item.Kategori ?? "")"
                                                data-subkategori="@Html.Encode(item.SubKategori ?? "")"
                                                data-tahun="@item.TahunAnggaran"
                                                data-peserta="@item.JumlahPeserta"
                                                data-biaya="@item.BiayaPerOrang.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                data-realisasi="@item.RealisasiBiaya.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                data-vendor="@Html.Encode(item.Vendor ?? "")"
                                                data-catatan="@Html.Encode(item.Catatan ?? "")">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger btn-delete-item" title="Hapus"
                                                data-id="@item.Id" data-judul="@Html.Encode(item.Judul)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (Model.TotalPages >= 1)
                {
                    <div class="card-footer bg-transparent d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div class="d-flex align-items-center gap-2 small text-muted">
                            @{
                                var startItem = Model.TotalItems > 0 ? (Model.CurrentPage - 1) * Model.PageSize + 1 : 0;
                                var endItem = Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalItems);
                            }
                            <span>Menampilkan @startItem–@endItem dari @Model.TotalItems item</span>
                            <select id="pageSizeSelect" class="form-select form-select-sm" style="width:auto">
                                @foreach (var ps in Model.PageSizeOptions)
                                {
                                    <option value="@ps" selected="@(Model.PageSize == ps)">@ps / halaman</option>
                                }
                            </select>
                        </div>
                        @if (Model.TotalPages > 1)
                        {
                            <nav>
                                <ul class="pagination pagination-sm mb-0">
                                    @{
                                        var pages = new List<int>();
                                        for (int i = 1; i <= Model.TotalPages; i++)
                                        {
                                            if (i == 1 || i == Model.TotalPages || (i >= Model.CurrentPage - 1 && i <= Model.CurrentPage + 1))
                                                pages.Add(i);
                                        }
                                    }
                                    @for (int idx = 0; idx < pages.Count; idx++)
                                    {
                                        if (idx > 0 && pages[idx] - pages[idx - 1] > 1)
                                        {
                                            <li class="page-item disabled"><span class="page-link">…</span></li>
                                        }
                                        <li class="page-item @(pages[idx] == Model.CurrentPage ? "active" : "")">
                                            <a class="page-link" href="@PageUrl(pages[idx])">@pages[idx]</a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Tab Ringkasan -->
        <div class="tab-pane fade" id="tab-ringkasan" role="tabpanel" aria-labelledby="ringkasan-tab">
            <!-- Summary Cards — 5 cards -->
            <div class="row g-3 mb-4">
                <div class="col-6 col-lg">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center">
                            <div class="text-muted small">Total Item</div>
                            <div class="fs-3 fw-bold">@Model.TotalItems</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-lg">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center">
                            <div class="text-muted small">Total Rencana</div>
                            <div class="fs-5 fw-bold text-primary">Rp @Model.TotalRencana.ToString("#,0")</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-lg">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center">
                            <div class="text-muted small">Total Realisasi</div>
                            <div class="fs-5 fw-bold text-success">Rp @Model.TotalRealisasi.ToString("#,0")</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-lg">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center">
                            <div class="text-muted small">Sisa Anggaran</div>
                            <div class="fs-5 fw-bold @(Model.Variance >= 0 ? "text-success" : "text-danger")">Rp @Model.Variance.ToString("#,0")</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-lg">
                    @{
                        var penyerapan = Model.TotalRencana > 0 ? (int)(Model.TotalRealisasi / Model.TotalRencana * 100) : 0;
                    }
                    <div class="card border-0 shadow-sm">
                        <div class="card-body text-center">
                            <div class="text-muted small">Penyerapan</div>
                            <div class="fs-5 fw-bold @(penyerapan >= 80 ? "text-success" : penyerapan >= 50 ? "text-warning" : "text-danger")">@penyerapan%</div>
                            <div class="progress mt-2" style="height:6px">
                                <div class="progress-bar @(penyerapan >= 80 ? "bg-success" : penyerapan >= 50 ? "bg-warning" : "bg-danger")" style="width:@(Math.Min(penyerapan, 100))%"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Charts -->
            @if (Model.ChartData.Any())
            {
                <div class="row g-3 mb-4">
                    <div class="col-lg-8">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <h6 class="card-title mb-3">Budget vs Realisasi per Kategori</h6>
                                <canvas id="budgetChart" height="80"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <h6 class="card-title mb-3">Distribusi per Type</h6>
                                <canvas id="typeChart" height="160"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
                @if (Model.TopItems.Any())
                {
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-body">
                            <h6 class="card-title mb-3">Top 10 Item Anggaran Terbesar</h6>
                            <canvas id="topChart" height="60"></canvas>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <form method="post" asp-action="BudgetTrainingEdit">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="editId" />
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i>Edit Budget Item</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <h6 class="text-muted fw-semibold mb-2 pb-1 border-bottom"><i class="bi bi-info-circle me-1"></i>Informasi Umum</h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Type <span class="text-danger">*</span></label>
                            <select name="Type" id="editType" class="form-select" required>
                                <option value="Training">Training</option>
                                <option value="Assessment">Assessment</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Tahun Anggaran <span class="text-danger">*</span></label>
                            <input type="number" name="TahunAnggaran" id="editTahun" class="form-control" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Judul <span class="text-danger">*</span></label>
                            <input type="text" name="Judul" id="editJudul" class="form-control" required maxlength="200" />
                        </div>
                    </div>
                    <h6 class="text-muted fw-semibold mb-2 pb-1 border-bottom"><i class="bi bi-people me-1"></i>Kategori & Peserta</h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Kategori</label>
                            <select name="Kategori" id="editKategori" class="form-select">
                                <option value="">-- Pilih Kategori --</option>
                                @foreach (var cat in (IEnumerable<dynamic>)ViewBag.KategoriOptions)
                                {
                                    <option value="@cat.Name">@cat.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Sub Kategori</label>
                            <select name="SubKategori" id="editSubKategori" class="form-select" disabled>
                                <option value="">-- Pilih Sub Kategori --</option>
                                @foreach (var sub in (IEnumerable<dynamic>)ViewBag.SubKategoriOptions)
                                {
                                    <option value="@sub.Name" data-parent-id="@sub.ParentId">@sub.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Jumlah Peserta <span class="text-danger">*</span></label>
                            <input type="number" name="JumlahPeserta" id="editPeserta" class="form-control" min="0" required oninput="updateEditCalc()" />
                        </div>
                    </div>
                    <h6 class="text-muted fw-semibold mb-2 pb-1 border-bottom"><i class="bi bi-cash-stack me-1"></i>Anggaran & Vendor</h6>
                    <div class="row g-3">
                        <div class="col-12">
                            <div class="btn-group btn-group-sm" role="group">
                                <input type="radio" class="btn-check" name="editBiayaMode" id="editModePerOrang" value="perorang" checked>
                                <label class="btn btn-outline-primary" for="editModePerOrang">Biaya per Orang</label>
                                <input type="radio" class="btn-check" name="editBiayaMode" id="editModeTotal" value="total">
                                <label class="btn btn-outline-primary" for="editModeTotal">Biaya Total</label>
                            </div>
                        </div>
                        <input type="hidden" name="BiayaPerOrang" id="editBiayaHidden" value="0" />
                        <div class="col-md-6 edit-mode-perorang">
                            <label class="form-label">Biaya per Orang <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">Rp</span>
                                <input type="number" id="editBiaya" class="form-control" min="0" step="1000" oninput="updateEditCalc()" />
                            </div>
                        </div>
                        <div class="col-md-6 edit-mode-total" style="display:none">
                            <label class="form-label">Biaya Total <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">Rp</span>
                                <input type="number" id="editBiayaTotal" class="form-control" min="0" step="1000" oninput="updateEditCalc()" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Realisasi Biaya</label>
                            <div class="input-group">
                                <span class="input-group-text">Rp</span>
                                <input type="number" name="RealisasiBiaya" id="editRealisasi" class="form-control" min="0" step="1000" />
                            </div>
                        </div>
                        <div class="col-12 edit-mode-perorang">
                            <label class="form-label">Estimasi Total</label>
                            <div class="input-group">
                                <span class="input-group-text">Rp</span>
                                <input type="text" id="editEstimasi" class="form-control bg-light" readonly disabled placeholder="Otomatis: Peserta x Biaya per Orang" />
                            </div>
                        </div>
                        <div class="col-12 edit-mode-total" style="display:none">
                            <label class="form-label">Biaya per Orang (kalkulasi)</label>
                            <div class="input-group">
                                <span class="input-group-text">Rp</span>
                                <input type="text" id="editBiayaPreview" class="form-control bg-light" readonly disabled placeholder="Otomatis: Total / Peserta" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Vendor</label>
                            <input type="text" name="Vendor" id="editVendor" class="form-control" maxlength="200" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Catatan</label>
                            <textarea name="Catatan" id="editCatatan" class="form-control" rows="2" maxlength="500"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Simpan Perubahan</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Konfirmasi Hapus</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Yakin ingin menghapus item:<br/><strong id="deleteItemName"></strong>?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                <form method="post" asp-action="BudgetTrainingDelete" id="deleteForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteId" />
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Hapus</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Bulk Update Realisasi Modal -->
<div class="modal fade" id="bulkUpdateModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i>Bulk Update Realisasi</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <table class="table table-sm">
                    <thead><tr><th>Judul</th><th class="text-end" style="width:180px">Realisasi</th></tr></thead>
                    <tbody id="bulkUpdateBody"></tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                <button type="button" class="btn btn-primary" onclick="submitBulkUpdate()"><i class="bi bi-save me-1"></i>Simpan</button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<script>
    var antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]').value;

    function formatRupiah(val) {
        if (!val || isNaN(val)) return '';
        return Number(val).toLocaleString('id-ID');
    }

    // === Toggle Mode Logic ===
    function toggleMode(prefix, mode) {
        document.querySelectorAll('.' + prefix + '-mode-perorang').forEach(function(el) {
            el.style.display = mode === 'perorang' ? '' : 'none';
        });
        document.querySelectorAll('.' + prefix + '-mode-total').forEach(function(el) {
            el.style.display = mode === 'total' ? '' : 'none';
        });
    }

    document.querySelectorAll('input[name="editBiayaMode"]').forEach(function(radio) {
        radio.addEventListener('change', function() {
            toggleMode('edit', this.value);
            updateEditCalc();
        });
    });

    function getEditMode() {
        return document.querySelector('input[name="editBiayaMode"]:checked').value;
    }

    function updateEditCalc() {
        var p = parseInt(document.getElementById('editPeserta').value) || 0;
        var mode = getEditMode();
        if (mode === 'perorang') {
            var b = parseInt(document.getElementById('editBiaya').value) || 0;
            document.getElementById('editEstimasi').value = (p * b) > 0 ? formatRupiah(p * b) : '';
            document.getElementById('editBiayaHidden').value = b;
        } else {
            var total = parseInt(document.getElementById('editBiayaTotal').value) || 0;
            var perOrang = p > 0 ? Math.round(total / p) : 0;
            document.getElementById('editBiayaPreview').value = perOrang > 0 ? formatRupiah(perOrang) : '';
            document.getElementById('editBiayaHidden').value = perOrang;
        }
    }

    // === Edit Modal — via data-* attributes (event delegation) ===
    var editKategoriMap = {};
    @foreach (var cat in (IEnumerable<dynamic>)ViewBag.KategoriOptions)
    {
        @:editKategoriMap["@cat.Name"] = @cat.Id;
    }

    var editKategoriSelect = document.getElementById('editKategori');
    var editSubKategoriSelect = document.getElementById('editSubKategori');

    editKategoriSelect.addEventListener('change', function() {
        var selectedName = this.value;
        var parentId = editKategoriMap[selectedName];
        var options = editSubKategoriSelect.querySelectorAll('option[data-parent-id]');
        options.forEach(function(opt) {
            opt.hidden = parentId === undefined || parseInt(opt.dataset.parentId) !== parentId;
        });
        editSubKategoriSelect.value = '';
        editSubKategoriSelect.disabled = !selectedName;
    });

    document.addEventListener('click', function(e) {
        var btn = e.target.closest('.btn-edit-item');
        if (!btn) return;
        var d = btn.dataset;
        document.getElementById('editId').value = d.id;
        document.getElementById('editType').value = d.type;
        document.getElementById('editJudul').value = d.judul;
        document.getElementById('editTahun').value = d.tahun;
        document.getElementById('editPeserta').value = d.peserta;
        document.getElementById('editBiaya').value = d.biaya;
        document.getElementById('editRealisasi').value = d.realisasi;
        document.getElementById('editVendor').value = d.vendor;
        document.getElementById('editCatatan').value = d.catatan;

        editKategoriSelect.value = d.kategori;
        var parentId = editKategoriMap[d.kategori];
        editSubKategoriSelect.querySelectorAll('option[data-parent-id]').forEach(function(opt) {
            opt.hidden = parentId === undefined || parseInt(opt.dataset.parentId) !== parentId;
        });
        editSubKategoriSelect.disabled = !d.kategori;
        editSubKategoriSelect.value = d.subkategori;

        document.getElementById('editModePerOrang').checked = true;
        toggleMode('edit', 'perorang');
        var totalComputed = (parseInt(d.peserta) || 0) * (parseInt(d.biaya) || 0);
        document.getElementById('editBiayaTotal').value = totalComputed > 0 ? totalComputed : '';
        document.getElementById('editBiayaHidden').value = d.biaya;
        updateEditCalc();
        new bootstrap.Modal(document.getElementById('editModal')).show();
    });

    // === Delete Modal — via data-* attributes ===
    document.addEventListener('click', function(e) {
        var btn = e.target.closest('.btn-delete-item');
        if (!btn) return;
        document.getElementById('deleteId').value = btn.dataset.id;
        document.getElementById('deleteItemName').textContent = btn.dataset.judul;
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    });

    // === Inline Edit Realisasi ===
    document.addEventListener('click', function(e) {
        var cell = e.target.closest('.realisasi-cell');
        if (!cell || cell.querySelector('input')) return;
        var currentVal = cell.dataset.value;
        var id = cell.dataset.id;
        var origText = cell.textContent;
        cell.innerHTML = '<input type="number" class="form-control form-control-sm text-end" value="' + currentVal + '" min="0" step="1000" style="width:120px;display:inline-block" />';
        var input = cell.querySelector('input');
        input.focus();
        input.select();

        function save() {
            var newVal = input.value;
            if (newVal === currentVal) { cell.textContent = origText; return; }
            fetch('@Url.Action("BudgetTrainingQuickUpdate")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': antiForgeryToken },
                body: 'id=' + id + '&realisasi=' + newVal
            }).then(function(r) { return r.json(); }).then(function(data) {
                if (data.success) {
                    cell.dataset.value = newVal;
                    cell.textContent = Number(newVal).toLocaleString('id-ID');

                    // Update row styling
                    var tr = cell.closest('tr');
                    var anggaran = parseFloat(tr.dataset.anggaran) || 0;
                    var pct = anggaran > 0 ? Math.round(Number(newVal) / anggaran * 100) : 0;

                    // Row class
                    if (pct > 100) { tr.classList.add('table-danger'); } else { tr.classList.remove('table-danger'); }

                    // Progress bar
                    var bar = tr.querySelector('.progress-bar');
                    if (bar) {
                        bar.style.width = Math.min(pct, 100) + '%';
                        bar.className = 'progress-bar ' + (pct > 100 ? 'bg-danger' : pct >= 80 ? 'bg-success' : pct >= 50 ? 'bg-warning' : 'bg-info');
                    }

                    // Pct text
                    var pctSpan = tr.querySelector('.progress').parentElement.querySelector('span');
                    if (pctSpan) {
                        pctSpan.textContent = pct + '%';
                        pctSpan.className = 'small ' + (pct > 100 ? 'text-danger fw-bold' : 'text-muted');
                    }

                    // Warning icon
                    var container = tr.querySelector('.d-flex.align-items-center.gap-2');
                    var icon = container.querySelector('.bi-exclamation-triangle-fill');
                    if (pct > 100) {
                        if (!icon) {
                            var i = document.createElement('i');
                            i.className = 'bi bi-exclamation-triangle-fill text-danger small';
                            i.title = 'Over Budget!';
                            container.appendChild(i);
                        }
                    } else if (icon) {
                        icon.remove();
                    }

                    // Update edit button data-realisasi
                    var editBtn = tr.querySelector('.btn-edit-item');
                    if (editBtn) { editBtn.dataset.realisasi = newVal; }
                } else {
                    cell.textContent = origText;
                }
            }).catch(function() { cell.textContent = origText; alert('Gagal menyimpan. Coba lagi.'); });
        }

        input.addEventListener('blur', save);
        input.addEventListener('keydown', function(ev) {
            if (ev.key === 'Enter') { ev.preventDefault(); input.blur(); }
            if (ev.key === 'Escape') { cell.textContent = origText; }
        });
    });

    // === Checkbox / Bulk Selection ===
    var selectAllBox = document.getElementById('selectAll');
    selectAllBox.addEventListener('change', function() {
        document.querySelectorAll('.row-check').forEach(function(cb) { cb.checked = selectAllBox.checked; });
        updateBulkBar();
    });
    document.addEventListener('change', function(e) {
        if (e.target.classList.contains('row-check')) updateBulkBar();
    });

    function getSelectedIds() {
        return Array.from(document.querySelectorAll('.row-check:checked')).map(function(cb) { return parseInt(cb.value); });
    }

    function updateBulkBar() {
        var count = getSelectedIds().length;
        document.getElementById('bulkCount').textContent = count;
        document.getElementById('bulkBar').classList.toggle('d-none', count === 0);
    }

    function clearSelection() {
        document.querySelectorAll('.row-check').forEach(function(cb) { cb.checked = false; });
        selectAllBox.checked = false;
        updateBulkBar();
    }

    function bulkDeleteSelected() {
        var ids = getSelectedIds();
        if (!ids.length) return;
        if (!confirm('Hapus ' + ids.length + ' item yang dipilih?')) return;
        fetch('@Url.Action("BudgetTrainingBulkDelete")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': antiForgeryToken },
            body: JSON.stringify(ids)
        }).then(function(r) { return r.json(); }).then(function(data) {
            if (data.success) location.reload();
            else alert(data.message || 'Gagal menghapus');
        }).catch(function() { alert('Terjadi kesalahan jaringan'); });
    }

    function openBulkUpdateModal() {
        var ids = getSelectedIds();
        if (!ids.length) return;
        var tbody = document.getElementById('bulkUpdateBody');
        tbody.innerHTML = '';
        ids.forEach(function(id) {
            var row = document.querySelector('.row-check[value="' + id + '"]').closest('tr');
            var judul = row.children[3].textContent;
            var realisasi = row.querySelector('.realisasi-cell').dataset.value;
            var tr2 = document.createElement('tr');
            var tdJudul = document.createElement('td');
            tdJudul.textContent = judul;
            var tdInput = document.createElement('td');
            tdInput.innerHTML = '<input type="number" class="form-control form-control-sm text-end bulk-real-input" data-id="' + id + '" value="' + realisasi + '" min="0" step="1000" />';
            tr2.appendChild(tdJudul);
            tr2.appendChild(tdInput);
            tbody.appendChild(tr2);
        });
        new bootstrap.Modal(document.getElementById('bulkUpdateModal')).show();
    }

    function submitBulkUpdate() {
        var updates = {};
        document.querySelectorAll('.bulk-real-input').forEach(function(input) {
            updates[input.dataset.id] = parseFloat(input.value) || 0;
        });
        fetch('@Url.Action("BudgetTrainingBulkUpdateRealisasi")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': antiForgeryToken },
            body: JSON.stringify(updates)
        }).then(function(r) { return r.json(); }).then(function(data) {
            if (data.success) location.reload();
            else alert(data.message || 'Gagal memperbarui');
        }).catch(function() { alert('Terjadi kesalahan jaringan'); });
    }

    // === Page Size Selector ===
    var pageSizeEl = document.getElementById('pageSizeSelect');
    if (pageSizeEl) {
        pageSizeEl.addEventListener('change', function() {
            var url = new URL(window.location);
            url.searchParams.set('pageSize', this.value);
            url.searchParams.set('page', '1');
            window.location = url;
        });
    }

    // === Form validation ===
    document.querySelector('#editModal form').addEventListener('submit', function(e) {
        var hidden = parseInt(document.getElementById('editBiayaHidden').value) || 0;
        if (hidden <= 0) {
            e.preventDefault();
            var mode = getEditMode();
            var target = mode === 'perorang' ? document.getElementById('editBiaya') : document.getElementById('editBiayaTotal');
            target.focus();
            alert('Silakan isi ' + (mode === 'perorang' ? 'Biaya per Orang' : 'Biaya Total'));
        }
    });

    // === Charts — Lazy init on tab shown ===
    var chartInitialized = false;
    document.getElementById('ringkasan-tab').addEventListener('shown.bs.tab', function () {
        if (chartInitialized) return;
        chartInitialized = true;
        @if (Model.ChartData.Any())
        {
            <text>
        // Bar chart — Budget vs Realisasi per Kategori
        new Chart(document.getElementById('budgetChart'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartData.Select(c => c.Kategori))),
                datasets: [
                    { label: 'Rencana', data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartData.Select(c => c.Rencana))), backgroundColor: 'rgba(54, 162, 235, 0.7)' },
                    { label: 'Realisasi', data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartData.Select(c => c.Realisasi))), backgroundColor: 'rgba(75, 192, 192, 0.7)' }
                ]
            },
            options: {
                responsive: true,
                scales: { y: { beginAtZero: true, ticks: { callback: v => 'Rp ' + v.toLocaleString('id-ID') } } },
                plugins: { tooltip: { callbacks: { label: ctx => ctx.dataset.label + ': Rp ' + ctx.raw.toLocaleString('id-ID') } } }
            }
        });

        // Doughnut chart — distribusi per Type
        new Chart(document.getElementById('typeChart'), {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartByType.Select(c => c.Kategori))),
                datasets: [{
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartByType.Select(c => c.Rencana))),
                    backgroundColor: ['rgba(13, 202, 240, 0.7)', 'rgba(111, 66, 193, 0.7)']
                }]
            },
            options: {
                responsive: true,
                plugins: { tooltip: { callbacks: { label: ctx => ctx.label + ': Rp ' + ctx.raw.toLocaleString('id-ID') } } }
            }
        });
            </text>
        }
        @if (Model.TopItems.Any())
        {
            <text>
        // Horizontal bar — Top 10
        new Chart(document.getElementById('topChart'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopItems.Select(t => t.Judul))),
                datasets: [{ label: 'Anggaran', data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopItems.Select(t => t.Anggaran))), backgroundColor: 'rgba(255, 159, 64, 0.7)' }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                scales: { x: { beginAtZero: true, ticks: { callback: v => 'Rp ' + v.toLocaleString('id-ID') } } },
                plugins: { tooltip: { callbacks: { label: ctx => 'Rp ' + ctx.raw.toLocaleString('id-ID') } } }
            }
        });
            </text>
        }
    });

    // Hash routing for tab persistence
    (function () {
        var hash = window.location.hash;
        if (hash === '#ringkasan') {
            var tab = new bootstrap.Tab(document.getElementById('ringkasan-tab'));
            tab.show();
        }
        document.querySelectorAll('#budgetTabs button[data-bs-toggle="tab"]').forEach(function (btn) {
            btn.addEventListener('shown.bs.tab', function (e) {
                if (e.target.id === 'ringkasan-tab') {
                    history.replaceState(null, null, '#ringkasan');
                } else {
                    history.replaceState(null, null, window.location.pathname + window.location.search);
                }
            });
        });
    })();
</script>
}

<style>
    .bg-purple { background-color: #6f42c1; }
    .realisasi-cell { cursor: pointer; }
    .realisasi-cell:hover { background-color: rgba(var(--bs-primary-rgb), 0.08); }
</style>
