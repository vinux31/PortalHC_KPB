@model List<HcPortal.Models.ExamSummaryItem>

@{
    ViewData["Title"] = "Tinjau Jawaban Anda";
    int unanswered = ViewBag.UnansweredCount as int? ?? 0;
    int assessmentId = ViewBag.AssessmentId as int? ?? 0;
    int? assignmentId = ViewBag.AssignmentId as int?;
    var answers = ViewBag.Answers as Dictionary<int, int> ?? new Dictionary<int, int>();
    bool timerExpired = ViewBag.TimerExpired as bool? ?? false;
}

<!-- Minimal header — no sticky needed here -->
<div class="container py-4" style="max-width: 860px;">
    <div class="text-center mb-4">
        <h4 class="fw-bold">Tinjau Jawaban Anda</h4>
        <p class="text-muted">@ViewBag.AssessmentTitle</p>
    </div>

    @if (unanswered > 0)
    {
        <div class="alert alert-warning d-flex align-items-center mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            Anda memiliki <strong class="mx-1">@unanswered</strong> soal yang belum dijawab. Jawab semua soal terlebih dahulu sebelum mengumpulkan.
        </div>
    }
    else
    {
        <div class="alert alert-success d-flex align-items-center mb-4">
            <i class="bi bi-check-circle-fill me-2"></i>
            Semua @Model.Count soal sudah dijawab. Siap dikumpulkan.
        </div>
    }

    <!-- Summary table -->
    <div class="card shadow mb-4">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px">#</th>
                        <th>Pertanyaan</th>
                        <th>Jawaban Anda</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="@(item.IsAnswered ? "" : "table-warning")">
                            <td class="fw-bold">@item.DisplayNumber</td>
                            <td>
                                <span class="badge @QuestionTypeLabels.BadgeClass(item.QuestionType) small me-2">@QuestionTypeLabels.Short(item.QuestionType)</span>
                                <span class="text-truncate d-inline-block" style="max-width: 380px;"
                                      title="@item.QuestionText">
                                    @item.QuestionText
                                </span>
                                @await Html.PartialAsync("_QuestionImage", new { ImagePath = item.ImagePath, ImageAlt = item.ImageAlt, Cap = 240 })
                                @{ string[] letters = { "A", "B", "C", "D" }; }
                                @for (int oi = 0; oi < item.OptionImages.Count; oi++)
                                {
                                    var optImg = item.OptionImages[oi];
                                    var letter = oi < letters.Length ? letters[oi] : (oi + 1).ToString();
                                    @await Html.PartialAsync("_QuestionImage", new { ImagePath = optImg.ImagePath, ImageAlt = optImg.ImageAlt, Cap = 120, AriaContext = "opsi " + letter })
                                }
                            </td>
                            <td>
                                @if (item.QuestionType == "MultipleAnswer")
                                {
                                    @if (item.SelectedOptionTexts.Any())
                                    {
                                        <span class="text-success">Jawaban: @string.Join(", ", item.SelectedOptionTexts)</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger fw-bold">Belum dijawab</span>
                                    }
                                }
                                else if (item.QuestionType == "Essay")
                                {
                                    @if (!string.IsNullOrWhiteSpace(item.TextAnswer))
                                    {
                                        <span class="text-success">@(item.TextAnswer.Length > 50 ? item.TextAnswer.Substring(0, 50) + "..." : item.TextAnswer)</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger fw-bold">Belum dijawab</span>
                                    }
                                }
                                else
                                {
                                    @if (item.IsAnswered)
                                    {
                                        <span class="text-success">@item.SelectedOptionText</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Belum dijawab</span>
                                    }
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Auto-save reassurance badge -->
    <div class="d-flex justify-content-center mb-3">
        <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-2">
            <i class="bi bi-check-circle-fill me-1"></i>Semua jawaban sudah tersimpan
        </span>
    </div>

    @if (timerExpired)
    {
        @* Phase 313 D-13: banner info untuk awareness reload-after-timeup. *@
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle me-2"></i>
            Waktu ujian sudah habis. Submit otomatis sudah/sedang berjalan.
        </div>
    }

    <!-- Final submit form -->
    @{
        // Phase 313 CR-01 fix: token server-issued, hanya non-null saat timerExpired=true.
        var autoSubmitToken = ViewBag.AutoSubmitToken as string;
    }
    <form asp-action="SubmitExam" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@assessmentId" />
        <input type="hidden" name="isAutoSubmit" value="@(timerExpired ? "true" : "false")" id="autoSubmitFlag" />
        @if (!string.IsNullOrEmpty(autoSubmitToken))
        {
            @* Phase 313 CR-01: server-issued one-shot token untuk validasi auto-submit di Tier-1. *@
            <input type="hidden" name="autoSubmitToken" value="@autoSubmitToken" id="autoSubmitToken" />
        }
        @foreach (var kvp in answers)
        {
            <input type="hidden" name="answers[@kvp.Key]" value="@kvp.Value" />
        }

        <div class="d-flex justify-content-between align-items-center">
            @if (timerExpired)
            {
                <span class="text-danger fw-semibold">
                    <i class="bi bi-clock-fill me-1"></i>Waktu habis — ujian harus dikumpulkan
                </span>
            }
            else
            {
                <a asp-action="StartExam" asp-route-id="@assessmentId" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Kembali ke Ujian
                </a>
            }

            @* Phase 313 D-03 / C-02: 3-branch button — timerExpired (disabled+spinner), unanswered (disabled), else submit *@
            @if (timerExpired)
            {
                <button type="button" class="btn btn-secondary btn-lg fw-bold" disabled
                        id="manualSubmitDisabledBtn"
                        title="Auto-submit sedang berjalan, mohon tunggu">
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    Waktu Habis - Submit Otomatis Berjalan...
                </button>
            }
            else if (unanswered > 0)
            {
                <button type="button" class="btn btn-success btn-lg fw-bold" disabled
                        title="Jawab semua soal terlebih dahulu">
                    <i class="bi bi-check-circle-fill me-2"></i>Kumpulkan Ujian
                </button>
            }
            else
            {
                <button type="submit" class="btn btn-success btn-lg fw-bold"
                        onclick="return confirm('Kumpulkan ujian? Tindakan ini tidak dapat dibatalkan.')">
                    <i class="bi bi-check-circle-fill me-2"></i>Kumpulkan Ujian
                </button>
            }
        </div>
    </form>
</div>

@await Html.PartialAsync("_ImageLightboxModal")

@section Scripts {
<script>
    (function () {
        // Phase 313 D-10: auto-submit retry 3x exponential backoff [1s, 2s, 4s].
        // Hanya aktif kalau timerExpired (form auto-fired dari StartExam.cshtml redirect chain).
        // Phase 313 IN-01 fix: reuse Razor variable `timerExpired` (line 9), no duplicate ViewBag read.
        var timerExpired = @Json.Serialize(timerExpired);
        if (!timerExpired) return; // Happy path — pakai native form submit + confirm.

        var form = document.querySelector('form[action$="/SubmitExam"]');
        if (!form) return;

        var maxAttempts = 3;
        var delays = [1000, 2000, 4000]; // D-10 exponential backoff
        var attempt = 0;
        var stopRetry = false; // Phase 313 CR-02 fix: stop chain kalau server reject (Tier-1/Tier-2).

        function attemptSubmit() {
            if (stopRetry) return;
            attempt++;
            var fd = new FormData(form);
            return fetch(form.action, { method: 'POST', body: fd, redirect: 'follow' })
                .then(function (r) {
                    if (r.redirected) {
                        // Phase 313 CR-02 fix: redirect ke /CMP/StartExam = signal "submit ditolak"
                        // (Tier-1 atau Tier-2 fire). JANGAN follow — itu bisa memicu loop
                        // StartExam → ExamSummary → SubmitExam → StartExam tanpa batas.
                        // Hanya redirect ke /CMP/Results yang dianggap sukses.
                        if (/\/CMP\/StartExam(\/|\?|$)/i.test(r.url)) {
                            stopRetry = true;
                            showRetryFailBanner('Server menolak submit (waktu sudah lewat grace). Hubungi admin — jawaban Anda tersimpan di server.');
                            return; // STOP retry chain, jangan navigate.
                        }
                        window.location.href = r.url;
                        return;
                    }
                    if (!r.ok) throw new Error('HTTP ' + r.status);
                    // Server returned non-redirect 2xx — fallback: reload to current URL.
                    window.location.reload();
                })
                .catch(function (err) {
                    console.error('[Phase 313] Submit attempt ' + attempt + ' failed', err);
                    if (stopRetry) return;
                    if (attempt < maxAttempts) {
                        setTimeout(attemptSubmit, delays[attempt - 1]);
                    } else {
                        showRetryFailBanner(); // D-11 banner permanent
                    }
                });
        }

        function showRetryFailBanner(customMessage) {
            // D-11: banner permanent — server-side last-resort save deferred ke v16.0+.
            // Phase 313 CR-02: optional customMessage untuk membedakan reject server vs gagal jaringan.
            var container = document.querySelector('.container.py-4') || document.querySelector('main') || document.body;
            if (!container) return;
            var banner = document.createElement('div');
            banner.className = 'alert alert-warning fw-semibold';
            banner.setAttribute('role', 'alert');
            var defaultMsg =
                'Submit gagal karena masalah jaringan. Hubungi admin. ' +
                'Jawaban Anda tersimpan di tab ini, jangan tutup browser.';
            banner.innerHTML =
                '<i class="bi bi-exclamation-triangle-fill me-2"></i>' +
                (customMessage || defaultMsg);
            container.prepend(banner);
        }

        // Auto-fire on page-ready kalau timerExpired (chain dari StartExam timer-up flow).
        if (document.readyState === 'complete') {
            attemptSubmit();
        } else {
            window.addEventListener('load', attemptSubmit);
        }
    })();
</script>
}
