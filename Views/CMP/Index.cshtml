@{
    ViewData["Title"] = "CMP - Competency Management Platform";
}

<div class="container-fluid py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-3">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">CMP</li>
        </ol>
    </nav>
    <div class="row mb-4">
        <div class="col">
            <h2 class="mb-1">
                <i class="bi bi-mortarboard me-2"></i>Competency Management Platform
            </h2>
            <p class="text-muted">Kelola kompetensi, asesmen, dan rencana pengembangan</p>
        </div>
    </div>

    <div class="row g-4">
        <!-- Dokumen KKJ & Alignment KKJ/IDP -->
        <div class="col-12 col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="icon-box bg-primary bg-opacity-10 text-primary rounded-3 p-3 me-3">
                            <i class="bi bi-file-earmark-richtext fs-3"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">Dokumen KKJ/IDP</h5>
                            <small class="text-muted fw-semibold">Kerangka Kompetensi</small>
                        </div>
                    </div>
                    <p class="text-muted mb-3">Dokumen kebutuhan kompetensi jabatan dan keselarasan KKJ & IDP</p>
                    <a href="@Url.Action("DokumenKkj", "CMP")" class="btn btn-primary w-100">
                        <i class="bi bi-arrow-right-circle me-2"></i>Lihat Dokumen
                    </a>
                </div>
            </div>
        </div>

        <!-- My Assessments (all roles) -->
        <div class="col-12 col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="icon-box bg-info bg-opacity-10 text-info rounded-3 p-3 me-3">
                            <i class="bi bi-clipboard-check fs-3"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">Assessment Saya</h5>
                            <small class="text-muted fw-semibold">Ujian & Evaluasi</small>
                        </div>
                    </div>
                    <p class="text-muted mb-3">Ikuti assessment, lihat hasil, dan pantau riwayat evaluasi Anda</p>
                    <a href="@Url.Action("Assessment", "CMP")" class="btn btn-info w-100">
                        <i class="bi bi-arrow-right-circle me-2"></i>Assessment Saya
                    </a>
                </div>
            </div>
        </div>

        <!-- Training Records -->
        <div class="col-12 col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="icon-box bg-secondary bg-opacity-10 text-secondary rounded-3 p-3 me-3">
                            <i class="bi bi-journal-text fs-3"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">Riwayat Pelatihan</h5>
                            <small class="text-muted fw-semibold">Pengembangan Kapabilitas</small>
                        </div>
                    </div>
                    <p class="text-muted mb-3">Lihat dan kelola riwayat pelatihan serta pengembangan kapabilitas</p>
                    <a href="@Url.Action("Records", "CMP")" class="btn btn-warning w-100">
                        <i class="bi bi-arrow-right-circle me-2"></i>Lihat Riwayat
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Analytics Dashboard (HC/Admin only) -->
    @if (User.IsInRole("Admin") || User.IsInRole("HC"))
    {
    <hr class="my-3" />
    <div class="mb-3">
        <span class="badge bg-dark bg-opacity-75"><i class="bi bi-shield-lock me-1"></i>Admin & HC</span>
    </div>
    <div class="row g-4 justify-content-center">
        <div class="col-12 col-md-6 col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="icon-box bg-success bg-opacity-10 text-success rounded-3 p-3 me-3">
                            <i class="bi bi-patch-check fs-3"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">Manajemen Sertifikasi</h5>
                            <small class="text-muted fw-semibold">Kelola Sertifikat</small>
                        </div>
                    </div>
                    <p class="text-muted mb-3">Lihat dan kelola semua sertifikat pelatihan dan asesmen pekerja</p>
                    <a href="@Url.Action("CertificationManagement", "CMP")" class="btn btn-success w-100">
                        <i class="bi bi-arrow-right-circle me-2"></i>Kelola Sertifikat
                    </a>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="icon-box bg-dark bg-opacity-10 text-dark rounded-3 p-3 me-3">
                            <i class="bi bi-graph-up fs-3"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">Dasbor Analitik</h5>
                            <small class="text-muted fw-semibold">Assessment & Sertifikat</small>
                        </div>
                    </div>
                    <p class="text-muted mb-3">Visualisasi fail rate, trend assessment, skor ET, dan sertifikat akan expired</p>
                    <a href="@Url.Action("AnalyticsDashboard", "CMP")" class="btn btn-dark w-100">
                        <i class="bi bi-arrow-right-circle me-2"></i>Lihat Analytics
                    </a>
                </div>
            </div>
        </div>
    </div>
    }
</div>

<style>
    .icon-box {
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card {
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
</style>
