@{
    ViewData["Title"] = "KKJ Matrix";
    var allBagians = ViewBag.AllBagians as List<HcPortal.Models.KkjBagian> ?? new();
    var selectedBagian = ViewBag.SelectedBagian as string ?? "";
    var files = ViewBag.Files as List<HcPortal.Models.KkjFile> ?? new();
}
@using System.Globalization

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "CMP")">CMP</a></li>
            <li class="breadcrumb-item active">KKJ Matrix</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-file-earmark-text me-2"></i>KKJ Matrix</h2>
            <p class="text-muted mb-0">Dokumen KKJ Matrix untuk bagian Anda. Klik tombol unduh untuk mengakses file.</p>
        </div>
        @if (allBagians.Count > 1)
        {
            <!-- Bagian selector (only for L1-L4 who can see multiple bagians) -->
            <div class="d-flex align-items-center gap-2">
                <label class="form-label mb-0 fw-semibold text-nowrap">Pilih Bagian:</label>
                <select class="form-select form-select-sm" style="min-width: 180px;"
                        onchange="window.location.href='@Url.Action("Kkj", "CMP")' + '?section=' + this.value">
                    @foreach (var bagian in allBagians)
                    {
                        if (bagian.Name == selectedBagian)
                        {
                            <option value="@bagian.Name" selected="selected">@bagian.Name</option>
                        }
                        else
                        {
                            <option value="@bagian.Name">@bagian.Name</option>
                        }
                    }
                </select>
            </div>
        }
    </div>

    @if (!allBagians.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            Tidak ada bagian yang tersedia untuk akun Anda.
        </div>
    }
    else if (!files.Any())
    {
        <!-- Empty state -->
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-folder2-open fs-1 text-muted mb-3 d-block"></i>
                <h5 class="text-muted">Belum Ada Dokumen</h5>
                <p class="text-muted">Belum ada dokumen KKJ Matrix yang di-upload untuk bagian <strong>@selectedBagian</strong>.</p>
            </div>
        </div>
    }
    else
    {
        <!-- File list -->
        <div class="card border-0 shadow-sm">
            <div class="card-header border-0 bg-white py-3">
                <h6 class="mb-0 fw-bold">
                    <i class="bi bi-folder me-2 text-primary"></i>
                    Dokumen Bagian @selectedBagian
                    <span class="badge bg-primary ms-2">@files.Count file</span>
                </h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Nama File</th>
                                <th>Tipe</th>
                                <th>Ukuran</th>
                                <th>Keterangan</th>
                                <th>Tanggal Upload</th>
                                <th class="text-center">Unduh</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var file in files)
                            {
                                <tr>
                                    <td>
                                        <i class="bi @(file.FileType == "pdf" ? "bi-file-earmark-pdf text-danger" : "bi-file-earmark-excel text-success") me-2"></i>
                                        @file.FileName
                                    </td>
                                    <td>
                                        <span class="badge @(file.FileType == "pdf" ? "bg-danger" : "bg-success")">
                                            @file.FileType.ToUpper()
                                        </span>
                                    </td>
                                    <td class="text-muted small">
                                        @(file.FileSizeBytes < 1048576 ? $"{file.FileSizeBytes / 1024}KB" : $"{file.FileSizeBytes / 1048576.0:F1}MB")
                                    </td>
                                    <td class="text-muted small">@(file.Keterangan ?? "-")</td>
                                    <td class="text-muted small">@file.UploadedAt.ToString("dd MMM yyyy", CultureInfo.GetCultureInfo("id-ID"))</td>
                                    <td class="text-center">
                                        <a href="@Url.Action("KkjFileDownload", "Admin", new { id = file.Id })"
                                           class="btn btn-sm btn-primary"
                                           title="Unduh @file.FileName">
                                            <i class="bi bi-download me-1"></i>Unduh
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
