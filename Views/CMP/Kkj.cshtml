@model List<HcPortal.Models.KkjMatrixItem>

@{
    ViewData["Title"] = "Matriks Kompetensi (KKJ)";
    ViewData["ContainerClass"] = "container-fluid px-4";

    var columns       = ViewBag.Columns as List<HcPortal.Models.KkjColumn> ?? new List<HcPortal.Models.KkjColumn>();
    var allBagians    = ViewBag.AllBagians as List<HcPortal.Models.KkjBagian> ?? new List<HcPortal.Models.KkjBagian>();
    var selectedSection = ViewBag.SelectedSection as string ?? "";
    int userLevel     = ViewBag.UserLevel is int ul ? ul : 6;
}

<style>
    /* Scrollbar */
    .custom-scrollbar::-webkit-scrollbar { height: 12px; width: 12px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 4px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #c1c1c1; border-radius: 4px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #a8a8a8; }

    .table-responsive.custom-scrollbar {
        max-height: 78vh;
        overflow-x: auto;
        overflow-y: auto;
        border: 1px solid #ddd;
        border-radius: 8px;
    }

    /* Sticky header */
    thead th {
        position: sticky;
        top: 0;
        z-index: 20;
    }

    /* Sticky left columns */
    .sticky-col {
        position: sticky;
        background-color: white;
        z-index: 10;
        border-right: 1px solid #dee2e6;
    }
    thead th.sticky-col { z-index: 30; }

    /* Column widths */
    .col-no      { left: 0;      min-width: 50px;  max-width: 60px;  }
    .col-skill   { left: 50px;   min-width: 110px; }
    .col-subskill{ left: 160px;  min-width: 130px; }
    .col-index   { left: 290px;  min-width: 70px;  }
    .col-tech    { left: 360px;  min-width: 220px; border-right: 2px solid #adb5bd !important; }
    .col-target  { min-width: 55px; text-align: center; }

    /* Table sizing */
    .table-sm td, .table-sm th {
        font-size: 0.82rem;
        padding: 0.5rem 0.55rem;
        vertical-align: middle;
    }

    /* Matrix header */
    .matrix-header {
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
        color: white;
        text-align: center;
        vertical-align: middle;
        font-size: 0.85rem;
    }
    .matrix-subheader {
        background-color: #e9ecef;
        text-align: center;
        font-weight: 600;
        font-size: 0.78rem;
        color: #495057;
    }

    /* Target value color scale */
    .tv-1 { background-color: #f8d7da; color: #842029; font-weight: 600; }
    .tv-2 { background-color: #ffe5d0; color: #7d3900; font-weight: 600; }
    .tv-3 { background-color: #fff3cd; color: #664d03; font-weight: 600; }
    .tv-4 { background-color: #d1f0d8; color: #0a4013; font-weight: 600; }
    .tv-5 { background-color: #a8e6b3; color: #093311; font-weight: 600; }
    .tv-dash { background-color: #f8f9fa; color: #adb5bd; }

    /* Crosshair hover */
    .hover-row > td { background-color: #e8f0fe !important; }
    .hover-col { background-color: #e8f0fe !important; }
    .hover-cell { background-color: #cfe2ff !important; font-weight: bold; color: #084298; }
</style>

@* Breadcrumb *@
<nav aria-label="breadcrumb" class="mb-2">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="@Url.Action("Index", "CMP")">CMP</a></li>
        <li class="breadcrumb-item active" aria-current="page">KKJ Matrix</li>
    </ol>
</nav>

@* Page header *@
<div class="d-flex flex-wrap justify-content-between align-items-end mb-4 gap-3">
    <div>
        <h4 class="fw-bold text-primary mb-1">Matriks Kompetensi (KKJ)</h4>
        <p class="text-muted mb-0 small">Lihat target kompetensi per jabatan</p>
    </div>
    <div class="d-flex flex-column align-items-end gap-2">
        @* Search *@
        <div class="input-group input-group-sm" style="width:260px;">
            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
            <input type="text" id="searchInput" class="form-control border-start-0 ps-0" placeholder="Cari kompetensi...">
        </div>
    </div>
</div>

@* Bagian selector *@
<div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
    <label class="fw-semibold mb-0 text-muted small">Bagian:</label>
    @if (allBagians.Count <= 1 && allBagians.Count > 0)
    {
        @* Single bagian (L5/L6 worker) — show badge, no dropdown *@
        <span class="badge bg-primary px-3 py-2">
            <i class="bi bi-building me-1"></i>@selectedSection
        </span>
    }
    else if (allBagians.Count > 1)
    {
        @* Multiple bagians — dropdown navigation *@
        <select id="bagianDropdown" class="form-select form-select-sm" style="max-width:180px;"
                onchange="window.location.href='/CMP/Kkj?section=' + encodeURIComponent(this.value)">
            @foreach (var b in allBagians)
            {
                if (b.Name == selectedSection)
                {
                    <option value="@b.Name" selected="selected">@b.Name</option>
                }
                else
                {
                    <option value="@b.Name">@b.Name</option>
                }
            }
        </select>
    }
    else
    {
        <span class="text-muted small">Tidak ada bagian tersedia.</span>
    }

    <span class="badge bg-light text-muted border ms-1">@Model.Count kompetensi</span>
</div>

@* Table or empty state *@
@if (string.IsNullOrEmpty(selectedSection))
{
    <div class="alert alert-secondary">Pilih bagian untuk melihat KKJ Matrix.</div>
}
else if (!columns.Any() && !Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>
        Belum ada data KKJ Matrix untuk bagian <strong>@selectedSection</strong>.
    </div>
}
else
{
    <div class="table-responsive custom-scrollbar shadow-sm bg-white">
        <table class="table table-bordered table-sm table-hover mb-0" id="kkjTable">
            <thead>
                <tr>
                    <th rowspan="2" class="sticky-col col-no bg-white text-center">No</th>
                    <th rowspan="2" class="sticky-col col-skill bg-white">Skill Group</th>
                    <th rowspan="2" class="sticky-col col-subskill bg-white">Subskill Group</th>
                    <th rowspan="2" class="sticky-col col-index bg-white text-center">Indeks</th>
                    <th rowspan="2" class="sticky-col col-tech bg-white">Kompetensi Teknis</th>
                    @if (columns.Any())
                    {
                        <th colspan="@columns.Count" class="matrix-header">
                            @selectedSection — Target Level per Jabatan
                        </th>
                    }
                    else
                    {
                        <th class="text-muted text-center py-2 small">Belum ada kolom target</th>
                    }
                </tr>
                <tr class="matrix-subheader">
                    @foreach (var col in columns)
                    {
                        <th class="col-target">@col.Name</th>
                    }
                    @if (!columns.Any())
                    {
                        <th>-</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="@(5 + columns.Count)" class="text-center text-muted py-4">
                            Belum ada data kompetensi untuk bagian <strong>@selectedSection</strong>.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr data-item-id="@item.Id">
                        <td class="sticky-col col-no text-center">@item.No</td>
                        <td class="sticky-col col-skill text-muted">@item.SkillGroup</td>
                        <td class="sticky-col col-subskill text-muted">@item.SubSkillGroup</td>
                        <td class="sticky-col col-index text-center fw-semibold">@item.Indeks</td>
                        <td class="sticky-col col-tech fw-semibold text-primary">@item.Kompetensi</td>
                        @foreach (var col in columns)
                        {
                            var tv = item.TargetValues.FirstOrDefault(v => v.KkjColumnId == col.Id);
                            var val = tv?.Value ?? "-";
                            var cssClass = val switch {
                                "1" => "tv-1",
                                "2" => "tv-2",
                                "3" => "tv-3",
                                "4" => "tv-4",
                                "5" => "tv-5",
                                _   => "tv-dash"
                            };
                            <td class="col-target @cssClass">@val</td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    // --- Search ---
    var searchInput = document.getElementById('searchInput');
    var table = document.getElementById('kkjTable');
    if (searchInput && table) {
        searchInput.addEventListener('keyup', function () {
            var term = this.value.toLowerCase();
            table.querySelectorAll('tbody tr').forEach(function (row) {
                row.style.display = row.innerText.toLowerCase().includes(term) ? '' : 'none';
            });
        });
    }

    // --- Crosshair hover ---
    if (table) {
        table.addEventListener('mouseover', function (e) {
            var cell = e.target.closest('td');
            if (!cell || cell.closest('thead')) return;
            var mRow = cell.closest('tr');
            if (!mRow || mRow.parentElement.tagName !== 'TBODY') return;

            mRow.classList.add('hover-row');

            var cellIndex = cell.cellIndex;
            if (cellIndex >= 5) {
                cell.classList.add('hover-cell');
                table.querySelectorAll('tbody tr').forEach(function (row) {
                    var c = row.children[cellIndex];
                    if (c) c.classList.add('hover-col');
                });
            }
        });

        table.addEventListener('mouseout', function (e) {
            var cell = e.target.closest('td');
            if (!cell) return;
            var mRow = cell.closest('tr');
            if (mRow) mRow.classList.remove('hover-row');
            if (cell.classList.contains('hover-cell')) cell.classList.remove('hover-cell');
            table.querySelectorAll('.hover-col').forEach(function (c) { c.classList.remove('hover-col'); });
        });
    }
});
</script>
}
