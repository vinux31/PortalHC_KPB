@{
    ViewData["Title"] = "Alignment KKJ & IDP";
    var bagians = ViewBag.Bagians as List<HcPortal.Models.KkjBagian> ?? new List<HcPortal.Models.KkjBagian>();
    var filesByBagian = ViewBag.FilesByBagian as Dictionary<int, List<HcPortal.Models.CpdpFile>> ?? new Dictionary<int, List<HcPortal.Models.CpdpFile>>();
    var selectedBagianId = (int)(ViewBag.SelectedBagianId ?? 0);

    string FormatSize(long bytes) => bytes < 1024 * 1024 ? $"{bytes / 1024}KB" : $"{bytes / (1024 * 1024.0):F1}MB";
}
@using System.Globalization

<div class="py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Beranda</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "CMP")">CMP</a></li>
            <li class="breadcrumb-item active">Alignment KKJ & IDP</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-file-earmark-richtext me-2 text-primary"></i>Alignment KKJ & IDP</h2>
            <p class="text-muted mb-0">Unduh dokumen Alignment KKJ & IDP</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">

            @if (!bagians.Any())
            {
                <div class="p-4 text-center text-muted">
                    <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                    Belum ada bagian CPDP.
                </div>
            }
            else
            {
                @* Tab navigation *@
                <div class="d-flex align-items-center border-bottom px-3 pt-3">
                    <ul class="nav nav-tabs border-0 flex-grow-1" id="bagianTabs" role="tablist">
                        @foreach (var bagian in bagians.OrderBy(b => b.DisplayOrder))
                        {
                            <li class="nav-item" role="presentation">
                                <button class="nav-link @(bagian.Id == selectedBagianId ? "active" : "")"
                                        id="tab-@bagian.Id"
                                        data-bs-toggle="tab"
                                        data-bs-target="#pane-@bagian.Id"
                                        type="button"
                                        role="tab">
                                    @bagian.Name
                                </button>
                            </li>
                        }
                    </ul>
                </div>

                @* Tab panes *@
                <div class="tab-content" id="bagianTabContent">
                    @foreach (var bagian in bagians.OrderBy(b => b.DisplayOrder))
                    {
                        var bagianFiles = filesByBagian.ContainsKey(bagian.Id) ? filesByBagian[bagian.Id] : new List<HcPortal.Models.CpdpFile>();
                        var isActive = bagian.Id == selectedBagianId;

                        <div class="tab-pane fade @(isActive ? "show active" : "")"
                             id="pane-@bagian.Id"
                             role="tabpanel">

                            @* Bagian section header (read-only — no Hapus Bagian button) *@
                            <div class="px-4 py-3 border-bottom bg-light">
                                <h6 class="mb-0 fw-bold">@bagian.Name</h6>
                            </div>

                            @* File list *@
                            <div class="p-4">
                                @if (!bagianFiles.Any())
                                {
                                    <div class="alert alert-light border text-muted text-center py-4">
                                        <i class="bi bi-inbox fs-2 d-block mb-2 text-muted"></i>
                                        Belum ada dokumen CPDP untuk bagian ini.
                                    </div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-sm table-hover align-middle mb-3">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Nama File</th>
                                                    <th>Tipe</th>
                                                    <th>Ukuran</th>
                                                    <th>Keterangan</th>
                                                    <th>Tanggal Upload</th>
                                                    <th class="text-center">Aksi</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var file in bagianFiles)
                                                {
                                                    <tr>
                                                        <td>
                                                            <i class="bi @(file.FileType == "pdf" ? "bi-file-earmark-pdf text-danger" : "bi-file-earmark-excel text-success") me-2"></i>
                                                            @file.FileName
                                                        </td>
                                                        <td>
                                                            <span class="badge @(file.FileType == "pdf" ? "bg-danger" : "bg-success")">
                                                                @file.FileType.ToUpper()
                                                            </span>
                                                        </td>
                                                        <td><small>@FormatSize(file.FileSizeBytes)</small></td>
                                                        <td><small class="text-muted">@(file.Keterangan ?? "-")</small></td>
                                                        <td><small>@file.UploadedAt.ToString("dd MMM yyyy HH:mm", CultureInfo.GetCultureInfo("id-ID"))</small></td>
                                                        <td class="text-center">
                                                            <a href="@Url.Action("CpdpFileDownload", "Admin", new { id = file.Id })"
                                                               class="btn btn-sm btn-outline-primary"
                                                               title="Download">
                                                                <i class="bi bi-download me-1"></i>Download
                                                            </a>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>

                        </div>
                    }
                </div>
            }

        </div>
    </div>
</div>
