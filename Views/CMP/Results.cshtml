@* === Retake cooldown countdown (RTK-10 / D-01) — UX only; server otoritatif. Guard anti-ReferenceError (lesson 413). === *@
<script>
    (function () {
        var btn = document.getElementById('btnRetake');
        if (!btn) return;                                  // guard — tombol absen (cap/cooldown-less) → no-op
        var iso = btn.getAttribute('data-cooldown-until');
        if (!iso) return;                                  // guard — tak ada cooldown aktif → no-op
        var target = new Date(iso).getTime();
        if (isNaN(target)) return;                         // guard — atribut tak valid

        var span = document.getElementById('retakeCountdown');

        function pad(n) { return n < 10 ? '0' + n : '' + n; }

        function tick() {
            var remainingMs = target - Date.now();
            if (remainingMs <= 0) {
                clearInterval(timer);
                // Cooldown selesai → aktifkan tombol + sambungkan ke modal + relabel.
                btn.removeAttribute('disabled');
                btn.removeAttribute('data-cooldown-until');
                btn.setAttribute('data-bs-toggle', 'modal');
                btn.setAttribute('data-bs-target', '#retakeConfirmModal');
                btn.innerHTML = '<i class="bi bi-arrow-repeat me-1"></i>Ujian Ulang';
                return;
            }
            var totalSec = Math.floor(remainingMs / 1000);
            var h = Math.floor(totalSec / 3600);
            var m = Math.floor((totalSec % 3600) / 60);
            var s = totalSec % 60;
            if (span) { span.textContent = pad(h) + ':' + pad(m) + ':' + pad(s); }
        }

        var timer = setInterval(tick, 1000);
        tick();
    })();
</script>
