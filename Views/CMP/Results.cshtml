@model HcPortal.Models.AssessmentResultsViewModel
@using System.Globalization
@using HcPortal.Helpers

@{
    ViewData["Title"] = "Hasil Assessment";
    // SEC-02: Validate returnUrl is a local path to prevent open-redirect attacks
    var rawReturnUrl = Context.Request.Query["returnUrl"].ToString();
    var backUrl = (!string.IsNullOrEmpty(rawReturnUrl) && Uri.IsWellFormedUriString(rawReturnUrl, UriKind.Relative))
        ? rawReturnUrl
        : Url.Action("Assessment", "CMP")!;
}

<div class="container-fluid px-4 py-4">
    <!-- Page Header -->
    <div class="mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="mb-1"><i class="bi bi-bar-chart-line me-2"></i>Hasil Assessment</h2>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a asp-action="Assessment">Daftar Assessment</a></li>
                        <li class="breadcrumb-item active">Hasil</li>
                    </ol>
                </nav>
            </div>
            <div>
                <a href="@backUrl" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Kembali
                </a>
            </div>
        </div>
    </div>

    @* Phase 309 SUB-01: Pending grading banner *@
    @if (Model.IsPendingGrading)
    {
        <div class="alert alert-info mb-4">
            <i class="bi bi-info-circle-fill me-2"></i>
            <strong>Hasil sementara</strong> &mdash; Essay menunggu penilaian HC. Skor &amp; sertifikat akan diperbarui setelah penilaian selesai.
        </div>
    }

    <!-- Results Summary Card -->
    <div class="card shadow-sm mb-4">
        <div class="card-header @(Model.IsPendingGrading ? "bg-secondary" : (Model.IsPassed ? "bg-success" : "bg-danger")) text-white">
            <h4 class="mb-0">@Model.Title</h4>
        </div>
        <div class="card-body">
            <!-- Score Display -->
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="text-center p-4 border rounded">
                        <h6 class="text-muted mb-2">Nilai Anda</h6>
                        <h2 class="mb-1">@Model.Score%</h2>
                        <small class="text-muted">(@Model.CorrectAnswers/@Model.TotalQuestions benar)</small>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="text-center p-4 border rounded">
                        <h6 class="text-muted mb-2">Batas Nilai Kelulusan</h6>
                        <h2 class="mb-0">@Model.PassPercentage%</h2>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="text-center p-4 border rounded">
                        <h6 class="text-muted mb-2">Status</h6>
                        @if (Model.IsPendingGrading)
                        {
                            <span class="badge text-bg-secondary fs-5 py-2 px-3">
                                <i class="bi bi-hourglass-split me-1"></i>MENUNGGU PENILAIAN
                            </span>
                        }
                        else if (Model.IsPassed)
                        {
                            <span class="badge text-bg-success fs-5 py-2 px-3">
                                <i class="bi bi-check-circle-fill me-1"></i>LULUS
                            </span>
                        }
                        else
                        {
                            <span class="badge text-bg-danger fs-5 py-2 px-3">
                                <i class="bi bi-x-circle-fill me-1"></i>TIDAK LULUS
                            </span>
                        }
                    </div>
                </div>
            </div>

            <!-- Assessment Details -->
            <div class="row mb-3">
                <div class="col-md-4">
                    <p class="mb-1"><strong>Kategori:</strong></p>
                    <span class="badge bg-primary">@Model.Category</span>
                </div>
                <div class="col-md-4">
                    <p class="mb-1"><strong>Selesai:</strong></p>
                    <span>@(Model.CompletedAt?.ToString("dd MMM yyyy HH:mm", CultureInfo.GetCultureInfo("id-ID")) ?? "N/A")</span>
                </div>
                <div class="col-md-4">
                    <p class="mb-1"><strong>Peserta:</strong></p>
                    <span>@Model.UserFullName</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Pesan Motivasi + NomorSertifikat -->
    @if (Model.IsPendingGrading)
    {
        <div class="alert alert-info mb-4 d-flex align-items-center">
            <i class="bi bi-hourglass-split me-2 fs-5"></i>
            <span>Skor di atas adalah <strong>nilai sementara</strong> dari soal Pilihan Tunggal &amp; Pilihan Jamak. Skor final &amp; sertifikat tersedia setelah penilaian Essay selesai.</span>
        </div>
    }
    else if (Model.IsPassed)
    {
        <div class="alert alert-success mb-4">
            <i class="bi bi-check-circle-fill me-2"></i><strong>Selamat!</strong> Anda lulus assessment ini.
        </div>
        @if (!string.IsNullOrEmpty(Model.NomorSertifikat))
        {
            <div class="alert alert-info mb-4 d-flex align-items-center">
                <i class="bi bi-award-fill me-2 fs-5"></i>
                <span>Nomor Sertifikat: <strong>@Model.NomorSertifikat</strong></span>
            </div>
        }
        else if (Model.GenerateCertificate)
        {
            <div class="alert alert-warning mb-4 d-flex align-items-center">
                <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                <span>Sertifikat belum tergenerate. Silakan hubungi administrator.</span>
            </div>
        }
    }
    else
    {
        <div class="alert alert-warning mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i><strong>Terus semangat.</strong> Pelajari kembali materi dan coba lagi.
        </div>
    }

    @* === Section Perbandingan Pre-Post Test (D-11, D-13, D-14) === *@
    @if (ViewBag.HasComparisonSection == true)
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-light fw-bold">
                <i class="bi bi-bar-chart-line me-2" aria-hidden="true"></i> Perbandingan Pre-Post Test
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-bordered mb-0" aria-label="Perbandingan skor Pre-Test dan Post-Test per elemen kompetensi">
                        <thead class="table-light">
                            <tr>
                                <th>Elemen Kompetensi</th>
                                <th class="text-center" style="width: 150px;">Skor Pre</th>
                                <th class="text-center" style="width: 150px;">Skor Post</th>
                                <th class="text-center" style="width: 150px;">Gain Score</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in ViewBag.ComparisonData)
                            {
                                <tr>
                                    <td>@row.ElemenTeknis</td>
                                    <td class="text-center">@($"{row.PreScore:0.#}%")</td>
                                    <td class="text-center">@($"{row.PostScore:0.#}%")</td>
                                    <td class="text-center">
                                        @{
                                            var gain = (double?)row.GainScore;
                                            string gainText, gainClass;
                                            if (gain == null)
                                            {
                                                gainText = "\u2014";
                                                gainClass = "text-secondary";
                                            }
                                            else if (gain > 0)
                                            {
                                                gainText = $"+{gain:0.#}%";
                                                gainClass = "text-success";
                                            }
                                            else if (gain < 0)
                                            {
                                                gainText = $"{gain:0.#}%";
                                                gainClass = "text-danger";
                                            }
                                            else
                                            {
                                                gainText = "0%";
                                                gainClass = "text-secondary";
                                            }
                                        }
                                        <span class="fw-bold @gainClass">@gainText</span>
                                        @if (gain == null && ViewBag.GainScorePending == true)
                                        {
                                            <small class="d-block text-muted">Menunggu penilaian Essay</small>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Analisis Elemen Teknis -->
    @if (Model.ElemenTeknisScores != null && Model.ElemenTeknisScores.Any())
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="bi bi-radar me-2 text-primary"></i>Analisis Elemen Teknis</h5>
            </div>
            <div class="card-body">
                @if (Model.ElemenTeknisScores.Count >= 3)
                {
                    <div class="text-center mb-4">
                        <canvas id="subCompRadarChart" style="max-height: 350px;"></canvas>
                    </div>
                }
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Elemen Teknis</th>
                                <th class="text-center">Benar</th>
                                <th class="text-center">Total</th>
                                <th class="text-center">Persentase</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sc in Model.ElemenTeknisScores)
                            {
                                <tr>
                                    <td>@sc.Name</td>
                                    <td class="text-center">@sc.Correct</td>
                                    <td class="text-center">@sc.Total</td>
                                    <td class="text-center">
                                        <span class="badge @(sc.Percentage >= Model.PassPercentage ? "bg-success" : "bg-danger")">
                                            @sc.Percentage.ToString("F1")%
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light fw-bold">
                            @{
                                var totalBenar = Model.ElemenTeknisScores.Sum(s => s.Correct);
                                var totalSoal = Model.ElemenTeknisScores.Sum(s => s.Total);
                                var totalPct = totalSoal > 0 ? Math.Round((double)totalBenar / totalSoal * 100, 1) : 0;
                            }
                            <tr>
                                <td>Total</td>
                                <td class="text-center">@totalBenar</td>
                                <td class="text-center">@totalSoal</td>
                                <td class="text-center">
                                    <span class="badge @(totalPct >= Model.PassPercentage ? "bg-success" : "bg-danger")">
                                        @totalPct%
                                    </span>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        @if (Model.ElemenTeknisScores.Count >= 3)
        {
            <script>
            document.addEventListener('DOMContentLoaded', function() {
                var labels = @Html.Raw(Json.Serialize(Model.ElemenTeknisScores.Select(s => s.Name)));
                var data = @Html.Raw(Json.Serialize(Model.ElemenTeknisScores.Select(s => s.Percentage)));
                var truncated = labels.map(function(l) { return l.length > 20 ? l.substring(0, 20) + '...' : l; });

                new Chart(document.getElementById('subCompRadarChart'), {
                    type: 'radar',
                    data: {
                        labels: truncated,
                        datasets: [{
                            label: 'Persentase Benar',
                            data: data,
                            backgroundColor: 'rgba(54, 162, 235, 0.2)',
                            borderColor: 'rgba(54, 162, 235, 1)',
                            pointBackgroundColor: 'rgba(54, 162, 235, 1)',
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    title: function(items) { return labels[items[0].dataIndex]; },
                                    label: function(item) { return item.raw + '%'; }
                                }
                            }
                        },
                        scales: {
                            r: {
                                min: 0,
                                max: 100,
                                ticks: { stepSize: 25, callback: function(v) { return v + '%'; } },
                                pointLabels: { font: { size: 11 } }
                            }
                        }
                    }
                });
            });
            </script>
        }
    }

    <!-- Answer Review Section — v32.4 RTK-11 (Phase 407): tier 3-state LEAK-SAFE.
         ShowFullReview (lulus/exhausted/admin-bypass) = kunci jawaban tampil; ShowWrongFlagsOnly (gagal+sisa percobaan) = verdict-only, kunci DITAHAN; ShowScoreOnly = notice. -->
    @* MERGE v32.5↔v32.4: compose Phase 414 admin-bypass dengan RTK-11 leak-safe tiering.
       Non-owner Admin/HC (CanReviewAnswers && !AllowAnswerReview) → SELALU ShowFullReview (leak-safety N/A: admin tak mungkin retake).
       Owner/peserta (atau toggle ON) → ikut RetakeMode server-authoritative. Tak ada kebocoran kunci di kasus manapun. *@
    @{
        // M2 (merge): reviewer non-owner berwenang (Admin/HC/L3/L4-section) SELALU full review (Phase 414),
        // INDEPENDEN toggle. Sebelumnya effectiveReviewMode dihitung dari isAdminReviewBypass (= non-owner &&
        // toggle OFF) → saat toggle ON admin jatuh ke RetakeMode leak-safe (cuma Benar/Salah), langgar Phase 414.
        var isNonOwnerReviewer = !Model.IsResultOwner;
        var isAdminReviewBypass = isNonOwnerReviewer && !Model.AllowAnswerReview;   // hanya untuk nota "peserta tak bisa lihat" (toggle OFF) — semantik identik sebelumnya
        var effectiveReviewMode = isNonOwnerReviewer ? RetakeReviewMode.ShowFullReview : Model.RetakeMode;
    }
    @switch (effectiveReviewMode)
    {
        case RetakeReviewMode.ShowFullReview:
            @* ShowFullReview — markup full-review existing VERBATIM (kunci jawaban tampil; lulus ATAU retake tak mungkin lagi). *@
            if (Model.QuestionReviews != null)
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0"><i class="bi bi-list-check me-2"></i>Tinjauan Jawaban</h5>
                    </div>
                    @* Phase 414 (D-04): nota admin — review tampil HANYA karena bypass non-owner (toggle peserta OFF). Teks static encoded, no Html.Raw (T-414-02 XSS-safe). *@
                    @if (isAdminReviewBypass)
                    {
                        <div class="alert alert-info py-2 px-3 mb-0 small border-0 rounded-0">
                            <i class="bi bi-eye-slash me-1"></i>Peserta tidak dapat melihat tinjauan ini (Tinjauan Jawaban dinonaktifkan). Hanya admin/HC yang melihatnya.
                        </div>
                    }
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            @foreach (var question in Model.QuestionReviews)
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div class="flex-grow-1">
                                            <h6 class="mb-2"><strong>Soal @question.QuestionNumber:</strong> @question.QuestionText</h6>
                                            @await Html.PartialAsync("_QuestionImage", new { ImagePath = question.ImagePath, ImageAlt = question.ImageAlt, Cap = 240 })
                                        </div>
                                        <div>
                                            @if (question.IsEssayPending)
                                            {
                                                <span class="badge text-bg-secondary">
                                                    <i class="bi bi-hourglass-split me-1"></i>Menunggu Penilaian
                                                </span>
                                            }
                                            else if (question.IsCorrect)
                                            {
                                                <span class="badge text-bg-success">
                                                    <i class="bi bi-check-circle-fill me-1"></i>Benar
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge text-bg-danger">
                                                    <i class="bi bi-x-circle-fill me-1"></i>Salah
                                                </span>
                                            }
                                        </div>
                                    </div>

                                    <!-- Options List -->
                                    <div class="list-group">
                                        @{ string[] letters = { "A", "B", "C", "D", "E", "F" }; }
                                        @for (int oi = 0; oi < question.Options.Count; oi++)
                                        {
                                            var option = question.Options[oi];
                                            var letter = oi < letters.Length ? letters[oi] : (oi + 1).ToString();
                                            var itemClass = "";
                                            var icon = "";

                                            if (option.IsCorrect)
                                            {
                                                itemClass = "list-group-item-success";
                                                icon = "bi-check-circle-fill text-success";
                                            }
                                            else if (option.IsSelected && !option.IsCorrect)
                                            {
                                                itemClass = "list-group-item-danger";
                                                icon = "bi-x-circle-fill text-danger";
                                            }

                                            <div class="list-group-item @itemClass d-flex flex-column">
                                                <div class="d-flex align-items-center">
                                                    @if (!string.IsNullOrEmpty(icon))
                                                    {
                                                        <i class="bi @icon me-2"></i>
                                                    }
                                                    <span>@option.OptionText</span>
                                                    @if (option.IsSelected && !option.IsCorrect)
                                                    {
                                                        <small class="ms-auto text-muted">(Jawaban Anda)</small>
                                                    }
                                                    @if (option.IsCorrect)
                                                    {
                                                        <small class="ms-auto text-muted">(Jawaban Benar)</small>
                                                    }
                                                </div>
                                                @await Html.PartialAsync("_QuestionImage", new { ImagePath = option.ImagePath, ImageAlt = option.ImageAlt, Cap = 120, AriaContext = "opsi " + letter })
                                            </div>
                                        }
                                    </div>

                                    @* D-07 (Phase 383): soal essay tak punya Options → render teks jawaban worker (Pitfall 1). *@
                                    @if (!question.Options.Any() && !string.IsNullOrEmpty(question.UserAnswer))
                                    {
                                        <div class="list-group">
                                            <div class="list-group-item">
                                                <small class="text-muted d-block">Jawaban Anda:</small>
                                                <span>@question.UserAnswer</span>
                                                <small class="text-muted d-block mt-2">@question.CorrectAnswer</small>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
            break;

        case RetakeReviewMode.ShowWrongFlagsOnly:
            @* ShowWrongFlagsOnly — LEAK-SAFE (RTK-11/D-03): gagal + masih ada sisa percobaan → kunci jawaban DITAHAN.
               Render HANYA teks soal + jawaban worker + verdict tri-state. TANPA highlight opsi-benar, TANPA label kunci, TANPA rubrik essay. *@
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-list-check me-2"></i>Tinjauan Jawaban</h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-info" role="status">
                        <i class="bi bi-eye-slash me-2"></i>Kunci jawaban disembunyikan selama kamu masih punya kesempatan ujian ulang. Kamu bisa melihat soal mana yang benar atau salah, tetapi jawaban yang benar baru tampil setelah lulus atau percobaan habis.
                    </div>
                    @if (Model.QuestionReviews != null)
                    {
                        @foreach (var q in Model.QuestionReviews)
                        {
                            <div class="border rounded p-3 mb-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <h6 class="mb-2"><strong>Soal @q.QuestionNumber:</strong> @q.QuestionText</h6>
                                    @if (q.IsEssayPending)
                                    {
                                        <span class="badge text-bg-secondary"><i class="bi bi-hourglass-split me-1"></i>Menunggu Penilaian</span>
                                    }
                                    else if (q.IsCorrect)
                                    {
                                        <span class="badge text-bg-success"><i class="bi bi-check-circle-fill me-1"></i>Benar</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-danger"><i class="bi bi-x-circle-fill me-1"></i>Salah</span>
                                    }
                                </div>
                                @* OWN answer only — NO correct-option highlight, NO "(Jawaban Benar)", NO CorrectAnswer/explanation *@
                                @if (!string.IsNullOrEmpty(q.UserAnswer))
                                {
                                    <div class="small"><span class="text-muted">Jawaban Anda:</span> @q.UserAnswer</div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
            break;

        case RetakeReviewMode.ShowScoreOnly:
            <div class="alert alert-info mb-4">
                <i class="bi bi-info-circle me-2"></i>Tinjauan jawaban tidak tersedia untuk assessment ini.
            </div>
            break;
    }

    @* === Riwayat Percobaan Saya (RTK-12) — kartu accordion ter-gate (ScoreOnly sembunyikan rincian per-soal) === *@
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Riwayat Percobaan Saya</h5>
        </div>
        <div class="card-body">
            @if (Model.RiwayatAttempts == null || !Model.RiwayatAttempts.Any())
            {
                <div class="text-muted text-center py-4">Belum ada riwayat percobaan. Riwayat akan muncul setelah kamu mengulang ujian.</div>
            }
            else
            {
                @await Html.PartialAsync("_RiwayatPekerja", Model.RiwayatAttempts,
                    new ViewDataDictionary(ViewData) { ["HideDetail"] = (effectiveReviewMode == RetakeReviewMode.ShowScoreOnly) })  @* L2 (merge): pakai effectiveReviewMode — admin bypass (ShowFullReview) ikut lihat detail riwayat, konsisten answer-review *@
            }
        </div>
    </div>

    @* === Retake control (RTK-10) — dirender dari flag VM; server tetap otoritatif (CMP/RetakeExam re-cek CanRetakeAsync). === *@
    @if (Model.IsCapReached)
    {
        <div class="alert alert-warning mb-4" role="alert">
            <i class="bi bi-lock-fill me-2"></i>
            Batas percobaan tercapai (@Model.MaxAttempts dari @Model.MaxAttempts). Hubungi HC bila perlu kesempatan tambahan.
        </div>
    }
    else if (Model.CanRetake)
    {
        <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
            <button type="button" class="btn btn-primary" id="btnRetake"
                    data-bs-toggle="modal" data-bs-target="#retakeConfirmModal">
                <i class="bi bi-arrow-repeat me-1"></i>Ujian Ulang
            </button>
            <span class="text-muted small">Percobaan ke-@Model.CurrentAttempt dari @Model.MaxAttempts</span>
        </div>
    }
    else if (Model.IsInCooldown && Model.CooldownUntilUtc.HasValue)
    {
        @* WR-01 (RTK-10): masa jeda belum lewat. CanRetake=false selama cooldown, jadi cabang ini WAJIB terpisah dari CanRetake agar countdown tampil. *@
        <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
            <button type="button" class="btn btn-primary" id="btnRetake" disabled
                    data-cooldown-until="@Model.CooldownUntilUtc.Value.ToString("o")">
                <i class="bi bi-hourglass-split me-1"></i>Bisa ulang dalam <span id="retakeCountdown">--:--:--</span>
            </button>
            <span class="text-muted small">Percobaan ke-@Model.CurrentAttempt dari @Model.MaxAttempts</span>
        </div>
    }
    else if (ViewBag.WindowClosed == true)
    {
        @* v32.7 RTH-01 (RTK-LOGIC-02): masa ujian tutup → retake mustahil. Alert informasional (BUKAN tombol disabled), reuse alert Bootstrap existing. *@
        <div class="alert alert-secondary mb-4" role="alert">
            <i class="bi bi-clock-history me-2"></i>
            Masa ujian sudah ditutup. Ujian ulang tidak tersedia untuk assessment ini. Hubungi HC bila perlu kesempatan tambahan.
        </div>
    }

    <!-- Action Buttons -->
    <div class="d-flex gap-2 mb-4">
        @if (!Model.IsPendingGrading && Model.IsPassed && Model.GenerateCertificate)
        {
            <a asp-action="Certificate" asp-route-id="@Model.AssessmentId" class="btn btn-primary" target="_blank">
                <i class="bi bi-award me-1"></i>Lihat Sertifikat
            </a>
        }
        <a href="@backUrl" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Kembali
        </a>
    </div>
</div>

@* === Modal konfirmasi Ujian Ulang (RTK-09 / D-02) — POST ber-antiforgery ke CMP/RetakeExam === *@
<div class="modal fade" id="retakeConfirmModal" tabindex="-1" aria-labelledby="retakeConfirmLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
