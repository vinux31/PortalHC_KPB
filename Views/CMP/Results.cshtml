@model HcPortal.Models.AssessmentResultsViewModel
@using System.Globalization

@{
    ViewData["Title"] = "Hasil Assessment";
    // SEC-02: Validate returnUrl is a local path to prevent open-redirect attacks
    var rawReturnUrl = Context.Request.Query["returnUrl"].ToString();
    var backUrl = (!string.IsNullOrEmpty(rawReturnUrl) && Uri.IsWellFormedUriString(rawReturnUrl, UriKind.Relative))
        ? rawReturnUrl
        : Url.Action("Assessment", "CMP")!;
}

<div class="container-fluid px-4 py-4">
    <!-- Page Header -->
    <div class="mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="mb-1"><i class="bi bi-bar-chart-line me-2"></i>Hasil Assessment</h2>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a asp-action="Assessment">Daftar Assessment</a></li>
                        <li class="breadcrumb-item active">Hasil</li>
                    </ol>
                </nav>
            </div>
            <div>
                <a href="@backUrl" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Kembali
                </a>
            </div>
        </div>
    </div>

    <!-- Results Summary Card -->
    <div class="card shadow-sm mb-4">
        <div class="card-header @(Model.IsPassed ? "bg-success" : "bg-danger") text-white">
            <h4 class="mb-0">@Model.Title</h4>
        </div>
        <div class="card-body">
            <!-- Score Display -->
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="text-center p-4 border rounded">
                        <h6 class="text-muted mb-2">Nilai Anda</h6>
                        <h2 class="mb-1">@Model.Score%</h2>
                        <small class="text-muted">(@Model.CorrectAnswers/@Model.TotalQuestions benar)</small>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="text-center p-4 border rounded">
                        <h6 class="text-muted mb-2">Nilai Kelulusan</h6>
                        <h2 class="mb-0">@Model.PassPercentage%</h2>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="text-center p-4 border rounded">
                        <h6 class="text-muted mb-2">Status</h6>
                        @if (Model.IsPassed)
                        {
                            <span class="badge text-bg-success fs-5 py-2 px-3">
                                <i class="bi bi-check-circle-fill me-1"></i>LULUS
                            </span>
                        }
                        else
                        {
                            <span class="badge text-bg-danger fs-5 py-2 px-3">
                                <i class="bi bi-x-circle-fill me-1"></i>TIDAK LULUS
                            </span>
                        }
                    </div>
                </div>
            </div>

            <!-- Assessment Details -->
            <div class="row mb-3">
                <div class="col-md-4">
                    <p class="mb-1"><strong>Kategori:</strong></p>
                    <span class="badge bg-primary">@Model.Category</span>
                </div>
                <div class="col-md-4">
                    <p class="mb-1"><strong>Selesai:</strong></p>
                    <span>@(Model.CompletedAt?.ToString("dd MMM yyyy HH:mm", CultureInfo.GetCultureInfo("id-ID")) ?? "N/A")</span>
                </div>
                <div class="col-md-4">
                    <p class="mb-1"><strong>Peserta:</strong></p>
                    <span>@Model.UserFullName</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Pesan Motivasi + NomorSertifikat -->
    @if (Model.IsPassed)
    {
        <div class="alert alert-success mb-4">
            <i class="bi bi-check-circle-fill me-2"></i><strong>Selamat!</strong> Anda lulus assessment ini.
        </div>
        @if (!string.IsNullOrEmpty(Model.NomorSertifikat))
        {
            <div class="alert alert-info mb-4 d-flex align-items-center">
                <i class="bi bi-award-fill me-2 fs-5"></i>
                <span>Nomor Sertifikat: <strong>@Model.NomorSertifikat</strong></span>
            </div>
        }
        else if (Model.GenerateCertificate)
        {
            <div class="alert alert-warning mb-4 d-flex align-items-center">
                <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                <span>Sertifikat belum tergenerate. Silakan hubungi administrator.</span>
            </div>
        }
    }
    else
    {
        <div class="alert alert-warning mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i><strong>Terus semangat.</strong> Pelajari kembali materi dan coba lagi.
        </div>
    }

    @* === Section Perbandingan Pre-Post Test (D-11, D-13, D-14) === *@
    @if (ViewBag.HasComparisonSection == true)
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-light fw-bold">
                <i class="bi bi-bar-chart-line me-2" aria-hidden="true"></i> Perbandingan Pre-Post Test
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-bordered mb-0" aria-label="Perbandingan skor Pre-Test dan Post-Test per elemen kompetensi">
                        <thead class="table-light">
                            <tr>
                                <th>Elemen Kompetensi</th>
                                <th class="text-center" style="width: 150px;">Skor Pre</th>
                                <th class="text-center" style="width: 150px;">Skor Post</th>
                                <th class="text-center" style="width: 150px;">Gain Score</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in ViewBag.ComparisonData)
                            {
                                <tr>
                                    <td>@row.ElemenTeknis</td>
                                    <td class="text-center">@($"{row.PreScore:0.#}%")</td>
                                    <td class="text-center">@($"{row.PostScore:0.#}%")</td>
                                    <td class="text-center">
                                        @{
                                            var gain = (double?)row.GainScore;
                                            string gainText, gainClass;
                                            if (gain == null)
                                            {
                                                gainText = "\u2014";
                                                gainClass = "text-secondary";
                                            }
                                            else if (gain > 0)
                                            {
                                                gainText = $"+{gain:0.#}%";
                                                gainClass = "text-success";
                                            }
                                            else if (gain < 0)
                                            {
                                                gainText = $"{gain:0.#}%";
                                                gainClass = "text-danger";
                                            }
                                            else
                                            {
                                                gainText = "0%";
                                                gainClass = "text-secondary";
                                            }
                                        }
                                        <span class="fw-bold @gainClass">@gainText</span>
                                        @if (gain == null && ViewBag.GainScorePending == true)
                                        {
                                            <small class="d-block text-muted">Menunggu penilaian Essay</small>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Analisis Elemen Teknis -->
    @if (Model.ElemenTeknisScores != null && Model.ElemenTeknisScores.Any())
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="bi bi-radar me-2 text-primary"></i>Analisis Elemen Teknis</h5>
            </div>
            <div class="card-body">
                @if (Model.ElemenTeknisScores.Count >= 3)
                {
                    <div class="text-center mb-4">
                        <canvas id="subCompRadarChart" style="max-height: 350px;"></canvas>
                    </div>
                }
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Elemen Teknis</th>
                                <th class="text-center">Benar</th>
                                <th class="text-center">Total</th>
                                <th class="text-center">Persentase</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sc in Model.ElemenTeknisScores)
                            {
                                <tr>
                                    <td>@sc.Name</td>
                                    <td class="text-center">@sc.Correct</td>
                                    <td class="text-center">@sc.Total</td>
                                    <td class="text-center">
                                        <span class="badge @(sc.Percentage >= Model.PassPercentage ? "bg-success" : "bg-danger")">
                                            @sc.Percentage.ToString("F1")%
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light fw-bold">
                            @{
                                var totalBenar = Model.ElemenTeknisScores.Sum(s => s.Correct);
                                var totalSoal = Model.ElemenTeknisScores.Sum(s => s.Total);
                                var totalPct = totalSoal > 0 ? Math.Round((double)totalBenar / totalSoal * 100, 1) : 0;
                            }
                            <tr>
                                <td>Total</td>
                                <td class="text-center">@totalBenar</td>
                                <td class="text-center">@totalSoal</td>
                                <td class="text-center">
                                    <span class="badge @(totalPct >= Model.PassPercentage ? "bg-success" : "bg-danger")">
                                        @totalPct%
                                    </span>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        @if (Model.ElemenTeknisScores.Count >= 3)
        {
            <script>
            document.addEventListener('DOMContentLoaded', function() {
                var labels = @Html.Raw(Json.Serialize(Model.ElemenTeknisScores.Select(s => s.Name)));
                var data = @Html.Raw(Json.Serialize(Model.ElemenTeknisScores.Select(s => s.Percentage)));
                var truncated = labels.map(function(l) { return l.length > 20 ? l.substring(0, 20) + '...' : l; });

                new Chart(document.getElementById('subCompRadarChart'), {
                    type: 'radar',
                    data: {
                        labels: truncated,
                        datasets: [{
                            label: 'Persentase Benar',
                            data: data,
                            backgroundColor: 'rgba(54, 162, 235, 0.2)',
                            borderColor: 'rgba(54, 162, 235, 1)',
                            pointBackgroundColor: 'rgba(54, 162, 235, 1)',
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    title: function(items) { return labels[items[0].dataIndex]; },
                                    label: function(item) { return item.raw + '%'; }
                                }
                            }
                        },
                        scales: {
                            r: {
                                min: 0,
                                max: 100,
                                ticks: { stepSize: 25, callback: function(v) { return v + '%'; } },
                                pointLabels: { font: { size: 11 } }
                            }
                        }
                    }
                });
            });
            </script>
        }
    }

    <!-- Answer Review Section -->
    @if (Model.AllowAnswerReview && Model.QuestionReviews != null)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="bi bi-list-check me-2"></i>Tinjauan Jawaban</h5>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    @foreach (var question in Model.QuestionReviews)
                    {
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="flex-grow-1">
                                    <h6 class="mb-2"><strong>Soal @question.QuestionNumber:</strong> @question.QuestionText</h6>
                                </div>
                                <div>
                                    @if (question.IsCorrect)
                                    {
                                        <span class="badge text-bg-success">
                                            <i class="bi bi-check-circle-fill me-1"></i>Benar
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-danger">
                                            <i class="bi bi-x-circle-fill me-1"></i>Salah
                                        </span>
                                    }
                                </div>
                            </div>

                            <!-- Options List -->
                            <div class="list-group">
                                @foreach (var option in question.Options)
                                {
                                    var itemClass = "";
                                    var icon = "";

                                    if (option.IsCorrect)
                                    {
                                        itemClass = "list-group-item-success";
                                        icon = "bi-check-circle-fill text-success";
                                    }
                                    else if (option.IsSelected && !option.IsCorrect)
                                    {
                                        itemClass = "list-group-item-danger";
                                        icon = "bi-x-circle-fill text-danger";
                                    }

                                    <div class="list-group-item @itemClass d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(icon))
                                        {
                                            <i class="bi @icon me-2"></i>
                                        }
                                        <span>@option.OptionText</span>
                                        @if (option.IsSelected && !option.IsCorrect)
                                        {
                                            <small class="ms-auto text-muted">(Jawaban Anda)</small>
                                        }
                                        @if (option.IsCorrect)
                                        {
                                            <small class="ms-auto text-muted">(Jawaban Benar)</small>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else if (!Model.AllowAnswerReview)
    {
        <div class="alert alert-info mb-4">
            <i class="bi bi-info-circle me-2"></i>Tinjauan jawaban tidak tersedia untuk assessment ini.
        </div>
    }

    <!-- Action Buttons -->
    <div class="d-flex gap-2 mb-4">
        @if (Model.IsPassed && Model.GenerateCertificate)
        {
            <a asp-action="Certificate" asp-route-id="@Model.AssessmentId" class="btn btn-primary" target="_blank">
                <i class="bi bi-award me-1"></i>Lihat Sertifikat
            </a>
        }
        <a href="@backUrl" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Kembali
        </a>
    </div>
</div>

<style>
    @@media print {
        #subCompRadarChart { width: 500px !important; height: 500px !important; }
        .card.shadow-sm { break-inside: avoid; }
        .badge { border: 1px solid #000; }
    }
</style>
