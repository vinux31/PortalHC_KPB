@model HcPortal.Models.AssessmentResultsViewModel
@using System.Globalization

@{
    ViewData["Title"] = "Assessment Results";
    var backUrl = Context.Request.Query["returnUrl"].ToString();
    if (string.IsNullOrEmpty(backUrl)) backUrl = Url.Action("Assessment", "CMP")!;
}

<div class="container-fluid px-4 py-4">
    <!-- Page Header -->
    <div class="mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="mb-1"><i class="bi bi-bar-chart-line me-2"></i>Assessment Results</h2>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a asp-action="Assessment">Assessments</a></li>
                        <li class="breadcrumb-item active">Results</li>
                    </ol>
                </nav>
            </div>
            <div>
                <a href="@backUrl" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Kembali
                </a>
            </div>
        </div>
    </div>

    <!-- Results Summary Card -->
    <div class="card shadow-sm mb-4">
        <div class="card-header @(Model.IsPassed ? "bg-success" : "bg-danger") text-white">
            <h4 class="mb-0">@Model.Title</h4>
        </div>
        <div class="card-body">
            <!-- Score Display -->
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="text-center p-4 border rounded">
                        <h6 class="text-muted mb-2">Your Score</h6>
                        <h2 class="mb-1">@Model.Score%</h2>
                        <small class="text-muted">(@Model.CorrectAnswers/@Model.TotalQuestions correct)</small>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="text-center p-4 border rounded">
                        <h6 class="text-muted mb-2">Pass Threshold</h6>
                        <h2 class="mb-0">@Model.PassPercentage%</h2>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="text-center p-4 border rounded">
                        <h6 class="text-muted mb-2">Status</h6>
                        @if (Model.IsPassed)
                        {
                            <span class="badge text-bg-success fs-5 py-2 px-3">
                                <i class="bi bi-check-circle-fill me-1"></i>PASSED
                            </span>
                        }
                        else
                        {
                            <span class="badge text-bg-danger fs-5 py-2 px-3">
                                <i class="bi bi-x-circle-fill me-1"></i>FAILED
                            </span>
                        }
                    </div>
                </div>
            </div>

            <!-- Assessment Details -->
            <div class="row mb-3">
                <div class="col-md-4">
                    <p class="mb-1"><strong>Category:</strong></p>
                    <span class="badge bg-primary">@Model.Category</span>
                </div>
                <div class="col-md-4">
                    <p class="mb-1"><strong>Completed:</strong></p>
                    <span>@(Model.CompletedAt?.ToString("dd MMM yyyy HH:mm", CultureInfo.GetCultureInfo("id-ID")) ?? "N/A")</span>
                </div>
                <div class="col-md-4">
                    <p class="mb-1"><strong>User:</strong></p>
                    <span>@Model.UserFullName</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Motivational Message -->
    @if (Model.IsPassed)
    {
        <div class="alert alert-success mb-4">
            <i class="bi bi-check-circle-fill me-2"></i><strong>Congratulations!</strong> You passed the assessment.
        </div>
    }
    else
    {
        <div class="alert alert-warning mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i><strong>Keep trying.</strong> Review the material and try again.
        </div>
    }

    <!-- Analisis Sub Kompetensi -->
    @if (Model.SubCompetencyScores != null && Model.SubCompetencyScores.Any())
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="bi bi-radar me-2 text-primary"></i>Analisis Sub Kompetensi</h5>
            </div>
            <div class="card-body">
                @if (Model.SubCompetencyScores.Count >= 3)
                {
                    <div class="text-center mb-4">
                        <canvas id="subCompRadarChart" style="max-height: 350px;"></canvas>
                    </div>
                }
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Sub Kompetensi</th>
                                <th class="text-center">Benar</th>
                                <th class="text-center">Total</th>
                                <th class="text-center">Persentase</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sc in Model.SubCompetencyScores)
                            {
                                <tr>
                                    <td>@sc.Name</td>
                                    <td class="text-center">@sc.Correct</td>
                                    <td class="text-center">@sc.Total</td>
                                    <td class="text-center">
                                        <span class="badge @(sc.Percentage >= Model.PassPercentage ? "bg-success" : "bg-danger")">
                                            @sc.Percentage%
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light fw-bold">
                            @{
                                var totalBenar = Model.SubCompetencyScores.Sum(s => s.Correct);
                                var totalSoal = Model.SubCompetencyScores.Sum(s => s.Total);
                                var totalPct = totalSoal > 0 ? Math.Round((double)totalBenar / totalSoal * 100, 1) : 0;
                            }
                            <tr>
                                <td>Total</td>
                                <td class="text-center">@totalBenar</td>
                                <td class="text-center">@totalSoal</td>
                                <td class="text-center">
                                    <span class="badge @(totalPct >= Model.PassPercentage ? "bg-success" : "bg-danger")">
                                        @totalPct%
                                    </span>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        @if (Model.SubCompetencyScores.Count >= 3)
        {
            <script>
            document.addEventListener('DOMContentLoaded', function() {
                var labels = @Html.Raw(Json.Serialize(Model.SubCompetencyScores.Select(s => s.Name)));
                var data = @Html.Raw(Json.Serialize(Model.SubCompetencyScores.Select(s => s.Percentage)));
                var truncated = labels.map(function(l) { return l.length > 20 ? l.substring(0, 20) + '...' : l; });

                new Chart(document.getElementById('subCompRadarChart'), {
                    type: 'radar',
                    data: {
                        labels: truncated,
                        datasets: [{
                            label: 'Persentase Benar',
                            data: data,
                            backgroundColor: 'rgba(54, 162, 235, 0.2)',
                            borderColor: 'rgba(54, 162, 235, 1)',
                            pointBackgroundColor: 'rgba(54, 162, 235, 1)',
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    title: function(items) { return labels[items[0].dataIndex]; },
                                    label: function(item) { return item.raw + '%'; }
                                }
                            }
                        },
                        scales: {
                            r: {
                                min: 0,
                                max: 100,
                                ticks: { stepSize: 25, callback: function(v) { return v + '%'; } },
                                pointLabels: { font: { size: 11 } }
                            }
                        }
                    }
                });
            });
            </script>
        }
    }

    <!-- Kompetensi Diperoleh (Competencies Earned) -->
    @if (Model.CompetencyGains != null && Model.CompetencyGains.Any())
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="bi bi-award me-2 text-success"></i>Kompetensi Diperoleh</h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Nama Kompetensi</th>
                            <th>Level Diperoleh</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var comp in Model.CompetencyGains)
                        {
                            <tr>
                                <td class="fw-semibold">@comp.CompetencyName</td>
                                <td>
                                    <span class="badge bg-success fs-6">Level @comp.LevelGranted</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- Answer Review Section -->
    @if (Model.AllowAnswerReview && Model.QuestionReviews != null)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="bi bi-list-check me-2"></i>Answer Review</h5>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    @foreach (var question in Model.QuestionReviews)
                    {
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="flex-grow-1">
                                    <h6 class="mb-2"><strong>Question @question.QuestionNumber:</strong> @question.QuestionText</h6>
                                </div>
                                <div>
                                    @if (question.IsCorrect)
                                    {
                                        <span class="badge text-bg-success">
                                            <i class="bi bi-check-circle-fill me-1"></i>Correct
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-danger">
                                            <i class="bi bi-x-circle-fill me-1"></i>Incorrect
                                        </span>
                                    }
                                </div>
                            </div>

                            <!-- Options List -->
                            <div class="list-group">
                                @foreach (var option in question.Options)
                                {
                                    var itemClass = "";
                                    var icon = "";

                                    if (option.IsCorrect)
                                    {
                                        itemClass = "list-group-item-success";
                                        icon = "bi-check-circle-fill text-success";
                                    }
                                    else if (option.IsSelected && !option.IsCorrect)
                                    {
                                        itemClass = "list-group-item-danger";
                                        icon = "bi-x-circle-fill text-danger";
                                    }

                                    <div class="list-group-item @itemClass d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(icon))
                                        {
                                            <i class="bi @icon me-2"></i>
                                        }
                                        <span>@option.OptionText</span>
                                        @if (option.IsSelected && !option.IsCorrect)
                                        {
                                            <small class="ms-auto text-muted">(Your answer)</small>
                                        }
                                        @if (option.IsCorrect)
                                        {
                                            <small class="ms-auto text-muted">(Correct answer)</small>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else if (!Model.AllowAnswerReview)
    {
        <div class="alert alert-info mb-4">
            <i class="bi bi-info-circle me-2"></i>Answer review is not available for this assessment.
        </div>
    }

    <!-- Action Buttons -->
    <div class="d-flex gap-2 mb-4">
        @if (Model.IsPassed)
        {
            <a asp-action="Certificate" asp-route-id="@Model.AssessmentId" class="btn btn-primary" target="_blank">
                <i class="bi bi-award me-1"></i>View Certificate
            </a>
        }
        <a href="@backUrl" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Kembali
        </a>
    </div>
</div>

<style>
    @@media print {
        #subCompRadarChart { width: 500px !important; height: 500px !important; }
        .card.shadow-sm { break-inside: avoid; }
        .badge { border: 1px solid #000; }
    }
</style>
