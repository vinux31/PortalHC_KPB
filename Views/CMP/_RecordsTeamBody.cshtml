@model List<HcPortal.Models.WorkerTrainingStatus>

@if (Model == null || Model.Count == 0)
{
    <tr>
        <td colspan="8" class="text-center p-5 text-muted">
            <i class="bi bi-inbox fs-1 d-block mb-2" aria-hidden="true"></i>
            Data belum ada
        </td>
    </tr>
}
else
{
    @foreach (var worker in Model)
    {
        <tr class="worker-row"
            data-section="@worker.Section"
            data-unit="@worker.Unit"
            data-name="@worker.WorkerName.ToLower()"
            data-nip="@((worker.NIP ?? "").ToLower())">
            <td class="p-3">
                <span class="fw-semibold">@worker.WorkerName</span>
            </td>
            <td class="p-3">@(worker.NIP ?? "---")</td>
            <td class="p-3">@worker.Position</td>
            <td class="p-3">@(worker.Section ?? "---")</td>
            <td class="p-3">@(worker.Unit ?? "---")</td>
            <td class="p-3 text-center">
                <span class="badge bg-primary">@worker.CompletedAssessments</span>
            </td>
            <td class="p-3 text-center">
                <span class="badge bg-success">@worker.CompletedTrainings</span>
            </td>
            <td class="p-3 text-center">
                <a asp-action="RecordsWorkerDetail" asp-route-workerId="@worker.WorkerId"
                   class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-eye me-1" aria-hidden="true"></i>Detail
                </a>
            </td>
        </tr>
    }
}
