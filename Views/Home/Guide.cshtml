@{
    ViewData["Title"] = "Panduan & Bantuan";
    var role = ViewBag.UserRole as string ?? "User";
    var isAdminOrHc = role == "Admin" || role == "HC";
}

<link rel="stylesheet" href="~/css/guide.css" />

<!-- Hero Section -->
<div class="guide-hero" data-aos="fade-down">
    <div class="guide-hero-content">
        <div class="row align-items-center">
            <div class="col-md-8">
                <p class="mb-2" style="opacity:.8; font-size:.9rem; font-weight:600; letter-spacing:.05em; text-transform:uppercase;">
                    <i class="bi bi-book me-1"></i> Pusat Bantuan
                </p>
                <h1 class="mb-2">Panduan & Bantuan</h1>
                <p>Pelajari cara menggunakan setiap fitur HC Portal secara lengkap, langkah demi langkah.</p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <span class="role-badge">
                    <i class="bi bi-person-badge-fill"></i>
                    Anda login sebagai: <strong>@role</strong>
                </span>
            </div>
        </div>
    </div>
</div>

<!-- Search Bar -->
<div class="guide-search-wrapper" data-aos="fade-up" data-aos-delay="100">
    <i class="bi bi-search guide-search-icon"></i>
    <input type="text" id="guideSearchInput" class="guide-search-input"
           placeholder="Cari panduan... (contoh: assessment, coaching, IDP, upload)" autocomplete="off" />
</div>

<!-- ==================================================
     SECTION: Panduan Per Modul (Card Grid)
     ================================================== -->
<div class="guide-section-heading" data-aos="fade-right">
    <div class="guide-section-icon"><i class="bi bi-grid-fill"></i></div>
    <h2>Panduan Penggunaan Fitur</h2>
</div>

<div class="guide-card-grid" id="moduleCardGrid">

    <!-- ===== CARD 1: CMP ===== -->
    <a asp-action="GuideDetail" asp-route-module="cmp" class="guide-module-card card-cmp searchable-card text-decoration-none" data-keywords="cmp competency assessment kkj cpdp mapping sertifikat training records library ujian soal" data-aos="fade-up" data-aos-delay="100">
        <div class="guide-card-header">
            <div class="guide-card-header-icon icon-cmp"><i class="bi bi-journal-bookmark-fill"></i></div>
            <div class="guide-card-header-text">
                <h5>CMP — Competency Management</h5>
                <p>7 panduan tersedia</p>
            </div>
            <i class="bi bi-chevron-right guide-card-chevron"></i>
        </div>
    </a>

    <!-- ===== CARD 2: CDP ===== -->
    <a asp-action="GuideDetail" asp-route-module="cdp" class="guide-module-card card-cdp searchable-card text-decoration-none" data-keywords="cdp career development idp silabus coaching proton deliverable evidence upload approval plan" data-aos="fade-up" data-aos-delay="150">
        <div class="guide-card-header">
            <div class="guide-card-header-icon icon-cdp"><i class="bi bi-graph-up-arrow"></i></div>
            <div class="guide-card-header-text">
                <h5>CDP — Career Development Portal</h5>
                <p>7 panduan tersedia</p>
            </div>
            <i class="bi bi-chevron-right guide-card-chevron"></i>
        </div>
    </a>

    <!-- ===== CARD 3: Akun & Profil ===== -->
    <a asp-action="GuideDetail" asp-route-module="account" class="guide-module-card card-account searchable-card text-decoration-none" data-keywords="akun profil password ganti settings login logout edit nama" data-aos="fade-up" data-aos-delay="200">
        <div class="guide-card-header">
            <div class="guide-card-header-icon icon-account"><i class="bi bi-person-circle"></i></div>
            <div class="guide-card-header-text">
                <h5>Akun & Profil</h5>
                <p>4 panduan tersedia</p>
            </div>
            <i class="bi bi-chevron-right guide-card-chevron"></i>
        </div>
    </a>

    @if (isAdminOrHc)
    {
        <!-- ===== CARD 4: Kelola Data (Admin/HC only) ===== -->
        <a asp-action="GuideDetail" asp-route-module="data" class="guide-module-card card-data searchable-card text-decoration-none" data-keywords="kelola data proton import sinkronisasi override sync" data-aos="fade-up" data-aos-delay="250">
            <div class="guide-card-header">
                <div class="guide-card-header-icon icon-data"><i class="bi bi-database-fill"></i></div>
                <div class="guide-card-header-text">
                    <h5>Kelola Data <span class="guide-step-badge-role ms-1">Admin & HC</span></h5>
                    <p>3 panduan tersedia</p>
                </div>
                <i class="bi bi-chevron-right guide-card-chevron"></i>
            </div>
        </a>

        <!-- ===== CARD 5: Admin Panel (Admin/HC only) ===== -->
        <a asp-action="GuideDetail" asp-route-module="admin" class="guide-module-card card-admin searchable-card text-decoration-none" data-keywords="admin panel kelola pekerja kkj cpdp upload mapping coach coachee assessment monitoring audit log" data-aos="fade-up" data-aos-delay="300">
            <div class="guide-card-header">
                <div class="guide-card-header-icon icon-admin"><i class="bi bi-gear-wide-connected"></i></div>
                <div class="guide-card-header-text">
                    <h5>Admin Panel <span class="guide-step-badge-role ms-1">Admin & HC</span></h5>
                    <p>12 panduan tersedia</p>
                </div>
                <i class="bi bi-chevron-right guide-card-chevron"></i>
            </div>
        </a>
    }

</div><!-- end guide-card-grid -->

<div class="no-results-msg" id="noResultsMsg">
    <i class="bi bi-search fs-2 mb-2 d-block"></i>
    Tidak ada panduan atau FAQ yang cocok dengan pencarian Anda.
</div>

<!-- ==================================================
     SECTION: FAQ — Line Text Style
     ================================================== -->
<div class="guide-faq-section" data-aos="fade-up">
    <div class="guide-section-heading mb-2">
        <div class="guide-section-icon"><i class="bi bi-chat-square-quote-fill"></i></div>
        <h2>Frequently Asked Questions</h2>
    </div>
    <p class="faq-subtitle">Pertanyaan yang sering diajukan. Klik pertanyaan untuk melihat jawabannya.</p>

    <!-- ─── Akun & Login ─── -->
    <div class="faq-category" id="faqGroup-akun">
        <div class="faq-category-title"><i class="bi bi-lock-fill me-1"></i> Akun & Login</div>

        <div class="faq-item searchable-faq" data-keywords="login cara masuk akun">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq1" aria-expanded="false">
                Bagaimana cara login ke HC Portal?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq1" class="collapse faq-answer">
                Buka halaman login di browser Anda, masukkan <strong>email</strong> dan <strong>password</strong> yang sudah terdaftar di sistem, lalu klik <strong>Login</strong>. Pastikan akun Anda sudah aktif dan diverifikasi oleh admin.
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="lupa password reset">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq2" aria-expanded="false">
                Bagaimana jika lupa password?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq2" class="collapse faq-answer">
                Hubungi <strong>Admin atau tim HC</strong> melalui jalur komunikasi internal untuk meminta reset password. Saat ini belum tersedia fitur self-service lupa password.
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="daftar akun baru registrasi pekerja">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq3" aria-expanded="false">
                Siapa yang bisa mendaftarkan akun baru?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq3" class="collapse faq-answer">
                Hanya <strong>Admin dan HC</strong> yang dapat menambahkan pekerja baru ke sistem melalui menu <strong>Admin Panel → Kelola Pekerja</strong>. Pekerja tidak dapat mendaftar sendiri.
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="ganti ubah password settings">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq4" aria-expanded="false">
                Bagaimana cara mengganti password?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq4" class="collapse faq-answer">
                Klik <strong>avatar / nama Anda</strong> di kanan atas navbar → pilih <strong>Settings</strong> → masukkan password lama dan password baru → klik <strong>Simpan</strong>.
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="akses menu tersembunyi role hak">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq5" aria-expanded="false">
                Kenapa saya tidak bisa mengakses menu tertentu?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq5" class="collapse faq-answer">
                Beberapa menu hanya tersedia untuk role tertentu. Menu <strong>Kelola Data</strong> dan <strong>Admin Panel</strong> hanya tampil untuk role <strong>Admin</strong> dan <strong>HC</strong>. Jika Anda merasa perlu akses lebih, hubungi Admin sistem.
            </div>
        </div>
    </div>

    <!-- ─── Assessment ─── -->
    <div class="faq-category" id="faqGroup-assessment">
        <div class="faq-category-title"><i class="bi bi-pencil-square me-1"></i> Assessment</div>

        <div class="faq-item searchable-faq" data-keywords="assessment apa ujian kompetensi">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq6" aria-expanded="false">
                Apa itu assessment?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq6" class="collapse faq-answer">
                Assessment adalah <strong>ujian kompetensi</strong> yang digunakan untuk mengukur tingkat pengetahuan dan kemampuan sesuai KKJ (Kebutuhan Kompetensi Jabatan) pada posisi Anda.
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="cara mengerjakan mulai assessment ujian soal">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq7" aria-expanded="false">
                Bagaimana cara mengerjakan assessment?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq7" class="collapse faq-answer">
                Buka halaman <strong>CMP</strong> → klik tombol <strong>Mulai</strong> pada assessment yang tersedia → kerjakan soal satu per satu → klik <strong>Submit</strong> setelah selesai, lalu konfirmasi pada dialog yang muncul.
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="batas waktu timer assessment ujian">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq8" aria-expanded="false">
                Apakah ada batas waktu mengerjakan assessment?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq8" class="collapse faq-answer">
                Ya, setiap assessment memiliki <strong>timer</strong> yang terlihat di bagian atas halaman ujian. Jika waktu habis, jawaban yang sudah diisi akan <strong>otomatis tersubmit</strong>. Jangan menutup browser saat ujian berlangsung.
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="ulang kembali assessment retake">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq9" aria-expanded="false">
                Bisakah saya mengerjakan ulang assessment?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq9" class="collapse faq-answer">
                Tergantung pada <strong>konfigurasi yang ditetapkan Admin</strong>. Beberapa assessment hanya boleh diambil sekali, sementara yang lain dapat diulang. Hubungi Admin atau HC jika Anda memerlukan izin untuk mengulang.
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="hasil nilai skor assessment lihat">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq10" aria-expanded="false">
                Bagaimana cara melihat hasil assessment?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq10" class="collapse faq-answer">
                Masuk ke halaman <strong>CMP</strong> → buka tab <strong>Results</strong> untuk melihat skor dan detail jawaban pada setiap assessment yang sudah diselesaikan.
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="sertifikat download unduh assessment">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq11" aria-expanded="false">
                Bagaimana cara download sertifikat?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq11" class="collapse faq-answer">
                Masuk ke halaman <strong>CMP</strong> → buka tab <strong>Sertifikat</strong> → klik tombol <strong>Download</strong> pada sertifikat yang tersedia. Sertifikat hanya akan muncul jika Anda telah lulus assessment terkait.
            </div>
        </div>
    </div>

    <!-- ─── CDP & Coaching ─── -->
    <div class="faq-category" id="faqGroup-cdp">
        <div class="faq-category-title"><i class="bi bi-bar-chart-fill me-1"></i> CDP & Coaching</div>

        <div class="faq-item searchable-faq" data-keywords="perbedaan cmp cdp beda apa">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq12" aria-expanded="false">
                Apa perbedaan CMP dan CDP?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq12" class="collapse faq-answer">
                <strong>CMP (Competency Management Program)</strong> berfokus pada pengelolaan kompetensi: KKJ, assessment, dan training records.<br><br>
                <strong>CDP (Career Development Portal)</strong> berfokus pada pengembangan karier: IDP, coaching terstruktur, dan deliverable pengembangan diri.
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="idp individual development plan apa">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq13" aria-expanded="false">
                Apa itu IDP (Individual Development Plan)?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq13" class="collapse faq-answer">
                IDP adalah <strong>rencana pengembangan kompetensi personal</strong> yang disusun untuk setiap pekerja. Berisi daftar aktivitas pengembangan (pelatihan, sertifikasi, dll.) yang perlu diselesaikan dalam periode tertentu.
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="plan idp silabus melihat lihat">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq14" aria-expanded="false">
                Bagaimana cara melihat Plan IDP saya?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq14" class="collapse faq-answer">
                Masuk ke halaman <strong>CDP</strong> → klik menu <strong>Plan IDP / Silabus</strong> untuk melihat daftar rencana pengembangan yang sudah ditetapkan untuk Anda.
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="coaching proton apa itu">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq15" aria-expanded="false">
                Apa itu Coaching Proton?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq15" class="collapse faq-answer">
                Coaching Proton adalah <strong>program coaching terstruktur</strong> di mana setiap coachee (pekerja) memiliki deliverable yang harus diselesaikan, dibuktikan dengan evidence, dan disetujui oleh coach atau atasan yang ditentukan.
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="upload evidence bukti deliverable cara">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq16" aria-expanded="false">
                Bagaimana cara upload evidence deliverable?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq16" class="collapse faq-answer">
                Masuk ke <strong>CDP → Coaching Proton</strong> → klik deliverable yang ingin disubmit → klik tombol <strong>Upload Evidence</strong> → pilih file bukti penyelesaian → klik <strong>Submit</strong> untuk mengirim ke coach/atasan.
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="approve approval deliverable siapa coach atasan">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq17" aria-expanded="false">
                Siapa yang bisa menyetujui (approve) deliverable?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq17" class="collapse faq-answer">
                Deliverable dapat disetujui oleh <strong>Coach yang di-assign</strong> kepada Anda, atau <strong>Atasan langsung</strong> yang tercatat dalam mapping Coach-Coachee. Mapping ini dikelola oleh Admin/HC.
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="progress coaching lihat monitoring">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq18" aria-expanded="false">
                Bagaimana cara melihat coaching progress saya?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq18" class="collapse faq-answer">
                Masuk ke halaman <strong>CDP</strong> → cek bagian <strong>Dashboard</strong> untuk ringkasan progress keseluruhan, atau masuk ke <strong>Coaching Proton</strong> untuk melihat status detail setiap deliverable.
            </div>
        </div>
    </div>

    <!-- ─── KKJ & CPDP ─── -->
    <div class="faq-category" id="faqGroup-kkj">
        <div class="faq-category-title"><i class="bi bi-file-earmark-text-fill me-1"></i> KKJ & CPDP</div>

        <div class="faq-item searchable-faq" data-keywords="kkj matrix apa kebutuhan kompetensi jabatan">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq19" aria-expanded="false">
                Apa itu KKJ Matrix?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq19" class="collapse faq-answer">
                KKJ Matrix (Kebutuhan Kompetensi Jabatan) adalah <strong>dokumen standar kompetensi</strong> yang mendefinisikan kompetensi apa saja yang diperlukan untuk setiap jabatan/posisi dalam organisasi.
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="kkj mana lihat saya dimana">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq20" aria-expanded="false">
                Di mana saya bisa melihat KKJ saya?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq20" class="collapse faq-answer">
                Masuk ke halaman <strong>CMP</strong> → klik tab <strong>Library KKJ</strong>. KKJ yang ditampilkan sudah disesuaikan dengan posisi/jabatan Anda.
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="cpdp apa competency proficiency development program">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq21" aria-expanded="false">
                Apa itu CPDP?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq21" class="collapse faq-answer">
                CPDP (Competency and Proficiency Development Program) adalah <strong>peta program pengembangan kompetensi</strong> yang menghubungkan gap kompetensi pekerja dengan program pelatihan atau kegiatan yang relevan.
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="upload kkj cpdp file admin hc">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq22" aria-expanded="false">
                Bagaimana cara upload file KKJ atau CPDP?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq22" class="collapse faq-answer">
                Fitur ini hanya tersedia untuk <strong>Admin dan HC</strong>. Masuk ke <strong>Admin Panel</strong> → pilih <strong>KKJ Matrix Files</strong> atau <strong>CPDP Files</strong> → klik <strong>Upload File</strong> → pilih file → Simpan.
            </div>
        </div>
    </div>

    @if (isAdminOrHc)
    {
        <!-- ─── Admin & Kelola Data ─── -->
        <div class="faq-category" id="faqGroup-admin">
            <div class="faq-category-title"><i class="bi bi-shield-fill-gear me-1"></i> Admin & Kelola Data</div>

            <div class="faq-item searchable-faq" data-keywords="tambah pekerja baru cara admin">
                <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq23" aria-expanded="false">
                    Bagaimana cara menambahkan pekerja baru?
                    <i class="bi bi-chevron-down faq-chevron"></i>
                </button>
                <div id="faq23" class="collapse faq-answer">
                    Masuk ke <strong>Admin Panel → Kelola Pekerja</strong> → klik tombol <strong>Tambah Pekerja</strong> → isi formulir data pekerja → simpan. Untuk import massal, gunakan fitur <strong>Import Workers</strong> sesuai template Excel yang tersedia.
                </div>
            </div>

            <div class="faq-item searchable-faq" data-keywords="import massal pekerja excel template">
                <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq24" aria-expanded="false">
                    Bagaimana cara import data pekerja secara massal?
                    <i class="bi bi-chevron-down faq-chevron"></i>
                </button>
                <div id="faq24" class="collapse faq-answer">
                    Masuk ke <strong>Admin Panel → Kelola Pekerja</strong> → klik <strong>Import Workers</strong> → download template Excel yang tersedia → isi data pekerja sesuai format → upload kembali file tersebut.
                </div>
            </div>

            <div class="faq-item searchable-faq" data-keywords="mapping coach coachee cara">
                <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq25" aria-expanded="false">
                    Bagaimana cara mapping Coach-Coachee?
                    <i class="bi bi-chevron-down faq-chevron"></i>
                </button>
                <div id="faq25" class="collapse faq-answer">
                    Masuk ke <strong>Admin Panel → Coach-Coachee Mapping</strong> → klik <strong>Tambah Mapping</strong> → pilih Coach dan Coachee → tentukan periode mapping → simpan. Mapping yang sudah tidak aktif dapat dinonaktifkan menggunakan tombol <strong>Nonaktifkan</strong>.
                </div>
            </div>

            <div class="faq-item searchable-faq" data-keywords="audit log apa itu aktivitas">
                <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq26" aria-expanded="false">
                    Apa itu Audit Log?
                    <i class="bi bi-chevron-down faq-chevron"></i>
                </button>
                <div id="faq26" class="collapse faq-answer">
                    Audit Log adalah <strong>catatan otomatis</strong> yang merekam semua aktivitas penting yang dilakukan user di sistem (login, upload file, perubahan data, dll.). Berguna untuk tracking, investigasi, dan keamanan sistem.
                </div>
            </div>

            <div class="faq-item searchable-faq" data-keywords="sinkronisasi sync proton import data">
                <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq27" aria-expanded="false">
                    Bagaimana cara sinkronisasi data dari Proton?
                    <i class="bi bi-chevron-down faq-chevron"></i>
                </button>
                <div id="faq27" class="collapse faq-answer">
                    Masuk ke menu <strong>Kelola Data</strong> di navbar → pilih opsi <strong>Import / Sync Data</strong> → proses sinkronisasi akan berjalan secara otomatis untuk mengambil data terbaru dari sistem Proton.
                </div>
            </div>
        </div>
    }

    <!-- ─── Umum ─── -->
    <div class="faq-category" id="faqGroup-umum">
        <div class="faq-category-title"><i class="bi bi-question-circle-fill me-1"></i> Umum</div>

        <div class="faq-item searchable-faq" data-keywords="browser chrome edge firefox rekomendasi">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq28" aria-expanded="false">
                Browser apa yang direkomendasikan?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq28" class="collapse faq-answer">
                Disarankan menggunakan <strong>Google Chrome</strong>, <strong>Microsoft Edge</strong>, atau <strong>Mozilla Firefox</strong> versi terbaru untuk pengalaman terbaik. Hindari menggunakan Internet Explorer atau browser lawas.
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="hp mobile handphone akses ponsel">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq29" aria-expanded="false">
                Apakah HC Portal bisa diakses dari HP?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq29" class="collapse faq-answer">
                Ya, HC Portal dirancang <strong>responsif (mobile-friendly)</strong> dan dapat diakses melalui browser di perangkat smartphone atau tablet. Namun untuk kemudahan pengisian data yang kompleks, disarankan menggunakan komputer/laptop.
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="kendala masalah error hubungi kontak bantuan">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq30" aria-expanded="false">
                Siapa yang harus dihubungi jika ada kendala?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq30" class="collapse faq-answer">
                Hubungi <strong>tim HC atau Admin sistem</strong> melalui jalur komunikasi internal yang berlaku di organisasi Anda (email, grup pesan, atau datang langsung).
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="role saya apa posisi admin hc coachee">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq31" aria-expanded="false">
                Bagaimana cara mengetahui role saya di sistem?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq31" class="collapse faq-answer">
                Role Anda ditampilkan di <strong>navbar kanan atas</strong>, di bawah nama Anda (contoh: badge "HC", "Admin", "Coachee"). Role juga ditampilkan di halaman ini pada bagian Hero di atas.
            </div>
        </div>

        <div class="faq-item searchable-faq" data-keywords="aman data keamanan privasi">
            <button class="faq-question" data-bs-toggle="collapse" data-bs-target="#faq32" aria-expanded="false">
                Apakah data saya aman di HC Portal?
                <i class="bi bi-chevron-down faq-chevron"></i>
            </button>
            <div id="faq32" class="collapse faq-answer">
                Ya. HC Portal menggunakan sistem <strong>autentikasi dan otorisasi berbasis role</strong> yang ketat. Setiap user hanya dapat mengakses data sesuai hak aksesnya. Data penting diproteksi oleh mekanisme keamanan aplikasi.
            </div>
        </div>
    </div>

</div><!-- end faq section -->

@section Scripts {
<script>
(function () {
    // ─── Update chevron arrow state for Bootstrap collapse (only for FAQs now) ───
    document.querySelectorAll('.guide-faq-section [data-bs-toggle="collapse"]').forEach(function(trigger) {
        var targetId = trigger.getAttribute('data-bs-target');
        var target = document.querySelector(targetId);
        if (!target) return;

        target.addEventListener('show.bs.collapse', function() {
            trigger.setAttribute('aria-expanded', 'true');
        });
        target.addEventListener('hide.bs.collapse', function() {
            trigger.setAttribute('aria-expanded', 'false');
        });
    });

    // ─── Client-side Search ───
    var searchInput = document.getElementById('guideSearchInput');
    var noResults   = document.getElementById('noResultsMsg');

    searchInput.addEventListener('input', function () {
        var q = this.value.toLowerCase().trim();

        // Filter module cards
        var cards = document.querySelectorAll('.searchable-card');
        var visibleCards = 0;
        cards.forEach(function(card) {
            var kw = (card.dataset.keywords || '') + ' ' + card.innerText.toLowerCase();
            if (!q || kw.includes(q)) {
                card.classList.remove('search-hidden');
                visibleCards++;
            } else {
                card.classList.add('search-hidden');
            }
        });

        // Filter FAQ items
        var faqItems = document.querySelectorAll('.searchable-faq');
        var visibleFaq = 0;
        faqItems.forEach(function(item) {
            var kw = (item.dataset.keywords || '') + ' ' + item.innerText.toLowerCase();
            if (!q || kw.includes(q)) {
                item.classList.remove('search-hidden');
                visibleFaq++;
            } else {
                item.classList.add('search-hidden');
            }
        });

        // Show/hide category headings
        document.querySelectorAll('.faq-category').forEach(function(cat) {
            var visible = cat.querySelectorAll('.searchable-faq:not(.search-hidden)').length;
            cat.style.display = visible > 0 ? '' : 'none';
        });

        // Show/hide no-results message
        noResults.style.display = (visibleCards === 0 && visibleFaq === 0 && q) ? 'block' : 'none';
    });
})();
</script>
}
