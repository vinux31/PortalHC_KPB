@model HcPortal.Models.Guide.GuideViewModel
@{
    ViewData["Title"] = "Panduan & Bantuan";
    var printDate = DateTime.Now.ToString("dd/MM/yyyy HH:mm");

    var faqCategoryDisplay = new[]
    {
        (Cat: HcPortal.Models.Guide.FaqCategory.Akun,        Label: "Akun & Login",            Icon: "bi-lock-fill",              Slug: "akun"),
        (Cat: HcPortal.Models.Guide.FaqCategory.Assessment,  Label: "Assessment",              Icon: "bi-pencil-square",          Slug: "assessment"),
        (Cat: HcPortal.Models.Guide.FaqCategory.CdpCoaching, Label: "CDP & Coaching",          Icon: "bi-bar-chart-fill",         Slug: "cdp"),
        (Cat: HcPortal.Models.Guide.FaqCategory.Umum,        Label: "Umum",                    Icon: "bi-question-circle-fill",   Slug: "umum"),
        (Cat: HcPortal.Models.Guide.FaqCategory.KkjCpdp,     Label: "KKJ & CPDP",              Icon: "bi-file-earmark-text-fill", Slug: "kkj"),
        (Cat: HcPortal.Models.Guide.FaqCategory.AdminData,   Label: "Admin & Kelola Data",     Icon: "bi-shield-fill-gear",       Slug: "admin")
    };
}

<link rel="stylesheet" href="~/css/guide.css" />

<a href="#guide-search" class="skip-link">Lompat ke pencarian</a>
<a href="#guide-modules" class="skip-link">Lompat ke modul</a>
<a href="#guide-faq" class="skip-link">Lompat ke FAQ</a>

<main role="main" id="main-content" data-print-date="@printDate">
<div class="guide-hero" data-aos="fade-down">
    <div class="guide-hero-content">
        <div class="row align-items-center">
            <div class="col-12">
                <p class="mb-2" style="opacity:.8; font-size:.9rem; font-weight:600; letter-spacing:.05em; text-transform:uppercase;">
                    <i class="bi bi-book me-1"></i> Pusat Bantuan
                </p>
                <h1 class="mb-2">Panduan & Bantuan</h1>
                <p class="mb-3">Pelajari cara menggunakan setiap fitur HC Portal secara lengkap, langkah demi langkah.</p>
                <span class="guide-role-badge">
                    <i class="bi bi-person-badge-fill"></i>
                    Anda login sebagai: <strong>@Model.UserRole</strong>
                </span>
            </div>
        </div>
    </div>
</div>

<nav role="navigation" aria-label="Breadcrumb navigasi" class="guide-breadcrumb mb-3" data-aos="fade-down">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">
                <i class="bi bi-house-door me-1" aria-hidden="true"></i>Beranda
            </a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Panduan</li>
    </ol>
</nav>

<div class="guide-search-wrapper" id="guide-search" data-aos="fade-up" data-aos-delay="100">
    <i class="bi bi-search guide-search-icon" aria-hidden="true"></i>
    <input type="text" id="guideSearchInput" class="guide-search-input"
           aria-label="Cari panduan"
           aria-describedby="search-hint keyboard-help"
           placeholder="Cari panduan... (contoh: assessment, coaching, IDP, upload)" autocomplete="off" />
    <span id="search-hint" class="sr-only">Ketik untuk mencari panduan dan FAQ</span>
    <div id="search-results" aria-live="polite" aria-atomic="true" class="sr-only"></div>
    <div id="keyboard-help" class="sr-only">Gunakan Tab untuk navigasi, Enter/Space untuk membuka, Escape untuk menutup pencarian</div>
</div>

<div class="guide-filter-chips" data-aos="fade-up" data-aos-delay="120" role="group" aria-label="Filter berdasarkan role">
    <span class="filter-label">Filter role:</span>
    <button type="button" class="filter-chip active" data-role-filter="all">Semua</button>
    <button type="button" class="filter-chip" data-role-filter="coachee">Coachee</button>
    <button type="button" class="filter-chip" data-role-filter="coach">Coach</button>
    <button type="button" class="filter-chip" data-role-filter="atasan">Atasan</button>
    <button type="button" class="filter-chip" data-role-filter="manager">Manager</button>
    <button type="button" class="filter-chip" data-role-filter="admin">Admin &amp; HC</button>
</div>

<section aria-labelledby="modules-heading">
<div class="guide-section-heading" data-aos="fade-right" id="modules-heading">
    <div class="guide-section-icon"><i class="bi bi-grid-fill" aria-hidden="true"></i></div>
    <h2>Panduan Penggunaan Fitur</h2>
</div>

<div class="guide-card-grid" id="guide-modules" role="list">
    @foreach (var card in Model.ModuleCards)
    {
        <partial name="_Guide/_ModuleCard" model="card" />
    }
</div>
</section>

<div class="no-results-msg" id="noResultsMsg" role="status" aria-live="polite">
    <i class="bi bi-search fs-2 mb-2 d-block" aria-hidden="true"></i>
    Tidak ada panduan atau FAQ yang cocok dengan pencarian Anda.
</div>

<section aria-labelledby="faq-heading" class="guide-faq-section" id="guide-faq" data-aos="fade-up">
    <div class="guide-section-heading mb-2">
        <div class="guide-section-icon"><i class="bi bi-chat-square-quote-fill" aria-hidden="true"></i></div>
        <h2 id="faq-heading">Frequently Asked Questions</h2>
    </div>
    <p class="faq-subtitle">Pertanyaan yang sering diajukan. Klik pertanyaan untuk melihat jawabannya.</p>

    <div class="d-flex justify-content-end mb-3">
        <button type="button" class="btn btn-outline-secondary btn-sm" id="faqToggleAll" onclick="toggleAllFaq()">
            <i class="bi bi-arrows-expand me-1"></i> Buka Semua
        </button>
    </div>

    @foreach (var grp in faqCategoryDisplay)
    {
        if (!Model.FaqsByCategory.TryGetValue(grp.Cat, out var faqs) || faqs.Count == 0)
        {
            continue;
        }
        <div class="faq-category" id="faqGroup-@grp.Slug">
            <div class="faq-category-title"><i class="bi @grp.Icon me-1"></i> @grp.Label</div>
            @foreach (var faq in faqs)
            {
                <partial name="_Guide/_FaqItem" model="faq" />
            }
        </div>
    }
</section>

<button type="button" class="guide-back-to-top" id="backToTopBtn" aria-label="Kembali ke atas" title="Kembali ke atas">
    <i class="bi bi-chevron-up"></i>
</button>
</main>

@section Scripts {
<script>
// ─── Back-to-top button ───
(function () {
    var btn = document.getElementById('backToTopBtn');
    if (!btn) return;
    window.addEventListener('scroll', function () {
        btn.classList.toggle('visible', window.scrollY > 300);
    });
    btn.addEventListener('click', function () {
        window.scrollTo({ top: 0, behavior: 'smooth' });
    });
})();

function toggleAllFaq() {
    var btn = document.getElementById('faqToggleAll');
    var allCollapses = document.querySelectorAll('.faq-answer');
    var anyOpen = Array.from(allCollapses).some(function(el) { return el.classList.contains('show'); });

    allCollapses.forEach(function(el) {
        var bsCollapse = bootstrap.Collapse.getOrCreateInstance(el, { toggle: false });
        if (anyOpen) {
            bsCollapse.hide();
        } else {
            bsCollapse.show();
        }
    });

    if (anyOpen) {
        btn.innerHTML = '<i class="bi bi-arrows-expand me-1"></i> Buka Semua';
    } else {
        btn.innerHTML = '<i class="bi bi-arrows-collapse me-1"></i> Tutup Semua';
    }
}

// ─── Role filter chips (Phase 4) ───
(function () {
    var chips = document.querySelectorAll('.filter-chip');
    if (chips.length === 0) return;

    chips.forEach(function(chip) {
        chip.addEventListener('click', function() {
            chips.forEach(function(c) { c.classList.remove('active'); });
            this.classList.add('active');

            var role = this.dataset.roleFilter;

            // Map chip role-filter slug → RoleGroup tokens di data-roles
            var roleMap = {
                'coachee':  ['coachee'],
                'coach':    ['coach'],
                'atasan':   ['atasan'],
                'manager':  ['manager'],
                'admin':    ['adminhc']
            };
            var targets = roleMap[role] || [];

            document.querySelectorAll('.searchable-card, .searchable-faq').forEach(function(el) {
                if (role === 'all') {
                    el.classList.remove('role-filtered-out');
                    return;
                }
                var roles = (el.dataset.roles || '').toLowerCase().split(/\s+/);
                // Match kalau item tagged All, atau salah satu target match
                var match = roles.includes('all') || targets.some(function(t) { return roles.includes(t); });
                el.classList.toggle('role-filtered-out', !match);
            });

            document.querySelectorAll('.faq-category').forEach(function(cat) {
                var visible = cat.querySelectorAll('.searchable-faq:not(.role-filtered-out)').length;
                cat.style.display = visible > 0 ? '' : 'none';
            });
        });
    });
})();

(function () {
    // ─── Mobile-specific placeholder text ───
    var searchInput = document.getElementById('guideSearchInput');
    if (searchInput && window.innerWidth <= 768) {
        searchInput.placeholder = 'Cari panduan...';
    }

    // ─── Smooth scroll to top when clicking module cards ───
    document.querySelectorAll('.guide-module-card').forEach(function(card) {
        card.addEventListener('click', function(e) {
            setTimeout(function() {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }, 100);
        });
    });

    // ─── Update chevron arrow state for Bootstrap collapse (only for FAQs now) ───
    document.querySelectorAll('.guide-faq-section [data-bs-toggle="collapse"]').forEach(function(trigger) {
        var targetId = trigger.getAttribute('data-bs-target');
        var target = document.querySelector(targetId);
        if (!target) return;

        trigger.addEventListener('keydown', function(e) {
            if (e.key === ' ' || e.key === 'Spacebar') {
                e.preventDefault();
                this.click();
            }
        });

        target.addEventListener('show.bs.collapse', function() {
            trigger.setAttribute('aria-expanded', 'true');
            target.classList.add('fade-in');
        });
        target.addEventListener('hide.bs.collapse', function() {
            trigger.setAttribute('aria-expanded', 'false');
            target.classList.remove('fade-in');
        });
    });

    // ─── Client-side Search ───
    var noResults   = document.getElementById('noResultsMsg');
    var searchResults = document.getElementById('search-results');

    searchInput.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            this.value = '';
            this.dispatchEvent(new Event('input'));
            this.blur();
        }
    });

    searchInput.addEventListener('input', function () {
        var q = this.value.toLowerCase().trim();

        var cards = document.querySelectorAll('.searchable-card');
        var visibleCards = 0;
        cards.forEach(function(card) {
            var kw = (card.dataset.keywords || '') + ' ' + card.innerText.toLowerCase();
            if (!q || kw.includes(q)) {
                card.classList.remove('search-hidden');
                visibleCards++;
            } else {
                card.classList.add('search-hidden');
            }
        });

        var faqItems = document.querySelectorAll('.searchable-faq');
        var visibleFaq = 0;
        faqItems.forEach(function(item) {
            var kw = (item.dataset.keywords || '') + ' ' + item.innerText.toLowerCase();
            if (!q || kw.includes(q)) {
                item.classList.remove('search-hidden');
                visibleFaq++;
            } else {
                item.classList.add('search-hidden');
            }
        });

        document.querySelectorAll('.faq-category').forEach(function(cat) {
            var visible = cat.querySelectorAll('.searchable-faq:not(.search-hidden)').length;
            cat.style.display = visible > 0 ? '' : 'none';
        });

        noResults.style.display = (visibleCards === 0 && visibleFaq === 0 && q) ? 'block' : 'none';

        if (q && visibleCards === 0 && visibleFaq === 0) {
            searchInput.classList.add('shake');
            setTimeout(function() {
                searchInput.classList.remove('shake');
            }, 400);
        }

        var totalCards = cards.length;
        if (q && visibleCards === 0) {
            searchResults.textContent = 'Tidak ada panduan yang cocok dengan pencarian "' + q + '"';
        } else if (q) {
            searchResults.textContent = 'Ditemukan ' + visibleCards + ' dari ' + totalCards + ' panduan untuk "' + q + '"';
        } else {
            searchResults.textContent = '';
        }

        highlightSearchTerms(q, document.querySelector('.guide-card-grid'));
        highlightSearchTerms(q, document.querySelector('.guide-faq-section'));
    });

    function highlightSearchTerms(query, container) {
        if (!query) {
            container.querySelectorAll('mark.search-highlight').forEach(function(mark) {
                var parent = mark.parentNode;
                parent.replaceChild(document.createTextNode(mark.textContent), mark);
                parent.normalize();
            });
            return;
        }

        container.querySelectorAll('mark.search-highlight').forEach(function(mark) {
            var parent = mark.parentNode;
            parent.replaceChild(document.createTextNode(mark.textContent), mark);
            parent.normalize();
        });

        var walker = document.createTreeWalker(
            container,
            NodeFilter.SHOW_TEXT,
            {
                acceptNode: function(node) {
                    if (node.parentElement.tagName.match(/^(SCRIPT|STYLE|MARK|INPUT|TEXTAREA)$/)) {
                        return NodeFilter.FILTER_REJECT;
                    }
                    return NodeFilter.FILTER_ACCEPT;
                }
            }
        );

        var textNodes = [];
        var node;
        while (node = walker.nextNode()) {
            if (node.textContent.toLowerCase().includes(query)) {
                textNodes.push(node);
            }
        }

        textNodes.forEach(function(textNode) {
            var text = textNode.textContent;
            var regex = new RegExp('(' + query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
            if (regex.test(text)) {
                var fragment = document.createDocumentFragment();
                var lastIdx = 0;
                text.replace(regex, function(match, p1, idx) {
                    if (idx > lastIdx) {
                        fragment.appendChild(document.createTextNode(text.slice(lastIdx, idx)));
                    }
                    var mark = document.createElement('mark');
                    mark.className = 'search-highlight';
                    mark.textContent = match;
                    fragment.appendChild(mark);
                    lastIdx = idx + match.length;
                });
                if (lastIdx < text.length) {
                    fragment.appendChild(document.createTextNode(text.slice(lastIdx)));
                }
                textNode.parentNode.replaceChild(fragment, textNode);
            }
        });
    }
})();
</script>
}
