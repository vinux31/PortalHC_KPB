@model dynamic

@{
    ViewData["Title"] = "Detail Panduan";
    var module = ViewBag.Module as string ?? "cmp";
    var userRole = ViewBag.UserRole as string ?? "User";
    
    string moduleTitle = "";
    string moduleIcon = "";
    string moduleCategory = "";
    
    string moduleBreadcrumb = "";

    switch (module)
    {
        case "cmp":
            moduleTitle = "CMP — Competency Management";
            moduleIcon = "bi-journal-bookmark-fill";
            moduleCategory = "cmp";
            moduleBreadcrumb = "CMP";
            break;
        case "cdp":
            moduleTitle = "CDP — Career Development Portal";
            moduleIcon = "bi-graph-up-arrow";
            moduleCategory = "cdp";
            moduleBreadcrumb = "CDP";
            break;
        case "account":
            moduleTitle = "Akun & Profil";
            moduleIcon = "bi-person-circle";
            moduleCategory = "account";
            moduleBreadcrumb = "Akun";
            break;
        case "data":
            moduleTitle = "Kelola Data";
            moduleIcon = "bi-database-fill";
            moduleCategory = "data";
            moduleBreadcrumb = "Kelola Data";
            break;
        case "admin":
            moduleTitle = "Admin Panel";
            moduleIcon = "bi-gear-wide-connected";
            moduleCategory = "admin";
            moduleBreadcrumb = "Admin Panel";
            break;
    }
}

<link rel="stylesheet" href="~/css/guide.css" />

<main role="main" id="main-content">
<!-- Breadcrumb -->
<nav role="navigation" aria-label="Breadcrumb navigasi" class="guide-breadcrumb mb-3" data-aos="fade-down">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">
                <i class="bi bi-house-door me-1" aria-hidden="true"></i>Beranda
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Guide" class="text-decoration-none text-muted">Panduan</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">@moduleBreadcrumb</li>
    </ol>
</nav>

<!-- Header Detail -->
<div class="guide-detail-header @($"guide-header-{moduleCategory}")" data-aos="fade-up" data-aos-delay="100">
    <div class="guide-detail-header-icon">
        <i class="bi @moduleIcon"></i>
    </div>
    <div class="guide-detail-header-text">
        <h2 class="mb-1">@moduleTitle</h2>
        <p class="mb-0 text-white-50">Panduan langkah demi langkah penggunaan fitur</p>
    </div>
</div>

<!-- Tutorial Lengkap (PDF-style guides) -->
@if (module == "cmp")
{
<div class="guide-tutorial-card guide-tutorial-card--cmp" data-aos="fade-up" data-aos-delay="150">
    <div class="guide-tutorial-inner d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div class="d-flex align-items-center gap-3">
            <div class="guide-tutorial-icon">
                <i class="bi bi-file-earmark-pdf-fill fs-4"></i>
            </div>
            <div>
                <h5 class="guide-tutorial-title mb-1 fw-bold">Panduan Lengkap Assessment</h5>
                <p class="mb-0 text-muted small">Tutorial end-to-end mengerjakan assessment: dari mulai ujian, mengerjakan soal, submit, melihat hasil, hingga download sertifikat.</p>
            </div>
        </div>
        <div class="d-flex gap-2">
            <a href="~/documents/guides/Panduan-Lengkap-Assessment.html" target="_blank" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-eye me-1"></i> Lihat
            </a>
            <a href="~/documents/guides/Panduan-Lengkap-Assessment.html" download="Panduan-Lengkap-Assessment.html" class="btn btn-primary btn-sm">
                <i class="bi bi-download me-1"></i> Download
            </a>
        </div>
    </div>
</div>
}
else if (module == "cdp")
{
<div class="guide-tutorial-card guide-tutorial-card--cdp" data-aos="fade-up" data-aos-delay="150">
    <div class="guide-tutorial-inner d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div class="d-flex align-items-center gap-3">
            <div class="guide-tutorial-icon">
                <i class="bi bi-file-earmark-pdf-fill fs-4"></i>
            </div>
            <div>
                <h5 class="guide-tutorial-title mb-1 fw-bold">Panduan Lengkap Coaching Proton</h5>
                <p class="mb-0 text-muted small">Tutorial end-to-end untuk Coachee, Coach, dan Atasan: dari melihat silabus, upload evidence, approval, hingga Final Assessment.</p>
            </div>
        </div>
        <div class="d-flex gap-2">
            <a href="~/documents/guides/Panduan-Lengkap-Coaching-Proton.html" target="_blank" class="btn btn-outline-success btn-sm">
                <i class="bi bi-eye me-1"></i> Lihat
            </a>
            <a href="~/documents/guides/Panduan-Lengkap-Coaching-Proton.html" download="Panduan-Lengkap-Coaching-Proton.html" class="btn btn-success btn-sm">
                <i class="bi bi-download me-1"></i> Download
            </a>
        </div>
    </div>
</div>
}
else if (module == "admin")
{
@if (userRole == "Admin" || userRole == "HC")
{
<div class="guide-tutorial-card guide-tutorial-card--admin" data-aos="fade-up" data-aos-delay="150">
    <div class="guide-tutorial-inner d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div class="d-flex align-items-center gap-3">
            <div class="guide-tutorial-icon">
                <i class="bi bi-file-earmark-pdf-fill fs-4"></i>
            </div>
            <div>
                <h5 class="guide-tutorial-title mb-1 fw-bold">Panduan Konfigurasi Active Directory</h5>
                <p class="mb-0 text-muted small">Tutorial lengkap konfigurasi Active Directory untuk integrasi autentikasi HC Portal.</p>
            </div>
        </div>
        <div class="d-flex gap-2">
            <a href="~/documents/guides/ActiveDirectory-Guide.html" target="_blank" class="btn btn-outline-danger btn-sm">
                <i class="bi bi-eye me-1"></i> Lihat
            </a>
            <a href="~/documents/guides/ActiveDirectory-Guide.html" download="ActiveDirectory-Guide.html" class="btn btn-danger btn-sm">
                <i class="bi bi-download me-1"></i> Download
            </a>
        </div>
    </div>
</div>
}
}

<!-- List Panduan (Fungsi expandable steps) -->
<div class="guide-detail-content" data-aos="fade-up" data-aos-delay="200">
    
    <div class="guide-list-container accordion" id="guideAccordion">
        
        @if (module == "cmp")
        {
            <!-- CMP 1 -->
            <div class="guide-list-item accordion-item">
                <h2 class="accordion-header" id="cmpHeading1">
                    <button class="accordion-button collapsed guide-list-btn" type="button" data-bs-toggle="collapse" data-bs-target="#cmpCollapse1" aria-expanded="false">
                        Cara Melihat Library KKJ (Kebutuhan Kompetensi Jabatan)
                    </button>
                </h2>
                <div id="cmpCollapse1" class="accordion-collapse collapse" data-bs-parent="">
                    <div class="accordion-body guide-list-body">
                        <ul class="guide-steps">
                            <li class="guide-step-item"><div class="guide-step-badge">1</div><div class="guide-step-text"><strong>Akses CMP</strong><span>Klik menu <b>CMP</b> di navbar atas.</span></div></li>
                            <li class="guide-step-item"><div class="guide-step-badge">2</div><div class="guide-step-text"><strong>Buka Tab Library</strong><span>Klik tab <b>Library KKJ</b>. Anda akan melihat daftar kompetensi khusus untuk posisi Anda.</span></div></li>
                        </ul>
                    </div>
                </div>
            </div>
            
            <!-- CMP 2 -->
            <div class="guide-list-item accordion-item">
                <h2 class="accordion-header" id="cmpHeading2">
                    <button class="accordion-button collapsed guide-list-btn" type="button" data-bs-toggle="collapse" data-bs-target="#cmpCollapse2" aria-expanded="false">
                        Cara Melihat Mapping KKJ — CPDP
                    </button>
                </h2>
                <div id="cmpCollapse2" class="accordion-collapse collapse" data-bs-parent="">
                    <div class="accordion-body guide-list-body">
                        <ul class="guide-steps">
                            <li class="guide-step-item"><div class="guide-step-badge">1</div><div class="guide-step-text"><strong>Akses CMP</strong><span>Klik menu <b>CMP</b> di navbar atas.</span></div></li>
                            <li class="guide-step-item"><div class="guide-step-badge">2</div><div class="guide-step-text"><strong>Buka Tab Mapping</strong><span>Klik tab <b>CPDP Mapping</b> untuk melihat pemetaan pengembangan kompetensi Anda.</span></div></li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- CMP 3 (Training Records) -->
            <div class="guide-list-item accordion-item">
                <h2 class="accordion-header" id="cmpHeading6">
                    <button class="accordion-button collapsed guide-list-btn" type="button" data-bs-toggle="collapse" data-bs-target="#cmpCollapse6" aria-expanded="false">
                        Cara Melihat Riwayat Training (Capability Building Records)
                    </button>
                </h2>
                <div id="cmpCollapse6" class="accordion-collapse collapse" data-bs-parent="">
                    <div class="accordion-body guide-list-body">
                        <ul class="guide-steps">
                            <li class="guide-step-item"><div class="guide-step-badge">1</div><div class="guide-step-text"><strong>Buka Tab Training Records</strong><span>Di menu CMP, klik tab <b>Training Records</b> (Riwayat Pelatihan).</span></div></li>
                            <li class="guide-step-item"><div class="guide-step-badge">2</div><div class="guide-step-text"><strong>Review Riwayat</strong><span>Semua pelatihan baik internal maupun eksternal yang di-input oleh HC akan tampil di tabel riwayat beserta jam pelatihannya.</span></div></li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- CMP 7 -->
            @if (userRole == "Admin" || userRole == "HC")
            {
            <div class="guide-list-item accordion-item">
                <h2 class="accordion-header" id="cmpHeading7">
                    <button class="accordion-button collapsed guide-list-btn" type="button" data-bs-toggle="collapse" data-bs-target="#cmpCollapse7" aria-expanded="false">
                        Cara Monitoring Records Tim <span class="guide-role-badge ms-2">Atasan / HC</span>
                    </button>
                </h2>
                <div id="cmpCollapse7" class="accordion-collapse collapse" data-bs-parent="">
                    <div class="accordion-body guide-list-body">
                        <ul class="guide-steps">
                            <li class="guide-step-item"><div class="guide-step-badge">1</div><div class="guide-step-text"><strong>Tab Records Team</strong><span>Di menu CMP, klik tab <b>Records Team</b>.</span></div></li>
                            <li class="guide-step-item"><div class="guide-step-badge">2</div><div class="guide-step-text"><strong>List Anggota Tim</strong><span>Anda akan melihat semua anggota tim di bawah supervisi Anda beserta persentase kepatuhan (compliance) dan jam pelatihannya.</span></div></li>
                            <li class="guide-step-item"><div class="guide-step-badge">3</div><div class="guide-step-text"><strong>Detail Pekerja</strong><span>Klik nama pekerja untuk melihat lebih detail riwayat assessment dan training-nya.</span></div></li>
                        </ul>
                    </div>
                </div>
            </div>
            }
        }
        else if (module == "cdp")
        {
            <!-- CDP Guides -->
            <!-- CDP 1 -->
            <div class="guide-list-item accordion-item">
                <h2 class="accordion-header" id="cdpHeading1">
                    <button class="accordion-button collapsed guide-list-btn btn-cdp" type="button" data-bs-toggle="collapse" data-bs-target="#cdpCollapse1">
                        Cara Melihat Plan IDP / Silabus
                    </button>
                </h2>
                <div id="cdpCollapse1" class="accordion-collapse collapse" data-bs-parent="">
                    <div class="accordion-body guide-list-body">
                        <ul class="guide-steps">
                            <li class="guide-step-item step-variant-green"><div class="guide-step-badge">1</div><div class="guide-step-text"><strong>Masuk ke CDP</strong><span>Pilih menu <b>CDP</b> di navbar.</span></div></li>
                            <li class="guide-step-item step-variant-green"><div class="guide-step-badge">2</div><div class="guide-step-text"><strong>Buka Plan IDP</strong><span>Pada bagian sidebar menu CDP, klik <b>Plan IDP / Silabus</b>. Sistem akan menampilkan daftar silabus sesuai jabatan dan level Anda.</span></div></li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- CDP 2-4 removed: covered by Panduan Lengkap Coaching Proton PDF tutorial -->

            <!-- CDP 5 (Approve/Reject — Admin/HC only) -->
            @if (userRole == "Admin" || userRole == "HC")
            {
            <div class="guide-list-item accordion-item">
                <h2 class="accordion-header" id="cdpHeading5">
                    <button class="accordion-button collapsed guide-list-btn btn-cdp" type="button" data-bs-toggle="collapse" data-bs-target="#cdpCollapse5">
                        Cara Approve / Reject Deliverable (Coaching Guidance) <span class="guide-role-badge ms-2">Admin / HC</span>
                    </button>
                </h2>
                <div id="cdpCollapse5" class="accordion-collapse collapse" data-bs-parent="">
                    <div class="accordion-body guide-list-body">
                        <ul class="guide-steps">
                            <li class="guide-step-item step-variant-green"><div class="guide-step-badge">1</div><div class="guide-step-text"><strong>Cek Request Masuk</strong><span>Buka CDP dan cek notifikasi approval yang muncul saat coachee submit evidence.</span></div></li>
                            <li class="guide-step-item step-variant-green"><div class="guide-step-badge">2</div><div class="guide-step-text"><strong>Review Bukti</strong><span>Download evidence yang disertakan coachee tersebut. Review kelengkapannya.</span></div></li>
                            <li class="guide-step-item step-variant-green"><div class="guide-step-badge">3</div><div class="guide-step-text"><strong>Aksi Approve/Reject</strong><span>Klik tombol <b>Approve</b> hijau jika sesuai, atau <b>Reject</b> (beri catatan perbaikan) jika evidence belum memenuhi standar.</span></div></li>
                        </ul>
                    </div>
                </div>
            </div>
            }

            <!-- CDP 6: Coaching Proton Dashboard -->
            @if (userRole == "Admin" || userRole == "HC")
            {
            <div class="guide-list-item accordion-item">
                <h2 class="accordion-header" id="cdpHeading6">
                    <button class="accordion-button collapsed guide-list-btn btn-cdp" type="button" data-bs-toggle="collapse" data-bs-target="#cdpCollapse6">
                        Cara Melihat Coaching Proton Dashboard <span class="guide-role-badge ms-2">Admin / HC</span>
                    </button>
                </h2>
                <div id="cdpCollapse6" class="accordion-collapse collapse" data-bs-parent="">
                    <div class="accordion-body guide-list-body">
                        <ul class="guide-steps">
                            <li class="guide-step-item step-variant-green"><div class="guide-step-badge">1</div><div class="guide-step-text"><strong>Akses Dashboard</strong><span>Di halaman CDP, klik kartu <b>Coaching Proton Dashboard</b>.</span></div></li>
                            <li class="guide-step-item step-variant-green"><div class="guide-step-badge">2</div><div class="guide-step-text"><strong>Monitoring Keseluruhan</strong><span>Lihat chart progress dan statistik coaching secara global (untuk HC) atau level Unit Kerja.</span></div></li>
                            <li class="guide-step-item step-variant-green"><div class="guide-step-badge">3</div><div class="guide-step-text"><strong>Filter Data</strong><span>Gunakan filter Section, Unit, Kategori, dan Track untuk mempersempit data yang ditampilkan.</span></div></li>
                        </ul>
                    </div>
                </div>
            </div>
            }

            <!-- CDP 7 -->
            <div class="guide-list-item accordion-item">
                <h2 class="accordion-header" id="cdpHeading7">
                    <button class="accordion-button collapsed guide-list-btn btn-cdp" type="button" data-bs-toggle="collapse" data-bs-target="#cdpCollapse7">
                        Cara Melihat Daftar Deliverable & Status Progress
                    </button>
                </h2>
                <div id="cdpCollapse7" class="accordion-collapse collapse" data-bs-parent="">
                    <div class="accordion-body guide-list-body">
                        <ul class="guide-steps">
                            <li class="guide-step-item step-variant-green"><div class="guide-step-badge">1</div><div class="guide-step-text"><strong>Buka Halaman Deliverable</strong><span>Masuk ke menu <b>CDP</b>, klik <b>Deliverable</b> di panel navigasi kiri.</span></div></li>
                            <li class="guide-step-item step-variant-green"><div class="guide-step-badge">2</div><div class="guide-step-text"><strong>Pantau Status Progress</strong><span>Lihat daftar deliverable yang ditugaskan. Status: <i>Not Started, In Progress, Pending Approval, Approved, Rejected</i>. Filter berdasarkan status atau periode.</span></div></li>
                            <li class="guide-step-item step-variant-green"><div class="guide-step-badge">3</div><div class="guide-step-text"><strong>Detail Deliverable</strong><span>Klik judul deliverable untuk melihat deskripsi lengkap, target tanggal selesai, dan riwayat coaching session.</span></div></li>
                        </ul>
                    </div>
                </div>
            </div>
        }
        else if (module == "account")
        {
            <!-- Account Guides -->
            <!-- Account 1 -->
            <div class="guide-list-item accordion-item">
                <h2 class="accordion-header" id="accHeading1">
                    <button class="accordion-button collapsed guide-list-btn btn-account" type="button" data-bs-toggle="collapse" data-bs-target="#accCollapse1">
                        Cara Login ke HC Portal
                    </button>
                </h2>
                <div id="accCollapse1" class="accordion-collapse collapse" data-bs-parent="">
                    <div class="accordion-body guide-list-body">
                        <ul class="guide-steps">
                            <li class="guide-step-item step-variant-teal"><div class="guide-step-badge">1</div><div class="guide-step-text"><strong>Buka Portal</strong><span>Akses URL HC Portal melalui browser.</span></div></li>
                            <li class="guide-step-item step-variant-teal"><div class="guide-step-badge">2</div><div class="guide-step-text"><strong>Masukkan Kredensial</strong><span>Ketik <b>email</b> dan <b>password</b> yang sudah diaktifkan. Klik Log In.</span></div></li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Account 2,3 -->
            <div class="guide-list-item accordion-item">
                <h2 class="accordion-header" id="accHeading2">
                    <button class="accordion-button collapsed guide-list-btn btn-account" type="button" data-bs-toggle="collapse" data-bs-target="#accCollapse2">
                        Cara Melihat & Edit Profil (Nama, Posisi)
                    </button>
                </h2>
                <div id="accCollapse2" class="accordion-collapse collapse" data-bs-parent="">
                    <div class="accordion-body guide-list-body">
                        <ul class="guide-steps">
                            <li class="guide-step-item step-variant-teal"><div class="guide-step-badge">1</div><div class="guide-step-text"><strong>Buka Profil</strong><span>Klik avatar profil Anda di pojok kanan atas layar, lalu pilih <b>My Profile</b>.</span></div></li>
                            <li class="guide-step-item step-variant-teal"><div class="guide-step-badge">2</div><div class="guide-step-text"><strong>Edit Data Personal</strong><span>Klik tombol pensil/Edit di profil. Edit informasi yang diperlukan, lalu tekan Simpan.</span></div></li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Account 4 -->
            <div class="guide-list-item accordion-item">
                <h2 class="accordion-header" id="accHeading3">
                    <button class="accordion-button collapsed guide-list-btn btn-account" type="button" data-bs-toggle="collapse" data-bs-target="#accCollapse3">
                        Cara Mengganti Password
                    </button>
                </h2>
                <div id="accCollapse3" class="accordion-collapse collapse" data-bs-parent="">
                    <div class="accordion-body guide-list-body">
                        <ul class="guide-steps">
                            <li class="guide-step-item step-variant-teal"><div class="guide-step-badge">1</div><div class="guide-step-text"><strong>Settings</strong><span>Klik avatar profil Anda, pilih <b>Settings</b>.</span></div></li>
                            <li class="guide-step-item step-variant-teal"><div class="guide-step-badge">2</div><div class="guide-step-text"><strong>Change Password</strong><span>Pilih tab Change Password. Masukkan password lama Anda dan ketikkan password baru. Konfirmasi dan Simpan.</span></div></li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Account 5 -->
            <div class="guide-list-item accordion-item">
                <h2 class="accordion-header" id="accHeading4">
                    <button class="accordion-button collapsed guide-list-btn btn-account" type="button" data-bs-toggle="collapse" data-bs-target="#accCollapse4">
                        Cara Logout & Memahami Role System
                    </button>
                </h2>
                <div id="accCollapse4" class="accordion-collapse collapse" data-bs-parent="">
                    <div class="accordion-body guide-list-body">
                        <ul class="guide-steps">
                            <li class="guide-step-item step-variant-teal"><div class="guide-step-badge">1</div><div class="guide-step-text"><strong>Logout dari Portal</strong><span>Klik avatar profil di pojok kanan atas, lalu pilih <b>Logout</b> untuk keluar dari sistem dengan aman.</span></div></li>
                            <li class="guide-step-item step-variant-teal"><div class="guide-step-badge">2</div><div class="guide-step-text"><strong>Memahami Role Badge</strong><span>Role Anda ditampilkan di navbar (badge: HC, Admin, Coachee). Role menentukan akses menu. Hubungi Admin jika role tidak sesuai.</span></div></li>
                        </ul>
                    </div>
                </div>
            </div>
        }
        else if (module == "data")
        {
            <!-- Data Guides -->
            <!-- Data 1 -->
            <div class="guide-list-item accordion-item">
                <h2 class="accordion-header" id="dataHeading1">
                    <button class="accordion-button collapsed guide-list-btn btn-data" type="button" data-bs-toggle="collapse" data-bs-target="#dataCollapse1">
                        Cara Kelola Data Silabus
                    </button>
                </h2>
                <div id="dataCollapse1" class="accordion-collapse collapse" data-bs-parent="">
                    <div class="accordion-body guide-list-body">
                        <ul class="guide-steps">
                            <li class="guide-step-item step-variant-orange"><div class="guide-step-badge">1</div><div class="guide-step-text"><strong>Masuk Kelola Data</strong><span>Klik navbar <b>Kelola Data</b>. Bagian default adalah konfigurasi Silabus.</span></div></li>
                            <li class="guide-step-item step-variant-orange"><div class="guide-step-badge">2</div><div class="guide-step-text"><strong>Tambah/Edit Silabus</strong><span>Gunakan panel inline editing untuk menambah kompetensi silabus baru, update judulnya, atau hapus dan nonaktifkan (Deactivate) jika silabus tsb sudah obsolete.</span></div></li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Data 2 -->
            <div class="guide-list-item accordion-item">
                <h2 class="accordion-header" id="dataHeading2">
                    <button class="accordion-button collapsed guide-list-btn btn-data" type="button" data-bs-toggle="collapse" data-bs-target="#dataCollapse2">
                        Cara Upload dan Kelola Guidance File
                    </button>
                </h2>
                <div id="dataCollapse2" class="accordion-collapse collapse" data-bs-parent="">
                    <div class="accordion-body guide-list-body">
                        <ul class="guide-steps">
                            <li class="guide-step-item step-variant-orange"><div class="guide-step-badge">1</div><div class="guide-step-text"><strong>Buka Guidance List</strong><span>Di menu Kelola Data, pilih <b>Guidance Files</b>.</span></div></li>
                            <li class="guide-step-item step-variant-orange"><div class="guide-step-badge">2</div><div class="guide-step-text"><strong>Upload File Petunjuk</strong><span>Klik tombol <b>Upload Guidance</b>, pilih target Unit/Bagian, lalu lampirkan file yang akan menjadi rujukan/guidance resmi bagi coachee.</span></div></li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Data 3 -->
            <div class="guide-list-item accordion-item">
