@model HcPortal.Models.DashboardHomeViewModel
@using System.Globalization

@{
    ViewData["Title"] = "Home";
}

<link rel="stylesheet" href="~/css/home.css" />

<div class="hero-section mb-4">
    <div class="hero-content">
        <div class="row align-items-center">
            <div class="col-md-9">
                <div class="d-flex align-items-center gap-4">
                    <div class="hero-avatar">
                        <i class="fas fa-user"></i>
                    </div>
                    <div>
                        <h1 class="hero-greeting mb-2">
                            @Model.Greeting, @Model.CurrentUser.FullName!
                        </h1>
                        <p class="hero-subtitle mb-0">
                            <span class="hero-badge">
                                <i class="fas fa-briefcase"></i>
                                @(Model.CurrentUser.Position ?? "Staff")
                            </span>
                            <span class="hero-badge ms-2">
                                <i class="fas fa-building"></i>
                                @(Model.CurrentUser.Unit ?? "N/A")
                            </span>
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 text-end">
                <p class="mb-0 fs-5 fw-semibold">@DateTime.Now.ToString("dddd", CultureInfo.GetCultureInfo("id-ID"))</p>
                <p class="mb-0 fs-6 opacity-75">@DateTime.Now.ToString("dd MMMM yyyy", CultureInfo.GetCultureInfo("id-ID"))</p>
            </div>
        </div>
    </div>
</div>

@if (Model.ExpiredCount > 0 || Model.AkanExpiredCount > 0)
{
    <partial name="_CertAlertBanner" model="Model" />
}

<div class="row g-4">
    <div class="col-md-4 col-6">
        <a asp-controller="CDP" asp-action="Index" class="card border-0 shadow-sm h-100 text-decoration-none menu-card">
            <div class="card-body d-flex flex-column align-items-center justify-content-center py-4">
                <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-3 mb-3">
                    <i class="bi bi-person-gear fs-3"></i>
                </div>
                <small class="text-center mb-0 text-dark fw-semibold">Competency Development Portal</small>
            </div>
        </a>
    </div>
    <div class="col-md-4 col-6">
        <a asp-controller="CMP" asp-action="Assessment" class="card border-0 shadow-sm h-100 text-decoration-none menu-card">
            <div class="card-body d-flex flex-column align-items-center justify-content-center py-4">
                <div class="bg-success bg-opacity-10 text-success rounded-3 p-3 mb-3">
                    <i class="bi bi-clipboard-check fs-3"></i>
                </div>
                <h6 class="text-center mb-0 text-dark">Assessment</h6>
            </div>
        </a>
    </div>
    <div class="col-md-4 col-6">
        <a asp-controller="CMP" asp-action="Index" class="card border-0 shadow-sm h-100 text-decoration-none menu-card">
            <div class="card-body d-flex flex-column align-items-center justify-content-center py-4">
                <div class="bg-info bg-opacity-10 text-info rounded-3 p-3 mb-3">
                    <i class="bi bi-mortarboard fs-3"></i>
                </div>
                <small class="text-center mb-0 text-dark fw-semibold">Competency Management Portal</small>
            </div>
        </a>
    </div>
</div>

<div class="row g-4 mt-0">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100 progress-card">
            <div class="card-header bg-transparent border-0 py-3">
                <h6 class="mb-0 fw-bold">
                    <i class="bi bi-graph-up me-2 text-success"></i>
                    Progress Overview
                </h6>
            </div>
            <div class="card-body pt-0">
                <div class="progress-item mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted small">CDP Deliverables</span>
                        <span class="fw-bold text-primary">@Model.Progress.CdpProgress%</span>
                    </div>
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-primary" role="progressbar" style="width: @Model.Progress.CdpProgress%" aria-valuenow="@Model.Progress.CdpProgress" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <small class="text-muted">@Model.Progress.CdpCompleted / @Model.Progress.CdpTotal deliverables approved</small>
                </div>

                <div class="progress-item mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted small">Assessment</span>
                        <span class="fw-bold text-success">@Model.Progress.AssessmentProgress%</span>
                    </div>
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: @Model.Progress.AssessmentProgress%" aria-valuenow="@Model.Progress.AssessmentProgress" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <small class="text-muted">@Model.Progress.AssessmentCompleted / @Model.Progress.AssessmentTotal completed</small>
                </div>

                <div class="progress-item">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted small">Coaching Sessions</span>
                        <span class="fw-bold text-warning">@Model.Progress.CoachingProgress%</span>
                    </div>
                    <div class="progress mb-2" style="height: 8px;">
                        <div class="progress-bar bg-warning" role="progressbar" style="width: @Model.Progress.CoachingProgress%" aria-valuenow="@Model.Progress.CoachingProgress" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <small class="text-muted">@Model.Progress.CoachingCompleted / @Model.Progress.CoachingTotal submitted</small>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card border-0 shadow-sm h-100 upcoming-events-card">
            <div class="card-header bg-transparent border-0 py-3">
                <div class="d-flex align-items-center justify-content-between">
                    <h6 class="mb-0 fw-bold">
                        <i class="bi bi-calendar-event me-2 text-primary"></i>
                        Upcoming Events
                    </h6>
                    <span class="badge bg-primary rounded-pill">@Model.UpcomingEvents.Count</span>
                </div>
            </div>
            <div class="card-body pt-0">
                @if (Model.UpcomingEvents.Any())
                {
                    <div class="row">
                        @foreach (var evt in Model.UpcomingEvents)
                        {
                            <div class="col-md-6 mb-3">
                                <a href="@evt.Url" class="text-decoration-none">
                                    <div class="event-item-card border rounded-3 p-3 h-100">
                                        <div class="d-flex align-items-start gap-3">
                                            <div class="event-icon bg-@evt.Color bg-opacity-10 text-@evt.Color rounded-2 p-2">
                                                <i class="bi @evt.Icon"></i>
                                            </div>
                                            <div class="flex-grow-1 min-width-0">
                                                <p class="mb-1 fw-semibold text-dark text-truncate">@evt.Title</p>
                                                <small class="text-muted text-truncate d-block">@evt.Description</small>
                                            </div>
                                        </div>
                                        <div class="mt-2 text-end">
                                            <span class="badge bg-@evt.Color bg-opacity-10 text-@evt.Color">@evt.Date.ToString("dd MMM yyyy")</span>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="bi bi-calendar-check fs-1 text-muted opacity-50"></i>
                        <p class="text-muted mb-0 mt-2">Tidak ada event mendatang</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
