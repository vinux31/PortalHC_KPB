@model HcPortal.Models.MaintenanceMode
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pemeliharaan - PortalHC KPB</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
</head>
<body class="d-flex align-items-center justify-content-center" style="min-height:100vh;background:#fff;">
    <div class="text-center px-3" style="max-width:500px;">
        <img src="~/images/logo.png" alt="PortalHC" style="max-width:120px;" class="mb-4" />
        <div class="mb-3"><i class="bi bi-tools text-primary" style="font-size:48px;"></i></div>
        <h1 class="fw-bold" style="font-size:1.75rem;">Sedang Dalam Pemeliharaan</h1>
        <p class="text-muted mt-3">@Model.Message</p>
        @if (Model.EstimatedEndTime.HasValue)
        {
            <span class="badge bg-info text-dark"><i class="bi bi-clock"></i> Estimasi selesai: @Model.EstimatedEndTime.Value.ToString("dd MMM yyyy HH:mm")</span>
        }
        @if (Model.Scope != "All")
        {
            <div class="mt-4">
                <p class="text-muted small">Halaman berikut sedang dalam pemeliharaan:</p>
                <ul class="list-unstyled">
                    @foreach (var m in Model.Scope.Split(',', StringSplitOptions.RemoveEmptyEntries))
                    {
                        <li>@(m switch { "CMP" => "Assessment (CMP)", "CDP" => "Pengembangan Kompetensi (CDP)", "Proton" => "Coaching Proton", "Admin" => "Kelola Data", "Home" => "Dashboard & Panduan", "Account" => "Profil & Pengaturan", _ => m })</li>
                    }
                </ul>
            </div>
        }
        <p class="text-muted small mt-4">Hubungi admin jika ada pertanyaan mendesak.</p>
    </div>
</body>
</html>
