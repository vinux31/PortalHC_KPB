@{
    ViewData["Title"] = "Import Silabus Proton dari Excel";
    var importResults = ViewBag.ImportResults as List<HcPortal.Controllers.ImportSilabusResult>;
    var successCount = importResults?.Count(r => r.Status == "Created" || r.Status == "Updated") ?? 0;
    var createdCount = importResults?.Count(r => r.Status == "Created") ?? 0;
    var updatedCount = importResults?.Count(r => r.Status == "Updated") ?? 0;
    var errorCount = importResults?.Count(r => r.Status == "Error") ?? 0;
    var bagian = Context.Request.Query["bagian"].ToString();
    var unit = Context.Request.Query["unit"].ToString();
    var trackId = Context.Request.Query["trackId"].ToString();
}

<div class="container py-4" style="max-width: 860px;">

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "ProtonData", new { bagian, unit, trackId })">Silabus Proton</a></li>
            <li class="breadcrumb-item active" aria-current="page">Import Silabus</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-file-earmark-arrow-up me-2 text-success"></i>Import Silabus Proton dari Excel
            </h2>
            <p class="text-muted mb-0">Tambah atau perbarui entri silabus sekaligus dengan upload file Excel</p>
        </div>
        <a href="@Url.Action("Index", "ProtonData", new { bagian, unit, trackId })" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Kembali
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Results Summary -->
    @if (importResults != null)
    {
        <div class="row g-3 mb-4">
            <div class="col-4">
                <div class="card border-0 shadow-sm text-center p-3">
                    <div class="fs-2 fw-bold text-success">@createdCount</div>
                    <div class="small text-muted">Baris Dibuat</div>
                </div>
            </div>
            <div class="col-4">
                <div class="card border-0 shadow-sm text-center p-3">
                    <div class="fs-2 fw-bold text-info">@updatedCount</div>
                    <div class="small text-muted">Baris Diperbarui</div>
                </div>
            </div>
            <div class="col-4">
                <div class="card border-0 shadow-sm text-center p-3">
                    <div class="fs-2 fw-bold text-danger">@errorCount</div>
                    <div class="small text-muted">Error / Gagal</div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header border-0">
                <h6 class="mb-0 fw-bold">Hasil Import — @importResults.Count baris diproses</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-sm align-middle mb-0">
                        <thead class="sticky-top bg-white">
                            <tr>
                                <th class="p-3">No</th>
                                <th class="p-3">Kompetensi</th>
                                <th class="p-3">SubKompetensi</th>
                                <th class="p-3">Deliverable</th>
                                <th class="p-3 text-center">Status</th>
                                <th class="p-3">Keterangan</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in importResults)
                            {
                                var rowClass = r.Status switch
                                {
                                    "Created" => "table-success",
                                    "Updated" => "table-info",
                                    "Error" => "table-danger",
                                    _ => ""
                                };
                                var statusBadge = r.Status switch
                                {
                                    "Created" => "<span class=\"badge bg-success\"><i class=\"bi bi-plus-lg me-1\"></i>Dibuat</span>",
                                    "Updated" => "<span class=\"badge bg-info text-dark\"><i class=\"bi bi-pencil me-1\"></i>Diperbarui</span>",
                                    "Error" => "<span class=\"badge bg-danger\"><i class=\"bi bi-x-lg me-1\"></i>Error</span>",
                                    _ => "<span class=\"badge bg-secondary\">?</span>"
                                };
                                <tr class="@rowClass">
                                    <td class="p-3">@r.RowNumber</td>
                                    <td class="p-3 fw-semibold"><small>@r.Kompetensi</small></td>
                                    <td class="p-3"><small>@r.SubKompetensi</small></td>
                                    <td class="p-3"><small>@r.Deliverable</small></td>
                                    <td class="p-3 text-center">@Html.Raw(statusBadge)</td>
                                    <td class="p-3"><small>@r.Message</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Upload Card -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-primary bg-opacity-10 border-0">
            <h6 class="mb-0 fw-bold text-primary">
                <i class="bi bi-upload me-2"></i>Upload File Excel
            </h6>
        </div>
        <div class="card-body">
            <div class="alert alert-info d-flex align-items-center gap-3 mb-4">
                <i class="bi bi-info-circle-fill fs-4 flex-shrink-0"></i>
                <div>
                    <strong>Langkah 1 — Download Template</strong><br />
                    <span class="small">Download template Excel (berisi data silabus saat ini), isi baris baru atau ubah Target, lalu upload kembali.</span>
                </div>
                <a href="@Url.Action("DownloadSilabusTemplate", "ProtonData", new { bagian, unit, trackId })"
                   class="btn btn-success btn-sm ms-auto flex-shrink-0">
                    <i class="bi bi-file-earmark-excel me-1"></i>Download Template
                </a>
            </div>

            <p class="fw-semibold mb-2"><strong>Langkah 2 — Upload File yang Sudah Diisi</strong></p>

            <form asp-action="ImportSilabus" asp-controller="ProtonData" method="post" enctype="multipart/form-data" id="importForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="bagian" value="@bagian" />
                <input type="hidden" name="unit" value="@unit" />
                <input type="hidden" name="trackId" value="@trackId" />

                <div class="upload-zone border-2 border-dashed rounded-3 p-5 text-center mb-3"
                     id="uploadZone"
                     style="border-color: #d1d5db; cursor: pointer; transition: all 0.2s;"
                     onclick="document.getElementById('excelFileInput').click()">
                    <i class="bi bi-cloud-arrow-up fs-1 text-muted mb-3 d-block"></i>
                    <p class="fw-semibold mb-1" id="dropText">Klik atau drag &amp; drop file Excel di sini</p>
                    <p class="small text-muted mb-0">Format yang didukung: .xlsx</p>
                </div>

                <input type="file" name="excelFile" id="excelFileInput" accept=".xlsx" class="d-none" />

                <div class="d-flex justify-content-end gap-2 mt-3">
                    <a href="@Url.Action("Index", "ProtonData", new { bagian, unit, trackId })" class="btn btn-light">Batal</a>
                    <button type="submit" class="btn btn-primary px-4" id="btnImport" disabled>
                        <i class="bi bi-check2-all me-2"></i>Proses Import
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Format Notes -->
    <div class="card border-0 shadow-sm">
        <div class="card-header border-0">
            <h6 class="mb-0 fw-bold"><i class="bi bi-table me-2"></i>Format Kolom Template</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-striped mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="px-3">Kolom</th>
                            <th class="px-3">Keterangan</th>
                            <th class="px-3">Wajib?</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td class="px-3">Bagian</td><td class="px-3">Nama bagian (diisi otomatis, tidak diubah saat import)</td><td class="px-3"><span class="badge bg-secondary">Info</span></td></tr>
                        <tr><td class="px-3">Unit</td><td class="px-3">Nama unit (diisi otomatis, tidak diubah saat import)</td><td class="px-3"><span class="badge bg-secondary">Info</span></td></tr>
                        <tr><td class="px-3">Track</td><td class="px-3">Nama track (diisi otomatis, tidak diubah saat import)</td><td class="px-3"><span class="badge bg-secondary">Info</span></td></tr>
                        <tr><td class="px-3">Kompetensi</td><td class="px-3">Nama kompetensi (level 1)</td><td class="px-3"><span class="badge bg-danger">Ya</span></td></tr>
                        <tr><td class="px-3">SubKompetensi</td><td class="px-3">Nama sub-kompetensi / elemen teknis (level 2)</td><td class="px-3"><span class="badge bg-danger">Ya</span></td></tr>
                        <tr><td class="px-3">Deliverable</td><td class="px-3">Nama deliverable (level 3)</td><td class="px-3"><span class="badge bg-danger">Ya</span></td></tr>
                        <tr><td class="px-3">Target</td><td class="px-3">Target pencapaian (opsional, diperbarui jika baris sudah ada)</td><td class="px-3"><span class="badge bg-secondary">Opsional</span></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

<style>
    .upload-zone:hover, .upload-zone.drag-over {
        border-color: #2563eb !important;
        background-color: #eff6ff;
    }
    .border-dashed {
        border-style: dashed !important;
    }
</style>

<script>
    const fileInput = document.getElementById('excelFileInput');
    const dropZone = document.getElementById('uploadZone');
    const dropText = document.getElementById('dropText');
    const btnImport = document.getElementById('btnImport');

    fileInput.addEventListener('change', function () {
        if (this.files.length > 0) {
            dropText.textContent = `File dipilih: ${this.files[0].name}`;
            dropZone.style.borderColor = '#16a34a';
            dropZone.style.backgroundColor = '#f0fdf4';
            btnImport.disabled = false;
        }
    });

    dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('drag-over'); });
    dropZone.addEventListener('dragleave', () => { dropZone.classList.remove('drag-over'); });
    dropZone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropZone.classList.remove('drag-over');
        const file = e.dataTransfer.files[0];
        if (file && file.name.endsWith('.xlsx')) {
            const dt = new DataTransfer();
            dt.items.add(file);
            fileInput.files = dt.files;
            dropText.textContent = `File dipilih: ${file.name}`;
            dropZone.style.borderColor = '#16a34a';
            dropZone.style.backgroundColor = '#f0fdf4';
            btnImport.disabled = false;
        } else {
            dropText.textContent = 'Hanya file .xlsx yang didukung!';
            dropZone.style.borderColor = '#dc2626';
        }
    });
</script>
