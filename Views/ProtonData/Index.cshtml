@using HcPortal.Models
@{
    ViewData["Title"] = "Silabus & Coaching Guidance";
    ViewData["ContainerClass"] = "container-fluid";

    var allTracks = ViewBag.AllTracks as List<ProtonTrack> ?? new List<ProtonTrack>();
    var selectedBagian = ViewBag.Bagian as string ?? "";
    var selectedUnit = ViewBag.Unit as string ?? "";
    var selectedTrackId = ViewBag.TrackId as int?;
    var silabusRowsJson = ViewBag.SilabusRowsJson as string ?? "[]";
    var showInactive = (bool)(ViewBag.ShowInactive ?? false);
}

<div class="d-flex align-items-start mb-4">
    <div>
        <h2 class="fw-bold text-dark mb-1"><i class="bi bi-book me-2 text-primary"></i>Silabus &amp; Coaching Guidance</h2>
        <p class="text-muted">Kelola silabus Proton dan file coaching guidance per Bagian, Unit, dan Track.</p>
    </div>
</div>

@* AntiForgeryToken for POST actions in Plans 02/03 *@
@Html.AntiForgeryToken()

@* Bootstrap Nav Tabs *@
<ul class="nav nav-tabs mb-4" id="protonDataTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="status-tab" data-bs-toggle="tab" data-bs-target="#statusTabContent"
                type="button" role="tab" aria-controls="statusTabContent" aria-selected="true">
            <i class="bi bi-clipboard-check me-1"></i>Status
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="silabus-tab" data-bs-toggle="tab" data-bs-target="#silabusTabContent"
                type="button" role="tab" aria-controls="silabusTabContent" aria-selected="false">
            <i class="bi bi-list-ol me-1"></i>Silabus
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="guidance-tab" data-bs-toggle="tab" data-bs-target="#guidanceTabContent"
                type="button" role="tab" aria-controls="guidanceTabContent" aria-selected="false">
            <i class="bi bi-file-earmark-text me-1"></i>Coaching Guidance
        </button>
    </li>
</ul>

<div class="tab-content" id="protonDataTabContent">

    @* ====== STATUS TAB ====== *@
    <div class="tab-pane fade show active" id="statusTabContent" role="tabpanel" aria-labelledby="status-tab">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-bordered table-sm mb-0">
                        <thead>
                            <tr>
                                <th></th>
                                <th class="text-center" style="width:120px">Silabus</th>
                                <th class="text-center" style="width:120px">Guidance</th>
                            </tr>
                        </thead>
                        <tbody id="statusTableBody">
                            <tr><td colspan="3" class="text-center py-4"><div class="spinner-border spinner-border-sm"></div> Memuat...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    @* ====== SILABUS TAB ====== *@
    <div class="tab-pane fade" id="silabusTabContent" role="tabpanel" aria-labelledby="silabus-tab">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h6 class="fw-bold text-muted mb-3"><i class="bi bi-funnel me-1"></i>Filter Silabus</h6>
                <form method="get" action="@Url.Action("Index", "ProtonData")" id="silabusFilterForm">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Bagian</label>
                            <select class="form-select" id="silabusBagian" name="bagian" required>
                                <option value="">-- Pilih Bagian --</option>
                                @foreach (var bagian in OrganizationStructure.SectionUnits.Keys)
                                {
                                    <option value="@bagian" selected="@(selectedBagian == bagian ? "selected" : null)">@bagian</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Unit</label>
                            <select class="form-select" id="silabusUnit" name="unit" required disabled="@(string.IsNullOrEmpty(selectedBagian) ? "disabled" : null)">
                                <option value="">-- Pilih Unit --</option>
                                @if (!string.IsNullOrEmpty(selectedBagian) && OrganizationStructure.SectionUnits.ContainsKey(selectedBagian))
                                {
                                    foreach (var unit in OrganizationStructure.SectionUnits[selectedBagian])
                                    {
                                        <option value="@unit" selected="@(selectedUnit == unit ? "selected" : null)">@unit</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Track</label>
                            <select class="form-select" id="silabusTrack" name="trackId" required>
                                <option value="">-- Pilih Track --</option>
                                @foreach (var track in allTracks)
                                {
                                    <option value="@track.Id" selected="@(selectedTrackId == track.Id ? "selected" : null)">@track.DisplayName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-search me-1"></i>Muat Data
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        @* Tampilkan Inactive toggle *@
        @if (!string.IsNullOrEmpty(selectedBagian) && !string.IsNullOrEmpty(selectedUnit) && selectedTrackId.HasValue)
        {
            <div class="d-flex justify-content-end mb-2">
                @if (showInactive)
                {
                    <a href="@Url.Action("Index", "ProtonData", new { bagian = selectedBagian, unit = selectedUnit, trackId = selectedTrackId, showInactive = false })"
                       class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-eye-slash me-1"></i>Sembunyikan Inactive
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Index", "ProtonData", new { bagian = selectedBagian, unit = selectedUnit, trackId = selectedTrackId, showInactive = true })"
                       class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-eye me-1"></i>Tampilkan Inactive
                    </a>
                }
            </div>
        }

        @* Silabus data display area — rendered by JS *@
        <div id="silabusTableContainer"></div>

        @* JSON data island for JS consumption *@
        <script type="application/json" id="silabusData">@Html.Raw(silabusRowsJson)</script>

        @* Filter state for JS *@
        <script type="application/json" id="silabusFilter">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
            bagian = selectedBagian,
            unit = selectedUnit,
            trackId = selectedTrackId,
            hasFilter = !string.IsNullOrEmpty(selectedBagian) && !string.IsNullOrEmpty(selectedUnit) && selectedTrackId.HasValue,
            showInactive = showInactive
        }))</script>
    </div>

    @* ====== Delete confirmation modal (shared for Silabus tab) ====== *@
    <div class="modal fade" id="silabusDeleteModal" tabindex="-1" aria-labelledby="silabusDeleteModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="silabusDeleteModalLabel">Konfirmasi Hapus</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Hapus deliverable <strong id="silabusDeleteName"></strong>?</p>
                    <p class="text-danger small">Tindakan ini tidak dapat dibatalkan.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                    <button type="button" class="btn btn-danger" id="btnConfirmSilabusDelete">Hapus</button>
                </div>
            </div>
        </div>
    </div>

    @* ====== Delete Kompetensi confirmation modal ====== *@
    <div class="modal fade" id="kompetensiDeleteModal" tabindex="-1" aria-labelledby="kompetensiDeleteModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="kompetensiDeleteModalLabel">Konfirmasi Hapus Kompetensi</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Hapus Kompetensi <strong id="kompetensiDeleteName"></strong>?</p>
                    <p id="kompetensiCascadeInfo" class="small"></p>
                    <p class="text-danger small">Tindakan ini tidak dapat dibatalkan.</p>
                    <div class="alert alert-danger d-none" id="kompetensiDeleteError"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                    <button type="button" class="btn btn-danger" id="btnConfirmKompetensiDelete">Hapus</button>
                </div>
            </div>
        </div>
    </div>

    @* ====== COACHING GUIDANCE TAB ====== *@
    <div class="tab-pane fade" id="guidanceTabContent" role="tabpanel" aria-labelledby="guidance-tab">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h6 class="fw-bold text-muted mb-3"><i class="bi bi-funnel me-1"></i>Filter Coaching Guidance</h6>
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Bagian</label>
                        <select class="form-select" id="guidanceBagian">
                            <option value="">-- Pilih Bagian --</option>
                            @foreach (var bagian in OrganizationStructure.SectionUnits.Keys)
                            {
                                <option value="@bagian">@bagian</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Unit</label>
                        <select class="form-select" id="guidanceUnit" disabled>
                            <option value="">-- Pilih Unit --</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Track</label>
                        <select class="form-select" id="guidanceTrack">
                            <option value="">-- Pilih Track --</option>
                            @foreach (var track in allTracks)
                            {
                                <option value="@track.Id">@track.DisplayName</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button type="button" class="btn btn-primary w-100" id="btnLoadGuidance">
                            <i class="bi bi-search me-1"></i>Muat Data
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div id="guidanceTableContainer">
            <div class="text-center py-5 text-muted">
                <i class="bi bi-file-earmark-text fs-1 mb-3 d-block opacity-50"></i>
                <p>Pilih Bagian, Unit, dan Track untuk menampilkan file coaching guidance.</p>
            </div>
        </div>
    </div>

    @* ====== Guidance Replace Modal ====== *@
    <div class="modal fade" id="guidanceReplaceModal" tabindex="-1" aria-labelledby="guidanceReplaceModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="guidanceReplaceModalLabel">Ganti File</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Mengganti file: <strong id="guidanceReplaceFileName"></strong></p>
                    <input type="file" class="form-control" id="guidanceReplaceFile"
                           accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx" />
                    <div class="text-danger small mt-1" id="guidanceReplaceError"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                    <button type="button" class="btn btn-warning" id="btnConfirmReplace">Ganti</button>
                </div>
            </div>
        </div>
    </div>

    @* ====== Guidance Delete Modal ====== *@
    <div class="modal fade" id="guidanceDeleteModal" tabindex="-1" aria-labelledby="guidanceDeleteModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="guidanceDeleteModalLabel">Konfirmasi Hapus</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Hapus file <strong id="guidanceDeleteFileName"></strong>?</p>
                    <p class="text-danger small">Tindakan ini tidak dapat dibatalkan.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                    <button type="button" class="btn btn-danger" id="btnConfirmGuidanceDelete">Hapus</button>
                </div>
            </div>
        </div>
    </div>


</div>

@section Scripts {
<script>
    // Organization structure from server
    const orgStructure = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        HcPortal.Models.OrganizationStructure.SectionUnits));

    // ====== Status tab ======
    function loadStatusData() {
        $('#statusTableBody').html('<tr><td colspan="3" class="text-center py-4"><div class="spinner-border spinner-border-sm"></div> Memuat...</td></tr>');
        $.get('/ProtonData/StatusData', function(data) {
            var html = '';
            var currentBagian = '', currentUnit = '';
            data.forEach(function(row) {
                if (row.bagian !== currentBagian) {
                    html += '<tr class="table-light"><td class="fw-bold">' + row.bagian + '</td><td></td><td></td></tr>';
                    currentBagian = row.bagian;
                    currentUnit = '';
                }
                if (row.unit !== currentUnit) {
                    html += '<tr><td style="padding-left:2rem" class="fw-semibold">' + row.unit + '</td><td></td><td></td></tr>';
                    currentUnit = row.unit;
                }
                var silabusIcon = row.silabusOk
                    ? '<i class="bi bi-check-circle-fill text-success"></i>'
                    : '<i class="bi bi-exclamation-triangle-fill text-warning"></i>';
                var guidanceIcon = row.guidanceOk
                    ? '<i class="bi bi-check-circle-fill text-success"></i>'
                    : '<i class="bi bi-exclamation-triangle-fill text-warning"></i>';
                html += '<tr><td style="padding-left:4rem">' + row.trackName + '</td><td class="text-center">' + silabusIcon + '</td><td class="text-center">' + guidanceIcon + '</td></tr>';
            });
            $('#statusTableBody').html(html);
        });
    }

    $(function() { loadStatusData(); });
    $('#status-tab').on('shown.bs.tab', function() { loadStatusData(); });

    // ====== Silabus tab filter cascade ======
    document.getElementById('silabusBagian').addEventListener('change', function () {
        const bagian = this.value;
        const unitSelect = document.getElementById('silabusUnit');
        unitSelect.innerHTML = '<option value="">-- Pilih Unit --</option>';
        if (bagian && orgStructure[bagian]) {
            orgStructure[bagian].forEach(u => {
                const opt = document.createElement('option');
                opt.value = u;
                opt.textContent = u;
                unitSelect.appendChild(opt);
            });
        }
        unitSelect.disabled = !bagian;
    });

    // ====== Coaching Guidance tab filter cascade ======
    document.getElementById('guidanceBagian').addEventListener('change', function () {
        const bagian = this.value;
        const unitSelect = document.getElementById('guidanceUnit');
        unitSelect.innerHTML = '<option value="">-- Pilih Unit --</option>';
        if (bagian && orgStructure[bagian]) {
            orgStructure[bagian].forEach(u => {
                const opt = document.createElement('option');
                opt.value = u;
                opt.textContent = u;
                unitSelect.appendChild(opt);
            });
        }
        unitSelect.disabled = !bagian;
    });

    // ====== Silabus CRUD (Plan 02) ======
    (function () {
        // State
        let silabusRows = JSON.parse(document.getElementById('silabusData').textContent || '[]');
        let isEditMode = false;
        let deleteTargetIndex = -1;

        // Filter context
        const filterRaw = document.getElementById('silabusFilter').textContent;
        const silabusFilter = JSON.parse(filterRaw);
        const currentBagian = silabusFilter.bagian || '';
        const currentUnit = silabusFilter.unit || '';
        const currentTrackId = silabusFilter.trackId || 0;
        const hasFilter = silabusFilter.hasFilter;
        const isShowingInactive = silabusFilter.showInactive || false;

        const container = document.getElementById('silabusTableContainer');

        // ---- Render: View mode with rowspan merge ----
        function renderViewTable() {
            if (!hasFilter) {
                container.innerHTML = `
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-funnel fs-1 mb-3 d-block opacity-50"></i>
                        <p>Pilih Bagian, Unit, dan Track kemudian klik <strong>Muat Data</strong> untuk menampilkan silabus.</p>
                    </div>`;
                return;
            }

            let html = `<div class="d-flex align-items-center justify-content-between mb-3">
                <span class="text-muted small">Menampilkan silabus untuk: <strong>${escHtml(currentUnit)}</strong></span>
                <button id="btnEdit" class="btn btn-warning btn-sm"><i class="bi bi-pencil me-1"></i>Edit</button>
            </div>`;

            if (silabusRows.length === 0) {
                html += `<div class="alert alert-info">Belum ada data silabus. Klik 'Edit' untuk mulai menambahkan data.</div>`;
            } else {
                html += `<div class="table-responsive"><table class="table table-bordered table-sm">
                    <thead class="table-light">
                        <tr>
                            <th style="width:60px">No</th>
                            <th>Kompetensi</th>
                            <th>Sub Kompetensi</th>
                            <th>Target</th>
                            <th>Deliverable</th>
                            <th style="width:130px">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>`;

                // Group rows by KompetensiId for action buttons (deactivate acts on Kompetensi level)
                // Track which KompetensiId has already had its action button rendered
                const renderedKompIds = new Set();

                let i = 0;
                while (i < silabusRows.length) {
                    const row = silabusRows[i];
                    const isRowActive = row.IsActive !== false;
                    // Compute kompetensi rowspan
                    let kompSpan = 1;
                    while (i + kompSpan < silabusRows.length && silabusRows[i + kompSpan].Kompetensi === row.Kompetensi) kompSpan++;

                    // Render rows for this kompetensi group
                    let j = i;
                    while (j < i + kompSpan) {
                        const subRow = silabusRows[j];
                        // Compute sub-kompetensi rowspan within this kompetensi group
                        let subSpan = 1;
                        while (j + subSpan < i + kompSpan && silabusRows[j + subSpan].SubKompetensi === subRow.SubKompetensi) subSpan++;

                        // Render rows for this sub-kompetensi group
                        for (let k = j; k < j + subSpan; k++) {
                            const dRow = silabusRows[k];
                            const dRowIsActive = dRow.IsActive !== false;
                            const rowCss = dRowIsActive ? '' : ' class="table-secondary text-muted"';
                            html += `<tr${rowCss}>`;
                            if (k === i) {
                                const bgStyle = dRowIsActive ? 'background:#f8f9fa' : 'background:#e9ecef';
                                html += `<td rowspan="${kompSpan}" class="align-middle fw-semibold text-center" style="${bgStyle}">${escHtml(dRow.No)}</td>`;
                                html += `<td rowspan="${kompSpan}" class="align-middle fw-semibold">${escHtml(dRow.Kompetensi)}</td>`;
                            }
                            if (k === j) {
                                html += `<td rowspan="${subSpan}" class="align-middle">${escHtml(dRow.SubKompetensi)}</td>`;
                                html += `<td rowspan="${subSpan}" class="align-middle">${escHtml(dRow.Target || '-')}</td>`;
                            }
                            html += `<td>${escHtml(dRow.Deliverable)}</td>`;
                            // Action button — show once per kompetensi group (rowspan)
                            if (k === i) {
                                const kompId = dRow.KompetensiId || 0;
                                let actionBtn = '';
                                if (kompId > 0) {
                                    if (dRowIsActive) {
                                        actionBtn = `<button class="btn btn-sm btn-outline-warning btn-deactivate-row" title="Nonaktifkan" data-id="${kompId}" data-name="${escAttr(dRow.Kompetensi)}"><i class="bi bi-person-dash me-1"></i>Nonaktifkan</button>`;
                                    } else {
                                        actionBtn = `<button class="btn btn-sm btn-outline-success btn-reactivate-row" title="Aktifkan Kembali" data-id="${kompId}" data-name="${escAttr(dRow.Kompetensi)}"><i class="bi bi-person-check me-1"></i>Aktifkan</button>`;
                                    }
                                    actionBtn += `<button class="btn btn-sm btn-outline-danger btn-delete-kompetensi ms-1" title="Hapus" data-id="${kompId}" data-name="${escAttr(dRow.Kompetensi)}"><i class="bi bi-trash me-1"></i>Hapus</button>`;
                                }
                                html += `<td rowspan="${kompSpan}" class="align-middle text-center">${actionBtn}</td>`;
                            }
                            html += '</tr>';
                        }
                        j += subSpan;
                    }
                    i += kompSpan;
                }

                html += `</tbody></table></div>`;
            }

            container.innerHTML = html;
            document.getElementById('btnEdit').addEventListener('click', function () {
                isEditMode = true;
                renderEditTable();
            });
        }

        // ---- Render: Edit mode (expanded rows with inputs) ----
        function renderEditTable() {
            let html = `<div class="d-flex align-items-center justify-content-between mb-3" id="silabusEditToolbar">
                <span class="text-muted small">Mode Edit — <strong>${escHtml(currentUnit)}</strong></span>
                <div class="d-flex gap-2">
                    <button id="btnBatal" class="btn btn-secondary btn-sm"><i class="bi bi-x-circle me-1"></i>Batal</button>
                    <button id="btnSaveAll" class="btn btn-success btn-sm"><i class="bi bi-save me-1"></i>Simpan Semua</button>
                </div>
            </div>`;

            html += `<div class="table-responsive"><table class="table table-bordered table-sm" id="silabusEditTable">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px">No</th>
                        <th>Kompetensi</th>
                        <th>Sub Kompetensi</th>
                        <th>Target</th>
                        <th>Deliverable</th>
                        <th style="width:90px">Aksi</th>
                    </tr>
                </thead>
                <tbody>`;

            if (silabusRows.length === 0) {
                html += `<tr id="emptyRow"><td colspan="6" class="text-center text-muted py-3">Belum ada baris. Klik tombol "Tambah Baris" di bawah.</td></tr>`;
            } else {
                silabusRows.forEach(function (row, idx) {
                    html += renderEditRow(row, idx);
                });
            }

            html += `</tbody></table></div>`;
            html += `<div class="mt-2">
                <button class="btn btn-outline-primary btn-sm" id="btnTambahBaris">
                    <i class="bi bi-plus-circle me-1"></i>Tambah Baris
                </button>
            </div>`;

            container.innerHTML = html;

            // Wire toolbar buttons
            document.getElementById('btnBatal').addEventListener('click', function () {
                isEditMode = false;
                // Reload original data from server
                window.location.reload();
            });

            document.getElementById('btnSaveAll').addEventListener('click', saveAll);

            document.getElementById('btnTambahBaris').addEventListener('click', function () {
                const lastIdx = silabusRows.length - 1;
                const newRow = {
                    KompetensiId: 0, Kompetensi: '',
                    SubKompetensiId: 0, SubKompetensi: '',
                    DeliverableId: 0, Deliverable: '', No: '', Target: ''
                };
                silabusRows.push(newRow);
                renderEditTable();
            });

            // Wire row-level buttons
            wireEditTableEvents();
        }

        function renderEditRow(row, idx) {
            return `<tr data-idx="${idx}">
                <td><input type="text" class="form-control form-control-sm" data-field="No" value="${escAttr(row.No)}"></td>
                <td><input type="text" class="form-control form-control-sm" data-field="Kompetensi" value="${escAttr(row.Kompetensi)}"></td>
                <td><input type="text" class="form-control form-control-sm" data-field="SubKompetensi" value="${escAttr(row.SubKompetensi)}"></td>
                <td><input type="text" class="form-control form-control-sm" data-field="Target" value="${escAttr(row.Target || '')}" maxlength="500"></td>
                <td><input type="text" class="form-control form-control-sm" data-field="Deliverable" value="${escAttr(row.Deliverable)}"></td>
                <td class="text-center">
                    <button class="btn btn-sm btn-outline-primary btn-insert-row me-1" title="Sisipkan baris setelah ini" data-idx="${idx}">
                        <i class="bi bi-plus-circle"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-danger btn-delete-row" title="Hapus baris" data-idx="${idx}">
                        <i class="bi bi-trash"></i>
                    </button>
                </td>
            </tr>`;
        }

        function wireEditTableEvents() {
            const tbody = document.querySelector('#silabusEditTable tbody');
            if (!tbody) return;

            // Input changes → update silabusRows array
            tbody.addEventListener('input', function (e) {
                const input = e.target;
                if (input.tagName !== 'INPUT') return;
                const tr = input.closest('tr');
                if (!tr) return;
                const idx = parseInt(tr.dataset.idx);
                const field = input.dataset.field;
                if (!isNaN(idx) && field && silabusRows[idx] !== undefined) {
                    silabusRows[idx][field] = input.value;
                }
            });

            // Insert row (+ button)
            tbody.addEventListener('click', function (e) {
                const btn = e.target.closest('.btn-insert-row');
                if (!btn) return;
                const idx = parseInt(btn.dataset.idx);
                const currRow = silabusRows[idx] || {};
                const newRow = {
                    KompetensiId: 0, Kompetensi: currRow.Kompetensi || '',
                    SubKompetensiId: 0, SubKompetensi: currRow.SubKompetensi || '',
                    DeliverableId: 0, Deliverable: '', No: '', Target: currRow.Target || ''
                };
                silabusRows.splice(idx + 1, 0, newRow);
                renderEditTable();
            });

            // Delete row (trash button)
            tbody.addEventListener('click', function (e) {
                const btn = e.target.closest('.btn-delete-row');
                if (!btn) return;
                const idx = parseInt(btn.dataset.idx);
                const row = silabusRows[idx];
                if (!row) return;

                if (row.DeliverableId > 0) {
                    // Saved row — show modal confirmation
                    deleteTargetIndex = idx;
                    document.getElementById('silabusDeleteName').textContent = row.Deliverable || '(tanpa nama)';
                    const modal = new bootstrap.Modal(document.getElementById('silabusDeleteModal'));
                    modal.show();
                } else {
                    // Unsaved row — remove directly
                    silabusRows.splice(idx, 1);
                    renderEditTable();
                }
            });
        }

        // ---- Delete modal confirm ----
        document.getElementById('btnConfirmSilabusDelete').addEventListener('click', async function () {
            const modal = bootstrap.Modal.getInstance(document.getElementById('silabusDeleteModal'));
            modal.hide();

            if (deleteTargetIndex < 0 || deleteTargetIndex >= silabusRows.length) return;
            const row = silabusRows[deleteTargetIndex];

            if (row.DeliverableId > 0) {
                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    const resp = await fetch('/ProtonData/SilabusDelete', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                        body: JSON.stringify({ DeliverableId: row.DeliverableId })
                    });
                    const data = await resp.json();
                    if (!data.success) {
                        alert('Gagal menghapus: ' + (data.message || 'Error tidak diketahui'));
                        return;
                    }
                } catch (err) {
                    alert('Terjadi kesalahan jaringan. Silakan coba lagi.');
                    return;
                }
            }

            silabusRows.splice(deleteTargetIndex, 1);
            deleteTargetIndex = -1;
            renderEditTable();
        });

        // ---- Nonaktifkan silabus (soft delete) ----
        document.getElementById('silabusTableContainer').addEventListener('click', async function (e) {
            const deactivateBtn = e.target.closest('.btn-deactivate-row');
            if (deactivateBtn) {
                const id = deactivateBtn.dataset.id;
                const name = deactivateBtn.dataset.name;
                if (!confirm(`Nonaktifkan silabus "${name}"?\n\nSilabus tidak akan muncul di Plan IDP dan Coaching Proton. Dapat diaktifkan kembali.`)) return;
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                try {
                    const resp = await fetch('/ProtonData/SilabusDeactivate', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                        body: JSON.stringify({ KompetensiId: parseInt(id) })
                    });
                    const result = await resp.json();
                    if (result.success) {
                        setTimeout(() => window.location.reload(), 300);
                    } else {
                        alert(result.message || 'Gagal menonaktifkan silabus.');
                    }
                } catch (err) {
                    alert('Terjadi kesalahan jaringan. Silakan coba lagi.');
                }
                return;
            }

            const reactivateBtn = e.target.closest('.btn-reactivate-row');
            if (reactivateBtn) {
                const id = reactivateBtn.dataset.id;
                const name = reactivateBtn.dataset.name;
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                try {
                    const resp = await fetch('/ProtonData/SilabusReactivate', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                        body: JSON.stringify({ KompetensiId: parseInt(id) })
                    });
                    const result = await resp.json();
                    if (result.success) {
                        setTimeout(() => window.location.reload(), 300);
                    } else {
                        alert(result.message || 'Gagal mengaktifkan silabus.');
                    }
                } catch (err) {
                    alert('Terjadi kesalahan jaringan. Silakan coba lagi.');
                }
                return;
            }

            // ---- Delete Kompetensi (hard delete) ----
            const deleteBtn = e.target.closest('.btn-delete-kompetensi');
            if (deleteBtn) {
                const id = deleteBtn.dataset.id;
                const name = deleteBtn.dataset.name;
                const errorDiv = document.getElementById('kompetensiDeleteError');
                errorDiv.classList.add('d-none');
                errorDiv.textContent = '';
                document.getElementById('kompetensiDeleteName').textContent = name;
                document.getElementById('kompetensiCascadeInfo').textContent = 'Memuat informasi...';
                document.getElementById('btnConfirmKompetensiDelete').dataset.id = id;

                const modal = new bootstrap.Modal(document.getElementById('kompetensiDeleteModal'));
                modal.show();

                try {
                    const resp = await fetch(`/ProtonData/GetKompetensiCascadeInfo?id=${id}`);
                    const info = await resp.json();
                    if (info.success) {
                        document.getElementById('kompetensiCascadeInfo').textContent =
                            `Ini akan menghapus ${info.subKompetensiCount} Sub Kompetensi, ${info.deliverableCount} Deliverable, ${info.progressCount} Progress Coaching, ${info.sessionCount} Sesi Coaching.`;
                    } else {
                        document.getElementById('kompetensiCascadeInfo').textContent = info.message || 'Gagal memuat info.';
                    }
                } catch (err) {
                    document.getElementById('kompetensiCascadeInfo').textContent = 'Gagal memuat informasi cascade.';
                }
                return;
            }
        });

        // ---- Confirm Kompetensi Delete ----
        document.getElementById('btnConfirmKompetensiDelete').addEventListener('click', async function () {
            const id = this.dataset.id;
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const errorDiv = document.getElementById('kompetensiDeleteError');
            errorDiv.classList.add('d-none');
            this.disabled = true;
            this.textContent = 'Menghapus...';
            try {
                const resp = await fetch('/ProtonData/DeleteKompetensi', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                    body: JSON.stringify({ KompetensiId: parseInt(id) })
                });
                const result = await resp.json();
                if (result.success) {
                    bootstrap.Modal.getInstance(document.getElementById('kompetensiDeleteModal')).hide();
                    loadSilabusData();
                } else {
                    errorDiv.textContent = result.message || 'Gagal menghapus kompetensi.';
                    errorDiv.classList.remove('d-none');
                }
            } catch (err) {
                errorDiv.textContent = 'Terjadi kesalahan jaringan. Silakan coba lagi.';
                errorDiv.classList.remove('d-none');
            } finally {
                this.disabled = false;
                this.textContent = 'Hapus';
            }
        });

        // ---- Save All ----
        async function saveAll() {
            // Read current input values from DOM into silabusRows
            const rows = document.querySelectorAll('#silabusEditTable tbody tr[data-idx]');
            rows.forEach(function (tr) {
                const idx = parseInt(tr.dataset.idx);
                if (isNaN(idx) || !silabusRows[idx]) return;
                tr.querySelectorAll('input[data-field]').forEach(function (inp) {
                    silabusRows[idx][inp.dataset.field] = inp.value;
                });
            });

            // Validate
            for (let i = 0; i < silabusRows.length; i++) {
                const r = silabusRows[i];
                if (!r.Kompetensi || !r.Kompetensi.trim()) {
                    alert(`Baris ${i + 1}: Kolom Kompetensi tidak boleh kosong.`);
                    return;
                }
                if (!r.SubKompetensi || !r.SubKompetensi.trim()) {
                    alert(`Baris ${i + 1}: Kolom Sub Kompetensi tidak boleh kosong.`);
                    return;
                }
                if (!r.Deliverable || !r.Deliverable.trim()) {
                    alert(`Baris ${i + 1}: Kolom Deliverable tidak boleh kosong.`);
                    return;
                }
                if (!r.Target || !r.Target.trim()) {
                    alert(`Baris ${i + 1}: Kolom Target tidak boleh kosong.`);
                    return;
                }
            }

            // Enrich with filter context
            const payload = silabusRows.map(function (r) {
                return Object.assign({}, r, { Bagian: currentBagian, Unit: currentUnit, TrackId: currentTrackId });
            });

            const btn = document.getElementById('btnSaveAll');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Menyimpan...';

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                const resp = await fetch('/ProtonData/SilabusSave', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                    body: JSON.stringify(payload)
                });
                const data = await resp.json();
                if (data.success) {
                    window.location.href = `/ProtonData/Index?bagian=${encodeURIComponent(currentBagian)}&unit=${encodeURIComponent(currentUnit)}&trackId=${currentTrackId}`;
                } else {
                    alert('Gagal menyimpan: ' + (data.message || 'Error tidak diketahui'));
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-save me-1"></i>Simpan Semua';
                }
            } catch (err) {
                alert('Terjadi kesalahan jaringan. Silakan coba lagi.');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-save me-1"></i>Simpan Semua';
            }
        }

        // ---- Utilities ----
        function escHtml(str) {
            if (!str) return '';
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;');
        }
        function escAttr(str) {
            if (!str) return '';
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/"/g, '&quot;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;');
        }

        // ---- Initial render ----
        if (isEditMode) {
            renderEditTable();
        } else {
            renderViewTable();
        }
    })();

    // ====== Coaching Guidance CRUD (Plan 03) ======
    (function () {
        let guidanceReplaceId = -1;
        let guidanceDeleteId = -1;
        let currentGuidanceBagian = '';
        let currentGuidanceUnit = '';
        let currentGuidanceTrackId = '';

        // --- Load files ---
        async function loadGuidanceFiles() {
            const bagian = document.getElementById('guidanceBagian').value;
            const unit = document.getElementById('guidanceUnit').value;
            const trackId = document.getElementById('guidanceTrack').value;

            currentGuidanceBagian = bagian;
            currentGuidanceUnit = unit;
            currentGuidanceTrackId = trackId;

            if (!bagian || !unit || !trackId) {
                document.getElementById('guidanceTableContainer').innerHTML =
                    '<p class="text-muted mt-3">Pilih Bagian, Unit, dan Track untuk melihat file.</p>';
                return;
            }

            try {
                const resp = await fetch(`/ProtonData/GuidanceList?bagian=${encodeURIComponent(bagian)}&unit=${encodeURIComponent(unit)}&trackId=${encodeURIComponent(trackId)}`);
                const files = await resp.json();
                renderGuidanceTable(files, bagian, unit, trackId);
            } catch (err) {
                document.getElementById('guidanceTableContainer').innerHTML =
                    '<div class="alert alert-danger">Gagal memuat data file. Silakan coba lagi.</div>';
            }
        }

        // --- Render table + upload form ---
        function renderGuidanceTable(files, bagian, unit, trackId) {
            const container = document.getElementById('guidanceTableContainer');
            let html = '';

            if (files.length === 0) {
                html += '<p class="text-muted mt-3">Belum ada file coaching guidance.</p>';
            } else {
                html += `<div class="table-responsive mt-3"><table class="table table-bordered table-sm">
                    <thead class="table-light">
                        <tr>
                            <th>Nama File</th>
                            <th style="width:120px;">Ukuran</th>
                            <th style="width:170px;">Tanggal Upload</th>
                            <th style="width:180px;">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>`;
                files.forEach(function (f) {
                    html += `<tr>
                        <td>${escapeHtml(f.fileName)}</td>
                        <td>${formatFileSize(f.fileSize)}</td>
                        <td>${escapeHtml(f.uploadedAt)}</td>
                        <td>
                            <a href="/ProtonData/GuidanceDownload?id=${f.id}" class="btn btn-sm btn-outline-primary me-1" title="Download"><i class="bi bi-download"></i></a>
                            <button class="btn btn-sm btn-outline-warning me-1" onclick="showReplaceModal(${f.id}, '${escapeJs(f.fileName)}')" title="Ganti File"><i class="bi bi-arrow-repeat"></i></button>
                            <button class="btn btn-sm btn-outline-danger" onclick="showGuidanceDeleteModal(${f.id}, '${escapeJs(f.fileName)}')" title="Hapus"><i class="bi bi-trash"></i></button>
                        </td>
                    </tr>`;
                });
                html += '</tbody></table></div>';
            }

            // Upload form
            html += `<div class="card border-0 shadow-sm mt-3">
                <div class="card-body">
                    <h6 class="fw-semibold mb-2"><i class="bi bi-upload me-1"></i>Upload File Baru</h6>
                    <form id="guidanceUploadForm" class="d-flex gap-2 align-items-end flex-wrap">
                        <div class="flex-grow-1">
                            <input type="file" class="form-control form-control-sm" id="guidanceFile"
                                   accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx" required />
                            <div class="text-muted small mt-1">PDF, Word, Excel, PowerPoint — maks. 10 MB</div>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="bi bi-upload me-1"></i>Upload
                        </button>
                    </form>
                    <div class="text-danger small mt-1" id="guidanceUploadError"></div>
                </div>
            </div>`;

            container.innerHTML = html;

            // Wire upload form submit
            document.getElementById('guidanceUploadForm').addEventListener('submit', async function (e) {
                e.preventDefault();
                const fileInput = document.getElementById('guidanceFile');
                const errorDiv = document.getElementById('guidanceUploadError');
                errorDiv.textContent = '';

                if (!fileInput.files || fileInput.files.length === 0) {
                    errorDiv.textContent = 'Pilih file terlebih dahulu.';
                    return;
                }

                const formData = new FormData();
                formData.append('bagian', currentGuidanceBagian);
                formData.append('unit', currentGuidanceUnit);
                formData.append('trackId', currentGuidanceTrackId);
                formData.append('file', fileInput.files[0]);
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                const submitBtn = this.querySelector('[type=submit]');
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Uploading...';

                try {
                    const resp = await fetch('/ProtonData/GuidanceUpload', {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': token },
                        body: formData
                    });
                    const data = await resp.json();
                    if (data.success) {
                        await loadGuidanceFiles();
                    } else {
                        errorDiv.textContent = data.error || 'Upload gagal.';
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = '<i class="bi bi-upload me-1"></i>Upload';
                    }
                } catch (err) {
                    errorDiv.textContent = 'Terjadi kesalahan jaringan. Silakan coba lagi.';
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="bi bi-upload me-1"></i>Upload';
                }
            });
        }

        // --- Replace modal ---
        window.showReplaceModal = function (id, fileName) {
            guidanceReplaceId = id;
            document.getElementById('guidanceReplaceFileName').textContent = fileName;
            document.getElementById('guidanceReplaceFile').value = '';
            document.getElementById('guidanceReplaceError').textContent = '';
            const modal = new bootstrap.Modal(document.getElementById('guidanceReplaceModal'));
            modal.show();
        };

        document.getElementById('btnConfirmReplace').addEventListener('click', async function () {
            const fileInput = document.getElementById('guidanceReplaceFile');
            const errorDiv = document.getElementById('guidanceReplaceError');
            errorDiv.textContent = '';

            if (!fileInput.files || fileInput.files.length === 0) {
                errorDiv.textContent = 'Pilih file terlebih dahulu.';
                return;
            }

            const formData = new FormData();
            formData.append('id', guidanceReplaceId);
            formData.append('file', fileInput.files[0]);
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            this.disabled = true;
            this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Mengganti...';

            try {
                const resp = await fetch('/ProtonData/GuidanceReplace', {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token },
                    body: formData
                });
                const data = await resp.json();
                if (data.success) {
                    bootstrap.Modal.getInstance(document.getElementById('guidanceReplaceModal')).hide();
                    await loadGuidanceFiles();
                } else {
                    errorDiv.textContent = data.error || 'Gagal mengganti file.';
                }
            } catch (err) {
                errorDiv.textContent = 'Terjadi kesalahan jaringan. Silakan coba lagi.';
            }

            this.disabled = false;
            this.innerHTML = 'Ganti';
        });

        // --- Delete modal ---
        window.showGuidanceDeleteModal = function (id, fileName) {
            guidanceDeleteId = id;
            document.getElementById('guidanceDeleteFileName').textContent = fileName;
            const modal = new bootstrap.Modal(document.getElementById('guidanceDeleteModal'));
            modal.show();
        };

        document.getElementById('btnConfirmGuidanceDelete').addEventListener('click', async function () {
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            this.disabled = true;
            this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Menghapus...';

            try {
                const resp = await fetch('/ProtonData/GuidanceDelete', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                    body: JSON.stringify({ id: guidanceDeleteId })
                });
                const data = await resp.json();
                if (data.success) {
                    bootstrap.Modal.getInstance(document.getElementById('guidanceDeleteModal')).hide();
                    await loadGuidanceFiles();
                } else {
                    alert('Gagal menghapus: ' + (data.error || 'Error tidak diketahui'));
                }
            } catch (err) {
                alert('Terjadi kesalahan jaringan. Silakan coba lagi.');
            }

            this.disabled = false;
            this.innerHTML = 'Hapus';
        });

        // --- Filter cascade: wire load on change ---
        document.getElementById('guidanceUnit').addEventListener('change', function () {
            loadGuidanceFiles();
        });
        document.getElementById('guidanceTrack').addEventListener('change', function () {
            loadGuidanceFiles();
        });
        document.getElementById('btnLoadGuidance').addEventListener('click', function () {
            loadGuidanceFiles();
        });

        // --- Helper functions ---
        function formatFileSize(bytes) {
            if (bytes < 1024) return bytes + ' B';
            if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
            return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
        }

        function escapeHtml(str) {
            if (!str) return '';
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;');
        }

        function escapeJs(str) {
            if (!str) return '';
            return String(str).replace(/\\/g, '\\\\').replace(/'/g, "\\'").replace(/"/g, '\\"');
        }
    })();



</script>
}
