@model ErrorViewModel
@{
    var code = Model.StatusCode ?? 500;
    var title = code switch
    {
        400 => "Permintaan Tidak Valid",
        401 => "Akses Ditolak",
        403 => "Tidak Diizinkan",
        404 => "Halaman Tidak Ditemukan",
        _ => "Terjadi Kesalahan"
    };
    var message = code switch
    {
        400 => "Permintaan yang Anda kirim tidak dapat diproses.",
        401 => "Anda harus login terlebih dahulu untuk mengakses halaman ini.",
        403 => "Anda tidak memiliki izin untuk mengakses halaman ini.",
        404 => "Halaman yang Anda cari tidak ditemukan atau telah dipindahkan.",
        _ => "Terjadi kesalahan saat memproses permintaan Anda."
    };
    ViewData["Title"] = title;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <h1 class="display-1 fw-bold text-muted">@code</h1>
            <h2 class="mb-3">@title</h2>
            <p class="text-muted mb-4">@message</p>
            <a href="/" class="btn btn-primary">
                <i class="bi bi-house-door me-1"></i> Kembali ke Beranda
            </a>
        </div>
    </div>
</div>
