@model dynamic
@*
    Partial reusable render gambar soal/opsi (D-04 anti-drift, Phase 354).
    Single source of truth markup <img> + trigger lightbox — dipakai 6 surface.
    Pemanggil: @await Html.PartialAsync("_QuestionImage", new { ImagePath = ..., ImageAlt = ..., Cap = 240, AriaContext = "..." })
      - Cap 240 = gambar SOAL (default). Cap <= 120 = gambar OPSI (block-bawah D-03).
    Render NOTHING bila ImagePath null/whitespace (L-02, no placeholder).
*@
@{
    string? imagePath = Model?.ImagePath as string;
    string? imageAlt = Model?.ImageAlt as string;
    int cap = Model?.Cap is int c ? c : 240;
    string? ariaContext = Model?.AriaContext as string;
    bool isOption = cap <= 120;
    string ariaLabel = string.IsNullOrWhiteSpace(imageAlt)
        ? (string.IsNullOrWhiteSpace(ariaContext) ? "Perbesar gambar" : "Perbesar gambar " + ariaContext)
        : "Perbesar gambar: " + imageAlt;
}
@if (!string.IsNullOrWhiteSpace(imagePath))
{
    <img src="@imagePath" alt="@imageAlt"
         class="img-fluid rounded border mb-3 question-image-zoom@(isOption ? " d-block w-100 mt-2 mb-0" : "")"
         style="max-height:@(cap)px; cursor:pointer"
         loading="lazy"
         role="button" tabindex="0"
         data-bs-toggle="modal" data-bs-target="#imageLightboxModal"
         data-img-src="@imagePath" data-img-alt="@imageAlt"
         aria-label="@ariaLabel" />
}
